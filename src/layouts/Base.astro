---
import { T, pick, localePath, hreflangs, SITE, DEFAULT_LANG } from '../i18n.js';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const {
  lang = DEFAULT_LANG,
  slug = '',
  active = '',
  activeSub = '',
  title = {},
  description = {},
  preloadHero = false,
  singleLang = false,   /* páginas de un solo idioma (blog posts) → sin hreflang alternates */
  switchSlug = null,    /* a dónde apunta el selector de idioma (posts → índice del blog) */
  langUrls = null,      /* {en,de,es} URLs exactas para el selector (post → mismo artículo traducido) */
  canonicalPath = null, /* path exacto para canonical/og:url (case studies en su URL vieja) */
} = Astro.props;

const t = (k) => pick(T[k], lang);
const pageTitle = pick(title, lang);
const pageDesc = pick(description, lang);
const canonical = canonicalPath ? SITE + canonicalPath : SITE + localePath(lang, slug);
const alts = hreflangs(slug);
const OG_IMG = SITE + '/assets/og.jpg';
const HERO = 'https://i.vimeocdn.com/video/1983545212-07a82dee809132cc97d62a6cd25ae7e99e36c5d2451766896df1118f39c74552-d';

// Identidad global (Organization + WebSite) en cada página — bueno para SEO/AI-SEO
const orgGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfessionalService',
      '@id': SITE + '/#organization',
      name: 'Viven AG',
      alternateName: 'Viven Film & Video Production',
      url: SITE + '/',
      description: 'Viven is a video production company based in Zurich, Switzerland, producing brand, product, employer-branding, how-to and social media videos for leading brands across Europe.',
      foundingDate: '2017',
      founder: { '@type': 'Person', name: 'Sebastian Cepeda', jobTitle: 'Founder & Executive Producer', description: 'Producer of the first Swiss feature film on Netflix.' },
      telephone: '+41435083381',
      email: 'info@viven.ch',
      vatID: 'CHE-266.556.186',
      address: { '@type': 'PostalAddress', streetAddress: 'Zeughausstrasse 31', postalCode: '8004', addressLocality: 'Zürich', addressCountry: 'CH' },
      areaServed: ['CH', 'Europe'],
      sameAs: ['https://www.linkedin.com/company/viven-ag', 'https://www.instagram.com/viven.ag', 'https://www.facebook.com/VIVENAG', 'https://x.com/vivenag/'],
      knowsAbout: ['Brand video production', 'Product video production', 'Employer branding video', 'How-to and tutorial video', 'Social media video', 'Corporate video production', 'Commercial and TVC production'],
    },
    { '@type': 'WebSite', '@id': SITE + '/#website', url: SITE + '/', name: 'Viven', publisher: { '@id': SITE + '/#organization' }, inLanguage: ['en', 'de', 'es'] },
  ],
};
---
<!DOCTYPE html>
<html lang={lang} data-fixed-lang>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{pageTitle}</title>
<meta name="description" content={pageDesc} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="theme-color" content="#0f1826" />
<meta name="robots" content="index,follow,max-image-preview:large" />
<script is:inline>/* noindex del dominio de pruebas de Netlify (evita contenido duplicado con viven.ch). Se desactiva solo en el dominio final. */if(location.hostname.indexOf('netlify.app')>-1){var _m=document.createElement('meta');_m.name='robots';_m.content='noindex,nofollow';document.head.appendChild(_m);}</script>

<link rel="canonical" href={canonical} />
{!singleLang && alts.map((a) => (<link rel="alternate" hreflang={a.lang} href={a.href} />))}
{singleLang && langUrls && Object.entries(langUrls).map(([l, u]) => (<link rel="alternate" hreflang={l} href={SITE + u} />))}
{singleLang && langUrls && <link rel="alternate" hreflang="x-default" href={SITE + (langUrls.en || Object.values(langUrls)[0])} />}

<meta property="og:type" content="website" />
<meta property="og:site_name" content="Viven" />
<meta property="og:locale" content={lang} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={pageDesc} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={OG_IMG} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="675" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={pageDesc} />
<meta name="twitter:image" content={OG_IMG} />

<link rel="preload" as="font" type="font/woff2" href="/assets/fonts/sg-var.woff2" crossorigin />
<link rel="preload" as="font" type="font/woff2" href="/assets/fonts/inter-var.woff2" crossorigin />
<link rel="preconnect" href="https://i.vimeocdn.com" />
{preloadHero && (
  <link rel="preload" as="image" fetchpriority="high" href={HERO + '?w=828'} imagesrcset={HERO + '?w=828 828w, ' + HERO + '?w=1600 1600w'} imagesizes="100vw" />
)}
<link rel="stylesheet" href="/assets/site.css" />

<script type="application/ld+json" set:html={JSON.stringify(orgGraph)} />
<slot name="jsonld" />
</head>
<body>

<svg width="0" height="0" style="position:absolute" aria-hidden="true"><symbol id="viven-logo" viewBox="125 126 1374 288" fill="currentColor"><path d="M756.66,346.9l114.7-80.57c-37.87-83.92-102.57-60.93-102.57-60.93l-71.71,57.88v65.56c0,38.77,25.21,75.91,62.34,80.84h68.27l35.95-40.9-107,.1C756.66,371,756.7,346.56,756.66,346.9Zm.06-108.77s55.51-13.37,55.51,34.2l-55.51,39C757,310.8,756.72,238.13,756.72,238.13Z"/><path d="M270.4,255.39l-32.57,61.44L179,197.28l-54.41,44.41,22.58,22.58,74.76,149.91,106.6-198H237.09ZM431.78,125.83H372.19v49.22h59.59Zm1,71.45-82.54,67.36,22.95,22.95v78.47l-32.57,38.86H465.37l-32.58-38.86Zm704.72,207.64-32.58-38.86V286.85c0-43.67-29.24-84-71.06-89.57l-50.34,41.08L962.06,195.8l-57.37,47,22.58,22.95V366.06L894.7,404.92h124.73l-32.57-38.86V248.73h11.85a46.75,46.75,0,0,1,46.63,47V404.92ZM621.28,255.39l-32.57,61.44L529.86,197.28l-54.41,44.41L498,264.27,572.8,414.18l106.6-198H588Z"/><path d="M1168,219.81v14h18.21v6.48H1168v17.14h-7.24v-44.1h25.45v6.49Z"/><path d="M1201.84,212.25a5.08,5.08,0,1,1-5,5.11A5.09,5.09,0,0,1,1201.84,212.25Zm-3.41,15.81h6.87v29.36h-6.87Z"/><path d="M1218.27,213.32h6.87v44.1h-6.87Z"/><path d="M1275.15,257.42V241c0-4.66-1.63-7.62-5.48-7.62-3.46,0-6.17,2.14-6.17,9.13v14.93h-6.87V240.91c0-4.66-1.51-7.55-5.35-7.55-3.46,0-6.3,2.14-6.3,9.13v14.93h-6.87V228.06H1245v4.1a8.93,8.93,0,0,1,8.19-4.85c5.35,0,8,2.33,9.26,5.23a9.86,9.86,0,0,1,9-5.23c8.82,0,10.58,6.05,10.58,11.52v18.59Z"/><path d="M1160.77,275.55h15.81a15.43,15.43,0,1,1,0,30.86H1168v13.23h-7.24ZM1184.9,291c0-4.85-3.28-8.94-8.32-8.94H1168v17.89h8.57C1181.62,299.93,1184.9,295.83,1184.9,291Z"/><path d="M1220.73,296.65a10,10,0,0,0-2.7-.31c-5.86,0-9.08,3.33-9.08,10.64v12.66h-6.86V290.29H1209V295c1.33-2.71,5.17-5.1,9.08-5.1a7,7,0,0,1,2.7.44Z"/><path d="M1226,305a15.5,15.5,0,1,1,15.43,15.44A15.06,15.06,0,0,1,1226,305Zm24.13,0c0-5-3.4-9.32-8.7-9.32s-8.56,4.29-8.56,9.32,3.4,9.33,8.56,9.33S1250.15,310,1250.15,305Z"/><path d="M1289.7,315.67a11,11,0,0,1-9.07,4.73c-8.94,0-15.05-7.12-15.05-15.44s6.11-15.43,15.05-15.43a11,11,0,0,1,9.07,4.73V275.55h6.87v44.09h-6.87Zm0-10.71c0-5-3.4-9.32-8.69-9.32s-8.57,4.29-8.57,9.32,3.4,9.33,8.57,9.33S1289.7,310,1289.7,305Z"/><path d="M1336.19,290.29v29.35h-6.87v-4.09c-1.83,3.15-5.23,4.85-9.58,4.85s-7.18-1.51-8.81-4c-1.45-2.21-1.89-4.66-1.89-8.69V290.29h6.86v15.18c0,5,1.45,8.88,6.36,8.88s7.06-3.84,7.06-8.88V290.29Z"/><path d="M1368.75,301c-.38-3.22-2.27-5.36-6.93-5.36-5.29,0-7.88,4.35-7.88,9.32s2.4,9.33,8.32,9.33c4,0,5.67-1.77,6.55-4.73h6.87c-1,6.11-5.42,10.84-13.93,10.84-9.57,0-14.67-7.43-14.67-15.44s5.1-15.43,14.61-15.43,13.48,5.8,13.92,11.47Z"/><path d="M1402.82,319.64a33,33,0,0,1-5.1.38c-3.34,0-9.51-.44-9.51-10.33V296h-5v-5.73h5v-8.88h6.86v8.88h6.74V296h-6.74v12.1c0,5.1,1.58,5.73,4.29,5.73a27.13,27.13,0,0,0,3.46-.25Z"/><path d="M1415.86,274.48a5.07,5.07,0,1,1-5,5.1A5.08,5.08,0,0,1,1415.86,274.48Zm-3.4,15.81h6.86v29.35h-6.86Z"/><path d="M1430.09,305a15.5,15.5,0,1,1,15.43,15.44A15.06,15.06,0,0,1,1430.09,305Zm24.13,0c0-5-3.4-9.32-8.7-9.32S1437,299.93,1437,305s3.4,9.33,8.56,9.33S1454.22,310,1454.22,305Z"/><path d="M1471.85,290.29h6.87v4.09c1.82-3.15,5.22-4.85,9.57-4.85s7.18,1.51,8.82,4c1.45,2.2,1.89,4.66,1.89,8.69v17.45h-6.87V304.46c0-5-1.44-8.88-6.36-8.88s-7,3.84-7,8.88v15.18h-6.87Z"/></symbol></svg>

<SiteHeader lang={lang} slug={slug} active={active} activeSub={activeSub} switchSlug={switchSlug} langUrls={langUrls} />

<slot />

<SiteFooter lang={lang} />

<div class="sticky-cta">
  <a href={localePath(lang, 'contact')} class="btn btn-primary">{t('cta')}</a>
</div>

<div class="modal" id="video-modal" aria-hidden="true" role="dialog" aria-modal="true">
  <div class="modal-backdrop" data-close></div>
  <div class="modal-inner">
    <button class="modal-close" type="button" data-close aria-label="Close">&times;</button>
    <div class="modal-video" id="video-mount"></div>
  </div>
</div>

<script src="/assets/site.js" defer></script>
</body>
</html>
