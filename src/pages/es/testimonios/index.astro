---
import Base from '../../../layouts/Base.astro';
import { localePath } from '../../../i18n.js';
const lang = "es";
const p = (s) => localePath(lang, s);
const title = {"es":"Testimonios de clientes | Viven"};
const description = {"es":"Todos los testimonios: 5.0 en Google, video-testimonios de Siemens y Meteomatics, y cada reseña escrita en un solo lugar."};
---
<Base lang={lang} slug="testimonios" active="" singleLang={true} langUrls={{"en": "/en/testimonials/", "de": "/de/testimonials/", "es": "/es/testimonios/"}} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={"{\"@context\": \"https://schema.org\", \"@type\": \"Organization\", \"@id\": \"https://www.viven.ch/#organization\", \"aggregateRating\": {\"@type\": \"AggregateRating\", \"ratingValue\": 5, \"reviewCount\": 47, \"bestRating\": 5, \"worstRating\": 1}, \"review\": [{\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"Paula Fernandez\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"Working with Sofia and her team was a fantastic experience. We were on a very strict timeline, but they managed to deliver a high-quality corporate video in record time. Their attention to detail, speed, and communication were excellent.\"}, {\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"Jesse Kim\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"I couldn't complete my Netflix original series project well without the Viven AG team. They have a great team vibe, flexibility and great attitude. I believe it all came from Sebastian's leadership.\"}, {\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"Anne-Catherine V\u00f6lkers\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"We worked with Capgemini Switzerland on a client success story video with Viven AG and were really satisfied. We appreciated the professional, structured way of their work, their spontaneous availability and fast execution. We can for sure recommend Viven AG!\"}, {\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"Manuela Kleiner\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"Working with the entire Viven team is simply a pleasure. Their professionalism, reliability, expertise and the final result are all perfect. We've been working with Viven for several years and already look forward to the next SENSAI Beauty project.\"}, {\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"Thomas St\u00e4mpfli\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"Viven consulted on and executed most professionally our explainer video for TomFit. They delivered in time and in budget. It was truly a pleasure to work with them.\"}, {\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"Young Suh\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"I brought my team of 70 to film a Korean TV series for 5 days, and Sebastian helped make it happen. He went above and beyond \u2014 Switzerland suddenly felt approachable, even with its high production costs.\"}, {\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"SV Group\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"VIVEN supported us in the development and production of a corporate video on digitalization in the hospitality industry. We are absolutely delighted with the results and would work with VIVEN again at any time.\"}, {\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"P\u00e9ter Fankhauser\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"Super friendly, very flexible and professional team with excellent results for our product release video. I can highly recommend Viven and we'll definitely work with them again in the future!\"}, {\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"Young-il Lee\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"I had an amazing time working with Sebastian and his team in Switzerland on a Netflix series. He's a master at supporting teams and making things run smoothly. His hospitality and genuine kindness absolutely blew me away.\"}, {\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"Vlad Gheorghiu\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"The Viven team produced a very professional testimonial video which exceeded our expectations. They communicate professionally and went above and beyond to understand our needs.\"}, {\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"Tristan Piguet\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"We worked with VIVEN to produce an international 45-minute documentary on robotics. The crew was very professional and kind, and the storytelling and all the technical details were perfectly handled.\"}, {\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"Alba Guillen\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"We worked with Viven to produce videos and photos for our rebranding and the result was really nice. The team is so professional and they understand what you need from the very beginning. I really recommend them.\"}, {\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"John McGinty\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"I've worked with Sebastian and team a couple of times and on both occasions it has been a pleasure! A super friendly team who create stunning visuals. Always my first port of call when I need a film crew in Switzerland.\"}, {\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"Alexander Stauch\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"From the concept to the shooting days to the production of breathtaking videos, Viven offers an absolutely ingenious complete package that meets the highest standards. And working with Sebastian and his team is extremely fun.\"}, {\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"Ignacio Delgado Muerza\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"Super professional, hard-working team \u2014 multilingual and talented creative filmmakers. It was a pleasure to work with Sebastian and the entire Viven crew on several projects in Zurich.\"}, {\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"Marie Obien\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"Sebastian and the entire team are very professional, responsive, and really great to work with. Our video projects are all very well done and even exceeded our expectations.\"}, {\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"Annaliza Savage\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"I found VIVEN for a last-minute shoot near Zurich. Very professional crew! I loved working with Sebastian \u2014 VIVEN really went above and beyond. Definitely recommend.\"}, {\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"Kajsa Hansson\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"Always a pleasure working with Viven for my company's productions. Sebastian, our point of contact, is super responsive, flexible and accommodating. We're always more than happy with the final videos!\"}, {\"@type\": \"Review\", \"author\": {\"@type\": \"Person\", \"name\": \"Porsche Zentrum Basel\"}, \"reviewRating\": {\"@type\": \"Rating\", \"ratingValue\": 5, \"bestRating\": 5}, \"reviewBody\": \"We would like to thank the Viven team again for their outstanding work. It's always a pleasure \u2014 we're already looking forward to future productions.\"}]}"}></script>
<section class="page-hero"><div class="wrap"><div class="post-wrap">
  <span class="eyebrow">Testimonios</span>
  <h1>Lo que dicen nuestros clientes.</h1>
  <p class="lead"><span style="color:var(--acid);letter-spacing:2px">★★★★★</span> 5.0 en Google en 47+ reseñas — todas de 5 estrellas. Acá están todas, más nuestros clientes frente a cámara.</p>
</div></div></section>
<section class="sec" style="padding-top:16px"><div class="wrap">
  <h2 style="font-size:22px;margin-bottom:18px">Clientes frente a cámara</h2>
  <div class="ts-vids">
      <div class="ts-vid reveal"><div class="ts-vid-frame"><iframe src="https://player.vimeo.com/video/1036679041?dnt=1" loading="lazy" title="Siemens · Meteomatics · SV Group — Testimonials 2023" allow="fullscreen; picture-in-picture" allowfullscreen></iframe></div><p class="muted-note" style="margin-top:8px">Siemens · Meteomatics · SV Group — Testimonials 2023</p></div>
      <div class="ts-vid reveal"><div class="ts-vid-frame"><iframe src="https://player.vimeo.com/video/1033111627?dnt=1" loading="lazy" title="Siemens" allow="fullscreen; picture-in-picture" allowfullscreen></iframe></div><p class="muted-note" style="margin-top:8px">Siemens</p></div>
      <div class="ts-vid reveal"><div class="ts-vid-frame"><iframe src="https://player.vimeo.com/video/866320198?dnt=1" loading="lazy" title="Meteomatics" allow="fullscreen; picture-in-picture" allowfullscreen></iframe></div><p class="muted-note" style="margin-top:8px">Meteomatics</p></div>
  </div>
</div></section>
<section class="sec" style="padding-top:10px"><div class="wrap">
  <h2 style="font-size:22px;margin-bottom:18px">Reseñas escritas <span class="count">(19)</span></h2>
  <div class="ts-grid">
      <div class="testi reveal"><div class="starz">★★★★★</div><p>Working with Sofia and her team was a fantastic experience. We were on a very strict timeline, but they managed to deliver a high-quality corporate video in record time. Their attention to detail, speed, and communication were excellent.</p><div class="who"><strong>Paula Fernandez</strong><span class="who-co">Corporate video · vía Google</span></div></div>
      <div class="testi reveal"><div class="starz">★★★★★</div><p>I couldn't complete my Netflix original series project well without the Viven AG team. They have a great team vibe, flexibility and great attitude. I believe it all came from Sebastian's leadership.</p><div class="who"><strong>Jesse Kim</strong><span class="who-co">Netflix original series · vía Google</span></div></div>
      <div class="testi reveal"><div class="starz">★★★★★</div><p>We worked with Capgemini Switzerland on a client success story video with Viven AG and were really satisfied. We appreciated the professional, structured way of their work, their spontaneous availability and fast execution. We can for sure recommend Viven AG!</p><div class="who"><strong>Anne-Catherine Völkers</strong><span class="who-co">Capgemini Switzerland · vía Google</span></div></div>
      <div class="testi reveal"><div class="starz">★★★★★</div><p>Working with the entire Viven team is simply a pleasure. Their professionalism, reliability, expertise and the final result are all perfect. We've been working with Viven for several years and already look forward to the next SENSAI Beauty project.</p><div class="who"><strong>Manuela Kleiner</strong><span class="who-co">SENSAI Beauty · vía Google</span></div></div>
      <div class="testi reveal"><div class="starz">★★★★★</div><p>Viven consulted on and executed most professionally our explainer video for TomFit. They delivered in time and in budget. It was truly a pleasure to work with them.</p><div class="who"><strong>Thomas Stämpfli</strong><span class="who-co">TomFit · vía Google</span></div></div>
      <div class="testi reveal"><div class="starz">★★★★★</div><p>I brought my team of 70 to film a Korean TV series for 5 days, and Sebastian helped make it happen. He went above and beyond — Switzerland suddenly felt approachable, even with its high production costs.</p><div class="who"><strong>Young Suh</strong><span class="who-co">Korean TV series · vía Google</span></div></div>
      <div class="testi reveal"><div class="starz">★★★★★</div><p>VIVEN supported us in the development and production of a corporate video on digitalization in the hospitality industry. We are absolutely delighted with the results and would work with VIVEN again at any time.</p><div class="who"><strong>SV Group</strong><span class="who-co">Hospitality & catering · vía Google</span></div></div>
      <div class="testi reveal"><div class="starz">★★★★★</div><p>Super friendly, very flexible and professional team with excellent results for our product release video. I can highly recommend Viven and we'll definitely work with them again in the future!</p><div class="who"><strong>Péter Fankhauser</strong><span class="who-co">Product launch · vía Google</span></div></div>
      <div class="testi reveal"><div class="starz">★★★★★</div><p>I had an amazing time working with Sebastian and his team in Switzerland on a Netflix series. He's a master at supporting teams and making things run smoothly. His hospitality and genuine kindness absolutely blew me away.</p><div class="who"><strong>Young-il Lee</strong><span class="who-co">Netflix series · vía Google</span></div></div>
      <div class="testi reveal"><div class="starz">★★★★★</div><p>The Viven team produced a very professional testimonial video which exceeded our expectations. They communicate professionally and went above and beyond to understand our needs.</p><div class="who"><strong>Vlad Gheorghiu</strong><span class="who-co">Testimonial video · vía Google</span></div></div>
      <div class="testi reveal"><div class="starz">★★★★★</div><p>We worked with VIVEN to produce an international 45-minute documentary on robotics. The crew was very professional and kind, and the storytelling and all the technical details were perfectly handled.</p><div class="who"><strong>Tristan Piguet</strong><span class="who-co">Robotics documentary · vía Google</span></div></div>
      <div class="testi reveal"><div class="starz">★★★★★</div><p>We worked with Viven to produce videos and photos for our rebranding and the result was really nice. The team is so professional and they understand what you need from the very beginning. I really recommend them.</p><div class="who"><strong>Alba Guillen</strong><span class="who-co">Brand relaunch · vía Google</span></div></div>
      <div class="testi reveal"><div class="starz">★★★★★</div><p>I've worked with Sebastian and team a couple of times and on both occasions it has been a pleasure! A super friendly team who create stunning visuals. Always my first port of call when I need a film crew in Switzerland.</p><div class="who"><strong>John McGinty</strong><span class="who-co">vía Google</span></div></div>
      <div class="testi reveal"><div class="starz">★★★★★</div><p>From the concept to the shooting days to the production of breathtaking videos, Viven offers an absolutely ingenious complete package that meets the highest standards. And working with Sebastian and his team is extremely fun.</p><div class="who"><strong>Alexander Stauch</strong><span class="who-co">vía Google</span></div></div>
      <div class="testi reveal"><div class="starz">★★★★★</div><p>Super professional, hard-working team — multilingual and talented creative filmmakers. It was a pleasure to work with Sebastian and the entire Viven crew on several projects in Zurich.</p><div class="who"><strong>Ignacio Delgado Muerza</strong><span class="who-co">vía Google</span></div></div>
      <div class="testi reveal"><div class="starz">★★★★★</div><p>Sebastian and the entire team are very professional, responsive, and really great to work with. Our video projects are all very well done and even exceeded our expectations.</p><div class="who"><strong>Marie Obien</strong><span class="who-co">vía Google</span></div></div>
      <div class="testi reveal"><div class="starz">★★★★★</div><p>I found VIVEN for a last-minute shoot near Zurich. Very professional crew! I loved working with Sebastian — VIVEN really went above and beyond. Definitely recommend.</p><div class="who"><strong>Annaliza Savage</strong><span class="who-co">vía Google</span></div></div>
      <div class="testi reveal"><div class="starz">★★★★★</div><p>Always a pleasure working with Viven for my company's productions. Sebastian, our point of contact, is super responsive, flexible and accommodating. We're always more than happy with the final videos!</p><div class="who"><strong>Kajsa Hansson</strong><span class="who-co">vía Google</span></div></div>
      <div class="testi reveal"><div class="starz">★★★★★</div><p>We would like to thank the Viven team again for their outstanding work. It's always a pleasure — we're already looking forward to future productions.</p><div class="who"><strong>Porsche Zentrum Basel</strong><span class="who-co">Porsche · vía Google</span></div></div>
  </div>
</div></section>
<style is:global>
.ts-vids{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px}
.ts-vid-frame{position:relative;aspect-ratio:16/9;border-radius:14px;overflow:hidden}
.ts-vid-frame iframe{position:absolute;inset:0;width:100%;height:100%;border:0}
.ts-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:14px}
.ts-grid .testi{margin:0}
</style>
</Base>
