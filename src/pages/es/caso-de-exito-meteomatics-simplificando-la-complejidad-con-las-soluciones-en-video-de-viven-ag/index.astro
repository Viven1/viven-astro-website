const jsonld = {"@context":"https://schema.org","@graph":[{"@type":"Article","mainEntityOfPage":{"@type":"WebPage","@id":url},"headline":"Meteomatics — simplificando la complejidad con las soluciones en video de Viven AG","description":description.es,"inLanguage":"es","author":{"@type":"Organization","@id":"https://www.viven.ch/#organization"},"publisher":{"@id":"https://www.viven.ch/#organization"},"url":url,"about":{"@type":"Organization","name":"Meteomatics"}},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://www.viven.ch/"},{"@type":"ListItem","position":2,"name":"Casos de éxito","item":"https://www.viven.ch/projects/"},{"@type":"ListItem","position":3,"name":"Meteomatics — Video","item":url}]},{"@type":"VideoObject","name":"Meteomatics — Explainer series by Viven","description":"Watch the work Viven produced for this case study.","embedUrl":"https://player.vimeo.com/video/772421307","thumbnailUrl":"https://vumbnail.com/772421307.jpg","uploadDate":"2024-01-01T08:00:00+01:00","publisher":{"@id":"https://www.viven.ch/#organization"}},{"@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "How do you explain a complex B2B product on video?", "acceptedAnswer": {"@type": "Answer", "text": "By translating technical value into human stories: Viven scripted and produced a video series for Meteomatics that shows what their weather intelligence enables — instead of how the technology works internally. Concept, script, filming and animation were handled end to end."}}, {"@type": "Question", "name": "What did Meteomatics use the videos for?", "acceptedAnswer": {"@type": "Answer", "text": "Mainly branding and visibility in new markets, plus emphasising brand values in existing markets — and the videos contributed directly to winning new customers, according to Meteomatics' Head of Marketing."}}, {"@type": "Question", "name": "How long does an explainer video series take to produce?", "acceptedAnswer": {"@type": "Answer", "text": "A single explainer typically takes 3–5 weeks from brief to delivery; a series is planned so episodes share shooting days and design systems, which lowers the cost per video significantly."}}, {"@type": "Question", "name": "Does Viven work with other technology companies?", "acceptedAnswer": {"@type": "Answer", "text": "Yes — Viven produces for tech and industrial clients including Siemens, ABB, Sonova, ANYbotics and LEM, from how-to series to product launches."}}]}]};
---
<Base lang={lang} slug={slug} active="projects" singleLang={true} langUrls={{"en":"/en/case-study-meteomatics-simplifying-complexity-with-viven-ags-video-solutions/","de":"/de/case-study-meteomatics-komplexitaet-vereinfachen-mit-den-videos-von-viven-ag/","es":"/es/caso-de-exito-meteomatics-simplificando-la-complejidad-con-las-soluciones-en-video-de-viven-ag/"}} title={title} description={description}>
