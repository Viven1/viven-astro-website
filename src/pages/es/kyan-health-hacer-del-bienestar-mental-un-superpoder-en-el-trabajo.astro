---
import Base from '../../layouts/Base.astro';
import CaseStudy from '../../components/CaseStudy.astro';
import projects from '../../data/projects.json';
const project = projects.find((x) => x.slug === "es/kyan-health-hacer-del-bienestar-mental-un-superpoder-en-el-trabajo");
const lang = "es";
const SITE = "https://www.viven.ch";
const title = {"es": "Kyan Health Hacer del bienestar mental un superpoder en el trabajo | Viven"};
const description = {"es": "Kyan Health se asocia con ON para mejorar el bienestar mental de los empleados a través de una aplicación de salud integral, promoviendo el autocuidado, la at"};
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VideoObject',
      name: project.headline,
      description: description[lang],
      thumbnailUrl: SITE + project.stills[0],
      embedUrl: 'https://player.vimeo.com/video/' + project.vimeo,
      uploadDate: "2023-05-01",
      publisher: { '@id': SITE + '/#organization' },
    },
    {
      '@type': 'CreativeWork',
      name: project.headline,
      about: project.client,
      inLanguage: lang,
      creator: { '@id': SITE + '/#organization' },
      url: SITE + "/es/kyan-health-hacer-del-bienestar-mental-un-superpoder-en-el-trabajo/",
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: SITE + '/' + lang + '/projects/' },
        { '@type': 'ListItem', position: 3, name: project.headline, item: SITE + "/es/kyan-health-hacer-del-bienestar-mental-un-superpoder-en-el-trabajo/" },
      ],
    },
  ],
};
---
<Base lang={lang} slug="projects" active="projects" singleLang={true} switchSlug="projects" canonicalPath={"/es/kyan-health-hacer-del-bienestar-mental-un-superpoder-en-el-trabajo/"} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(ld)}></script>
  <CaseStudy project={project} lang={lang} />
</Base>
