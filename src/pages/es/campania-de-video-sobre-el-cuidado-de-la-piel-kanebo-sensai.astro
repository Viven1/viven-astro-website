---
import Base from '../../layouts/Base.astro';
import CaseStudy from '../../components/CaseStudy.astro';
import projects from '../../data/projects.json';
const project = projects.find((x) => x.slug === "es/campania-de-video-sobre-el-cuidado-de-la-piel-kanebo-sensai");
const lang = "es";
const SITE = "https://www.viven.ch";
const title = {"es": "Campaña de videos tutoriales Kanebo Sensai | Viven"};
const description = {"es": "Kanebo y Viven crearon 11 videos tutoriales de alta calidad en los que se mostraban las técnicas de aplicación adecuadas para el cuidado de la piel Sensai, me"};
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VideoObject',
      name: project.headline,
      description: description[lang],
      thumbnailUrl: SITE + project.stills[0],
      embedUrl: 'https://player.vimeo.com/video/' + project.vimeo,
      uploadDate: "2024-09-01",
      publisher: { '@id': SITE + '/#organization' },
    },
    {
      '@type': 'CreativeWork',
      name: project.headline,
      about: project.client,
      inLanguage: lang,
      creator: { '@id': SITE + '/#organization' },
      url: SITE + "/es/campania-de-video-sobre-el-cuidado-de-la-piel-kanebo-sensai/",
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: SITE + '/' + lang + '/projects/' },
        { '@type': 'ListItem', position: 3, name: project.headline, item: SITE + "/es/campania-de-video-sobre-el-cuidado-de-la-piel-kanebo-sensai/" },
      ],
    },
  ],
};
---
<Base lang={lang} slug="projects" active="projects" singleLang={true} switchSlug="projects" canonicalPath={"/es/campania-de-video-sobre-el-cuidado-de-la-piel-kanebo-sensai/"} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(ld)}></script>
  <CaseStudy project={project} lang={lang} />
</Base>
