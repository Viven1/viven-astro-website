---
import Base from '../../layouts/Base.astro';
import CaseStudy from '../../components/CaseStudy.astro';
import projects from '../../data/projects.json';
const project = projects.find((x) => x.slug === "es/caso-de-exito-meteomatics-simplificando-la-complejidad-con-las-soluciones-en-video-de-viven-ag");
const lang = "es";
const SITE = "https://www.viven.ch";
const title = {"es":"Caso de éxito: Meteomatics – Simplificando la Complejidad con Soluciones de Video | Viven"};
const description = {"es":"Meteomatics, un líder en datos meteorológicos, enfrentaba el reto de comunicar la complejidad de sus servicios de manera clara y atractiva. Para lograrlo, "};
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VideoObject',
      name: project.headline,
      description: description[lang],
      thumbnailUrl: SITE + project.stills[0],
      embedUrl: 'https://player.vimeo.com/video/' + project.vimeo,
      uploadDate: '2024-01-01',
      publisher: { '@id': SITE + '/#organization' },
    },
    {
      '@type': 'CreativeWork',
      name: project.headline,
      about: project.client,
      inLanguage: lang,
      creator: { '@id': SITE + '/#organization' },
      url: SITE + "/es/caso-de-exito-meteomatics-simplificando-la-complejidad-con-las-soluciones-en-video-de-viven-ag/",
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: SITE + '/' + lang + '/projects/' },
        { '@type': 'ListItem', position: 3, name: project.headline, item: SITE + "/es/caso-de-exito-meteomatics-simplificando-la-complejidad-con-las-soluciones-en-video-de-viven-ag/" },
      ],
    },
  ],
};
---
<Base lang={lang} slug="projects" active="projects" singleLang={true} switchSlug="projects" canonicalPath={"/es/caso-de-exito-meteomatics-simplificando-la-complejidad-con-las-soluciones-en-video-de-viven-ag/"} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(ld)}></script>
  <CaseStudy project={project} lang={lang} />
</Base>
