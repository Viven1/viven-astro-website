---
import Base from '../../layouts/Base.astro';
import CaseStudy from '../../components/CaseStudy.astro';
import projects from '../../data/projects.json';
const project = projects.find((x) => x.slug === "es/duelo-de-cocineros-de-la-copa-mundial-philips-con-rene-schudel");
const lang = "es";
const SITE = "https://www.viven.ch";
const title = {"es":"Philips — Duelo de cocineros con René Schudel | Viven"};
const description = {"es":"Experimenta la emoción del \"Duelo culinario de Philips\". El famoso chef de televisión suizo René Schudel se enfrenta al chef aficionado Mauro Mantovani uti"};
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VideoObject',
      name: project.headline,
      description: description[lang],
      thumbnailUrl: SITE + project.stills[0],
      embedUrl: 'https://player.vimeo.com/video/' + project.vimeo,
      uploadDate: '2024-01-01T00:00:00+00:00',
      publisher: { '@id': SITE + '/#organization' },
    },
    {
      '@type': 'CreativeWork',
      name: project.headline,
      about: project.client,
      inLanguage: lang,
      creator: { '@id': SITE + '/#organization' },
      url: SITE + "/es/duelo-de-cocineros-de-la-copa-mundial-philips-con-rene-schudel/",
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: SITE + '/' + lang + '/projects/' },
        { '@type': 'ListItem', position: 3, name: project.headline, item: SITE + "/es/duelo-de-cocineros-de-la-copa-mundial-philips-con-rene-schudel/" },
      ],
    },
  ],
};
---
<Base lang={lang} slug="projects" active="projects" singleLang={true} switchSlug="projects" canonicalPath={"/es/duelo-de-cocineros-de-la-copa-mundial-philips-con-rene-schudel/"} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(ld)}></script>
  <CaseStudy project={project} lang={lang} />
</Base>
