---
import Base from '../../layouts/Base.astro';
import CaseStudy from '../../components/CaseStudy.astro';
import projects from '../../data/projects.json';
const project = projects.find((x) => x.slug === "es/porsche-en-el-camino-hacia-la-electromovilidad-cautivadora-campania-para-las-redes-sociales");
const lang = "es";
const SITE = "https://www.viven.ch";
const title = {"es": "Porsche — Electromovilidad en redes sociales | Viven"};
const description = {"es": "Michael Lang explora las ventajas de la movilidad eléctrica con el Taycan Cross Turismo de Porsche, mostrando innovación y sostenibilidad en esta cautivadora "};
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VideoObject',
      name: project.headline,
      description: description[lang],
      thumbnailUrl: SITE + project.stills[0],
      embedUrl: 'https://player.vimeo.com/video/' + project.vimeo,
      uploadDate: "2021-09-01T00:00:00+00:00",
      publisher: { '@id': SITE + '/#organization' },
    },
    {
      '@type': 'CreativeWork',
      name: project.headline,
      about: project.client,
      inLanguage: lang,
      creator: { '@id': SITE + '/#organization' },
      url: SITE + "/es/porsche-en-el-camino-hacia-la-electromovilidad-cautivadora-campania-para-las-redes-sociales/",
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: SITE + '/' + lang + '/projects/' },
        { '@type': 'ListItem', position: 3, name: project.headline, item: SITE + "/es/porsche-en-el-camino-hacia-la-electromovilidad-cautivadora-campania-para-las-redes-sociales/" },
      ],
    },
  ],
};
---
<Base lang={lang} slug="projects" active="projects" singleLang={true} switchSlug="projects" canonicalPath={"/es/porsche-en-el-camino-hacia-la-electromovilidad-cautivadora-campania-para-las-redes-sociales/"} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(ld)}></script>
  <CaseStudy project={project} lang={lang} />
</Base>
