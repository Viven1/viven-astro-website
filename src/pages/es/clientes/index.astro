const lang = "es";
const p = (s) => localePath(lang, s);
const title = {"es":"Nuestros clientes | Viven"};
const description = {"es":"De UBS, Siemens y FIFA a Chanel, Porsche y Swarovski: las 89 marcas que confían su producción de video en Suiza a Viven."};
