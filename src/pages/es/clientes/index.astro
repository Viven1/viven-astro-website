<style is:global>
.cl-wall{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px}
.cl-logo{border:1px solid rgba(255,255,255,.1);border-radius:14px;padding:20px 14px;display:flex;align-items:center;justify-content:center;min-height:96px;transition:.25s}
.cl-logo img{width:100%;max-width:126px;height:50px;object-fit:contain;filter:brightness(0) invert(.92);opacity:.8;transition:.25s}
.cl-logo:hover{border-color:var(--acid,#ddf98f)}
.cl-logo:hover img{opacity:1}
:root[data-theme="light"] .cl-logo img{filter:brightness(0);opacity:.72}
@media(max-width:640px){.cl-wall{grid-template-columns:repeat(2,1fr)}.cl-logo{min-height:78px;padding:14px 10px}.cl-logo img{max-width:104px;height:40px}}
</style>
