---
import Base from '../../layouts/Base.astro';
import CaseStudy from '../../components/CaseStudy.astro';
import projects from '../../data/projects.json';
const project = projects.find((x) => x.slug === "es/campania-de-producto-vidby-traduccion-impulsada-por-inteligencia-artificial");
const lang = "es";
const SITE = "https://www.viven.ch";
const title = {"es":"Vidby - Traducciones impulsadas por IA - Campaña de producto | Viven"};
const description = {"es":"La atractiva estrategia de marketing de vídeo omnicanal de Vidby desvela un mundo en el que el idioma ya no es una barrera y ofrece un anticipo del futuro "};
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VideoObject',
      name: project.headline,
      description: description[lang],
      thumbnailUrl: SITE + project.stills[0],
      embedUrl: 'https://player.vimeo.com/video/' + project.vimeo,
      uploadDate: '2024-01-01',
      publisher: { '@id': SITE + '/#organization' },
    },
    {
      '@type': 'CreativeWork',
      name: project.headline,
      about: project.client,
      inLanguage: lang,
      creator: { '@id': SITE + '/#organization' },
      url: SITE + "/es/campania-de-producto-vidby-traduccion-impulsada-por-inteligencia-artificial/",
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: SITE + '/' + lang + '/projects/' },
        { '@type': 'ListItem', position: 3, name: project.headline, item: SITE + "/es/campania-de-producto-vidby-traduccion-impulsada-por-inteligencia-artificial/" },
      ],
    },
  ],
};
---
<Base lang={lang} slug="projects" active="projects" singleLang={true} switchSlug="projects" canonicalPath={"/es/campania-de-producto-vidby-traduccion-impulsada-por-inteligencia-artificial/"} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(ld)}></script>
  <CaseStudy project={project} lang={lang} />
</Base>
