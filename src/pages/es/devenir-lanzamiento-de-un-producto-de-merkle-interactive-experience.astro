---
import Base from '../../layouts/Base.astro';
import CaseStudy from '../../components/CaseStudy.astro';
import projects from '../../data/projects.json';
const project = projects.find((x) => x.slug === "es/devenir-lanzamiento-de-un-producto-de-merkle-interactive-experience");
const lang = "es";
const SITE = "https://www.viven.ch";
const title = {"es": "Devenir: Lanzamiento de un producto de Merkle Interactive Experience | Viven"};
const description = {"es": "Merkle lanzó un innovador juego controlado por la mente en el Digital Festival Zürich, mostrando su experiencia en la transformación de la experiencia del cli"};
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VideoObject',
      name: project.headline,
      description: description[lang],
      thumbnailUrl: SITE + project.stills[0],
      embedUrl: 'https://player.vimeo.com/video/' + project.vimeo,
      uploadDate: "2022-04-01",
      publisher: { '@id': SITE + '/#organization' },
    },
    {
      '@type': 'CreativeWork',
      name: project.headline,
      about: project.client,
      inLanguage: lang,
      creator: { '@id': SITE + '/#organization' },
      url: SITE + "/es/devenir-lanzamiento-de-un-producto-de-merkle-interactive-experience/",
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: SITE + '/' + lang + '/projects/' },
        { '@type': 'ListItem', position: 3, name: project.headline, item: SITE + "/es/devenir-lanzamiento-de-un-producto-de-merkle-interactive-experience/" },
      ],
    },
  ],
};
---
<Base lang={lang} slug="projects" active="projects" singleLang={true} switchSlug="projects" canonicalPath={"/es/devenir-lanzamiento-de-un-producto-de-merkle-interactive-experience/"} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(ld)}></script>
  <CaseStudy project={project} lang={lang} />
</Base>
