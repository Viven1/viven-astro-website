<Base lang={lang} slug="blog/video-de-employer-branding-tambien-importa-para-quienes-ya-estan-en-el-equipo" active="blog" singleLang={true} langUrls={{"es":"/es/blog/video-de-employer-branding-tambien-importa-para-quienes-ya-estan-en-el-equipo/","en":"/en/blog/employer-branding-video-why-it-matters-to-people-you-already-hired/","de":"/de/blog/employer-branding-video-warum-es-auch-fuer-die-eigenen-mitarbeitenden-zaehlt/"}} title={title} description={description}>
