---
import Base from '../../../layouts/Base.astro';
import Testimonials from '../../../components/Testimonials.astro';
import CalcBanner from '../../../components/CalcBanner.astro';
const lang='es';
const title={"es":"Blog — Producción de video en Zúrich | Viven"};
const description={"es":"Guías sobre video de marca, producto y employer branding — por Viven, productora de video en Zúrich."};

// Los posts propios en español se auto-descubren de su propio contenido (mismo
// criterio que en/de/blog). El fallback a la imagen del JSON-LD cubre los posts
// que no tienen <img> inline en el cuerpo.
const rawPosts = import.meta.glob('./*/index.astro', { query: '?raw', import: 'default', eager: true });
const extract = (raw) => {
  const jstr = (re) => { const m = String(raw).match(re); if (!m) return ''; try { return JSON.parse(m[1]); } catch { return ''; } };
  const title = jstr(/const title = \{"[a-z]{2}":("(?:[^"\\]|\\.)*")\}/).replace(/ \| Viven$/, '');
  const desc = String(jstr(/const description = \{"[a-z]{2}":("(?:[^"\\]|\\.)*")\}/) || '');
  const imgMatch = String(raw).match(/<img src="([^"]+)"/) || String(raw).match(/image\\":\\"([^\\]+)/);
  const img = (imgMatch && imgMatch[1]) || '/projects/siemens-shaping-the-future-together-employer-branding-campaign/02-RORES_clean_VIVEN.00_13_13_20.Still042.jpg';
  const date = (String(raw).match(/datePublished[^0-9]{0,6}([0-9]{4}-[0-9]{2}-[0-9]{2}[0-9T:.+]*)/) || [])[1] || '';
  return { title, desc, img, date };
};
const autoPosts = Object.entries(rawPosts).map(([path, raw]) => {
  const slug = path.split('/')[1];
  const e = extract(raw);
  return { slug, title: e.title || slug, desc: e.desc, img: e.img, date: e.date };
}).sort((a, b) => (b.date || '').localeCompare(a.date || ''));

// unos pocos destacados en EN para quien no encuentra suficiente contenido en
// español todavía — la imagen sale del propio post en inglés, no a mano.
const enRaw = import.meta.glob('../../en/blog/*/index.astro', { query: '?raw', import: 'default', eager: true });
const EN_HIGHLIGHTS = ['boost-brand-growth-with-an-effective-video-marketing-strategy', 'collaborating-with-swiss-filmmakers-what-you-need-to-know', 'commercial-video-production-in-switzerland-elevate-your-brand', 'documentary-production-in-switzerland-why-its-a-prime-location-for-storytelling', 'exploring-film-production-services-in-switzerland', 'how-b2b-brands-generate-qualified-leads-with-video', 'how-b2b-companies-simplify-complex-products-with-explainer-videos', 'how-big-brands-can-use-video-production-to-attract-new-prospects-and-drive-sales'];
const enHighlights = EN_HIGHLIGHTS.map((slug) => {
  const entry = Object.entries(enRaw).find(([path]) => path.includes('/' + slug + '/'));
  if (!entry) return null;
  const e = extract(entry[1]);
  return { slug, title: e.title || slug, desc: e.desc, img: e.img };
}).filter(Boolean);
---
<Base lang={lang} slug="blog" active="blog" singleLang={true} title={title} description={description}>
  <section class="page-hero"><div class="wrap"><span class="eyebrow">Blog</span><h1>Video que funciona, <span class="hl">explicado.</span></h1><p class="lead">Guías prácticas sobre video de marca, producto y employer branding.</p></div></section>
  <section class="sec" style="padding-top:0"><div class="wrap">
      <div class="blog-grid">
      {autoPosts.map((post) => (
        <a href={'/es/blog/' + post.slug + '/'} class="blog-card reveal">
          <div class="blog-card-img"><img src={post.img} loading="lazy" decoding="async" width="480" height="270" alt={post.title} /></div>
          <div class="blog-card-body"><h3>{post.title}</h3><p>{post.desc}</p><span class="more">Leer más →</span></div>
        </a>
      ))}
      </div>
      <p class="blog-note" style="margin-top:40px">Tenemos muchos más artículos en inglés y alemán. Algunos destacados:</p>
      <div class="blog-grid">
      {enHighlights.map((post) => (
        <a href={'/en/blog/' + post.slug + '/'} class="blog-card reveal">
          <div class="blog-card-img"><img src={post.img} loading="lazy" decoding="async" width="480" height="270" alt={post.title} /></div>
          <div class="blog-card-body"><h3>{post.title}</h3><p>{post.desc}</p><span class="more">Read (EN) →</span></div>
        </a>
      ))}
      </div>
  </div></section>
  <CalcBanner lang={lang} />
  <Testimonials lang={lang} />
</Base>
