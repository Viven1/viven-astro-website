---
import Base from '../layouts/Base.astro';
import CaseStudy from '../components/CaseStudy.astro';
import projects from '../data/projects.json';
const project = projects.find((x) => x.slug === "ubs-group-internal-consulting-employer-branding-campaign");
const lang = "en";
const SITE = "https://www.viven.ch";
const title = {"en": "UBS Group Internal Consulting — Employer Branding | Viven"};
const description = {"en": "Discover UBS's engaging employer branding campaign that highlights the benefits of internal consulting roles while humorously addressing external consulting c"};
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VideoObject',
      name: project.headline,
      description: description[lang],
      thumbnailUrl: SITE + project.stills[0],
      embedUrl: 'https://player.vimeo.com/video/' + project.vimeo,
      uploadDate: "2021-06-01",
      publisher: { '@id': SITE + '/#organization' },
    },
    {
      '@type': 'CreativeWork',
      name: project.headline,
      about: project.client,
      inLanguage: lang,
      creator: { '@id': SITE + '/#organization' },
      url: SITE + "/ubs-group-internal-consulting-employer-branding-campaign/",
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: SITE + '/' + lang + '/projects/' },
        { '@type': 'ListItem', position: 3, name: project.headline, item: SITE + "/ubs-group-internal-consulting-employer-branding-campaign/" },
      ],
    },
  ],
};
---
<Base lang={lang} slug="projects" active="projects" singleLang={true} switchSlug="projects" canonicalPath={"/ubs-group-internal-consulting-employer-branding-campaign/"} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(ld)}></script>
  <CaseStudy project={project} lang={lang} />
</Base>
