---
import Base from '../../layouts/Base.astro';
import CaseStudy from '../../components/CaseStudy.astro';
import projects from '../../data/projects.json';
const project = projects.find((x) => x.slug === "en/stadtspital-zurich-mis-spital-mis-laebe-employer-branding-social-media");
const lang = "en";
const SITE = "https://www.viven.ch";
const title = {"en": "Mis Spital. Mis Läbe. — Stadtspital Zurich | Viven"};
const description = {"en": "Discover the dynamic lifestyle of healthcare professionals at Stadtspital Zurich, showcasing their daily routines, teamwork, and personal passions beyond the "};
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VideoObject',
      name: project.headline,
      description: description[lang],
      thumbnailUrl: SITE + project.stills[0],
      embedUrl: 'https://player.vimeo.com/video/' + project.vimeo,
      uploadDate: "2023-11-01",
      publisher: { '@id': SITE + '/#organization' },
    },
    {
      '@type': 'CreativeWork',
      name: project.headline,
      about: project.client,
      inLanguage: lang,
      creator: { '@id': SITE + '/#organization' },
      url: SITE + "/en/stadtspital-zurich-mis-spital-mis-laebe-employer-branding-social-media/",
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: SITE + '/' + lang + '/projects/' },
        { '@type': 'ListItem', position: 3, name: project.headline, item: SITE + "/en/stadtspital-zurich-mis-spital-mis-laebe-employer-branding-social-media/" },
      ],
    },
  ],
};
---
<Base lang={lang} slug="projects" active="projects" singleLang={true} switchSlug="projects" canonicalPath={"/en/stadtspital-zurich-mis-spital-mis-laebe-employer-branding-social-media/"} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(ld)}></script>
  <CaseStudy project={project} lang={lang} />
</Base>
