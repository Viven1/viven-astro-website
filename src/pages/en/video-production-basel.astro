---
// Página de localización: Video Production Basel — hub farmacéutico/life-sciences,
// diferenciado de Zurich (corporate general) y Geneva (banca/NGO). Ver
// conversación: la home ya posee "video production zurich", así que Zurich no
// necesita página propia; Basel/Lausanne son oportunidades reales sin solape.
import Base from '../../layouts/Base.astro';
const lang = "en";
const d = {"title": "Video Production Basel — Life Sciences & Corporate Film | Viven", "description": "Video production in Basel for pharma, life-sciences and corporate brands. Zurich crew or local team, fixed quote, first cut in 2 weeks.", "h1": "Video Production Basel", "lead": "Viven is a Swiss video production company that shoots regularly in Basel — home to some of the world's largest pharmaceutical and life-sciences companies, a historic chemical industry, and Art Basel's global creative economy. We produce corporate films, internal communications and campaign videos for organisations that need precision as much as polish. Crew and equipment travel from Zurich at no hidden cost — under an hour by train — or we staff your shoot with trusted local crew. You see the first cut in about two weeks.", "sections": [{"h2": "How we produce in Basel", "html": "<p>Basel is under an hour from our Zurich base, so a day trip rarely shows up as a line item on your invoice. You choose the setup that fits your project:</p><ul><li><strong>Zurich crew on location:</strong> our core team and equipment travel to Basel with travel costs quoted upfront in your fixed offer — no surprise line items after the shoot.</li><li><strong>Local crew:</strong> for multi-day or recurring productions we work with vetted freelance crew based in the region, directed by us, so you get local availability with consistent quality.</li></ul><p>One producer owns your project from briefing to delivery, and we scout locations — labs, campuses, fair halls, riverside offices — before the shoot day, not on it. If your production needs site access approvals, badge clearance or filming permits inside restricted facilities, we sort that paperwork with you in the prep week.</p>"}, {"h2": "Built for Basel's life-sciences and creative economy", "html": "<p>Few Swiss cities combine such a technical audience with such a design-literate one. We produce video that holds up in both worlds:</p><ul><li><strong>Pharma and life sciences,</strong> where messaging has to survive legal and medical review without losing clarity — internal training, R&amp;D storytelling, investor and conference content.</li><li><strong>Chemical and industrial manufacturers,</strong> for whom process and safety communication is as important as brand film.</li><li><strong>Art Basel and the creative sector,</strong> where visual craft and pacing carry the whole message.</li><li><strong>Congresses and trade fairs</strong> at the Messe Basel — keynote capture, exhibitor films, highlight reels.</li></ul><p>Our own healthcare work — including hospital and workplace-wellbeing films for Stadtspital Zürich and Kyan Health — means we already know how to shoot around clinical environments, patient consent and review cycles. We have also filmed for UBS, Siemens, Porsche, ON, FIFA and Philips; the same standard travels with us to every Basel shoot.</p>"}, {"h2": "German precision, English delivery", "html": "<p>Basel runs on Swiss German day to day and standard German or English in the boardroom — and pharma and life-sciences content usually needs to travel straight to a global HQ audience regardless of where it was shot. We direct and shoot in German, English and Spanish in-house, so technical and scientific terminology stays accurate through the whole process instead of getting reinterpreted in translation afterwards. Every project ships with subtitle files and platform-ready cut-downs for internal portals, conference screens and social channels alike.</p><p>If your review process runs through a global medical or legal team, we build that extra approval layer into the timeline from day one rather than treating it as a delay.</p>"}, {"h2": "Budgets, timelines and how to start", "html": "<p>Basel projects at Viven range from CHF 4,000 for a focused interview or event video to CHF 80,000 for multi-day corporate or campaign work — always as a fixed offer, never open-ended billing. You review the first cut about two weeks after the shoot.</p><p>Viven was founded by the producer of the first Swiss feature film on Netflix, and that filmmaking background shows in how we light, frame and edit even the most technical corporate work. Tell us what your video needs to achieve in Basel, and you will have a concrete concept and quote within days. Many client relationships start with one tightly scoped project — a single interview day, one internal training film — and grow once process and result have proven themselves.</p>"}]};
const title = { "en": d.title };
const description = { "en": d.description };
const langUrls = { "en": "/en/video-production-basel/", "de": "/de/videoproduktion-basel/", "es": "/es/produccion-de-video-basilea/" };
const SITE = 'https://www.viven.ch';
const ld = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: d.h1, description: d.description,
  provider: { '@id': SITE + '/#organization' },
  areaServed: { '@type': 'City', name: 'Basel' },
  serviceType: 'Video production',
  url: SITE + '/en/video-production-basel/',
});
---
<Base lang={lang} slug="video-production-basel" active="services" title={title} description={description} singleLang={true} switchSlug="services" langUrls={langUrls}>
  <script type="application/ld+json" slot="jsonld" set:html={ld}></script>
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow">Basel — Switzerland</span>
      <h1 class="rsrc-h1">{d.h1}</h1>
      <p class="lead">{d.lead}</p>
    </div>
  </section>
  <section class="section">
    <div class="wrap rsrc-body">
      {d.sections.map((sec) => (
        <div class="rsrc-sec">
          <h2>{sec.h2}</h2>
          <div set:html={sec.html}></div>
        </div>
      ))}
      <div class="rsrc-ctabox">
        <div>
          <div class="rsrc-ctat">Planning a video in Basel?</div>
          <p class="rsrc-ctas">Tell us what you’re working on — clear quote, usually within one business day.</p>
        </div>
        <div class="rsrc-ctabtns">
          <a class="btn btn-primary" href="/en/contact/">Start a project</a>
          <a class="btn btn-ghost" href="/book/" target="_blank" rel="noopener">📅 Book a 15-min call</a>
        </div>
      </div>
    </div>
  </section>
  <style is:global>
    .rsrc-h1{font-size:clamp(28px,4.4vw,44px)!important}
    .rsrc-body{max-width:820px}
    .rsrc-sec{margin-bottom:30px}
    .rsrc-sec h2{font-size:clamp(19px,2.6vw,24px);margin-bottom:12px}
    .rsrc-sec p{color:var(--muted);font-size:15.5px;line-height:1.75;margin-bottom:12px}
    .rsrc-sec ul{margin:0 0 12px 20px;color:var(--muted);font-size:15.5px;line-height:1.75}
    .rsrc-sec li{margin-bottom:6px}
    .rsrc-sec strong{color:var(--text)}
    .rsrc-ctabox{display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;border:1px solid var(--line-strong);background:var(--navy-800);border-radius:18px;padding:26px 28px;margin:40px 0 8px}
    .rsrc-ctat{font-family:'Space Grotesk';font-weight:700;font-size:20px;margin-bottom:6px}
    .rsrc-ctas{color:var(--muted);font-size:14px;max-width:460px;margin:0}
    .rsrc-ctabtns{display:flex;gap:10px;flex-wrap:wrap}
  </style>
</Base>
