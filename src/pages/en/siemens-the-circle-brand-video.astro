---
import Base from '../../layouts/Base.astro';
import CaseStudy from '../../components/CaseStudy.astro';
import projects from '../../data/projects.json';
const project = projects.find((x) => x.slug === "en/siemens-the-circle-brand-video");
const lang = "en";
const SITE = "https://www.viven.ch";
const title = {"en":"Siemens - The Circle Brand Video | Viven"};
const description = {"en":"Presenter Rob Holub leads the audience through The Circle, an architectural and engineering marvel that redefines our connection with buildings and the env"};
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VideoObject',
      name: project.headline,
      description: description[lang],
      thumbnailUrl: SITE + project.stills[0],
      embedUrl: 'https://player.vimeo.com/video/' + project.vimeo,
      uploadDate: '2024-01-01T00:00:00+00:00',
      publisher: { '@id': SITE + '/#organization' },
    },
    {
      '@type': 'CreativeWork',
      name: project.headline,
      about: project.client,
      inLanguage: lang,
      creator: { '@id': SITE + '/#organization' },
      url: SITE + "/en/siemens-the-circle-brand-video/",
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: SITE + '/' + lang + '/projects/' },
        { '@type': 'ListItem', position: 3, name: project.headline, item: SITE + "/en/siemens-the-circle-brand-video/" },
      ],
    },
  ],
};
---
<Base lang={lang} slug="projects" active="projects" singleLang={true} switchSlug="projects" canonicalPath={"/en/siemens-the-circle-brand-video/"} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(ld)}></script>
  <CaseStudy project={project} lang={lang} />
</Base>
