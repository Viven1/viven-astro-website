---
import Base from '../../../layouts/Base.astro';
import Testimonials from '../../../components/Testimonials.astro';
const lang = "en";
const title = {"en":"Blog — Video Production Insights | Viven"};
const description = {"en":"Practical guides on brand, product and employer-branding video — from Viven, a Zurich video production company."};

// Posts publicados por el dashboard / motor de contenido: cualquier carpeta de post
// que no esté en las cards fijas de abajo se auto-descubre acá y aparece PRIMERA.
const KNOWN = new Set(['boost-brand-growth-with-an-effective-video-marketing-strategy', 'collaborating-with-swiss-filmmakers-what-you-need-to-know', 'commercial-video-production-in-switzerland-elevate-your-brand', 'documentary-production-in-switzerland-why-its-a-prime-location-for-storytelling', 'exploring-film-production-services-in-switzerland', 'film-production-in-switzerland-a-hub-for-creative-excellence', 'how-b2b-brands-generate-qualified-leads-with-video', 'how-b2b-companies-simplify-complex-products-with-explainer-videos', 'how-big-brands-can-use-video-production-to-attract-new-prospects-and-drive-sales', 'how-big-brands-can-use-video-production-to-drive-prospect-engagement-through-storytelling', 'how-big-brands-can-use-video-production-to-promote-case-studies-to-prospects', 'how-big-brands-can-use-video-production-to-promote-customer-advocacy-programs-to-existing-customers', 'how-big-brands-can-use-video-production-to-promote-customer-events-and-maximize-engagement', 'how-big-brands-can-use-video-production-to-promote-thought-leadership-to-prospects', 'how-big-brands-can-use-video-production-to-promote-upselling-opportunities-to-existing-customers', 'how-brands-build-trust-and-credibility-through-video', 'how-brands-can-use-video-production-to-engage-existing-customers-through-ongoing-education', 'how-brands-can-use-video-production-to-promote-seasonal-campaigns-to-prospects-and-customers', 'how-brands-can-use-video-production-to-promote-webinars-to-prospects', 'how-brands-increase-e-commerce-conversions-with-product-videos', 'how-brands-simplify-complex-products-with-explainer-videos', 'how-explainer-videos-can-increase-product-sales-and-customer-engagement', 'how-kanebo-elevates-luxury-through-cinematic-production-in-switzerland', 'how-multilingual-video-production-supports-brand-expansion', 'how-product-videos-shorten-the-sales-cycle-for-brands', 'how-to-build-brand-awareness-with-strategic-video-content', 'how-to-choose-video-production-company-zurich', 'how-to-partner-with-your-video-agency-to-drive-sales-and-strengthen-customer-engagement', 'how-to-use-video-production-to-engage-existing-customers-with-user-generated-content-campaigns', 'how-video-campaigns-drive-event-attendance-and-engagement', 'how-viven-helps-b2c-brands-dominate-social-media-with-scroll-stopping-videos', 'how-viven-helps-brands-boost-customer-engagement-with-social-media-videos', 'live-streaming-for-brands-how-to-engage-in-real-time-and-win-attention', 'maximise-business-impact-with-professional-video-production', 'maximizing-customer-conversion-with-explainer-videos-a-strategic-guide', 'strengthen-business-communication-with-corporate-video-production', 'testimonials-the-most-trusted-marketing-tool-in-2025', 'the-competitive-advantage-product-video-production-gives', 'understanding-film-funding-opportunities-in-switzerland', 'unlocking-business-growth-the-power-of-explainer-videos-in-generating-quality-leads', 'use-video-production-to-engage-existing-customers-through-exclusive-community-content', 'why-brands-choose-viven-as-their-video-agency-to-drive-sales-and-build-trust', 'why-customer-testimonial-videos-are-a-game-changer-for-big-brands', 'why-swiss-film-production-companies-are-in-high-demand', 'why-viven-is-the-video-agency-of-choice-for-b2b-brands', 'zurich-the-heart-of-switzerlands-film-production-scene']);
const rawPosts = import.meta.glob('./*/index.astro', { query: '?raw', import: 'default', eager: true });
const autoPosts = Object.entries(rawPosts).map(([path, raw]) => {
  const slug = path.split('/')[1];
  if (KNOWN.has(slug)) return null;
  const jstr = (re) => { const m = String(raw).match(re); if (!m) return ''; try { return JSON.parse(m[1]); } catch { return ''; } };
  const title = String(jstr(/const title = \{"[a-z]{2}":("(?:[^"\\]|\\.)*")\}/) || slug).replace(/ \| Viven$/, '');
  const desc = String(jstr(/const description = \{"[a-z]{2}":("(?:[^"\\]|\\.)*")\}/) || '');
  const img = (String(raw).match(/<img src="([^"]+)"/) || [])[1] || '/projects/siemens-shaping-the-future-together-employer-branding-campaign/02-RORES_clean_VIVEN.00_13_13_20.Still042.jpg';
  const date = (String(raw).match(/datePublished[^0-9]{0,6}([0-9]{4}-[0-9]{2}-[0-9]{2}[0-9T:.+]*)/) || [])[1] || '';
  return { slug, title, desc, img, date };
}).filter(Boolean).sort((a, b) => (b.date || '').localeCompare(a.date || ''));
