---
import Base from '../../../layouts/Base.astro';
import { localePath } from '../../../i18n.js';
const lang = "en";
const p = (s) => localePath(lang, s);
const slug = "case-study-meteomatics-simplifying-complexity-with-viven-ags-video-solutions";
const title = {"en":"Case Study: Meteomatics — Simplifying Complexity with Video | Viven"};
const description = {"en":"How Viven turned Meteomatics' complex weather-data offering into clear, engaging video for YouTube, Google Ads and LinkedIn — expanding reach and winning new customers."};
const url = "https://www.viven.ch/" + slug + "/";
const jsonld = {"@context":"https://schema.org","@graph":[{"@type":"Article","mainEntityOfPage":{"@type":"WebPage","@id":url},"headline":"Meteomatics — Simplifying Complexity with Viven AG's Video Solutions","description":description.en,"inLanguage":"en","author":{"@type":"Organization","@id":"https://www.viven.ch/#organization"},"publisher":{"@id":"https://www.viven.ch/#organization"},"url":url,"about":{"@type":"Organization","name":"Meteomatics"}},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://www.viven.ch/"},{"@type":"ListItem","position":2,"name":"Case studies","item":"https://www.viven.ch/projects/"},{"@type":"ListItem","position":3,"name":"Meteomatics — Video Solutions","item":url}]},{"@type":"VideoObject","name":"Meteomatics — Explainer series by Viven","description":"Watch the work Viven produced for this case study.","embedUrl":"https://player.vimeo.com/video/772421307","thumbnailUrl":"https://vumbnail.com/772421307.jpg","uploadDate":"2024-01-01","publisher":{"@id":"https://www.viven.ch/#organization"}},{"@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "How do you explain a complex B2B product on video?", "acceptedAnswer": {"@type": "Answer", "text": "By translating technical value into human stories: Viven scripted and produced a video series for Meteomatics that shows what their weather intelligence enables — instead of how the technology works internally. Concept, script, filming and animation were handled end to end."}}, {"@type": "Question", "name": "What did Meteomatics use the videos for?", "acceptedAnswer": {"@type": "Answer", "text": "Mainly branding and visibility in new markets, plus emphasising brand values in existing markets — and the videos contributed directly to winning new customers, according to Meteomatics' Head of Marketing."}}, {"@type": "Question", "name": "How long does an explainer video series take to produce?", "acceptedAnswer": {"@type": "Answer", "text": "A single explainer typically takes 3–5 weeks from brief to delivery; a series is planned so episodes share shooting days and design systems, which lowers the cost per video significantly."}}, {"@type": "Question", "name": "Does Viven work with other technology companies?", "acceptedAnswer": {"@type": "Answer", "text": "Yes — Viven produces for tech and industrial clients including Siemens, ABB, Sonova, ANYbotics and LEM, from how-to series to product launches."}}]}]};
---
<Base lang={lang} slug={slug} active="projects" singleLang={true} langUrls={{"en":"/en/" + slug + "/","de":"/de/projects/","es":"/es/projects/"}} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(jsonld)}></script>
<section class="page-hero post-hero">
  <div class="wrap">
    <div class="post-wrap">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href={p("")}>Home</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <a href={p("projects")}>Projects</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span>Meteomatics</span>
      </nav>
      <span class="eyebrow">Case study · Brand & lead generation</span>
      <h1>Meteomatics: Simplifying Complexity with Video Solutions</h1>
      <p class="lead">Meteomatics needed to explain highly technical weather data in a way anyone could grasp. Viven distilled that complexity into clear, visually striking video that expanded reach into new markets and helped win new customers.</p>
    </div>
  </div>
</section>
<section class="sec" style="padding:34px 0 0">
  <div class="wrap">
    <div class="post-wrap reveal">
      <span class="eyebrow">The final film</span>
      <h2 style="margin:8px 0 18px">Watch the result</h2>
      <div style="aspect-ratio:16/9;border-radius:16px;overflow:hidden;border:1px solid rgba(255,255,255,.1)">
        <iframe src="https://player.vimeo.com/video/772421307?dnt=1" title="Meteomatics — Explainer series by Viven" loading="lazy" allow="fullscreen" allowfullscreen style="width:100%;height:100%;border:0;display:block"></iframe>
      </div>
    </div>
  </div>
</section>
<section class="sec" style="padding:26px 0 0">
  <div class="wrap">
    <div class="post-wrap">
      <div class="cs-stats"><div class="cs-stat"><div class="v">B2B tech</div><div class="l">complexity made simple on video</div></div><div class="cs-stat"><div class="v">New markets</div><div class="l">entered with video-led branding</div></div><div class="cs-stat"><div class="v">New clients</div><div class="l">won across sectors</div></div></div>
    </div>
  </div>
</section>



<section class="sec" style="padding-top:40px">
  <div class="wrap">
    <div class="post-wrap post-body reveal">
      <h2>Client overview: Meteomatics</h2>
      <p><strong>Industry:</strong> Weather data solutions.<br><strong>Location:</strong> St. Gallen, Switzerland.<br><strong>Scope:</strong> Providing accurate, actionable weather data to industries worldwide.</p>
      <p>Meteomatics, a leader in weather data solutions, faced the challenge of communicating the complexity of their offering in a simple and engaging way. They partnered with Viven AG to create impactful video content.</p>

      <h2>The challenge</h2>
      <p>Weather data is inherently technical, involving advanced solutions and analytics. For Meteomatics, the main hurdle was presenting this complexity in a digestible and compelling manner for diverse audiences — in both new and existing markets.</p>

      <h2>The solution</h2>
      <p>Viven AG collaborated closely with Meteomatics to craft video content that distilled complex information into clear, relatable storylines, enhanced with captivating visuals. These videos became a cornerstone of Meteomatics' marketing strategy.</p>
      <ul>
        <li><strong>Storytelling:</strong> Simplified the technicalities into a clear, engaging narrative.</li>
        <li><strong>Visual appeal:</strong> Leveraged powerful imagery to reinforce key messages.</li>
        <li><strong>Versatile usage:</strong> Designed for multiple platforms — YouTube, Google Ads and LinkedIn campaigns.</li>
      </ul>

      <h2>The results</h2>
      <ul>
        <li><strong>Enhanced brand visibility:</strong> Expanded reach into new markets while strengthening presence in existing ones.</li>
        <li><strong>Audience engagement:</strong> Emphasised Meteomatics' brand values, resonating with potential and current customers.</li>
        <li><strong>Lead generation:</strong> The videos contributed to winning new clients across various sectors.</li>
      </ul>
      <blockquote><p>“We use the videos mainly for branding, to get more visibility in new markets, but they also help us emphasise our brand values in existing markets and win new customers there as well.”</p><cite>— Alexander Stauch, Head of Marketing, Meteomatics</cite></blockquote>

      <h2>Why Viven AG?</h2>
      <p>Alexander Stauch highlights several reasons Viven AG stands out as a partner:</p>
      <ul>
        <li><strong>Exceptional video quality:</strong> Videos that not only look great but deliver results.</li>
        <li><strong>Seamless collaboration:</strong> Proactive support and advice, with quick, constructive feedback loops and a process that aligns with client needs.</li>
      </ul>
      <blockquote><p>“The whole process of working together is very fun. They helped us a lot with everything, gave us good advice, and always took us seriously.”</p><cite>— Alexander Stauch</cite></blockquote>
      <blockquote><p>“If anyone is still unsure whether they really want to work with Viven, all I can say is: convince yourself! Start the process. You will not regret it. In the end, the videos will speak for themselves.”</p><cite>— Alexander Stauch</cite></blockquote>

      <h2>About Meteomatics</h2>
      <p>Meteomatics, based in St. Gallen, provides high-quality weather data solutions to a broad range of industries worldwide. Their mission is to empower businesses with the insights they need to make informed decisions.</p>

      <h2>Hear it from the client</h2>
      <div style="aspect-ratio:16/9;border-radius:16px;overflow:hidden;border:1px solid rgba(255,255,255,.1);margin-bottom:8px">
        <iframe src="https://player.vimeo.com/video/866320198?dnt=1" title="Meteomatics — client testimonial" loading="lazy" allow="fullscreen" allowfullscreen style="width:100%;height:100%;border:0;display:block"></iframe>
      </div>
      <h2>Frequently asked questions</h2>
      <div class="cs-faq">
        <div class="cs-q"><h3>How do you explain a complex B2B product on video?</h3><p>By translating technical value into human stories: Viven scripted and produced a video series for Meteomatics that shows what their weather intelligence enables — instead of how the technology works internally. Concept, script, filming and animation were handled end to end.</p></div>
        <div class="cs-q"><h3>What did Meteomatics use the videos for?</h3><p>Mainly branding and visibility in new markets, plus emphasising brand values in existing markets — and the videos contributed directly to winning new customers, according to Meteomatics' Head of Marketing.</p></div>
        <div class="cs-q"><h3>How long does an explainer video series take to produce?</h3><p>A single explainer typically takes 3–5 weeks from brief to delivery; a series is planned so episodes share shooting days and design systems, which lowers the cost per video significantly.</p></div>
        <div class="cs-q"><h3>Does Viven work with other technology companies?</h3><p>Yes — Viven produces for tech and industrial clients including Siemens, ABB, Sonova, ANYbotics and LEM, from how-to series to product launches.</p></div>
      </div>

      <p>Explore our <a href={p("services/how-to-video")}>explainer & how-to video production</a> or see <a href={p("projects")}>more of our work</a>.</p>

    </div>
  </div>
</section>

<!-- ============ CTA / FORM ============ -->
<section class="cta" id="start">
  <div class="wrap">
    <div class="cta-card reveal">
      <div>
        <span class="eyebrow">Let's talk</span>
        <h2>Want results like these?</h2>
        <p class="lead">Tell us your goal — we'll come back with three concept ideas, timing and a clear quote within 48 hours. Free, no obligation.</p>
        <ul>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span>First draft within two weeks</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span>One partner, brief to delivery</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span>Multilingual delivery</span></li>
        </ul>
      </div>
      <div>
        <div class="lead-form-mount"></div>
        <p class="form-note">We'll reply within one business day. No spam, ever.</p>
        <p class="book-call-note"><span>Prefer to talk it through?</span> <a class="book-call" href="https://meetings.hubspot.com/sofia-trevino?uuid=76bf013f-3825-4341-8a95-fee769f70c49" target="_blank" rel="noopener">Book a free 15-min call →</a></p>
      </div>
    </div>
  </div>
</section>
</Base>
