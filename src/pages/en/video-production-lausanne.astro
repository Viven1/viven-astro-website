---
// Página de localización: Video Production Lausanne — Olympic Capital, EPFL,
// sedes internacionales. Diferenciado de Geneva: foco deporte/ciencia, no
// banca/NGO, aunque comparta región "Romandie".
import Base from '../../layouts/Base.astro';
const lang = "en";
const d = {"title": "Video Production Lausanne — Sport, Science & Corporate Film | Viven", "description": "Video production in Lausanne, Olympic Capital and home to EPFL and global HQs. Zurich crew or local team, fixed quote, first cut in 2 weeks.", "h1": "Video Production Lausanne", "lead": "Viven is a Swiss video production company producing corporate and campaign video for Lausanne's unusual mix of global sport, science and business. As Olympic Capital, Lausanne is home to the IOC and dozens of international sport federations; EPFL anchors a fast-growing deep-tech and life-sciences scene; and several multinationals run global operations from the region, including Philip Morris International, for whom we've produced brand video. Crew and equipment travel from Zurich at no hidden cost, or we staff your shoot with trusted local crew from the Romandie. You see the first cut in about two weeks.", "sections": [{"h2": "How we produce in Lausanne", "html": "<p>Lausanne is a regular stop for our production team, not an away game. You choose the setup that fits your project and budget:</p><ul><li><strong>Zurich crew on location:</strong> our core team and equipment travel to Lausanne with travel costs quoted upfront in your fixed offer — no surprise line items after the shoot.</li><li><strong>Local Romand crew:</strong> for multi-day or recurring productions we work with vetted freelance crews based in the Romandie, directed by us, so you get local speed with consistent quality.</li></ul><p>One producer owns your project from briefing to delivery, and we scout locations — Olympic House, lakeside campuses, EPFL labs, hotel conference floors — before the shoot day, not on it. If your production needs federation accreditation, campus access or filming permits at restricted sites, we sort that paperwork with you in the prep week.</p>"}, {"h2": "Built for Lausanne's sport, science and global business", "html": "<p>Few cities combine an Olympic ecosystem with a deep-tech research campus. We produce video for both audiences:</p><ul><li><strong>International sport federations,</strong> from highlight reels and athlete profiles to congress keynote capture and campaign films that need to read well on a global broadcast feed.</li><li><strong>EPFL spinouts and deep-tech startups,</strong> where investor and product-explainer video has to make hard science genuinely clear, not just cinematic.</li><li><strong>Multinational regional headquarters,</strong> including Philip Morris International, for whom we produced brand video communicating scientific positioning to international audiences.</li><li><strong>Congresses and conferences</strong> at Beaulieu, SwissTech Convention Center or hotel venues — keynote capture, highlight reels, delegate interviews.</li></ul><p>We have also filmed for UBS, Siemens, Porsche, ON and FIFA; the same standard travels with us to every Lausanne shoot.</p>"}, {"h2": "French for the Romandie, English for the world", "html": "<p>Lausanne runs on French and English side by side — Olympic federations and EPFL research groups both operate internationally, while local teams and stakeholders work in French. We shoot and direct interviews in English, German and Spanish in-house; French subtitles and full French-language versions are delivered through native-speaking partners — translated for the Romand market, not machine-converted. Every project ships with subtitle files and social cut-downs, so a single shoot covers your Swiss-French audience, your international federation or HQ, and your global channels.</p><p>And if your stakeholders review in French, we build that into the approval process from day one rather than bolting it on at the end.</p>"}, {"h2": "Budgets, timelines and how to start", "html": "<p>Lausanne projects at Viven range from CHF 4,000 for a focused interview or event video to CHF 80,000 for multi-day brand campaigns — always as a fixed offer, never open-ended billing. You review the first cut about two weeks after the shoot.</p><p>Viven was founded by the producer of the first Swiss feature film on Netflix, and that filmmaking background shows in how we light, frame and edit corporate and sport content alike. Tell us what your video needs to achieve in Lausanne, and you will have a concrete concept and quote within days. Many client relationships start with one tightly scoped project — a single interview day, one flagship film — and grow once process and result have proven themselves.</p>"}]};
const title = { "en": d.title };
const description = { "en": d.description };
const langUrls = { "en": "/en/video-production-lausanne/", "de": "/de/videoproduktion-lausanne/", "es": "/es/produccion-de-video-lausana/" };
const SITE = 'https://www.viven.ch';
const ld = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: d.h1, description: d.description,
  provider: { '@id': SITE + '/#organization' },
  areaServed: { '@type': 'City', name: 'Lausanne' },
  serviceType: 'Video production',
  url: SITE + '/en/video-production-lausanne/',
});
---
<Base lang={lang} slug="video-production-lausanne" active="services" title={title} description={description} singleLang={true} switchSlug="services" langUrls={langUrls}>
  <script type="application/ld+json" slot="jsonld" set:html={ld}></script>
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow">Lausanne — Switzerland</span>
      <h1 class="rsrc-h1">{d.h1}</h1>
      <p class="lead">{d.lead}</p>
    </div>
  </section>
  <section class="section">
    <div class="wrap rsrc-body">
      {d.sections.map((sec) => (
        <div class="rsrc-sec">
          <h2>{sec.h2}</h2>
          <div set:html={sec.html}></div>
        </div>
      ))}
      <div class="rsrc-ctabox">
        <div>
          <div class="rsrc-ctat">Planning a video in Lausanne?</div>
          <p class="rsrc-ctas">Tell us what you’re working on — clear quote, usually within one business day.</p>
        </div>
        <div class="rsrc-ctabtns">
          <a class="btn btn-primary" href="/en/contact/">Start a project</a>
          <a class="btn btn-ghost" href="/book/" target="_blank" rel="noopener">📅 Book a 15-min call</a>
        </div>
      </div>
    </div>
  </section>
  <style is:global>
    .rsrc-h1{font-size:clamp(28px,4.4vw,44px)!important}
    .rsrc-body{max-width:820px}
    .rsrc-sec{margin-bottom:30px}
    .rsrc-sec h2{font-size:clamp(19px,2.6vw,24px);margin-bottom:12px}
    .rsrc-sec p{color:var(--muted);font-size:15.5px;line-height:1.75;margin-bottom:12px}
    .rsrc-sec ul{margin:0 0 12px 20px;color:var(--muted);font-size:15.5px;line-height:1.75}
    .rsrc-sec li{margin-bottom:6px}
    .rsrc-sec strong{color:var(--text)}
    .rsrc-ctabox{display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;border:1px solid var(--line-strong);background:var(--navy-800);border-radius:18px;padding:26px 28px;margin:40px 0 8px}
    .rsrc-ctat{font-family:'Space Grotesk';font-weight:700;font-size:20px;margin-bottom:6px}
    .rsrc-ctas{color:var(--muted);font-size:14px;max-width:460px;margin:0}
    .rsrc-ctabtns{display:flex;gap:10px;flex-wrap:wrap}
  </style>
</Base>
