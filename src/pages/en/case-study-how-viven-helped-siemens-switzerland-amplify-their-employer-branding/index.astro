---
import Base from '../../../layouts/Base.astro';
import { localePath } from '../../../i18n.js';
const lang = "en";
const p = (s) => localePath(lang, s);
const slug = "case-study-how-viven-helped-siemens-switzerland-amplify-their-employer-branding";
const title = {"en":"Case Study: How Viven Helped Siemens Switzerland Amplify Their Employer Branding | Viven"};
const description = {"en":"How Viven produced 120+ videos and 100+ photos in 5 days for Siemens Switzerland — driving a 3× increase in social and website traffic for their employer branding."};
const url = "https://www.viven.ch/" + slug + "/";
const jsonld = {"@context":"https://schema.org","@graph":[{"@type":"Article","mainEntityOfPage":{"@type":"WebPage","@id":url},"headline":"How Viven Helped Siemens Switzerland Amplify Their Employer Branding","description":description.en,"inLanguage":"en","author":{"@type":"Organization","@id":"https://www.viven.ch/#organization"},"publisher":{"@id":"https://www.viven.ch/#organization"},"url":url,"about":{"@type":"Organization","name":"Siemens Switzerland"}},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://www.viven.ch/"},{"@type":"ListItem","position":2,"name":"Case studies","item":"https://www.viven.ch/projects/"},{"@type":"ListItem","position":3,"name":"Siemens Switzerland — Employer Branding","item":url}]},{"@type":"VideoObject","name":"Siemens Switzerland — Employer Branding video by Viven","description":"Watch the work Viven produced for this case study.","embedUrl":"https://player.vimeo.com/video/828322230","thumbnailUrl":"https://vumbnail.com/828322230.jpg","uploadDate":"2024-01-01","publisher":{"@id":"https://www.viven.ch/#organization"}},{"@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "How long did the Siemens employer branding production take?", "acceptedAnswer": {"@type": "Answer", "text": "The full production ran across five filming days on location. Viven handled pre-production, crewing, filming and post-production end to end, delivering a library of over 120 videos and 100 photos."}}, {"@type": "Question", "name": "What results did Siemens Switzerland see from the video campaign?", "acceptedAnswer": {"@type": "Answer", "text": "Siemens observed a 3× increase in social media and website traffic, higher organic engagement, and a content library that powers their employer branding for the next two to three years."}}, {"@type": "Question", "name": "How much does an employer branding video production cost in Switzerland?", "acceptedAnswer": {"@type": "Answer", "text": "It depends on scope — number of filming days, locations and deliverables. Viven builds packages from single-day shoots to multi-day content libraries like this one. Request a quote and you'll receive three concept ideas, timing and a clear offer within 48 hours."}}, {"@type": "Question", "name": "Can Viven produce large content libraries for other companies?", "acceptedAnswer": {"@type": "Answer", "text": "Yes — the same batch-production model (many videos and photos captured in few, well-planned days) works for any organisation that needs 12+ months of content. Viven has produced for UBS, Porsche, ON, FIFA and Philips."}}]}]};
---
<Base lang={lang} slug={slug} active="projects" singleLang={true} langUrls={{"en":"/en/" + slug + "/","de":"/de/projects/","es":"/es/projects/"}} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(jsonld)}></script>
<section class="page-hero post-hero">
  <div class="wrap">
    <div class="post-wrap">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href={p("")}>Home</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <a href={p("projects")}>Projects</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span>Siemens Switzerland</span>
      </nav>
      <span class="eyebrow">Case study · Employer branding</span>
      <h1>How Viven Helped Siemens Switzerland Amplify Their Employer Branding</h1>
      <p class="lead">Over five filming days, Viven produced a content library of 120+ videos and 100+ photos that gave Siemens Switzerland a 3× lift in social and website traffic — and material to power their employer branding for years.</p>
    </div>
  </div>
</section>
<section class="sec" style="padding:34px 0 0">
  <div class="wrap">
    <div class="post-wrap reveal">
      <span class="eyebrow">The final film</span>
      <h2 style="margin:8px 0 18px">Watch the result</h2>
      <div style="aspect-ratio:16/9;border-radius:16px;overflow:hidden;border:1px solid rgba(255,255,255,.1)">
        <iframe src="https://player.vimeo.com/video/828322230?dnt=1" title="Siemens Switzerland — Employer Branding video by Viven" loading="lazy" allow="fullscreen" allowfullscreen style="width:100%;height:100%;border:0;display:block"></iframe>
      </div>
    </div>
  </div>
</section>
<section class="sec" style="padding:26px 0 0">
  <div class="wrap">
    <div class="post-wrap">
      <div class="cs-stats"><div class="cs-stat"><div class="v">5</div><div class="l">filming days on location</div></div><div class="cs-stat"><div class="v">120+</div><div class="l">videos · 100+ photos delivered</div></div><div class="cs-stat"><div class="v">3×</div><div class="l">lift in social & website traffic</div></div></div>
    </div>
  </div>
</section>



<section class="sec" style="padding-top:40px">
  <div class="wrap">
    <div class="post-wrap post-body reveal">
      <h2>Client overview: Siemens Switzerland</h2>
      <p><strong>Industry:</strong> Technology and innovation.<br><strong>Objective:</strong> Strengthen employer branding by showcasing company culture and fostering emotional connections with current and prospective employees.</p>
      <p>To achieve this, Siemens Switzerland needed high-quality video content that humanised their brand and resonated with both current and prospective employees — delivered through a seamless, efficient process.</p>

      <h2>The challenge</h2>
      <p>Like many organisations, Siemens faced the challenge of creating authentic, engaging content while anticipating that the process would be time-intensive and complex. They needed a trusted partner to simplify the journey and deliver exceptional results.</p>

      <h2>The solution</h2>
      <p>Siemens Switzerland partnered with Viven AG, a leader in corporate storytelling, to produce a comprehensive suite of content. Over five dedicated filming days, the collaboration yielded:</p>
      <ul>
        <li><strong>120+ professional videos</strong></li>
        <li><strong>100+ high-quality photos</strong></li>
      </ul>
      <p>This extensive content library equips Siemens with material to power their employer branding efforts for the next two to three years.</p>

      <h2>The results</h2>
      <p>The collaboration produced measurable outcomes that exceeded expectations:</p>
      <ul>
        <li><strong>Enhanced engagement:</strong> Siemens observed a <strong>3× increase in social media and website traffic</strong>, coupled with significantly higher organic engagement rates.</li>
        <li><strong>Extended content usability:</strong> The vast library of videos and photos provides ongoing support for Siemens' long-term employer branding strategy.</li>
        <li><strong>Stronger audience connection:</strong> The content highlights the people and culture behind Siemens Switzerland, creating lasting impressions both online and offline.</li>
      </ul>
      <blockquote><p>“We can truly showcase who Siemens Switzerland is and who works here.”</p><cite>— Marc Maurer, Employer Branding Specialist, Siemens Switzerland</cite></blockquote>

      <h2>Why Viven AG?</h2>
      <p>According to Marc Maurer, the success of the collaboration stemmed from Viven AG's ability to deliver:</p>
      <ul>
        <li><strong>Simplicity:</strong> “The entire process with Viven was very straightforward and easy to manage.”</li>
        <li><strong>Positive atmosphere:</strong> “The ambiance during production and on set was consistently uplifting and motivating.”</li>
        <li><strong>Client-centric approach:</strong> “The Viven team listened attentively, implemented feedback promptly, and consistently delivered exceptional results.”</li>
      </ul>

      <h2>About Siemens Switzerland</h2>
      <p>Siemens Switzerland is a global leader in technology and innovation, dedicated to creating solutions that impact lives. Their employer branding initiatives aim to highlight the vibrant culture and talented individuals driving the company's success.</p>

      <h2>A lasting partnership</h2>
      <p>With Viven AG's expertise, Siemens Switzerland has a powerful arsenal of content to elevate their employer branding efforts. The videos and photos have already left a lasting impression, helping Siemens connect with their audience and solidify their position as an employer of choice.</p>

      <h2>On set</h2>
      <div class="cs-gallery"><img src="/projects/siemens-shaping-the-future-together-employer-branding-campaign/01-RORES_clean_VIVEN.00_18_49_20.Still052.jpg" alt="Behind the scenes — Siemens employer branding by Viven" loading="lazy" decoding="async" /><img src="/projects/siemens-shaping-the-future-together-employer-branding-campaign/03-RORES_clean_VIVEN.00_09_29_23.Still033.jpg" alt="Behind the scenes — Siemens employer branding by Viven" loading="lazy" decoding="async" /><img src="/projects/siemens-shaping-the-future-together-employer-branding-campaign/06-RORES_clean_VIVEN.00_18_16_23.Still051.jpg" alt="Behind the scenes — Siemens employer branding by Viven" loading="lazy" decoding="async" /><img src="/projects/siemens-shaping-the-future-together-employer-branding-campaign/08-RORES_clean_VIVEN.00_00_29_06.Still017.jpg" alt="Behind the scenes — Siemens employer branding by Viven" loading="lazy" decoding="async" /></div>

      <h2>Hear it from the client</h2>
      <div style="aspect-ratio:16/9;border-radius:16px;overflow:hidden;border:1px solid rgba(255,255,255,.1);margin-bottom:8px">
        <iframe src="https://player.vimeo.com/video/1036679041?dnt=1" title="Client testimonials 2023 — Siemens, Meteomatics & SV Group" loading="lazy" allow="fullscreen" allowfullscreen style="width:100%;height:100%;border:0;display:block"></iframe>
      </div>
      <h2>Frequently asked questions</h2>
      <div class="faq">
        <details class="reveal"><summary>How long did the Siemens employer branding production take?</summary><p>The full production ran across five filming days on location. Viven handled pre-production, crewing, filming and post-production end to end, delivering a library of over 120 videos and 100 photos.</p></details>
        <details class="reveal"><summary>What results did Siemens Switzerland see from the video campaign?</summary><p>Siemens observed a 3× increase in social media and website traffic, higher organic engagement, and a content library that powers their employer branding for the next two to three years.</p></details>
        <details class="reveal"><summary>How much does an employer branding video production cost in Switzerland?</summary><p>It depends on scope — number of filming days, locations and deliverables. Viven builds packages from single-day shoots to multi-day content libraries like this one. Request a quote and you'll receive three concept ideas, timing and a clear offer within 48 hours.</p></details>
        <details class="reveal"><summary>Can Viven produce large content libraries for other companies?</summary><p>Yes — the same batch-production model (many videos and photos captured in few, well-planned days) works for any organisation that needs 12+ months of content. Viven has produced for UBS, Porsche, ON, FIFA and Philips.</p></details>
      </div>

      <p>Explore our <a href={p("services/employer-branding")}>employer branding video production</a> or see <a href={p("projects")}>more of our work</a>.</p>

    </div>
  </div>
</section>

<!-- ============ CTA / FORM ============ -->
<section class="cta" id="start">
  <div class="wrap">
    <div class="cta-card reveal">
      <div>
        <span class="eyebrow">Let's talk</span>
        <h2>Want results like these?</h2>
        <p class="lead">Tell us your goal — we'll come back with three concept ideas, timing and a clear quote within 48 hours. Free, no obligation.</p>
        <ul>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span>First draft within two weeks</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span>One partner, brief to delivery</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span>Multilingual delivery</span></li>
        </ul>
      </div>
      <div>
        <div class="lead-form-mount"></div>
        <p class="form-note">We'll reply within one business day. No spam, ever.</p>
        <p class="book-call-note"><span>Prefer to talk it through?</span> <a class="book-call" href="/book/" target="_blank" rel="noopener">Book a free 15-min call →</a></p>
      </div>
    </div>
  </div>
</section>
</Base>
