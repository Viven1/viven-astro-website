---
import Base from '../../../layouts/Base.astro';
import { localePath } from '../../../i18n.js';
const lang = "en";
const p = (s) => localePath(lang, s);
const slug = "case-study-how-viven-helped-siemens-switzerland-amplify-their-employer-branding";
const title = {"en":"Case Study: How Viven Helped Siemens Switzerland Amplify Their Employer Branding | Viven"};
const description = {"en":"How Viven produced 120+ videos and 100+ photos in 5 days for Siemens Switzerland — driving a 3× increase in social and website traffic for their employer branding."};
const url = "https://www.viven.ch/" + slug + "/";
const jsonld = {"@context":"https://schema.org","@graph":[{"@type":"Article","mainEntityOfPage":{"@type":"WebPage","@id":url},"headline":"How Viven Helped Siemens Switzerland Amplify Their Employer Branding","description":description.en,"inLanguage":"en","author":{"@type":"Organization","@id":"https://www.viven.ch/#organization"},"publisher":{"@id":"https://www.viven.ch/#organization"},"url":url,"about":{"@type":"Organization","name":"Siemens Switzerland"}},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://www.viven.ch/"},{"@type":"ListItem","position":2,"name":"Case studies","item":"https://www.viven.ch/projects/"},{"@type":"ListItem","position":3,"name":"Siemens Switzerland — Employer Branding","item":url}]}]};
---
<Base lang={lang} slug={slug} active="projects" singleLang={true} langUrls={{"en":"/en/" + slug + "/","de":"/de/case-study-wie-viven-siemens-schweiz-dabei-half-sein-employer-branding-zu-staerken/","es":"/es/projects/"}} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(jsonld)}></script>
<section class="page-hero post-hero">
  <div class="wrap">
    <div class="post-wrap">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href={p("")}>Home</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <a href={p("projects")}>Projects</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span>Siemens Switzerland</span>
      </nav>
      <span class="eyebrow">Case study · Employer branding</span>
      <h1>How Viven Helped Siemens Switzerland Amplify Their Employer Branding</h1>
      <p class="lead">Over five filming days, Viven produced a content library of 120+ videos and 100+ photos that gave Siemens Switzerland a 3× lift in social and website traffic — and material to power their employer branding for years.</p>
    </div>
  </div>
</section>

<section class="sec" style="padding-top:40px">
  <div class="wrap">
    <div class="post-wrap post-body reveal">
      <h2>Client overview: Siemens Switzerland</h2>
      <p><strong>Industry:</strong> Technology and innovation.<br><strong>Objective:</strong> Strengthen employer branding by showcasing company culture and fostering emotional connections with current and prospective employees.</p>
      <p>To achieve this, Siemens Switzerland needed high-quality video content that humanised their brand and resonated with both current and prospective employees — delivered through a seamless, efficient process.</p>

      <h2>The challenge</h2>
      <p>Like many organisations, Siemens faced the challenge of creating authentic, engaging content while anticipating that the process would be time-intensive and complex. They needed a trusted partner to simplify the journey and deliver exceptional results.</p>

      <h2>The solution</h2>
      <p>Siemens Switzerland partnered with Viven AG, a leader in corporate storytelling, to produce a comprehensive suite of content. Over five dedicated filming days, the collaboration yielded:</p>
      <ul>
        <li><strong>120+ professional videos</strong></li>
        <li><strong>100+ high-quality photos</strong></li>
      </ul>
      <p>This extensive content library equips Siemens with material to power their employer branding efforts for the next two to three years.</p>

      <h2>The results</h2>
      <p>The collaboration produced measurable outcomes that exceeded expectations:</p>
      <ul>
        <li><strong>Enhanced engagement:</strong> Siemens observed a <strong>3× increase in social media and website traffic</strong>, coupled with significantly higher organic engagement rates.</li>
        <li><strong>Extended content usability:</strong> The vast library of videos and photos provides ongoing support for Siemens' long-term employer branding strategy.</li>
        <li><strong>Stronger audience connection:</strong> The content highlights the people and culture behind Siemens Switzerland, creating lasting impressions both online and offline.</li>
      </ul>
      <blockquote><p>“We can truly showcase who Siemens Switzerland is and who works here.”</p><cite>— Marc Maurer, Employer Branding Specialist, Siemens Switzerland</cite></blockquote>

      <h2>Why Viven AG?</h2>
      <p>According to Marc Maurer, the success of the collaboration stemmed from Viven AG's ability to deliver:</p>
      <ul>
        <li><strong>Simplicity:</strong> “The entire process with Viven was very straightforward and easy to manage.”</li>
        <li><strong>Positive atmosphere:</strong> “The ambiance during production and on set was consistently uplifting and motivating.”</li>
        <li><strong>Client-centric approach:</strong> “The Viven team listened attentively, implemented feedback promptly, and consistently delivered exceptional results.”</li>
      </ul>

      <h2>About Siemens Switzerland</h2>
      <p>Siemens Switzerland is a global leader in technology and innovation, dedicated to creating solutions that impact lives. Their employer branding initiatives aim to highlight the vibrant culture and talented individuals driving the company's success.</p>

      <h2>A lasting partnership</h2>
      <p>With Viven AG's expertise, Siemens Switzerland has a powerful arsenal of content to elevate their employer branding efforts. The videos and photos have already left a lasting impression, helping Siemens connect with their audience and solidify their position as an employer of choice.</p>

      <p class="cs-cta"><strong>Ready to transform your employer branding strategy?</strong> <a href={p("contact")}>Contact Viven AG today</a> to create content that inspires and engages — or explore more of <a href={p("projects")}>our work</a>.</p>
    </div>
  </div>
</section>
</Base>
