---
// Página de localización: Video Production Geneva — keyword local (Ubersuggest: 40/mes, dificultad 17).
import Base from '../../layouts/Base.astro';
const lang = "en";
const d = {"title": "Video Production Geneva – Corporate Film & Video | Viven", "description": "Video production in Geneva for international organisations, banks and luxury brands. Zurich crew or local Romand team, fixed quote, first cut in 2 weeks.", "h1": "Video Production Geneva", "lead": "Viven is a Swiss video production company that shoots regularly in Geneva. We produce corporate films, campaign videos and event coverage for organisations across the Lake Geneva region — from private banks and watchmakers to NGOs and international agencies. Crew and equipment travel from Zurich at no hidden cost, or we staff your shoot with trusted local crew from the Romandie. You see the first cut in about two weeks.", "sections": [{"h2": "How we produce in Geneva", "html": "<p>Geneva is a regular stop for our production team, not an away game. You choose the setup that fits your project and budget:</p><ul><li><strong>Zurich crew on location:</strong> our core team and equipment travel to Geneva with travel costs quoted upfront in your fixed offer — no surprise line items after the shoot.</li><li><strong>Local Romand crew:</strong> for multi-day or recurring productions we work with vetted freelance crews based in the Romandie, directed by us, so you get local speed with consistent quality.</li></ul><p>Either way, one producer owns your project from briefing to delivery, and we scout locations — from Palexpo halls to lakefront offices — before the shoot day, not on it. If your production needs fair accreditation, hotel filming permits or access to restricted office floors, we sort that paperwork with you in the prep week.</p>"}, {"h2": "Built for Geneva's international ecosystem", "html": "<p>Few cities concentrate as many global audiences as Geneva. We produce video that holds up in this environment:</p><ul><li><strong>NGOs and international agencies</strong> that need mission films and campaign videos credible in front of donors, delegates and press.</li><li><strong>Private banking and wealth management,</strong> where discretion on set and clean approval workflows matter as much as the image.</li><li><strong>Watchmaking and luxury,</strong> including launch films and social cut-downs timed to fairs such as Watches &amp; Wonders.</li><li><strong>Congresses and corporate events</strong> at Palexpo, the CICG or hotel venues — keynote capture, highlight reels, speaker interviews.</li></ul><p>We have filmed for UBS, Siemens, Porsche, ON, FIFA and Philips; the standard those brands demand travels with us to every Geneva shoot.</p>"}, {"h2": "French for the Romandie, English for the world", "html": "<p>Geneva runs on French and English side by side, and your video should work in both. We shoot and direct interviews in English, German and Spanish in-house; French subtitles and full French-language versions are delivered through native-speaking partners — translated for the Romand market, not machine-converted. Every project ships with subtitle files and social cut-downs, so a single shoot covers your Swiss-French audience, your international headquarters and your global channels.</p><p>And if your stakeholders review in French, we build that into the approval process from day one rather than bolting it on at the end.</p>"}, {"h2": "Budgets, timelines and how to start", "html": "<p>Geneva projects at Viven range from CHF 4,000 for a focused interview or event video to CHF 80,000 for multi-day brand campaigns — always as a fixed offer, never open-ended billing. You review the first cut about two weeks after the shoot.</p><p>Viven was founded by the producer of the first Swiss feature film on Netflix, and that filmmaking background shows in how we light, frame and edit corporate work. Tell us what your video needs to achieve in Geneva, and you will have a concrete concept and quote within days. Many client relationships start with one tightly scoped project — a single interview day, one flagship film — and grow once process and result have proven themselves.</p>"}]};
const title = { "en": d.title };
const description = { "en": d.description };
const langUrls = { "en": "/en/video-production-geneva/", "de": "/de/videoproduktion-genf/" };
const SITE = 'https://www.viven.ch';
const ld = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: d.h1, description: d.description,
  provider: { '@id': SITE + '/#organization' },
  areaServed: { '@type': 'City', name: 'Geneva' },
  serviceType: 'Video production',
  url: SITE + '/en/video-production-geneva/',
});
---
<Base lang={lang} slug="video-production-geneva" active="services" title={title} description={description} singleLang={true} switchSlug="services" langUrls={langUrls}>
  <script type="application/ld+json" slot="jsonld" set:html={ld}></script>
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow">Geneva — Switzerland</span>
      <h1 class="rsrc-h1">{d.h1}</h1>
      <p class="lead">{d.lead}</p>
    </div>
  </section>
  <section class="section">
    <div class="wrap rsrc-body">
      {d.sections.map((sec) => (
        <div class="rsrc-sec">
          <h2>{sec.h2}</h2>
          <div set:html={sec.html}></div>
        </div>
      ))}
      <div class="rsrc-ctabox">
        <div>
          <div class="rsrc-ctat">Planning a video in Geneva?</div>
          <p class="rsrc-ctas">Tell us what you’re working on — clear quote, usually within one business day.</p>
        </div>
        <div class="rsrc-ctabtns">
          <a class="btn btn-primary" href="/en/contact/">Start a project</a>
          <a class="btn btn-ghost" href="/book/" target="_blank" rel="noopener">📅 Book a 15-min call</a>
        </div>
      </div>
    </div>
  </section>
  <style is:global>
    .rsrc-h1{font-size:clamp(28px,4.4vw,44px)!important}
    .rsrc-body{max-width:820px}
    .rsrc-sec{margin-bottom:30px}
    .rsrc-sec h2{font-size:clamp(19px,2.6vw,24px);margin-bottom:12px}
    .rsrc-sec p{color:var(--muted);font-size:15.5px;line-height:1.75;margin-bottom:12px}
    .rsrc-sec ul{margin:0 0 12px 20px;color:var(--muted);font-size:15.5px;line-height:1.75}
    .rsrc-sec li{margin-bottom:6px}
    .rsrc-sec strong{color:var(--text)}
    .rsrc-ctabox{display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;border:1px solid var(--line-strong);background:var(--navy-800);border-radius:18px;padding:26px 28px;margin:40px 0 8px}
    .rsrc-ctat{font-family:'Space Grotesk';font-weight:700;font-size:20px;margin-bottom:6px}
    .rsrc-ctas{color:var(--muted);font-size:14px;max-width:460px;margin:0}
    .rsrc-ctabtns{display:flex;gap:10px;flex-wrap:wrap}
  </style>
</Base>
