const jsonld = {"@context":"https://schema.org","@graph":[{"@type":"Article","mainEntityOfPage":{"@type":"WebPage","@id":url},"headline":"SV Group — Bringing IT, Operations, and Hospitality Together","description":description.en,"inLanguage":"en","author":{"@type":"Organization","@id":"https://www.viven.ch/#organization"},"publisher":{"@id":"https://www.viven.ch/#organization"},"url":url,"about":{"@type":"Organization","name":"SV Group"}},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://www.viven.ch/"},{"@type":"ListItem","position":2,"name":"Case studies","item":"https://www.viven.ch/projects/"},{"@type":"ListItem","position":3,"name":"SV Group","item":url}]},{"@type":"VideoObject","name":"SV Group — Innovation Film by Viven","description":"Watch the work Viven produced for this case study.","embedUrl":"https://player.vimeo.com/video/861150876","thumbnailUrl":"https://vumbnail.com/861150876.jpg","uploadDate":"2024-01-01","publisher":{"@id":"https://www.viven.ch/#organization"}},{"@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "Can you film in a live, working environment like a restaurant?", "acceptedAnswer": {"@type": "Answer", "text": "Yes — the SV Group film was shot in a restaurant serving over 350 people, with the crew adapting around live service. Careful pre-production makes filming possible without disrupting operations."}}, {"@type": "Question", "name": "What is a corporate video like this used for?", "acceptedAnswer": {"@type": "Answer", "text": "SV Group uses the film for recruiting (showing candidates the real working environment), customer engagement (a behind-the-scenes look that builds trust) and brand storytelling — three jobs in one production."}}, {"@type": "Question", "name": "How does Viven keep the client involved during production?", "acceptedAnswer": {"@type": "Answer", "text": "Open communication at every step: SV Group was consistently involved in the creative proces