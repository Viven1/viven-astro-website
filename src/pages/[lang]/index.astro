---
import Base from '../../layouts/Base.astro';
import Testimonials from '../../components/Testimonials.astro';
import { langPaths, localePath } from '../../i18n.js';
export const getStaticPaths = langPaths;
const { lang } = Astro.params;
const p = (s) => localePath(lang, s);
const title = {"en":"Viven — Video Production Zurich | Video that turns attention into revenue","de":"Viven — Videoproduktion Zürich | Videos, die Aufmerksamkeit in Umsatz verwandeln","es":"Viven — Producción de video en Zúrich | Video que convierte la atención en ingresos"};
const description = {"en":"Viven is a Zurich video production company producing brand, product, employer-branding and how-to films. Trusted by UBS, Siemens, Porsche and ON — 187 brands across 32 industries.","de":"Viven ist eine Videoproduktion aus Zürich für Marken-, Produkt-, Employer-Branding- und How-To-Filme. Im Einsatz für UBS, Siemens, Porsche und ON — 187 Marken in 32 Branchen.","es":"Viven es una productora de video en Zúrich: films de marca, producto, employer branding y tutoriales. Con la confianza de UBS, Siemens, Porsche y ON — 187 marcas en 32 industrias."};
---
<Base lang={lang} slug="" active="home" title={title} description={description} preloadHero>
  <script type="application/ld+json" slot="jsonld" set:html={"{\"@type\":\"VideoObject\",\"name\":\"Viven — Showreel\",\"description\":\"Viven's showreel of films for leading brands including UBS, Siemens, Porsche and ON.\",\"thumbnailUrl\":\"https://i.vimeocdn.com/video/1983545212-07a82dee809132cc97d62a6cd25ae7e99e36c5d2451766896df1118f39c74552-d?w=1280\",\"uploadDate\":\"2024-06-01\",\"embedUrl\":\"https://player.vimeo.com/video/1057568537\",\"publisher\":{\"@id\":\"https://www.viven.ch/#organization\"},\"@context\":\"https://schema.org\"}"}></script>
<!-- ============ HERO ============ -->
<section class="hero" id="top">
  <div class="hero-bg" data-vimeo="1057568537">
    <img class="reel"
         src="https://i.vimeocdn.com/video/1983545212-07a82dee809132cc97d62a6cd25ae7e99e36c5d2451766896df1118f39c74552-d?w=828"
         srcset="https://i.vimeocdn.com/video/1983545212-07a82dee809132cc97d62a6cd25ae7e99e36c5d2451766896df1118f39c74552-d?w=828 828w, https://i.vimeocdn.com/video/1983545212-07a82dee809132cc97d62a6cd25ae7e99e36c5d2451766896df1118f39c74552-d?w=1600 1600w"
         sizes="100vw" width="1600" height="900"
         alt="Viven showreel — video production Zurich"
         loading="eager" fetchpriority="high" decoding="async" />
    <div class="grain"></div>
  </div>
  <div class="hero-overlay"></div>
  <div class="wrap hero-inner">
    <h1 class="eyebrow" data-en="Video production, Zurich — Switzerland" data-de="Videoproduktion, Zürich — Schweiz" data-es="Producción de video, Zúrich — Suiza">Video production, Zurich — Switzerland</h1>
    <p class="hero-h1" data-en='Video that turns <span class="hl">attention into revenue.</span>'
        data-de='Videos, die <span class="hl">Aufmerksamkeit in Umsatz verwandeln.</span>'
        data-es='Video que convierte <span class="hl">la atención en ingresos.</span>'>
      Video that turns <span class="hl">attention into revenue.</span>
    </p>
    <p class="lead"
       data-en="Viven produces films that build trust in seconds. Trusted by UBS, Siemens, Porsche and ON."
       data-de="Viven produziert Filme, die in Sekunden Vertrauen schaffen. Im Einsatz für UBS, Siemens, Porsche und ON."
       data-es="Viven produce films que generan confianza en segundos. Elegida por UBS, Siemens, Porsche y ON.">
      Viven produces films that build trust in seconds. Trusted by UBS, Siemens, Porsche and ON.
    </p>
    <p class="hero-note">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg>
      <span data-en="First cut in two weeks — fixed timeline, agreed upfront."
            data-de="Erster Schnitt in zwei Wochen — fixer Zeitplan, vorab vereinbart."
            data-es="Primer corte en dos semanas — cronograma fijo, acordado de antemano.">First cut in two weeks — fixed timeline, agreed upfront.</span>
    </p>
    <div class="hero-cta">
      <a href={p("contact")} class="btn btn-primary" data-en="Start a project" data-de="Projekt starten" data-es="Iniciar proyecto">Start a project</a>
      <a href="https://vimeo.com/1057568537" target="_blank" rel="noopener" class="play-note" id="showreel-btn">
        <span class="play-ico"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></span>
        <span data-en="Watch the showreel" data-de="Showreel ansehen" data-es="Ver el showreel">Watch the showreel</span>
      </a>
    </div>
  </div>
</section>

<!-- ============ LOGO BAR ============ -->
<div class="logos">
  <div class="wrap">
    <p class="label" data-en="187 brands across 32 industries" data-de="187 Marken in 32 Branchen" data-es="187 marcas en 32 industrias">187 brands across 32 industries</p>
    <div class="marquee">
      <div class="marquee-track">
        <span>UBS</span><span>Siemens</span><span>Porsche</span><span>ON</span><span>Franke</span><span>V-ZUG</span><span>Chanel</span><span>FIFA</span><span>Philips</span><span>Swarovski</span><span>IBM</span><span>Sennheiser</span><span>Julius Bär</span><span>KPMG</span><span>Sigg</span>
        <span>UBS</span><span>Siemens</span><span>Porsche</span><span>ON</span><span>Franke</span><span>V-ZUG</span><span>Chanel</span><span>FIFA</span><span>Philips</span><span>Swarovski</span><span>IBM</span><span>Sennheiser</span><span>Julius Bär</span><span>KPMG</span><span>Sigg</span>
      </div>
    </div>
  </div>
</div>

<!-- ============ STATS ============ -->
<section class="sec" style="padding-bottom:0">
  <div class="wrap">
    <div class="stats reveal">
      <div class="stat"><div class="num">187</div><div class="lbl" data-en="Brands trusted us" data-de="Marken vertrauen uns" data-es="Marcas confiaron en nosotros">Brands trusted us</div></div>
      <div class="stat"><div class="num">32</div><div class="lbl" data-en="Industries served" data-de="Branchen bedient" data-es="Industrias atendidas">Industries served</div></div>
      <div class="stat"><div class="num">8</div><div class="lbl" data-en="Years producing for leading brands" data-de="Jahre Produktion für führende Marken" data-es="Años produciendo para marcas líderes">Years producing for leading brands</div></div>
    </div>
  </div>
</section>

<!-- ============ WHY VIDEO ============ -->
<section class="sec" id="why">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="Why video" data-de="Warum Video" data-es="Por qué video">Why video</span>
      <h2 data-en="Video isn't a creative service. It's a business tool."
          data-de="Video ist keine Kreativleistung. Es ist ein Business-Tool."
          data-es="El video no es un servicio creativo. Es una herramienta de negocio.">Video isn't a creative service. It's a business tool.</h2>
      <p data-en="The right film does the work of a hundred slides — building trust, moving people to act, and making complex messages simple."
         data-de="Der richtige Film leistet mehr als hundert Folien — er schafft Vertrauen, bewegt zum Handeln und macht komplexe Botschaften einfach."
         data-es="El film correcto hace el trabajo de cien diapositivas: genera confianza, mueve a la acción y simplifica lo complejo.">The right film does the work of a hundred slides — building trust, moving people to act, and making complex messages simple.</p>
    </div>
    <div class="value-grid">
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
        <h3 data-en="Build trust fast" data-de="Schnell Vertrauen schaffen" data-es="Generar confianza rápido">Build trust fast</h3>
        <p data-en="Cold visitors decide in seconds. Video earns credibility before a word is read." data-de="Kalte Besucher entscheiden in Sekunden. Video schafft Glaubwürdigkeit, bevor ein Wort gelesen wird." data-es="Los visitantes deciden en segundos. El video gana credibilidad antes de que lean una palabra.">Cold visitors decide in seconds. Video earns credibility before a word is read.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/></svg></div>
        <h3 data-en="Win the right people" data-de="Die Richtigen gewinnen" data-es="Ganar a las personas correctas">Win the right people</h3>
        <p data-en="Employer-branding films that attract talent and shape how your company is seen." data-de="Employer-Branding-Filme, die Talente anziehen und Ihr Unternehmensbild prägen." data-es="Films de employer branding que atraen talento y definen cómo se percibe tu empresa.">Employer-branding films that attract talent and shape how your company is seen.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg></div>
        <h3 data-en="Drive campaign results" data-de="Kampagnen-Ergebnisse" data-es="Impulsar resultados">Drive campaign results</h3>
        <p data-en="Films built for paid, social and web — measured on the outcomes that matter." data-de="Filme für Paid, Social und Web — gemessen an den Ergebnissen, die zählen." data-es="Films para paid, social y web — medidos por los resultados que importan.">Films built for paid, social and web — measured on the outcomes that matter.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.7c.6.5 1 1.3 1 2.1h6c0-.8.4-1.6 1-2.1A7 7 0 0 0 12 2z"/></svg></div>
        <h3 data-en="Make complex simple" data-de="Komplexes vereinfachen" data-es="Simplificar lo complejo">Make complex simple</h3>
        <p data-en="Turn hard-to-explain products and services into a story anyone gets in 60 seconds." data-de="Komplexe Produkte und Services in eine Geschichte verwandeln, die jeder in 60 Sekunden versteht." data-es="Convertir productos difíciles de explicar en una historia que cualquiera entiende en 60 segundos.">Turn hard-to-explain products and services into a story anyone gets in 60 seconds.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============ SERVICES ============ -->
<section class="sec" id="services">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="What we make" data-de="Was wir machen" data-es="Qué hacemos">What we make</span>
      <h2 data-en="One partner for every video your brand needs." data-de="Ein Partner für jedes Video, das Ihre Marke braucht." data-es="Un solo partner para cada video que tu marca necesita.">One partner for every video your brand needs.</h2>
    </div>
    <div class="services three">
      <a href={p("services/brand-video")} class="service reveal">
        <div class="thumb g-blue"></div>
        <div class="body">
          <span class="tag" data-en="Brand Videos" data-de="Markenfilme" data-es="Videos de marca">Brand Videos</span>
          <h3 data-en="Films that carry the campaign" data-de="Filme, die die Kampagne tragen" data-es="Films que sostienen la campaña">Films that carry the campaign</h3>
          <p data-en="High-impact brand films made to perform across paid media, social and your website." data-de="Wirkungsstarke Markenfilme für Paid Media, Social und Ihre Website." data-es="Films de marca de alto impacto para paid media, social y tu web.">High-impact brand films made to perform across paid media, social and your website.</p>
          <span class="more" data-en="Learn more →" data-de="Mehr erfahren →" data-es="Ver más →">Learn more →</span>
        </div>
      </a>
      <a href={p("services/product-video")} class="service reveal">
        <div class="thumb g-pink"></div>
        <div class="body">
          <span class="tag" data-en="Product Videos" data-de="Produktvideos" data-es="Videos de producto">Product Videos</span>
          <h3 data-en="Make products sell themselves" data-de="Produkte, die sich selbst verkaufen" data-es="Productos que se venden solos">Make products sell themselves</h3>
          <p data-en="Product films and launch videos that turn features into desire — and clicks into buyers." data-de="Produktfilme und Launch-Videos, die Features in Begehren verwandeln — und Klicks in Käufer." data-es="Films de producto y lanzamientos que convierten características en deseo — y clics en compradores.">Product films and launch videos that turn features into desire — and clicks into buyers.</p>
          <span class="more" data-en="Learn more →" data-de="Mehr erfahren →" data-es="Ver más →">Learn more →</span>
        </div>
      </a>
      <a href={p("services/employer-branding")} class="service reveal">
        <div class="thumb g-acid"></div>
        <div class="body">
          <span class="tag" data-en="Employer Branding" data-de="Employer Branding" data-es="Employer Branding">Employer Branding</span>
          <h3 data-en="Recruitment &amp; culture films" data-de="Recruiting- &amp; Kulturfilme" data-es="Films de cultura y reclutamiento">Recruitment &amp; culture films</h3>
          <p data-en="Show why people love working for you — and attract the talent you actually want." data-de="Zeigen Sie, warum Menschen gerne bei Ihnen arbeiten — und ziehen Sie die richtigen Talente an." data-es="Muestra por qué la gente ama trabajar contigo — y atrae el talento que realmente quieres.">Show why people love working for you — and attract the talent you actually want.</p>
          <span class="more" data-en="Learn more →" data-de="Mehr erfahren →" data-es="Ver más →">Learn more →</span>
        </div>
      </a>
      <a href={p("services/how-to-video")} class="service reveal">
        <div class="thumb g-teal"></div>
        <div class="body">
          <span class="tag" data-en="How-To &amp; Tutorials" data-de="How-To &amp; Tutorials" data-es="Tutoriales y How-To">How-To &amp; Tutorials</span>
          <h3 data-en="Explain anything simply" data-de="Alles einfach erklären" data-es="Explicar cualquier cosa, simple">Explain anything simply</h3>
          <p data-en="Explainer and tutorial videos that make complex offers easy to say yes to." data-de="Erklär- und Tutorial-Videos, die komplexe Angebote leicht verständlich machen." data-es="Videos explicativos y tutoriales que hacen fácil decir que sí a ofertas complejas.">Explainer and tutorial videos that make complex offers easy to say yes to.</p>
          <span class="more" data-en="Learn more →" data-de="Mehr erfahren →" data-es="Ver más →">Learn more →</span>
        </div>
      </a>
      <a href={p("services/social-media-video")} class="service reveal">
        <div class="thumb g-violet"></div>
        <div class="body">
          <span class="tag" data-en="Social Media" data-de="Social Media" data-es="Redes sociales">Social Media</span>
          <h3 data-en="Scroll-stopping content" data-de="Content, der den Scroll stoppt" data-es="Contenido que frena el scroll">Scroll-stopping content</h3>
          <p data-en="Short-form video series built for reach, engagement and conversion on every platform." data-de="Short-Form-Videoserien für Reichweite, Engagement und Conversion auf jeder Plattform." data-es="Series de video corto para alcance, engagement y conversión en cada plataforma.">Short-form video series built for reach, engagement and conversion on every platform.</p>
          <span class="more" data-en="Learn more →" data-de="Mehr erfahren →" data-es="Ver más →">Learn more →</span>
        </div>
      </a>
      <a href={p("services/corporate-video")} class="service reveal">
        <div class="thumb g-amber"></div>
        <div class="body">
          <span class="tag" data-en="Corporate &amp; Events" data-de="Corporate &amp; Events" data-es="Corporativo y eventos">Corporate &amp; Events</span>
          <h3 data-en="Communication &amp; event content" data-de="Kommunikation &amp; Event-Content" data-es="Comunicación y eventos">Communication &amp; event content</h3>
          <p data-en="Corporate communication, internal and event content that keeps your audience close." data-de="Unternehmenskommunikation, interne und Event-Inhalte, die Ihr Publikum binden." data-es="Comunicación corporativa, contenido interno y de eventos que mantiene cerca a tu audiencia.">Corporate communication, internal and event content that keeps your audience close.</p>
          <span class="more" data-en="Learn more →" data-de="Mehr erfahren →" data-es="Ver más →">Learn more →</span>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- ============ SELECTED WORK ============ -->
<section class="sec" id="work" style="padding-top:0">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="Selected work" data-de="Ausgewählte Arbeiten" data-es="Trabajos seleccionados">Selected work</span>
      <h2 data-en="See the work, not just the words." data-de="Sehen statt lesen." data-es="Mira el trabajo, no solo las palabras.">See the work, not just the words.</h2>
      <p data-en="A few recent films. Hit play." data-de="Ein paar aktuelle Filme. Einfach auf Play drücken." data-es="Algunos films recientes. Dale play.">A few recent films. Hit play.</p>
    </div>
    <div class="work-grid">
      <button class="work-tile reveal" type="button" data-vimeo="1068759296" data-label="V-Zug — Combair V600">
        <span class="wt-thumb"><img src="https://i.vimeocdn.com/video/1996950534-ab58c31114f162230baa21d656052dbd1f673936bd3e796469e75afa266991bb-d_960?region=us" width="960" height="540" loading="lazy" decoding="async" alt="V-Zug — Combair V600 product video" /></span>
        <span class="wt-play"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></span>
        <span class="wt-meta"><span class="wt-title">V-Zug — Combair V600</span></span>
      </button>
      <button class="work-tile reveal" type="button" data-vimeo="1009807480" data-label="Kanebo — Cellular Performance">
        <span class="wt-thumb"><img src="https://i.vimeocdn.com/video/1972637349-bac55279e3343b9554e2822c6c425b6313eb46cf95aad65427f39e76cea39c1b-d_960?region=us" width="960" height="540" loading="lazy" decoding="async" alt="Kanebo — Cellular Performance product video" /></span>
        <span class="wt-play"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></span>
        <span class="wt-meta"><span class="wt-title">Kanebo — Cellular Performance</span></span>
      </button>
      <button class="work-tile reveal" type="button" data-vimeo="1068759409" data-label="UBS — Group Internal Consulting">
        <span class="wt-thumb"><img src="https://i.vimeocdn.com/video/1996945412-11440cd0df3521e998bff13bcaab8bbed2a405430e442c73f998df74099d28b2-d_960?region=us" width="960" height="540" loading="lazy" decoding="async" alt="UBS — Group Internal Consulting employer branding video" /></span>
        <span class="wt-play"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></span>
        <span class="wt-meta"><span class="wt-title">UBS — Group Internal Consulting</span></span>
      </button>
      <button class="work-tile reveal" type="button" data-vimeo="639435034" data-label="Porsche — Der lange Weg">
        <span class="wt-thumb"></span>
        <span class="wt-play"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></span>
        <span class="wt-meta"><span class="wt-title">Porsche — Der lange Weg</span></span>
      </button>
      <button class="work-tile reveal" type="button" data-vimeo="1068759356" data-label="ON — Cloudstratus 3">
        <span class="wt-thumb"><img src="https://i.vimeocdn.com/video/1996948669-35967656e96be776d9061538739e83b53b16b9934945ba70c0399d120007b3da-d_960?region=us" width="960" height="540" loading="lazy" decoding="async" alt="ON — Cloudstratus 3 product video" /></span>
        <span class="wt-play"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></span>
        <span class="wt-meta"><span class="wt-title">ON — Cloudstratus 3</span></span>
      </button>
      <button class="work-tile reveal" type="button" data-vimeo="757649241" data-label="FIFA — Living Football">
        <span class="wt-thumb"></span>
        <span class="wt-play"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></span>
        <span class="wt-meta"><span class="wt-title">FIFA — Living Football</span></span>
      </button>
    </div>
    <div style="text-align:center;margin-top:44px" class="reveal">
      <a href={p("projects")} class="btn btn-ghost" data-en="See all projects" data-de="Alle Projekte ansehen" data-es="Ver todos los proyectos">See all projects</a>
    </div>
  </div>
</section>

<!-- ============ RESULTS ============ -->
<section class="sec" id="results" style="padding-top:0">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="Proof, not promises" data-de="Beweise statt Versprechen" data-es="Pruebas, no promesas">Proof, not promises</span>
      <h2 data-en="Real work. Real outcomes." data-de="Echte Arbeit. Echte Ergebnisse." data-es="Trabajo real. Resultados reales.">Real work. Real outcomes.</h2>
      <p data-en="A film is only worth making if it moves the numbers. Here's what ours did." data-de="Ein Film lohnt sich nur, wenn er die Zahlen bewegt. Das haben unsere bewirkt." data-es="Un film solo vale la pena si mueve los números. Esto lograron los nuestros.">A film is only worth making if it moves the numbers. Here's what ours did.</p>
    </div>
    <div class="cases">
      <div class="case reveal">
        <div class="top g1" data-vimeo="1033111627">
          <span class="client">Siemens</span>
          <button class="play" type="button" aria-label="Play video"><svg viewBox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z"/></svg></button>
        </div>
        <div class="content">
          <div class="metric" data-en="3× more website visits" data-de="3× mehr Website-Besuche" data-es="3× más visitas web">3× more website visits</div>
          <div class="row"><div class="k" data-en="Challenge" data-de="Herausforderung" data-es="Desafío">Challenge</div><div class="v" data-en="Cut through a crowded B2B market." data-de="In einem überfüllten B2B-Markt auffallen." data-es="Destacar en un mercado B2B saturado.">Cut through a crowded B2B market.</div></div>
          <div class="row"><div class="k" data-en="What we did" data-de="Was wir taten" data-es="Qué hicimos">What we did</div><div class="v" data-en="A brand film built for reach and clarity." data-de="Ein Markenfilm für Reichweite und Klarheit." data-es="Un film de marca hecho para alcance y claridad.">A brand film built for reach and clarity.</div></div>
          <blockquote class="cquote">
            <span data-en="“Significantly higher organic engagement and three times more website visits.”" data-de="„Deutlich höheres organisches Engagement und dreimal mehr Website-Besuche.“" data-es="«Un engagement orgánico significativamente mayor y el triple de visitas a la web.»">“Significantly higher organic engagement and three times more website visits.”</span>
            <cite>Marc Maurer — <span data-en="Employer Branding, Siemens Switzerland" data-de="Employer Branding, Siemens Schweiz" data-es="Employer Branding, Siemens Suiza">Employer Branding, Siemens Switzerland</span></cite>
          </blockquote>
        </div>
      </div>
      <div class="case reveal">
