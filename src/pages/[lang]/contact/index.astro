---
import Base from '../../../layouts/Base.astro';
import { langPaths, localePath } from '../../../i18n.js';
export const getStaticPaths = langPaths;
const { lang } = Astro.params;
const p = (s) => localePath(lang, s);
const title = {"en":"Contact Viven — Video Production Company in Zurich, Switzerland","de":"Kontakt Viven — Videoproduktion in Zürich, Schweiz","es":"Contacto Viven — Productora de video en Zúrich, Suiza"};
const description = {"en":"Start your video project with Viven, Zurich. Email info@viven.ch, call +41 43 508 33 81 or send the form — we reply within one business day with a clear, no-obligation quote.","de":"Starten Sie Ihr Videoprojekt mit Viven, Zürich. E-Mail an info@viven.ch, Anruf unter +41 43 508 33 81 oder Formular senden — Antwort innerhalb eines Werktags, unverbindlich.","es":"Empezá tu proyecto de video con Viven, Zúrich. Escribí a info@viven.ch, llamá al +41 43 508 33 81 o enviá el formulario — respondemos en un día hábil, sin compromiso."};
---
<Base lang={lang} slug="contact" active="contact" title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={"{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"ContactPage\",\"@id\":\"https://www.viven.ch/contact/#contactpage\",\"url\":\"https://www.viven.ch/contact/\",\"name\":\"Contact Viven — Video Production Company in Zurich\",\"description\":\"Contact Viven AG in Zurich to start your video project. Reply within one business day with a clear, no-obligation quote.\",\"inLanguage\":[\"en\",\"de\",\"es\"],\"about\":{\"@id\":\"https://www.viven.ch/#organization\"},\"mainEntity\":{\"@id\":\"https://www.viven.ch/#organization\"}},{\"@type\":\"BreadcrumbList\",\"@id\":\"https://www.viven.ch/contact/#breadcrumbs\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.viven.ch/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Contact\",\"item\":\"https://www.viven.ch/contact/\"}]}]}"}></script>
<!-- ============ PAGE HERO ============ -->
<section class="page-hero">
  <div class="wrap">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href={p("")} data-en="Home" data-de="Home" data-es="Inicio">Home</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span data-en="Contact" data-de="Kontakt" data-es="Contacto">Contact</span>
    </nav>
    <span class="eyebrow" data-en="Contact" data-de="Kontakt" data-es="Contacto">Contact</span>
    <h1 data-en='Tell us what <span class="hl">you&#39;re working on.</span>'
        data-de='Erzählen Sie uns <span class="hl">von Ihrem Projekt.</span>'
        data-es='Contanos en qué <span class="hl">estás trabajando.</span>'>
      Tell us what <span class="hl">you're working on.</span>
    </h1>
    <p class="lead"
       data-en="Tell us your goal — we'll come back with three concept ideas, timing and a clear quote within 48 hours. Free, no obligation."
       data-de="Nennen Sie uns Ihr Ziel — wir melden uns innert 48 Stunden mit drei Konzeptideen, Timing und einem klaren Angebot. Kostenlos und unverbindlich."
       data-es="Contanos tu objetivo — volvemos en 48 horas con tres ideas de concepto, tiempos y un presupuesto claro. Gratis y sin compromiso.">
      Tell us your goal — we'll come back with three concept ideas, timing and a clear quote within 48 hours. Free, no obligation.
    </p>
  </div>
</section>

<!-- ============ CONTACT ============ -->
<section class="sec" style="padding-top:20px">
  <div class="wrap">
    <div class="contact-grid">

      <!-- Left: contact channels -->
      <div>
        <div class="contact-card reveal">
          <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg></div>
          <div>
            <h3 data-en="Email" data-de="E-Mail" data-es="Email">Email</h3>
            <a class="val" href="mailto:info@viven.ch">info@viven.ch</a>
          </div>
        </div>
        <div class="contact-card reveal">
          <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
          <div>
            <h3 data-en="Phone" data-de="Telefon" data-es="Teléfono">Phone</h3>
            <a class="val" href="tel:+41435083381">+41 43 508 33 81</a>
          </div>
        </div>
        <div class="contact-card reveal">
          <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></div>
          <div>
            <h3 data-en="Studio" data-de="Studio" data-es="Estudio">Studio</h3>
            <a class="val" href="https://maps.google.com/?q=Zeughausstrasse+31,+8004+Z%C3%BCrich" target="_blank" rel="noopener">Zeughausstrasse 31, 8004 Zürich, Switzerland</a>
          </div>
        </div>
        <div class="contact-card reveal">
          <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div>
          <div>
            <h3 data-en="Follow" data-de="Folgen" data-es="Seguinos">Follow</h3>
            <p>
              <a class="val" style="display:inline" href="https://www.linkedin.com/company/viven-ag" target="_blank" rel="noopener">LinkedIn</a> ·
              <a class="val" style="display:inline" href="https://www.instagram.com/viven.ag" target="_blank" rel="noopener">Instagram</a> ·
              <a class="val" style="display:inline" href="https://www.facebook.com/VIVENAG" target="_blank" rel="noopener">Facebook</a> ·
              <a class="val" style="display:inline" href="https://x.com/vivenag/" target="_blank" rel="noopener">X</a>
            </p>
          </div>
        </div>

        <ul class="reveal" style="list-style:none;margin-top:28px;display:grid;gap:13px">
          <li style="display:flex;align-items:center;gap:12px;color:var(--text);font-size:15.5px"><svg style="width:19px;height:19px;color:var(--acid);flex-shrink:0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="First draft within two weeks" data-de="Erster Entwurf in zwei Wochen" data-es="Primer borrador en dos semanas">First draft within two weeks</span></li>
          <li style="display:flex;align-items:center;gap:12px;color:var(--text);font-size:15.5px"><svg style="width:19px;height:19px;color:var(--acid);flex-shrink:0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="Full production, in-house" data-de="Komplette Produktion, alles aus einer Hand" data-es="Producción completa, in-house">Full production, in-house</span></li>
          <li style="display:flex;align-items:center;gap:12px;color:var(--text);font-size:15.5px"><svg style="width:19px;height:19px;color:var(--acid);flex-shrink:0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="Multilingual delivery" data-de="Mehrsprachige Auslieferung" data-es="Entrega multilingüe">Multilingual delivery</span></li>
        </ul>
      </div>

      <!-- Right: form -->
      <div id="form" class="reveal" style="scroll-margin-top:100px">
        <span class="eyebrow" data-en="Let's talk" data-de="Sprechen wir" data-es="Hablemos">Let's talk</span>
        <h2 style="font-size:clamp(26px,3.4vw,38px);font-weight:700;margin:16px 0 24px"
            data-en="Start your project" data-de="Starten Sie Ihr Projekt" data-es="Empezá tu proyecto">Start your project</h2>
        <div class="lead-form-mount"></div>
        <p class="form-note" data-en="We'll reply within one business day. No spam, ever." data-de="Wir antworten innerhalb eines Werktags. Kein Spam." data-es="Respondemos en un día hábil. Nunca spam.">We'll reply within one business day. No spam, ever.</p>
        <p class="book-call-note"><span data-en="Prefer to talk it through?" data-de="Lieber direkt sprechen?" data-es="¿Preferís hablarlo directamente?">Prefer to talk it through?</span> <a class="book-call" href="https://meetings.hubspot.com/sofia-trevino?uuid=76bf013f-3825-4341-8a95-fee769f70c49" target="_blank" rel="noopener" data-en="Book a free 15-min call →" data-de="Gratis 15-Min-Call buchen →" data-es="Reservá una llamada gratis de 15 min →">Book a free 15-min call →</a></p>
      </div>

    </div>
  </div>
</section>

<!-- ============ REASSURANCE ============ -->
<section class="sec" style="padding-top:0">
  <div class="wrap">
    <div class="value-grid three">
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></div>
        <h3 data-en="We reply within one business day" data-de="Antwort innerhalb eines Werktags" data-es="Respondemos en un día hábil">We reply within one business day</h3>
        <p data-en="Your message lands directly with our producers — not in a ticket queue. Expect a real answer, fast." data-de="Ihre Nachricht landet direkt bei unseren Produzenten — nicht in einer Ticket-Warteschlange. Sie erhalten schnell eine echte Antwort." data-es="Tu mensaje llega directo a nuestros productores — no a una cola de tickets. Esperá una respuesta real, rápido.">Your message lands directly with our producers — not in a ticket queue. Expect a real answer, fast.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="m9 15 2 2 4-4"/></svg></div>
        <h3 data-en="No-obligation quote" data-de="Unverbindliches Angebot" data-es="Presupuesto sin compromiso">No-obligation quote</h3>
        <p data-en="You get ideas, timing and a clear price — then you decide. No pressure, no hidden costs." data-de="Sie erhalten Ideen, Timing und einen klaren Preis — dann entscheiden Sie. Kein Druck, keine versteckten Kosten." data-es="Recibís ideas, tiempos y un precio claro — y después decidís. Sin presión, sin costos ocultos.">You get ideas, timing and a clear price — then you decide. No pressure, no hidden costs.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></div>
        <h3 data-en="Only 5-star reviews" data-de="Nur 5-Sterne-Bewertungen" data-es="Solo reseñas de 5 estrellas">Only 5-star reviews</h3>
        <p data-en="187 brands across 32 industries have worked with us — and every published review is 5 stars." data-de="187 Marken aus 32 Branchen haben mit uns gearbeitet — und jede veröffentlichte Bewertung hat 5 Sterne." data-es="187 marcas de 32 industrias trabajaron con nosotros — y cada reseña publicada es de 5 estrellas.">187 brands across 32 industries have worked with us — and every published review is 5 stars.</p>
      </div>
    </div>
  </div>
</section>
</Base>
