---
// Página pillar de una pregunta del hub Resources.
// Cada entrada vive en UN idioma (los slugs vienen del sitio viejo, no son 1:1
// entre idiomas) → singleLang; el selector de idioma lleva al índice del hub.
import Base from '../../../layouts/Base.astro';
import { localePath } from '../../../i18n.js';
import resources from '../../../data/resources.json';
import rmap from '../../../data/resources-map.json';

export function getStaticPaths(){
  return resources.map((r) => ({ params: { lang: r.lang, slug: r.slug }, props: { entry: r } }));
}
const { lang } = Astro.params;
const { entry } = Astro.props;
const p = (s) => localePath(lang, s);
const SITE = 'https://www.viven.ch';

const related = resources.filter((r) => r.lang === lang && r.category === entry.category && r.slug !== entry.slug).slice(0, 5);

// equivalencias entre idiomas: si esta pregunta existe en otro idioma, el selector
// de idioma va a LA MISMA pregunta (y emitimos hreflang alternates)
const group = rmap.find((g) => g[lang] === entry.slug) || null;
const langUrls = group
  ? Object.fromEntries(['en', 'de', 'es'].filter((l) => group[l]).map((l) => [l, '/' + l + '/resources/' + group[l] + '/']))
  : null;

// un trabajo real por categoría, para "verlo en acción"
const CAT_VIDEO = {
  brand: { id: 502153490, t: 'Siemens — The Circle' },
  corporate: { id: 861150876, t: 'SV Group — Innovation Film' },
  product: { id: 1068759296, t: 'V-ZUG — Combair V600' },
  social: { id: 828322230, t: 'Siemens — Working Students' },
  employer: { id: 412290258, t: 'UBS — Apprenticeship' },
  howto: { id: 1026464530, t: 'V-ZUG — How-to' },
  animation: { id: 1068759356, t: 'ON — Product Launch' },
  event: { id: 757649241, t: 'FIFA — Living Football' },
  process: { id: 1057568537, t: 'Viven — Showreel' },
  general: { id: 1057568537, t: 'Viven — Showreel' },
};
const vid = CAT_VIDEO[entry.category] || CAT_VIDEO.general;

const L = {
  resources: { en: 'Resources', de: 'Wissen', es: 'Recursos' }[lang],
  home: { en: 'Home', de: 'Home', es: 'Inicio' }[lang],
  action: { en: 'See it in action', de: 'So sieht das aus', es: 'Así se ve en acción' }[lang],
  related: { en: 'Related questions', de: 'Verwandte Fragen', es: 'Preguntas relacionadas' }[lang],
  ctaT: { en: 'Planning a video?', de: 'Ein Video geplant?', es: '¿Planeando un video?' }[lang],
  ctaS: {
    en: 'Tell us what you’re working on — you’ll get a clear quote, usually within one business day.',
    de: 'Erzählen Sie uns von Ihrem Projekt — Sie erhalten eine klare Offerte, meist innert eines Arbeitstages.',
    es: 'Contanos en qué estás trabajando y recibís una cotización clara, normalmente en un día hábil.',
  }[lang],
  ctaBtn: { en: 'Start a project', de: 'Projekt starten', es: 'Empezar un proyecto' }[lang],
  ctaCall: { en: '📅 Book a 15-min call', de: '📅 15-Min-Call buchen', es: '📅 Agendar 15 min' }[lang],
};

const pageUrl = SITE + '/' + lang + '/resources/' + entry.slug + '/';
const ld = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage', '@id': pageUrl + '#faq', url: pageUrl, name: entry.question, inLanguage: lang,
      publisher: { '@id': SITE + '/#organization' },
      mainEntity: [{ '@type': 'Question', name: entry.question, acceptedAnswer: { '@type': 'Answer', text: entry.intro } }],
    },
    {
      '@type': 'BreadcrumbList', '@id': pageUrl + '#breadcrumbs',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: L.home, item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: L.resources, item: SITE + '/' + lang + '/resources/' },
        { '@type': 'ListItem', position: 3, name: entry.question, item: pageUrl },
      ],
    },
  ],
});

const title = { [lang]: entry.title };
const description = { [lang]: entry.description };
---
<Base lang={lang} slug={'resources/' + entry.slug} active="resources" title={title} description={description} singleLang={true} switchSlug="resources" langUrls={langUrls}>
  <script type="application/ld+json" slot="jsonld" set:html={ld}></script>

  <section class="page-hero">
    <div class="wrap">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href={p('')}>{L.home}</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <a href={p('resources')}>{L.resources}</a>
      </nav>
      <span class="eyebrow">{L.resources}</span>
      <h1 class="rsrc-h1">{entry.question}</h1>
      <p class="lead">{entry.intro}</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap rsrc-body">
      {entry.sections.map((sec) => (
        <div class="rsrc-sec">
          <h2>{sec.h2}</h2>
          <div set:html={sec.html}></div>
        </div>
      ))}

      <div class="rsrc-video">
        <h2>{L.action}</h2>
        <div class="rsrc-vframe">
          <iframe src={'https://player.vimeo.com/video/' + vid.id + '?dnt=1'} loading="lazy" title={vid.t}
            allow="autoplay; fullscreen; picture-in-picture" allowfullscreen referrerpolicy="strict-origin-when-cross-origin"></iframe>
        </div>
        <p class="rsrc-vcap">{vid.t}</p>
      </div>

      {related.length > 0 && (
        <div class="rsrc-related">
          <h2>{L.related}</h2>
          <div class="rsrc-grid">
            {related.map((r) => (
              <a class="rsrc-card" href={p('resources/' + r.slug)}>
                <span class="rsrc-q">{r.question}</span>
                <span class="rsrc-arrow">→</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="rsrc-ctabox">
        <div>
          <div class="rsrc-ctat">{L.ctaT}</div>
          <p class="rsrc-ctas">{L.ctaS}</p>
        </div>
        <div class="rsrc-ctabtns">
          <a class="btn btn-primary" href={p('contact')}>{L.ctaBtn}</a>
          <a class="btn btn-ghost" href="/book/" target="_blank" rel="noopener">{L.ctaCall}</a>
        </div>
      </div>
    </div>
  </section>

  <style is:global>
    .rsrc-h1{font-size:clamp(28px,4.4vw,44px)!important}
    .rsrc-body{max-width:820px}
    .rsrc-sec{margin-bottom:30px}
    .rsrc-sec h2{font-size:clamp(19px,2.6vw,24px);margin-bottom:12px}
    .rsrc-sec p{color:var(--muted);font-size:15.5px;line-height:1.75;margin-bottom:12px}
    .rsrc-sec ul{margin:0 0 12px 20px;color:var(--muted);font-size:15.5px;line-height:1.75}
    .rsrc-sec li{margin-bottom:6px}
    .rsrc-sec strong{color:var(--text)}
    .rsrc-video{margin:38px 0}
    .rsrc-video h2{font-size:clamp(19px,2.6vw,24px);margin-bottom:14px}
    .rsrc-vframe{position:relative;aspect-ratio:16/9;border-radius:16px;overflow:hidden;border:1px solid var(--line)}
    .rsrc-vframe iframe{position:absolute;inset:0;width:100%;height:100%;border:0}
    .rsrc-vcap{color:var(--muted-2);font-size:12.5px;margin-top:8px}
    .rsrc-related{margin:38px 0}
    .rsrc-related h2{font-size:clamp(19px,2.6vw,24px);margin-bottom:14px}
    .rsrc-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
    @media(max-width:720px){.rsrc-grid{grid-template-columns:1fr}}
    .rsrc-card{display:flex;align-items:center;justify-content:space-between;gap:12px;border:1px solid var(--line);border-radius:13px;background:var(--navy-800);padding:15px 18px;color:var(--text);text-decoration:none;font-size:15px;font-weight:500;transition:border-color .2s,transform .15s}
    .rsrc-card:hover{border-color:var(--acid);transform:translateY(-1px)}
    .rsrc-card .rsrc-arrow{color:var(--acid);flex:none}
    .rsrc-ctabox{display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;border:1px solid var(--line-strong);background:var(--navy-800);border-radius:18px;padding:26px 28px;margin:40px 0 8px}
    .rsrc-ctat{font-family:'Space Grotesk';font-weight:700;font-size:20px;margin-bottom:6px}
    .rsrc-ctas{color:var(--muted);font-size:14px;max-width:460px;margin:0}
    .rsrc-ctabtns{display:flex;gap:10px;flex-wrap:wrap}
  </style>
</Base>
