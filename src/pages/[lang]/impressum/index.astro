---
import Base from '../../../layouts/Base.astro';
import { langPaths, localePath } from '../../../i18n.js';
export const getStaticPaths = langPaths;
const { lang } = Astro.params;
const p = (s) => localePath(lang, s);
const title = {"en":"Impressum — Viven AG | Video Production Zurich","de":"Impressum — Viven AG | Videoproduktion Zürich","es":"Aviso legal — Viven AG | Producción de video en Zúrich"};
const description = {"en":"Legal notice (Impressum) of Viven AG, Zeughausstrasse 31, 8004 Zürich — company details, commercial register, VAT number and disclaimer.","de":"Impressum der Viven AG, Zeughausstrasse 31, 8004 Zürich — Firmenangaben, Handelsregister, MWST-Nummer und Haftungsausschluss.","es":"Aviso legal de Viven AG, Zeughausstrasse 31, 8004 Zúrich — datos de la empresa, registro mercantil, número de IVA y descargo de responsabilidad."};
---
<Base lang={lang} slug="impressum" title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.viven.ch/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Impressum\",\"item\":\"https://www.viven.ch/impressum/\"}]}"}></script>
<!-- ============ PAGE HERO ============ -->
<section class="page-hero" style="padding-bottom:30px">
  <div class="wrap">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href={p("")} data-en="Home" data-de="Home" data-es="Inicio">Home</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span data-en="Impressum" data-de="Impressum" data-es="Aviso legal">Impressum</span>
    </nav>
    <h1 data-en="Impressum" data-de="Impressum" data-es="Aviso legal">Impressum</h1>
  </div>
</section>

<!-- ============ CONTENT ============ -->
<section class="sec" style="padding-top:40px">
  <div class="wrap">
    <div class="prose">

      <h2 data-en="Company information" data-de="Angaben zum Unternehmen" data-es="Información de la empresa">Company information</h2>
