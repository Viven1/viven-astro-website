---
import Base from '../../../layouts/Base.astro';
import Testimonials from '../../../components/Testimonials.astro';
import { langPaths, localePath } from '../../../i18n.js';
export const getStaticPaths = langPaths;
const { lang } = Astro.params;
const p = (s) => localePath(lang, s);
const title = {"en":"Why Viven — Feature-Film Craft, Business Results | Video Production Zurich","de":"Warum Viven — Spielfilm-Handwerk, Business-Ergebnisse | Videoproduktion Zürich","es":"Por qué Viven — Oficio de cine, resultados de negocio | Producción de video Zúrich"};
const description = {"en":"Why 187 brands across 32 industries choose Viven: feature-film craft, business-first thinking, end-to-end production — founded by the first Swiss producer on Netflix.","de":"Warum 187 Marken aus 32 Branchen Viven wählen: Spielfilm-Handwerk, Business-first-Denken, Produktion über einen Partner — gegründet vom ersten Schweizer Produzenten auf Netflix.","es":"Por qué 187 marcas de 32 industrias eligen Viven: oficio de cine, mentalidad de negocio y producción de principio a fin — fundada por el primer productor suizo en Netflix."};
---
<Base lang={lang} slug="why-viven" active="why" title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={"{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"AboutPage\",\"@id\":\"https://www.viven.ch/why-viven/#webpage\",\"url\":\"https://www.viven.ch/why-viven/\",\"name\":\"Why Viven — Feature-film craft, business results\",\"description\":\"Why 187 brands across 32 industries choose Viven: feature-film discipline on set, business-first thinking, one accountable team, end to end and timelines agreed upfront — and kept.\",\"about\":{\"@id\":\"https://www.viven.ch/#organization\"},\"isPartOf\":{\"@id\":\"https://www.viven.ch/#website\"},\"inLanguage\":[\"en\",\"de\",\"es\"]},{\"@type\":\"BreadcrumbList\",\"@id\":\"https://www.viven.ch/why-viven/#breadcrumbs\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.viven.ch/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Why Viven\",\"item\":\"https://www.viven.ch/why-viven/\"}]},{\"@type\":\"Person\",\"@id\":\"https://www.viven.ch/why-viven/#sebastian-cepeda\",\"name\":\"Sebastian Cepeda\",\"jobTitle\":\"Founder & Executive Producer\",\"description\":\"First Swiss producer to bring an original feature film to Netflix.\",\"worksFor\":{\"@id\":\"https://www.viven.ch/#organization\"}}]}"}></script>
<!-- ============ PAGE HERO ============ -->
<section class="page-hero">
  <div class="wrap">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href={p("")} data-en="Home" data-de="Home" data-es="Inicio">Home</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span data-en="Why Viven" data-de="Warum Viven" data-es="Por qué Viven">Why Viven</span>
    </nav>
    <span class="eyebrow" data-en="Why Viven" data-de="Warum Viven" data-es="Por qué Viven">Why Viven</span>
    <h1 data-en='Feature-film craft. <span class="hl">Business results.</span>'
        data-de='Spielfilm-Handwerk. <span class="hl">Business-Ergebnisse.</span>'
        data-es='Oficio de cine. <span class="hl">Resultados de negocio.</span>'>
      Feature-film craft. <span class="hl">Business results.</span>
    </h1>
    <p class="lead"
       data-en="Viven was founded by Sebastian Cepeda — the first Swiss producer to bring an original feature film to Netflix. Today that same craft powers films for 187 brands across 32 industries."
       data-de="Viven wurde von Sebastian Cepeda gegründet — dem ersten Schweizer Produzenten, der einen Original-Spielfilm zu Netflix brachte. Heute steckt dieses Handwerk in Filmen für 187 Marken aus 32 Branchen."
       data-es="Viven fue fundada por Sebastian Cepeda — el primer productor suizo en llevar una película original a Netflix. Hoy ese mismo oficio impulsa films para 187 marcas de 32 industrias.">
      Viven was founded by Sebastian Cepeda — the first Swiss producer to bring an original feature film to Netflix. Today that same craft powers films for 187 brands across 32 industries.
    </p>
  </div>
</section>

<!-- ============ STATS ============ -->
<section class="sec" style="padding-top:0;padding-bottom:0">
  <div class="wrap">
    <div class="stats four reveal">
      <div class="stat"><div class="num">187</div><div class="lbl" data-en="Brands trusted us" data-de="Marken vertrauen uns" data-es="Marcas confiaron en nosotros">Brands trusted us</div></div>
      <div class="stat"><div class="num">32</div><div class="lbl" data-en="Industries served" data-de="Branchen bedient" data-es="Industrias atendidas">Industries served</div></div>
      <div class="stat"><div class="num">47</div><div class="lbl" data-en="Five-star Google reviews" data-de="Fünf-Sterne-Google-Bewertungen" data-es="Reseñas de 5 estrellas en Google">Five-star Google reviews</div></div>
      <div class="stat"><div class="num">1st</div><div class="lbl" data-en="Swiss original feature on Netflix" data-de="Schweizer Original-Spielfilm auf Netflix" data-es="Película original suiza en Netflix">Swiss original feature on Netflix</div></div>
    </div>
  </div>
</section>

<!-- ============ THE VIVEN DIFFERENCE ============ -->
<section class="sec" id="difference">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="The Viven difference" data-de="Der Viven-Unterschied" data-es="La diferencia Viven">The Viven difference</span>
      <h2 data-en="Why brands choose us — and stay." data-de="Warum Marken uns wählen — und bleiben." data-es="Por qué las marcas nos eligen — y se quedan.">Why brands choose us — and stay.</h2>
      <p data-en="Four things we do differently. None of them optional." data-de="Vier Dinge, die wir anders machen. Keines davon ist optional." data-es="Cuatro cosas que hacemos distinto. Ninguna es opcional.">Four things we do differently. None of them optional.</p>
    </div>
    <div class="value-grid">
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 8h16v12a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1z"/><path d="m4 8 2-5h3l-2 5"/><path d="m9 8 2-5h3l-2 5"/><path d="m14 8 2-5h3l-2 5"/></svg></div>
        <h3 data-en="Feature-film discipline" data-de="Spielfilm-Disziplin" data-es="Disciplina de cine">Feature-film discipline</h3>
        <p data-en="The same rigor we bring to cinema, on every set: planned shots, tight schedules, zero wasted time." data-de="Dieselbe Präzision wie im Kino, an jedem Set: geplante Einstellungen, straffe Zeitpläne, keine verlorene Zeit." data-es="El mismo rigor del cine, en cada set: tomas planificadas, cronogramas ajustados, cero tiempo perdido.">The same rigor we bring to cinema, on every set: planned shots, tight schedules, zero wasted time.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg></div>
        <h3 data-en="Business-first thinking" data-de="Business-first-Denken" data-es="Mentalidad de negocio">Business-first thinking</h3>
        <p data-en="We start with your goal, not a camera. Every creative choice is tied to the outcome you need." data-de="Wir starten mit Ihrem Ziel, nicht mit einer Kamera. Jede kreative Entscheidung zahlt auf Ihr Ergebnis ein." data-es="Empezamos con tu objetivo, no con una cámara. Cada decisión creativa apunta al resultado que necesitas.">We start with your goal, not a camera. Every creative choice is tied to the outcome you need.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 2 8.5 5v10L12 22l-8.5-5V7z"/><path d="M12 22V12"/><path d="m3.5 7 8.5 5 8.5-5"/></svg></div>
        <h3 data-en="End to end" data-de="Ein Partner, end to end" data-es="De principio a fin">End to end</h3>
        <p data-en="Concept, script, shoot, edit, sound and delivery — one team, one standard, no hand-offs." data-de="Konzept, Skript, Dreh, Schnitt, Sound und Auslieferung — ein Team, ein Standard, keine Übergaben." data-es="Concepto, guion, rodaje, edición, sonido y entrega — un equipo, un estándar, sin intermediarios.">Concept, script, shoot, edit, sound and delivery — one team, one standard, no hand-offs.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></div>
        <h3 data-en="Timelines that hold" data-de="Zeitpläne, die halten" data-es="Cronogramas que se cumplen">Timelines that hold</h3>
        <p data-en="We agree on the timeline before we start — and we keep it. Every time." data-de="Wir vereinbaren den Zeitplan vor dem Start — und halten ihn ein. Jedes Mal." data-es="Acordamos el cronograma antes de empezar — y lo cumplimos. Siempre.">We agree on the timeline before we start — and we keep it. Every time.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============ PROCESS ============ -->
<section class="sec" id="process" style="padding-top:0">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="How we work" data-de="So arbeiten wir" data-es="Cómo trabajamos">How we work</span>
      <h2 data-en="Four steps. Zero surprises." data-de="Vier Schritte. Null Überraschungen." data-es="Cuatro pasos. Cero sorpresas.">Four steps. Zero surprises.</h2>
      <p data-en="From first call to final delivery, you always know where your film stands." data-de="Vom ersten Gespräch bis zur finalen Auslieferung wissen Sie immer, wo Ihr Film steht." data-es="De la primera llamada a la entrega final, siempre sabes en qué punto está tu film.">From first call to final delivery, you always know where your film stands.</p>
    </div>
    <div class="process">
      <div class="step reveal">
        <div class="n">1</div>
        <h3 data-en="Creative development" data-de="Kreativentwicklung" data-es="Desarrollo creativo">Creative development</h3>
        <p data-en="We start with your goal, not with a camera. Together we define who the film must reach, what it should make them feel and what it should make them do. That brief drives every decision from first frame to last." data-de="Wir starten mit Ihrem Ziel, nicht mit der Kamera. Gemeinsam definieren wir, wen der Film erreichen muss, was er auslösen und wozu er bewegen soll. Dieses Briefing bestimmt jede Entscheidung — vom ersten bis zum letzten Bild." data-es="Empezamos con tu objetivo, no con una cámara. Juntos definimos a quién debe llegar el film, qué debe hacer sentir y qué acción debe provocar. Ese brief guía cada decisión, del primer al último cuadro.">We start with your goal, not with a camera. Together we define who the film must reach, what it should make them feel and what it should make them do. That brief drives every decision from first frame to last.</p>
      </div>
      <div class="step reveal">
        <div class="n">2</div>
        <h3 data-en="Pre-production" data-de="Pre-Production" data-es="Preproducción">Pre-production</h3>
        <p data-en="Casting, crewing, storyboarding and scheduling. Every location, every shot and every hour is locked before the shoot — so production runs without surprises." data-de="Casting, Crew, Storyboard und Zeitplan. Jede Location, jede Einstellung und jede Stunde steht fest, bevor gedreht wird — damit die Produktion ohne Überraschungen läuft." data-es="Casting, equipo, storyboard y calendario. Cada locación, cada toma y cada hora quedan definidas antes del rodaje — para que la producción avance sin sorpresas.">Casting, crewing, storyboarding and scheduling. Every location, every shot and every hour is locked before the shoot — so production runs without surprises.</p>
      </div>
      <div class="step reveal">
        <div class="n">3</div>
        <h3 data-en="Production" data-de="Produktion" data-es="Producción">Production</h3>
        <p data-en="On set we work with the efficiency and discipline of a feature film crew. Every shot is planned, every minute accounted for — and your team always knows what happens next." data-de="Am Set arbeiten wir mit der Effizienz und Disziplin einer Spielfilm-Crew. Jede Einstellung ist geplant, jede Minute verplant — und Ihr Team weiss immer, was als Nächstes passiert." data-es="En el set trabajamos con la eficiencia y disciplina de un equipo de cine. Cada toma está planificada, cada minuto contado — y tu equipo siempre sabe qué sigue.">On set we work with the efficiency and discipline of a feature film crew. Every shot is planned, every minute accounted for — and your team always knows what happens next.</p>
      </div>
      <div class="step reveal">
        <div class="n">4</div>
        <h3 data-en="Post-production" data-de="Post-Production" data-es="Postproducción">Post-production</h3>
        <p data-en="Expert editing, sound design and visual enhancements merge feature-film craft with your brand identity — until the film performs wherever you publish it." data-de="Professioneller Schnitt, Sound Design und visuelle Veredelung verbinden Spielfilm-Handwerk mit Ihrer Markenidentität — bis der Film überall dort wirkt, wo Sie ihn einsetzen." data-es="Edición experta, diseño de sonido y acabados visuales unen el oficio del cine con tu identidad de marca — hasta que el film funciona donde sea que lo publiques.">Expert editing, sound design and visual enhancements merge feature-film craft with your brand identity — until the film performs wherever you publish it.</p>
      </div>
    </div>
    <p class="reveal" style="text-align:center;margin-top:36px;color:var(--muted);font-size:15px"
       data-en="Social series take days. Employer-branding campaigns typically run 4–8 weeks. Either way: the timeline is agreed upfront — and kept."
       data-de="Social-Serien dauern Tage. Employer-Branding-Kampagnen typischerweise 4–8 Wochen. In jedem Fall: Der Zeitplan wird vorab vereinbart — und eingehalten."
       data-es="Las series para redes toman días. Las campañas de employer branding, típicamente 4–8 semanas. En todo caso: el cronograma se acuerda antes — y se cumple.">
      Social series take days. Employer-branding campaigns typically run 4–8 weeks. Either way: the timeline is agreed upfront — and kept.
    </p>
  </div>
</section>

<!-- ============ CLIENTS ============ -->
<section class="sec" id="clients" style="padding-top:0;padding-bottom:0">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="Clients" data-de="Kunden" data-es="Clientes">Clients</span>
      <h2 data-en="In good company." data-de="In guter Gesellschaft." data-es="En buena compañía.">In good company.</h2>
      <p data-en="187 brands across 32 industries trust Viven — including UBS, Siemens, Porsche, ON, Chanel, FIFA, Philips, Swarovski, IBM, Julius Bär, KPMG, V-ZUG and Franke."
         data-de="187 Marken aus 32 Branchen vertrauen Viven — darunter UBS, Siemens, Porsche, ON, Chanel, FIFA, Philips, Swarovski, IBM, Julius Bär, KPMG, V-ZUG und Franke."
         data-es="187 marcas de 32 industrias confían en Viven — entre ellas UBS, Siemens, Porsche, ON, Chanel, FIFA, Philips, Swarovski, IBM, Julius Bär, KPMG, V-ZUG y Franke.">
        187 brands across 32 industries trust Viven — including UBS, Siemens, Porsche, ON, Chanel, FIFA, Philips, Swarovski, IBM, Julius Bär, KPMG, V-ZUG and Franke.</p>
    </div>
  </div>
</section>

<!-- ============ LOGO BAR ============ -->
<div class="logos" style="margin-top:56px">
  <div class="wrap">
    <p class="label" data-en="187 brands across 32 industries" data-de="187 Marken in 32 Branchen" data-es="187 marcas en 32 industrias">187 brands across 32 industries</p>
    <div class="marquee">
      <div class="marquee-track">
        <span>UBS</span><span>Siemens</span><span>Porsche</span><span>ON</span><span>Franke</span><span>V-ZUG</span><span>Chanel</span><span>FIFA</span><span>Philips</span><span>Swarovski</span><span>IBM</span><span>Sennheiser</span><span>Julius Bär</span><span>KPMG</span><span>Sigg</span>
        <span>UBS</span><span>Siemens</span><span>Porsche</span><span>ON</span><span>Franke</span><span>V-ZUG</span><span>Chanel</span><span>FIFA</span><span>Philips</span><span>Swarovski</span><span>IBM</span><span>Sennheiser</span><span>Julius Bär</span><span>KPMG</span><span>Sigg</span>
      </div>
    </div>
  </div>
</div>

<!-- ============ RESULTS ============ -->
<section class="sec" id="results">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="Proof, not promises" data-de="Beweise statt Versprechen" data-es="Pruebas, no promesas">Proof, not promises</span>
      <h2 data-en="Real work. Real outcomes." data-de="Echte Arbeit. Echte Ergebnisse." data-es="Trabajo real. Resultados reales.">Real work. Real outcomes.</h2>
      <p data-en="A film is only worth making if it moves the numbers. Here's what ours did." data-de="Ein Film lohnt sich nur, wenn er die Zahlen bewegt. Das haben unsere bewirkt." data-es="Un film solo vale la pena si mueve los números. Esto lograron los nuestros.">A film is only worth making if it moves the numbers. Here's what ours did.</p>
    </div>
    <div class="cases">
      <div class="case reveal">
        <div class="top g1" data-vimeo="1033111627">
          <span class="client">Siemens</span>
          <button class="play" type="button" aria-label="Play video"><svg viewBox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z"/></svg></button>
        </div>
        <div class="content">
          <div class="metric" data-en="3× more website visits" data-de="3× mehr Website-Besuche" data-es="3× más visitas web">3× more website visits</div>
          <div class="row"><div class="k" data-en="Challenge" data-de="Herausforderung" data-es="Desafío">Challenge</div><div class="v" data-en="Cut through a crowded B2B market." data-de="In einem überfüllten B2B-Markt auffallen." data-es="Destacar en un mercado B2B saturado.">Cut through a crowded B2B market.</div></div>
          <div class="row"><div class="k" data-en="What we did" data-de="Was wir taten" data-es="Qué hicimos">What we did</div><div class="v" data-en="A brand film built for reach and clarity." data-de="Ein Markenfilm für Reichweite und Klarheit." data-es="Un film de marca hecho para alcance y claridad.">A brand film built for reach and clarity.</div></div>
        </div>
      </div>
      <div class="case reveal">
        <div class="top g2" data-vimeo="837553928">
          <span class="client">Meteomatics</span>
          <button class="play" type="button" aria-label="Play video"><svg viewBox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z"/></svg></button>
        </div>
        <div class="content">
          <div class="metric" data-en="Opened new markets" data-de="Neue Märkte erschlossen" data-es="Abrió nuevos mercados">Opened new markets</div>
          <div class="row"><div class="k" data-en="Challenge" data-de="Herausforderung" data-es="Desafío">Challenge</div><div class="v" data-en="Explain a complex product to new audiences." data-de="Ein komplexes Produkt neuen Zielgruppen erklären." data-es="Explicar un producto complejo a nuevas audiencias.">Explain a complex product to new audiences.</div></div>
          <div class="row"><div class="k" data-en="What we did" data-de="Was wir taten" data-es="Qué hicimos">What we did</div><div class="v" data-en="A clear, story-led product film." data-de="Ein klarer, story-getriebener Produktfilm." data-es="Un film de producto claro, guiado por la historia.">A clear, story-led product film.</div></div>
        </div>
      </div>
      <div class="case reveal">
        <div class="top g3" data-vimeo="896484047">
          <span class="client">SV Group</span>
          <button class="play" type="button" aria-label="Play video"><svg viewBox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z"/></svg></button>
        </div>
        <div class="content">
          <div class="metric" data-en="Recruiting + sales, one film" data-de="Recruiting + Sales, ein Film" data-es="Recruiting + ventas, un solo film">Recruiting + sales, one film</div>
          <div class="row"><div class="k" data-en="Challenge" data-de="Herausforderung" data-es="Desafío">Challenge</div><div class="v" data-en="Reach candidates and customers at once." data-de="Kandidaten und Kunden gleichzeitig erreichen." data-es="Llegar a candidatos y clientes a la vez.">Reach candidates and customers at once.</div></div>
          <div class="row"><div class="k" data-en="What we did" data-de="Was wir taten" data-es="Qué hicimos">What we did</div><div class="v" data-en="One versatile film, two business wins." data-de="Ein vielseitiger Film, zwei Erfolge." data-es="Un film versátil, dos victorias de negocio.">One versatile film, two business wins.</div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ TESTIMONIAL ============ -->
<section class="quote-sec" style="padding-top:0">
  <div class="wrap">
    <div class="quote-card reveal">
      <p data-en='Siemens saw <em>3× more website visits.</em> Meteomatics <em>opened new markets.</em> SV Group improved <em>both recruiting and sales</em> — with the same video.'
         data-de='Siemens verzeichnete <em>3× mehr Website-Besuche.</em> Meteomatics <em>erschloss neue Märkte.</em> Die SV Group verbesserte <em>Recruiting und Sales zugleich</em> — mit demselben Video.'
         data-es='Siemens logró <em>3× más visitas web.</em> Meteomatics <em>abrió nuevos mercados.</em> SV Group mejoró <em>recruiting y ventas a la vez</em> — con el mismo video.'>
        Siemens saw <em>3× more website visits.</em> Meteomatics <em>opened new markets.</em> SV Group improved <em>both recruiting and sales</em> — with the same video.
      </p>
      <div class="attr" data-en="Outcomes from Viven-produced films" data-de="Ergebnisse von Viven produzierter Filme" data-es="Resultados de films producidos por Viven">Outcomes from Viven-produced films</div>
    </div>
  </div>
</section>

<Testimonials lang={lang} />

<!-- ============ CTA / FORM ============ -->
<section class="cta" id="start" style="padding-top:0">
  <div class="wrap">
    <div class="cta-card reveal">
      <div>
        <span class="eyebrow" data-en="Let's talk" data-de="Sprechen wir" data-es="Hablemos">Let's talk</span>
        <h2 data-en="Tell us what you're working on." data-de="Erzählen Sie uns von Ihrem Projekt." data-es="Contanos en qué estás trabajando.">Tell us what you're working on.</h2>
        <p class="lead" data-en="Tell us your goal — we'll come back with three concept ideas, timing and a clear quote within 48 hours. Free, no obligation." data-de="Nennen Sie uns Ihr Ziel — wir melden uns innert 48 Stunden mit drei Konzeptideen, Timing und einem klaren Angebot. Kostenlos und unverbindlich." data-es="Contanos tu objetivo — volvemos en 48 horas con tres ideas de concepto, tiempos y un presupuesto claro. Gratis y sin compromiso.">Tell us your goal — we'll come back with three concept ideas, timing and a clear quote within 48 hours. Free, no obligation.</p>
        <ul>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="First draft within two weeks" data-de="Erster Entwurf in zwei Wochen" data-es="Primer borrador en dos semanas">First draft within two weeks</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="One partner, brief to delivery" data-de="Ein Partner, vom Brief bis zur Auslieferung" data-es="Un partner, de principio a fin">One partner, brief to delivery</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="Multilingual delivery" data-de="Mehrsprachige Auslieferung" data-es="Entrega multilingüe">Multilingual delivery</span></li>
        </ul>
      </div>
      <div>
