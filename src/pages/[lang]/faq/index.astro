---
import Base from '../../../layouts/Base.astro';
import Testimonials from '../../../components/Testimonials.astro';
import { langPaths, localePath } from '../../../i18n.js';
export const getStaticPaths = langPaths;
const { lang } = Astro.params;
const p = (s) => localePath(lang, s);
const title = {"en":"Video Production FAQ — Pricing, Process & Timing | Viven Zurich","de":"Videoproduktion FAQ — Preise, Prozess & Timing | Viven Zürich","es":"FAQ de producción de video — Precios y proceso | Viven Zúrich"};
const description = {"en":"Answers to the questions we hear most: video production costs, timelines, process, revisions, formats and languages. From Viven, the Zurich video production company.","de":"Antworten auf die häufigsten Fragen: Kosten, Timing, Prozess, Korrekturen, Formate und Sprachen der Videoproduktion. Von Viven, der Videoproduktion aus Zürich.","es":"Respuestas a las preguntas más frecuentes: costos de producción de video, plazos, proceso, revisiones, formatos e idiomas. De Viven, productora de video en Zúrich."};
---
<Base lang={lang} slug="faq" active="faq" title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={"{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"FAQPage\",\"@id\":\"https://www.viven.ch/faq/#faqpage\",\"url\":\"https://www.viven.ch/faq/\",\"name\":\"Video Production FAQ — Viven Zurich\",\"inLanguage\":[\"en\",\"de\",\"es\"],\"publisher\":{\"@id\":\"https://www.viven.ch/#organization\"},\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What kind of videos does Viven produce?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Brand films, product videos, employer-branding campaigns, how-to and tutorial content, social media series and corporate communication. If it moves your business, we produce it — from a single hero film to a full always-on content pipeline.\"}},{\"@type\":\"Question\",\"name\":\"Where is Viven based?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Our studio is at Zeughausstrasse 31, 8004 Zürich — in the heart of the city. From there we shoot across Switzerland and the rest of Europe, wherever your story takes place.\"}},{\"@type\":\"Question\",\"name\":\"Who has Viven worked with?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"187 brands across 32 industries — including UBS, Siemens, Porsche, ON, Chanel, FIFA and Philips. From global corporations to ambitious Swiss SMEs, the brief is always the same: video that moves the numbers.\"}},{\"@type\":\"Question\",\"name\":\"What makes Viven different?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Feature-film craft with a business-first mindset. Founder Sebastian Cepeda was the first Swiss producer to bring an original feature film to Netflix — and we apply that discipline to every brief. We start with your goal, not with a camera.\"}},{\"@type\":\"Question\",\"name\":\"How long does a video production take?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"You typically see a first draft about two weeks after the agreed start. Social media series can be turned around in days, while larger employer-branding campaigns usually run four to eight weeks. We agree on the timeline before we start — and we stick to it.\"}},{\"@type\":\"Question\",\"name\":\"How does the process work?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Four stages: Creative development, Pre-production, Production and Post-production. You get one contact person, clear milestones and a fixed schedule from kickoff to delivery — no surprises along the way.\"}},{\"@type\":\"Question\",\"name\":\"Does Viven handle the whole production?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Concept, script, casting, shoot, edit, sound design and finishing are all run by one Viven team, with the right specialists brought in for your project. You brief us once and receive delivery-ready assets — we coordinate the whole crew, so you never have to.\"}},{\"@type\":\"Question\",\"name\":\"How many revisions are included?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Every quote includes structured feedback rounds agreed upfront, so you always know where you stand. Clear checkpoints keep the project on schedule and on budget — with no surprise costs at the end.\"}},{\"@type\":\"Question\",\"name\":\"How much does a video cost?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Most projects range from CHF 4,000 to 80,000 — length, complexity and the number of shoot days drive the price. Tell us what you're working on and you'll get a clear, no-obligation quote, usually within one business day.\"}},{\"@type\":\"Question\",\"name\":\"Is video worth the investment?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Our clients think so. Siemens saw 3× more website visits after their brand film, and SV Group improved both recruiting and sales with a single video. A film is only worth making if it moves the numbers.\"}},{\"@type\":\"Question\",\"name\":\"Do you offer packages for ongoing content?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. For always-on social media content we offer batch production and retainer models: we plan and shoot efficiently in blocks, and you receive a steady stream of platform-ready videos at a lower cost per asset.\"}},{\"@type\":\"Question\",\"name\":\"In which languages do you deliver?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"English, German and Spanish — produced natively, not just translated. Subtitles and additional language versions are available for every film, so one production can serve all your markets.\"}},{\"@type\":\"Question\",\"name\":\"What formats do I get?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Delivery-ready masters plus the cutdowns you need: 16:9 for web and TV, 1:1 and 9:16 for social platforms. Every asset is optimised for the channel it will run on.\"}},{\"@type\":\"Question\",\"name\":\"Who owns the footage?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"You receive the usage rights agreed in your quote — clearly defined, no fine print. We keep your footage archived, so future cutdowns and new versions can be produced quickly without a new shoot.\"}},{\"@type\":\"Question\",\"name\":\"Can you work with our existing brand guidelines?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Absolutely. We work within your corporate identity — logo animation, typography, colour grading and tone of voice — so every film feels unmistakably yours. Just send the guidelines with your brief.\"}},{\"@type\":\"Question\",\"name\":\"Do you shoot outside Switzerland?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, we shoot across Europe regularly. Planning, crew and equipment logistics are handled by us end to end — you get the same process and the same quality, wherever the location.\"}}]},{\"@type\":\"BreadcrumbList\",\"@id\":\"https://www.viven.ch/faq/#breadcrumbs\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.viven.ch/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"FAQ\",\"item\":\"https://www.viven.ch/faq/\"}]}]}"}></script>
<!-- ============ PAGE HERO ============ -->
<section class="page-hero">
  <div class="wrap">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href={p("")} data-en="Home" data-de="Home" data-es="Inicio">Home</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span data-en="FAQ" data-de="FAQ" data-es="FAQ">FAQ</span>
    </nav>
    <span class="eyebrow" data-en="FAQ" data-de="FAQ" data-es="FAQ">FAQ</span>
    <h1 data-en='Questions, <span class="hl">answered.</span>'
        data-de='Fragen? <span class="hl">Beantwortet.</span>'
        data-es='Preguntas, <span class="hl">respondidas.</span>'>
      Questions, <span class="hl">answered.</span>
    </h1>
    <p class="lead"
       data-en="Everything you want to know before starting a video production — costs, timing, process and delivery. Straight answers, no jargon. Anything missing? Just ask."
       data-de="Alles, was Sie vor einer Videoproduktion wissen möchten — Kosten, Timing, Prozess und Lieferung. Klare Antworten, kein Fachjargon. Etwas fehlt? Fragen Sie uns."
       data-es="Todo lo que querés saber antes de empezar una producción de video: costos, tiempos, proceso y entrega. Respuestas claras, sin jerga. ¿Falta algo? Preguntanos.">
      Everything you want to know before starting a video production — costs, timing, process and delivery. Straight answers, no jargon. Anything missing? Just ask.
    </p>
  </div>
</section>

<!-- ============ FAQ ============ -->
<section class="sec" style="padding-top:20px">
  <div class="wrap">
    <div class="faq">

      <h2 class="faq-group-title" data-en="About Viven" data-de="Über Viven" data-es="Sobre Viven">About Viven</h2>

      <details class="reveal">
        <summary data-en="What kind of videos does Viven produce?" data-de="Welche Arten von Videos produziert Viven?" data-es="¿Qué tipo de videos produce Viven?">What kind of videos does Viven produce?</summary>
        <p data-en="Brand films, product videos, employer-branding campaigns, how-to and tutorial content, social media series and corporate communication. If it moves your business, we produce it — from a single hero film to a full always-on content pipeline."
           data-de="Markenfilme, Produktvideos, Employer-Branding-Kampagnen, How-To- und Tutorial-Content, Social-Media-Serien und Unternehmenskommunikation. Wenn es Ihr Geschäft voranbringt, produzieren wir es — vom einzelnen Hero-Film bis zur kompletten Always-on-Content-Pipeline."
           data-es="Films de marca, videos de producto, campañas de employer branding, tutoriales y contenido how-to, series para redes sociales y comunicación corporativa. Si mueve tu negocio, lo producimos — desde un solo film principal hasta una línea completa de contenido always-on.">Brand films, product videos, employer-branding campaigns, how-to and tutorial content, social media series and corporate communication. If it moves your business, we produce it — from a single hero film to a full always-on content pipeline.</p>
      </details>

      <details class="reveal">
        <summary data-en="Where is Viven based?" data-de="Wo ist Viven ansässig?" data-es="¿Dónde está Viven?">Where is Viven based?</summary>
        <p data-en="Our studio is at Zeughausstrasse 31, 8004 Zürich — in the heart of the city. From there we shoot across Switzerland and the rest of Europe, wherever your story takes place."
           data-de="Unser Studio liegt an der Zeughausstrasse 31, 8004 Zürich — mitten in der Stadt. Von dort aus drehen wir in der ganzen Schweiz und in ganz Europa, wo immer Ihre Geschichte spielt."
           data-es="Nuestro estudio está en Zeughausstrasse 31, 8004 Zúrich, en pleno centro de la ciudad. Desde ahí filmamos en toda Suiza y el resto de Europa, donde sea que ocurra tu historia.">Our studio is at Zeughausstrasse 31, 8004 Zürich — in the heart of the city. From there we shoot across Switzerland and the rest of Europe, wherever your story takes place.</p>
      </details>

      <details class="reveal">
        <summary data-en="Who has Viven worked with?" data-de="Mit wem hat Viven gearbeitet?" data-es="¿Con quién ha trabajado Viven?">Who has Viven worked with?</summary>
        <p data-en="187 brands across 32 industries — including UBS, Siemens, Porsche, ON, Chanel, FIFA and Philips. From global corporations to ambitious Swiss SMEs, the brief is always the same: video that moves the numbers."
           data-de="187 Marken in 32 Branchen — darunter UBS, Siemens, Porsche, ON, Chanel, FIFA und Philips. Vom Weltkonzern bis zum ambitionierten Schweizer KMU lautet der Auftrag immer gleich: Videos, die die Zahlen bewegen."
           data-es="187 marcas en 32 industrias — incluyendo UBS, Siemens, Porsche, ON, Chanel, FIFA y Philips. De corporaciones globales a pymes suizas ambiciosas, el encargo es siempre el mismo: video que mueve los números.">187 brands across 32 industries — including UBS, Siemens, Porsche, ON, Chanel, FIFA and Philips. From global corporations to ambitious Swiss SMEs, the brief is always the same: video that moves the numbers.</p>
      </details>

      <details class="reveal">
        <summary data-en="What makes Viven different?" data-de="Was macht Viven anders?" data-es="¿Qué hace diferente a Viven?">What makes Viven different?</summary>
        <p data-en="Feature-film craft with a business-first mindset. Founder Sebastian Cepeda was the first Swiss producer to bring an original feature film to Netflix — and we apply that discipline to every brief. We start with your goal, not with a camera."
           data-de="Spielfilm-Handwerk mit Business-first-Denken. Gründer Sebastian Cepeda war der erste Schweizer Produzent mit einem Original-Spielfilm auf Netflix — und diese Disziplin bringen wir in jedes Briefing. Wir starten mit Ihrem Ziel, nicht mit der Kamera."
           data-es="Oficio de largometraje con mentalidad de negocio. El fundador Sebastian Cepeda fue el primer productor suizo en llevar una película original a Netflix — y aplicamos esa disciplina a cada encargo. Empezamos con tu objetivo, no con una cámara.">Feature-film craft with a business-first mindset. Founder Sebastian Cepeda was the first Swiss producer to bring an original feature film to Netflix — and we apply that discipline to every brief. We start with your goal, not with a camera.</p>
      </details>

      <h2 class="faq-group-title" data-en="Process &amp; timing" data-de="Prozess &amp; Timing" data-es="Proceso y tiempos">Process &amp; timing</h2>

      <details class="reveal">
        <summary data-en="How long does a video production take?" data-de="Wie lange dauert eine Videoproduktion?" data-es="¿Cuánto tarda una producción de video?">How long does a video production take?</summary>
        <p data-en="You typically see a first draft about two weeks after the agreed start. Social media series can be turned around in days, while larger employer-branding campaigns usually run four to eight weeks. We agree on the timeline before we start — and we stick to it."
           data-de="Den ersten Entwurf sehen Sie in der Regel rund zwei Wochen nach dem vereinbarten Start. Social-Media-Serien liefern wir in Tagen, grössere Employer-Branding-Kampagnen dauern meist vier bis acht Wochen. Wir vereinbaren den Zeitplan vor dem Start — und halten ihn ein."
           data-es="Normalmente ves un primer borrador unas dos semanas después del inicio acordado. Las series para redes salen en días, mientras que las campañas grandes de employer branding suelen tomar de cuatro a ocho semanas. Acordamos el cronograma antes de empezar — y lo cumplimos.">You typically see a first draft about two weeks after the agreed start. Social media series can be turned around in days, while larger employer-branding campaigns usually run four to eight weeks. We agree on the timeline before we start — and we stick to it.</p>
      </details>

      <details class="reveal">
        <summary data-en="How does the process work?" data-de="Wie läuft der Prozess ab?" data-es="¿Cómo funciona el proceso?">How does the process work?</summary>
        <p data-en="Four stages: Creative development, Pre-production, Production and Post-production. You get one contact person, clear milestones and a fixed schedule from kickoff to delivery — no surprises along the way."
           data-de="Vier Phasen: Kreativentwicklung, Pre-Production, Produktion und Post-Production. Sie haben eine Ansprechperson, klare Meilensteine und einen fixen Zeitplan vom Kickoff bis zur Lieferung — ohne Überraschungen."
           data-es="Cuatro etapas: desarrollo creativo, preproducción, producción y postproducción. Tenés una sola persona de contacto, hitos claros y un calendario fijo del kickoff a la entrega — sin sorpresas en el camino.">Four stages: Creative development, Pre-production, Production and Post-production. You get one contact person, clear milestones and a fixed schedule from kickoff to delivery — no surprises along the way.</p>
      </details>

      <details class="reveal">
        <summary data-en="Does Viven handle the whole production?" data-de="Übernimmt Viven die gesamte Produktion?" data-es="¿Viven se encarga de toda la producción?">Does Viven handle the whole production?</summary>
        <p data-en="Yes. Concept, script, casting, shoot, edit, sound design and finishing are all run by one Viven team, with the right specialists brought in for your project. You brief us once and receive delivery-ready assets — we coordinate the whole crew, so you never have to."
           data-de="Ja. Konzept, Drehbuch, Casting, Dreh, Schnitt, Sound Design und Finishing entstehen komplett im Haus. Sie briefen uns einmal und erhalten lieferfertige Assets — ohne Jonglieren zwischen Agenturen, Freelancern und Postproduktionen."
           data-es="Sí. Concepto, guion, casting, rodaje, edición, diseño de sonido y acabado los lleva un mismo equipo de Viven, sumando los especialistas que cada proyecto necesita. Nos das el brief una vez y recibes material listo para publicar — coordinamos a todo el equipo por ti.">Yes. Concept, script, casting, shoot, edit, sound design and finishing are all run by one Viven team, with the right specialists brought in for your project. You brief us once and receive delivery-ready assets — we coordinate the whole crew, so you never have to.</p>
      </details>

      <details class="reveal">
        <summary data-en="How many revisions are included?" data-de="Wie viele Korrekturschleifen sind inbegriffen?" data-es="¿Cuántas revisiones están incluidas?">How many revisions are included?</summary>
        <p data-en="Every quote includes structured feedback rounds agreed upfront, so you always know where you stand. Clear checkpoints keep the project on schedule and on budget — with no surprise costs at the end."
           data-de="Jedes Angebot enthält vorab vereinbarte, strukturierte Feedback-Runden — Sie wissen also immer, woran Sie sind. Klare Checkpoints halten das Projekt im Zeit- und Kostenrahmen, ohne Überraschungen am Ende."
           data-es="Cada presupuesto incluye rondas de feedback estructuradas y acordadas de antemano, así siempre sabés dónde estás parado. Los checkpoints claros mantienen el proyecto en tiempo y presupuesto — sin costos sorpresa al final.">Every quote includes structured feedback rounds agreed upfront, so you always know where you stand. Clear checkpoints keep the project on schedule and on budget — with no surprise costs at the end.</p>
      </details>

      <h2 class="faq-group-title" data-en="Pricing" data-de="Preise" data-es="Precios">Pricing</h2>

      <details class="reveal">
        <summary data-en="How much does a video cost?" data-de="Was kostet ein Video?" data-es="¿Cuánto cuesta un video?">How much does a video cost?</summary>
        <p data-en="Most projects range from CHF 4,000 to 80,000 — length, complexity and the number of shoot days drive the price. Tell us what you&#39;re working on and you&#39;ll get a clear, no-obligation quote, usually within one business day."
           data-de="Die meisten Projekte liegen zwischen CHF 4'000 und 80'000 — Länge, Komplexität und die Anzahl der Drehtage bestimmen den Preis. Erzählen Sie uns von Ihrem Vorhaben und Sie erhalten ein klares, unverbindliches Angebot — in der Regel innerhalb eines Werktags."
           data-es="La mayoría de los proyectos van de CHF 4.000 a 80.000: la duración, la complejidad y los días de rodaje definen el precio. Contanos en qué estás trabajando y recibirás un presupuesto claro y sin compromiso, normalmente en un día hábil.">Most projects range from CHF 4,000 to 80,000 — length, complexity and the number of shoot days drive the price. Tell us what you're working on and you'll get a clear, no-obligation quote, usually within one business day.</p>
      </details>

      <details class="reveal">
        <summary data-en="Is video worth the investment?" data-de="Lohnt sich die Investition in Video?" data-es="¿Vale la pena invertir en video?">Is video worth the investment?</summary>
        <p data-en="Our clients think so. Siemens saw 3× more website visits after their brand film, and SV Group improved both recruiting and sales with a single video. A film is only worth making if it moves the numbers."
           data-de="Unsere Kunden sagen ja. Siemens verzeichnete 3× mehr Website-Besuche nach dem Markenfilm, und die SV Group verbesserte Recruiting und Sales mit einem einzigen Video. Ein Film lohnt sich nur, wenn er die Zahlen bewegt."
           data-es="Nuestros clientes creen que sí. Siemens logró 3× más visitas web después de su film de marca, y SV Group mejoró recruiting y ventas con un solo video. Un film solo vale la pena si mueve los números.">Our clients think so. Siemens saw 3× more website visits after their brand film, and SV Group improved both recruiting and sales with a single video. A film is only worth making if it moves the numbers.</p>
      </details>

      <details class="reveal">
        <summary data-en="Do you offer packages for ongoing content?" data-de="Bieten Sie Pakete für laufenden Content an?" data-es="¿Ofrecen paquetes para contenido continuo?">Do you offer packages for ongoing content?</summary>
        <p data-en="Yes. For always-on social media content we offer batch production and retainer models: we plan and shoot efficiently in blocks, and you receive a steady stream of platform-ready videos at a lower cost per asset."
           data-de="Ja. Für Always-on-Social-Media-Content bieten wir Batch-Produktion und Retainer-Modelle: Wir planen und drehen effizient in Blöcken, und Sie erhalten einen konstanten Strom plattformfertiger Videos zu tieferen Kosten pro Asset."
           data-es="Sí. Para contenido always-on en redes ofrecemos producción por lotes y modelos de retainer: planificamos y filmamos eficientemente en bloques, y recibís un flujo constante de videos listos para cada plataforma a menor costo por pieza.">Yes. For always-on social media content we offer batch production and retainer models: we plan and shoot efficiently in blocks, and you receive a steady stream of platform-ready videos at a lower cost per asset.</p>
      </details>

      <h2 class="faq-group-title" data-en="Delivery" data-de="Lieferung" data-es="Entrega">Delivery</h2>

      <details class="reveal">
        <summary data-en="In which languages do you deliver?" data-de="In welchen Sprachen liefern Sie?" data-es="¿En qué idiomas entregan?">In which languages do you deliver?</summary>
        <p data-en="English, German and Spanish — produced natively, not just translated. Subtitles and additional language versions are available for every film, so one production can serve all your markets."
           data-de="Englisch, Deutsch und Spanisch — nativ produziert, nicht bloss übersetzt. Untertitel und weitere Sprachversionen sind für jeden Film verfügbar, damit eine Produktion alle Ihre Märkte bedient."
           data-es="Inglés, alemán y español — producidos de forma nativa, no solo traducidos. Hay subtítulos y versiones en otros idiomas disponibles para cada film, así una sola producción sirve a todos tus mercados.">English, German and Spanish — produced natively, not just translated. Subtitles and additional language versions are available for every film, so one production can serve all your markets.</p>
      </details>

      <details class="reveal">
        <summary data-en="What formats do I get?" data-de="Welche Formate erhalte ich?" data-es="¿Qué formatos recibo?">What formats do I get?</summary>
        <p data-en="Delivery-ready masters plus the cutdowns you need: 16:9 for web and TV, 1:1 and 9:16 for social platforms. Every asset is optimised for the channel it will run on."
           data-de="Lieferfertige Master plus die Cutdowns, die Sie brauchen: 16:9 für Web und TV, 1:1 und 9:16 für Social-Plattformen. Jedes Asset ist für den Kanal optimiert, auf dem es laufen wird."
           data-es="Masters listos para publicar más los cortes que necesites: 16:9 para web y TV, 1:1 y 9:16 para redes sociales. Cada pieza está optimizada para el canal donde va a correr.">Delivery-ready masters plus the cutdowns you need: 16:9 for web and TV, 1:1 and 9:16 for social platforms. Every asset is optimised for the channel it will run on.</p>
      </details>

      <details class="reveal">
        <summary data-en="Who owns the footage?" data-de="Wem gehört das Filmmaterial?" data-es="¿Quién es dueño del material?">Who owns the footage?</summary>
        <p data-en="You receive the usage rights agreed in your quote — clearly defined, no fine print. We keep your footage archived, so future cutdowns and new versions can be produced quickly without a new shoot."
           data-de="Sie erhalten die im Angebot vereinbarten Nutzungsrechte — klar definiert, ohne Kleingedrucktes. Ihr Material bleibt bei uns archiviert, sodass künftige Cutdowns und neue Versionen schnell und ohne neuen Dreh entstehen können."
           data-es="Recibís los derechos de uso acordados en tu presupuesto — claramente definidos, sin letra chica. Mantenemos tu material archivado, así los futuros cortes y nuevas versiones se producen rápido, sin un nuevo rodaje.">You receive the usage rights agreed in your quote — clearly defined, no fine print. We keep your footage archived, so future cutdowns and new versions can be produced quickly without a new shoot.</p>
      </details>

      <details class="reveal">
        <summary data-en="Can you work with our existing brand guidelines?" data-de="Können Sie mit unseren bestehenden Brand Guidelines arbeiten?" data-es="¿Pueden trabajar con nuestras guías de marca existentes?">Can you work with our existing brand guidelines?</summary>
        <p data-en="Absolutely. We work within your corporate identity — logo animation, typography, colour grading and tone of voice — so every film feels unmistakably yours. Just send the guidelines with your brief."
           data-de="Selbstverständlich. Wir arbeiten innerhalb Ihrer Corporate Identity — Logo-Animation, Typografie, Farbkorrektur und Tonalität — damit jeder Film unverkennbar Ihre Handschrift trägt. Senden Sie die Guidelines einfach mit dem Briefing."
           data-es="Por supuesto. Trabajamos dentro de tu identidad corporativa — animación de logo, tipografía, corrección de color y tono de voz — para que cada film se sienta inconfundiblemente tuyo. Solo enviá las guías junto con tu brief.">Absolutely. We work within your corporate identity — logo animation, typography, colour grading and tone of voice — so every film feels unmistakably yours. Just send the guidelines with your brief.</p>
      </details>

      <details class="reveal">
        <summary data-en="Do you shoot outside Switzerland?" data-de="Drehen Sie auch ausserhalb der Schweiz?" data-es="¿Filman fuera de Suiza?">Do you shoot outside Switzerland?</summary>
        <p data-en="Yes, we shoot across Europe regularly. Planning, crew and equipment logistics are handled by us end to end — you get the same process and the same quality, wherever the location."
           data-de="Ja, wir drehen regelmässig in ganz Europa. Planung, Crew und Equipment-Logistik übernehmen wir komplett — Sie erhalten denselben Prozess und dieselbe Qualität, egal an welchem Ort."
           data-es="Sí, filmamos regularmente por toda Europa. Nos encargamos de la planificación, el equipo humano y la logística de punta a punta — obtenés el mismo proceso y la misma calidad, sin importar la locación.">Yes, we shoot across Europe regularly. Planning, crew and equipment logistics are handled by us end to end — you get the same process and the same quality, wherever the location.</p>
      </details>

    </div>
  </div>
</section>

<Testimonials lang={lang} />

<!-- ============ CTA / FORM ============ -->
<section class="cta" id="start" style="padding-top:0">
  <div class="wrap">
    <div class="cta-card reveal">
      <div>
