---
import Base from '../../../../layouts/Base.astro';
import CalcBanner from '../../../../components/CalcBanner.astro';
import Testimonials from '../../../../components/Testimonials.astro';
import VideoGallery from '../../../../components/VideoGallery.astro';
import { langPaths, localePath } from '../../../../i18n.js';
export const getStaticPaths = langPaths;
const { lang } = Astro.params;
const p = (s) => localePath(lang, s);
const title = {"en":"Social Media Video Production Zurich | Short-Form — Viven","de":"Social-Media-Videoproduktion Zürich | Short-Form — Viven","es":"Producción de video para redes sociales Zúrich — Viven"};
const description = {"en":"Social media video production in Zurich. Scroll-stopping short-form series in 9:16 with hooks in the first 2 seconds — batch-produced for always-on content.","de":"Social-Media-Videoproduktion in Zürich. Scroll-stoppende Short-Form-Serien in 9:16 mit Hooks in den ersten 2 Sekunden — als Batch produziert für Always-on-Content.","es":"Producción de video para redes sociales en Zúrich. Series short-form en 9:16 que frenan el scroll, con hooks en los primeros 2 segundos — producción en lote para contenido always-on."};
---
<Base lang={lang} slug="services/social-media-video" active="services" activeSub="social" title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={"{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"Service\",\"@id\":\"https://www.viven.ch/services/social-media-video/#service\",\"name\":\"Social Media Video Production\",\"serviceType\":\"Social media and short-form video production\",\"description\":\"Scroll-stopping short-form video series built for reach, engagement and conversion. Platform-native formats in 9:16, hooks in the first 2 seconds, batch production for always-on content. Produced in Zurich by Viven — trusted by UBS, Siemens, Porsche and ON.\",\"url\":\"https://www.viven.ch/services/social-media-video/\",\"provider\":{\"@id\":\"https://www.viven.ch/#organization\"},\"areaServed\":[\"CH\",\"Europe\"]},{\"@type\":\"BreadcrumbList\",\"@id\":\"https://www.viven.ch/services/social-media-video/#breadcrumbs\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.viven.ch/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Services\",\"item\":\"https://www.viven.ch/services/\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Social Media Videos\",\"item\":\"https://www.viven.ch/services/social-media-video/\"}]},{\"@type\":\"FAQPage\",\"@id\":\"https://www.viven.ch/services/social-media-video/#faq\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"How many videos can you produce from one shoot day?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"That is the point of batch production: we plan every shoot to produce a series, not a single video. Depending on format, locations and talent, one well-planned day can cover several weeks of publishing. We define the exact batch size with you before the shoot — so you know what you get.\"}},{\"@type\":\"Question\",\"name\":\"Which formats do you deliver?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Platform-native by default: 9:16 vertical for Reels, TikTok, Shorts and Stories, plus 1:1 and 16:9 masters where they make sense. Every video comes with captions, since most social video is watched on mute — and named, organized files ready to publish.\"}},{\"@type\":\"Question\",\"name\":\"Do the videos work for organic and paid?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Both — and we plan for it. Organic pieces are built to feel native and earn engagement; paid variants add clear CTAs and multiple hooks so you can test what converts. One production feeds both channels instead of two separate budgets.\"}},{\"@type\":\"Question\",\"name\":\"How fast is the turnaround?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"You see a first draft within about two weeks. Batches are delivered on a rolling schedule, so you can start publishing while the rest of the series is being finished. The full timeline is agreed before we start — and we stick to it.\"}}]}]}"}></script>
<!-- ============ PAGE HERO ============ -->
<section class="page-hero has-video">
  <div class="hero-bg" data-vimeo="848311486" data-mp4="/assets/heroes/848311486.mp4"><img class="reel" src="https://i.vimeocdn.com/video/1701928213-f2ea72ae6ed3928faf7753449709dd4118084e42f8e13168bd9e6fdabc939eaa-d_960?region=us" width="1600" height="900" alt="" fetchpriority="high" decoding="async" /><div class="grain"></div></div>
  <div class="hero-overlay"></div>
  <div class="wrap">
    <div class="crumbs">
      <a href={p("")} data-en="Home" data-de="Home" data-es="Inicio">Home</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href={p("services")} data-en="Services" data-de="Leistungen" data-es="Servicios">Services</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span data-en="Social Media Videos" data-de="Social-Media-Videos" data-es="Videos para redes sociales">Social Media Videos</span>
    </div>
    <span class="eyebrow" data-en="Social media video — Zurich, Switzerland" data-de="Social-Media-Video — Zürich, Schweiz" data-es="Video para redes sociales — Zúrich, Suiza">Social media video — Zurich, Switzerland</span>
    <h1 data-en='Social media videos that <span class="hl">stop the scroll.</span>'
        data-de='Social-Media-Videos, die <span class="hl">den Scroll stoppen.</span>'
        data-es='Videos para redes que <span class="hl">frenan el scroll.</span>'>
      Social media videos that <span class="hl">stop the scroll.</span>
    </h1>
    <p class="lead"
       data-en="Short-form video series built for reach, engagement and conversion. Platform-native 9:16, hooks in the first 2 seconds — batch-produced so your feed never goes quiet."
       data-de="Short-Form-Videoserien für Reichweite, Engagement und Conversion. Plattformgerecht in 9:16, mit Hooks in den ersten 2 Sekunden — als Batch produziert, damit Ihr Feed nie verstummt."
       data-es="Series de video corto para alcance, engagement y conversión. Nativas de cada plataforma en 9:16, con hooks en los primeros 2 segundos — producidas en lote para que tu feed nunca se apague.">
      Short-form video series built for reach, engagement and conversion. Platform-native 9:16, hooks in the first 2 seconds — batch-produced so your feed never goes quiet.
    </p>
    <div class="hero-cta">
      <a href={p("contact")} class="btn btn-primary" data-en="Start a project" data-de="Projekt starten" data-es="Iniciar proyecto">Start a project</a>
      <a href="#work" class="btn btn-ghost" data-en="See the films" data-de="Filme ansehen" data-es="Ver los films">See the films</a>
    </div>
  </div>
</section>

<!-- ============ WHAT YOU GET ============ -->
<section class="sec" id="value">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="What you get" data-de="Was Sie bekommen" data-es="Qué obtienes">What you get</span>
      <h2 data-en="Built for the feed. Not cut down for it."
          data-de="Für den Feed gemacht. Nicht dafür zurechtgeschnitten."
          data-es="Hecho para el feed. No recortado para el feed.">Built for the feed. Not cut down for it.</h2>
      <p data-en="A TV spot squeezed into a phone screen loses. We make video that's native to each platform from the first frame."
         data-de="Ein TV-Spot, in einen Handybildschirm gepresst, verliert. Wir machen Video, das vom ersten Frame an nativ für jede Plattform ist."
         data-es="Un spot de TV apretado en la pantalla de un teléfono pierde. Hacemos video nativo para cada plataforma desde el primer frame.">A TV spot squeezed into a phone screen loses. We make video that's native to each platform from the first frame.</p>
    </div>
    <div class="value-grid">
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
        <h3 data-en="Hooks in 2 seconds" data-de="Hooks in 2 Sekunden" data-es="Hooks en 2 segundos">Hooks in 2 seconds</h3>
        <p data-en="The scroll decides in the first 2 seconds. Every video opens with a hook that earns the next ten." data-de="Der Scroll entscheidet in den ersten 2 Sekunden. Jedes Video startet mit einem Hook, der die nächsten zehn verdient." data-es="El scroll se decide en los primeros 2 segundos. Cada video abre con un hook que se gana los próximos diez.">The scroll decides in the first 2 seconds. Every video opens with a hook that earns the next ten.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="7" y="2" width="10" height="20" rx="2"/><path d="M11 18h2"/></svg></div>
        <h3 data-en="Platform-native formats" data-de="Plattformgerechte Formate" data-es="Formatos nativos">Platform-native formats</h3>
        <p data-en="9:16 vertical for Reels, TikTok and Shorts — with captions on by default, because most viewers watch on mute." data-de="9:16 vertikal für Reels, TikTok und Shorts — mit Untertiteln als Standard, weil die meisten ohne Ton schauen." data-es="Vertical 9:16 para Reels, TikTok y Shorts — con subtítulos por defecto, porque la mayoría mira sin sonido.">9:16 vertical for Reels, TikTok and Shorts — with captions on by default, because most viewers watch on mute.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg></div>
        <h3 data-en="Batch production" data-de="Batch-Produktion" data-es="Producción en lote">Batch production</h3>
        <p data-en="Shoot once, publish for weeks. One planned production day feeds an always-on content calendar." data-de="Einmal drehen, wochenlang publizieren. Ein geplanter Drehtag füllt einen Always-on-Content-Kalender." data-es="Rueda una vez, publica durante semanas. Un día de producción bien planificado alimenta un calendario de contenido always-on.">Shoot once, publish for weeks. One planned production day feeds an always-on content calendar.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg></div>
        <h3 data-en="Built for outcomes" data-de="Auf Ergebnisse gebaut" data-es="Hecho para resultados">Built for outcomes</h3>
        <p data-en="Reach, engagement, conversion — organic and paid. We plan the series around the metric you need to move." data-de="Reichweite, Engagement, Conversion — organisch und Paid. Wir planen die Serie um die Kennzahl, die Sie bewegen müssen." data-es="Alcance, engagement, conversión — orgánico y paid. Planificamos la serie alrededor de la métrica que necesitas mover.">Reach, engagement, conversion — organic and paid. We plan the series around the metric you need to move.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============ WORK ============ -->
<section class="sec" id="work" style="padding-top:0">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="Selected work" data-de="Ausgewählte Arbeiten" data-es="Trabajos seleccionados">Selected work</span>
      <h2 data-en="Social films we've made." data-de="Social-Filme von uns." data-es="Films para redes que hicimos.">Social films we've made.</h2>
      <p data-en="Made to be watched, not skipped. Hit play." data-de="Gemacht, um gesehen zu werden — nicht übersprungen. Einfach auf Play drücken." data-es="Hechos para verse, no para saltarse. Dale play.">Made to be watched, not skipped. Hit play.</p>
    </div>
    <VideoGallery cat="social" lang={lang} limit={9} />
    <div style="text-align:center;margin-top:44px" class="reveal">
      <a href={p("projects")} class="btn btn-ghost" data-en="See all projects" data-de="Alle Projekte ansehen" data-es="Ver todos los proyectos">See all projects</a>
    </div>
  </div>
</section>

<!-- ============ STATS ============ -->
<section class="sec" style="padding-top:0">
  <div class="wrap">
    <div class="stats reveal">
      <div class="stat"><div class="num">2s</div><div class="lbl" data-en="To win or lose the scroll" data-de="Um den Scroll zu gewinnen oder zu verlieren" data-es="Para ganar o perder el scroll">To win or lose the scroll</div></div>
      <div class="stat"><div class="num">9:16</div><div class="lbl" data-en="Platform-native by default" data-de="Plattformgerecht als Standard" data-es="Nativo de plataforma por defecto">Platform-native by default</div></div>
      <div class="stat"><div class="num">187</div><div class="lbl" data-en="Brands trusted us" data-de="Marken vertrauen uns" data-es="Marcas confiaron en nosotros">Brands trusted us</div></div>
    </div>
  </div>
</section>

<!-- ============ FAQ ============ -->
<section class="sec" id="faq" style="padding-top:0">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="FAQ" data-de="FAQ" data-es="FAQ">FAQ</span>
      <h2 data-en="Social media video, answered." data-de="Social-Media-Video, beantwortet." data-es="Video para redes, respondido.">Social media video, answered.</h2>
    </div>
    <div class="faq reveal">
      <details>
        <summary data-en="How many videos can you produce from one shoot day?" data-de="Wie viele Videos entstehen an einem Drehtag?" data-es="¿Cuántos videos pueden producir en un día de rodaje?">How many videos can you produce from one shoot day?</summary>
        <p data-en="That's the point of batch production: we plan every shoot to produce a series, not a single video. Depending on format, locations and talent, one well-planned day can cover several weeks of publishing. We define the exact batch size with you before the shoot — so you know what you get."
           data-de="Genau dafür gibt es Batch-Produktion: Wir planen jeden Dreh für eine Serie, nicht für ein einzelnes Video. Je nach Format, Locations und Talent kann ein gut geplanter Tag mehrere Wochen Publishing abdecken. Die genaue Batch-Grösse definieren wir mit Ihnen vor dem Dreh — damit Sie wissen, was Sie bekommen."
           data-es="Ese es el punto de la producción en lote: planificamos cada rodaje para producir una serie, no un solo video. Según el formato, las locaciones y el talento, un día bien planificado puede cubrir varias semanas de publicación. Definimos el tamaño exacto del lote contigo antes del rodaje — para que sepas qué recibes.">That's the point of batch production: we plan every shoot to produce a series, not a single video. Depending on format, locations and talent, one well-planned day can cover several weeks of publishing. We define the exact batch size with you before the shoot — so you know what you get.</p>
      </details>
      <details>
        <summary data-en="Which formats do you deliver?" data-de="Welche Formate liefern Sie?" data-es="¿Qué formatos entregan?">Which formats do you deliver?</summary>
        <p data-en="Platform-native by default: 9:16 vertical for Reels, TikTok, Shorts and Stories, plus 1:1 and 16:9 masters where they make sense. Every video comes with captions, since most social video is watched on mute — and named, organized files ready to publish."
           data-de="Plattformgerecht als Standard: 9:16 vertikal für Reels, TikTok, Shorts und Stories, dazu 1:1- und 16:9-Master, wo sie sinnvoll sind. Jedes Video kommt mit Untertiteln — die meisten schauen Social Video ohne Ton — und mit benannten, sauber organisierten Dateien, bereit zum Publizieren."
           data-es="Nativo de cada plataforma por defecto: vertical 9:16 para Reels, TikTok, Shorts y Stories, más masters en 1:1 y 16:9 donde tengan sentido. Cada video incluye subtítulos — la mayoría mira video social sin sonido — y archivos nombrados y organizados, listos para publicar.">Platform-native by default: 9:16 vertical for Reels, TikTok, Shorts and Stories, plus 1:1 and 16:9 masters where they make sense. Every video comes with captions, since most social video is watched on mute — and named, organized files ready to publish.</p>
      </details>
      <details>
        <summary data-en="Do the videos work for organic and paid?" data-de="Funktionieren die Videos organisch und als Paid?" data-es="¿Los videos funcionan en orgánico y en paid?">Do the videos work for organic and paid?</summary>
        <p data-en="Both — and we plan for it. Organic pieces are built to feel native and earn engagement; paid variants add clear CTAs and multiple hooks so you can test what converts. One production feeds both channels instead of two separate budgets."
           data-de="Beides — und wir planen es von Anfang an ein. Organische Videos wirken nativ und verdienen sich Engagement; Paid-Varianten erhalten klare CTAs und mehrere Hooks, damit Sie testen können, was konvertiert. Eine Produktion speist beide Kanäle statt zwei getrennter Budgets."
           data-es="Ambos — y lo planificamos así. Las piezas orgánicas se construyen para sentirse nativas y ganar engagement; las variantes de paid añaden CTAs claros y varios hooks para que pruebes qué convierte. Una sola producción alimenta ambos canales en lugar de dos presupuestos separados.">Both — and we plan for it. Organic pieces are built to feel native and earn engagement; paid variants add clear CTAs and multiple hooks so you can test what converts. One production feeds both channels instead of two separate budgets.</p>
      </details>
      <details>
        <summary data-en="How fast is the turnaround?" data-de="Wie schnell ist die Lieferung?" data-es="¿Qué tan rápida es la entrega?">How fast is the turnaround?</summary>
        <p data-en="You see a first draft within about two weeks. Batches are delivered on a rolling schedule, so you can start publishing while the rest of the series is being finished. The full timeline is agreed before we start — and we stick to it."
           data-de="Den ersten Entwurf sehen Sie nach rund zwei Wochen. Batches liefern wir rollierend — Sie können also publizieren, während der Rest der Serie fertiggestellt wird. Den gesamten Zeitplan vereinbaren wir vor dem Start — und wir halten ihn ein."
           data-es="Ves un primer borrador en unas dos semanas. Los lotes se entregan de forma escalonada, así puedes empezar a publicar mientras el resto de la serie se termina. El cronograma completo se acuerda antes de empezar — y lo cumplimos.">You see a first draft within about two weeks. Batches are delivered on a rolling schedule, so you can start publishing while the rest of the series is being finished. The full timeline is agreed before we start — and we stick to it.</p>
      </details>
    </div>
  </div>
</section>


<Testimonials lang={lang} cat="social" />

<CalcBanner lang={lang} />

<!-- ============ CTA / FORM ============ -->
<section class="cta" id="start" style="padding-top:0">
  <div class="wrap">
    <div class="cta-card reveal">
      <div>
        <span class="eyebrow" data-en="Let's talk" data-de="Sprechen wir" data-es="Hablemos">Let's talk</span>
        <h2 data-en="Tell us what you're working on." data-de="Erzählen Sie uns von Ihrem Projekt." data-es="Contanos en qué estás trabajando.">Tell us what you're working on.</h2>
        <p class="lead" data-en="Tell us your goal — we'll come back with timing and a clear quote within 48 hours. Free, no obligation." data-de="Nennen Sie uns Ihr Ziel — wir melden uns innert 48 Stunden mit Timing und einem klaren Angebot. Kostenlos und unverbindlich." data-es="Contanos tu objetivo — volvemos en 48 horas con tiempos y un presupuesto claro. Gratis y sin compromiso.">Tell us your goal — we'll come back with timing and a clear quote within 48 hours. Free, no obligation.</p>
        <ul>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="First draft within two weeks" data-de="Erster Entwurf in zwei Wochen" data-es="Primer borrador en dos semanas">First draft within two weeks</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="One partner, brief to delivery" data-de="Ein Partner, vom Brief bis zur Auslieferung" data-es="Un partner, de principio a fin">One partner, brief to delivery</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="Multilingual delivery" data-de="Mehrsprachige Auslieferung" data-es="Entrega multilingüe">Multilingual delivery</span></li>
        </ul>
      </div>
      <div>
        <div class="lead-form-mount"></div>
        <p class="form-note" data-en="We'll reply within one business day. No spam, ever." data-de="Wir antworten innerhalb eines Werktags. Kein Spam." data-es="Respondemos en un día hábil. Nunca spam.">We'll reply within one business day. No spam, ever.</p>
        <p class="book-call-note"><span data-en="Prefer to talk it through?" data-de="Lieber direkt sprechen?" data-es="¿Preferís hablarlo directamente?">Prefer to talk it through?</span> <a class="book-call" href="/book/" target="_blank" rel="noopener" data-en="Book a free 15-min call →" data-de="Gratis 15-Min-Call buchen →" data-es="Reservá una llamada gratis de 15 min →">Book a free 15-min call →</a></p>
      </div>
    </div>
  </div>
</section>
</Base>
