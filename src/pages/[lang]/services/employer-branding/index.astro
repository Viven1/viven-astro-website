---
import Base from '../../../../layouts/Base.astro';
import Testimonials from '../../../../components/Testimonials.astro';
import VideoGallery from '../../../../components/VideoGallery.astro';
import { langPaths, localePath } from '../../../../i18n.js';
export const getStaticPaths = langPaths;
const { lang } = Astro.params;
const p = (s) => localePath(lang, s);
const title = {"en":"Employer Branding Videos Zurich | Recruiting Films — Viven","de":"Employer-Branding-Videos Zürich | Recruiting-Filme — Viven","es":"Videos de Employer Branding Zúrich | Recruiting — Viven"};
const description = {"en":"Employer branding video production in Zurich. Recruiting and culture films that attract the right talent and cut cost-per-hire — for UBS, Siemens and KPMG.","de":"Employer-Branding-Videoproduktion in Zürich. Recruiting- und Kulturfilme, die die richtigen Talente anziehen und die Cost-per-Hire senken — für UBS, Siemens und KPMG.","es":"Producción de videos de employer branding en Zúrich. Films de recruiting y cultura que atraen al talento correcto y reducen el coste por contratación — para UBS, Siemens y KPMG."};
---
<Base lang={lang} slug="services/employer-branding" active="services" activeSub="employer" title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={"{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"Service\",\"@id\":\"https://www.viven.ch/services/employer-branding/#service\",\"name\":\"Employer Branding Video Production\",\"serviceType\":\"Employer branding and recruiting video production\",\"description\":\"Recruiting and culture films that attract the right talent, cut cost-per-hire and show real company culture instead of stock footage. Produced in Zurich by Viven — trusted by UBS, Siemens, Porsche and ON.\",\"url\":\"https://www.viven.ch/services/employer-branding/\",\"provider\":{\"@id\":\"https://www.viven.ch/#organization\"},\"areaServed\":[\"CH\",\"Europe\"]},{\"@type\":\"BreadcrumbList\",\"@id\":\"https://www.viven.ch/services/employer-branding/#breadcrumbs\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.viven.ch/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Services\",\"item\":\"https://www.viven.ch/services/\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Employer Branding\",\"item\":\"https://www.viven.ch/services/employer-branding/\"}]},{\"@type\":\"FAQPage\",\"@id\":\"https://www.viven.ch/services/employer-branding/#faq\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What makes a good employer branding video?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Honesty. Real employees, real workplaces and a clear picture of who thrives at your company. A good film makes the right candidates think 'that could be me' — and lets the wrong ones self-select out before they apply. Generic promises and stock footage do the opposite.\"}},{\"@type\":\"Question\",\"name\":\"Where should we use an employer branding video?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Everywhere you meet candidates: LinkedIn, your career page, job ads, recruiting events and onboarding. We deliver one master film plus platform-ready cuts, so a single production works across every channel you hire on.\"}},{\"@type\":\"Question\",\"name\":\"How long does an employer branding video take to produce?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"You see a first draft within about two weeks of the shoot. We agree on the full timeline before we start — and we stick to it. One team owns it from concept to final cut, which keeps the schedule tight.\"}},{\"@type\":\"Question\",\"name\":\"Should we film our employees or hire actors?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Your employees. Authenticity is the whole point of employer branding, and candidates can spot actors instantly. Our directors are experienced at making non-actors feel comfortable on camera. Actors only make sense for specific staged scenes — and we will tell you when that is the case.\"}}]}]}"}></script>
<!-- ============ PAGE HERO ============ -->
<section class="page-hero has-video">
  <div class="hero-bg" data-vimeo="836933990" data-mp4="/assets/heroes/836933990.mp4"><img class="reel" src="https://i.vimeocdn.com/video/1685072465-9f35d8125bc547bb676bc396752d78b3dc06977b7d34a065ce2948607193a535-d_960?region=us" width="1600" height="900" alt="" fetchpriority="high" decoding="async" /><div class="grain"></div></div>
  <div class="hero-overlay"></div>
  <div class="wrap">
    <div class="crumbs">
      <a href={p("")} data-en="Home" data-de="Home" data-es="Inicio">Home</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href={p("services")} data-en="Services" data-de="Leistungen" data-es="Servicios">Services</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span data-en="Employer Branding" data-de="Employer Branding" data-es="Employer Branding">Employer Branding</span>
    </div>
    <span class="eyebrow" data-en="Employer branding — Zurich, Switzerland" data-de="Employer Branding — Zürich, Schweiz" data-es="Employer branding — Zúrich, Suiza">Employer branding — Zurich, Switzerland</span>
    <h1 data-en='Employer branding films that <span class="hl">attract the right talent.</span>'
        data-de='Employer-Branding-Filme, die <span class="hl">die richtigen Talente anziehen.</span>'
        data-es='Films de employer branding que <span class="hl">atraen al talento correcto.</span>'>
      Employer branding films that <span class="hl">attract the right talent.</span>
    </h1>
    <p class="lead"
       data-en="Recruiting and culture films that show who you really are — no stock footage, no empty phrases. The right people apply. Your cost-per-hire drops. Trusted by UBS, Siemens and KPMG."
       data-de="Recruiting- und Kulturfilme, die zeigen, wer Sie wirklich sind — ohne Stock-Material, ohne leere Phrasen. Die richtigen Menschen bewerben sich. Ihre Cost-per-Hire sinkt. Im Einsatz für UBS, Siemens und KPMG."
       data-es="Films de recruiting y cultura que muestran quién eres realmente — sin material de stock, sin frases vacías. Las personas correctas aplican. Tu coste por contratación baja. Con la confianza de UBS, Siemens y KPMG.">
      Recruiting and culture films that show who you really are — no stock footage, no empty phrases. The right people apply. Your cost-per-hire drops. Trusted by UBS, Siemens and KPMG.
    </p>
    <div class="hero-cta">
      <a href={p("contact")} class="btn btn-primary" data-en="Start a project" data-de="Projekt starten" data-es="Iniciar proyecto">Start a project</a>
      <a href="#work" class="btn btn-ghost" data-en="See the films" data-de="Filme ansehen" data-es="Ver los films">See the films</a>
    </div>
  </div>
</section>

<!-- ============ WHAT YOU GET ============ -->
<section class="sec" id="value">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="What you get" data-de="Was Sie bekommen" data-es="Qué obtienes">What you get</span>
      <h2 data-en="Recruiting is marketing. Treat it that way."
          data-de="Recruiting ist Marketing. Behandeln Sie es auch so."
          data-es="El reclutamiento es marketing. Trátalo como tal.">Recruiting is marketing. Treat it that way.</h2>
      <p data-en="Candidates research you like customers research a product. A strong employer branding film wins them over before the first interview."
         data-de="Kandidaten recherchieren Sie wie Kunden ein Produkt. Ein starker Employer-Branding-Film überzeugt sie vor dem ersten Gespräch."
         data-es="Los candidatos te investigan como los clientes investigan un producto. Un buen film de employer branding los convence antes de la primera entrevista.">Candidates research you like customers research a product. A strong employer branding film wins them over before the first interview.</p>
    </div>
    <div class="value-grid">
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/></svg></div>
        <h3 data-en="Attract the right talent" data-de="Die richtigen Talente anziehen" data-es="Atraer al talento correcto">Attract the right talent</h3>
        <p data-en="A film that shows who thrives at your company — so the right candidates apply and the wrong ones self-select out." data-de="Ein Film, der zeigt, wer in Ihrem Unternehmen aufblüht — damit sich die Richtigen bewerben und die Falschen selbst aussortieren." data-es="Un film que muestra quién prospera en tu empresa — para que apliquen los correctos y los demás se autodescarten.">A film that shows who thrives at your company — so the right candidates apply and the wrong ones self-select out.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg></div>
        <h3 data-en="Cut cost-per-hire" data-de="Cost-per-Hire senken" data-es="Reducir el coste por contratación">Cut cost-per-hire</h3>
        <p data-en="One production works on every job ad, all year. Better applicants per franc spent — measurable in your funnel." data-de="Eine Produktion wirkt in jeder Stellenanzeige, das ganze Jahr. Bessere Bewerbungen pro Franken — messbar in Ihrem Funnel." data-es="Una sola producción funciona en cada anuncio de empleo, todo el año. Mejores candidatos por cada franco — medible en tu funnel.">One production works on every job ad, all year. Better applicants per franc spent — measurable in your funnel.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
        <h3 data-en="Real culture, not stock" data-de="Echte Kultur statt Stock" data-es="Cultura real, no stock">Real culture, not stock</h3>
        <p data-en="Real employees, real workplaces, real moments. Candidates trust what they can verify on day one." data-de="Echte Mitarbeitende, echte Arbeitsplätze, echte Momente. Kandidaten vertrauen dem, was sie am ersten Tag wiedererkennen." data-es="Empleados reales, lugares reales, momentos reales. Los candidatos confían en lo que pueden verificar el primer día.">Real employees, real workplaces, real moments. Candidates trust what they can verify on day one.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.7c.6.5 1 1.3 1 2.1h6c0-.8.4-1.6 1-2.1A7 7 0 0 0 12 2z"/></svg></div>
        <h3 data-en="Everywhere you hire" data-de="Überall, wo Sie einstellen" data-es="Donde sea que contrates">Everywhere you hire</h3>
        <p data-en="One master film plus cuts for LinkedIn, your career page and job ads — a single shoot, working on every channel." data-de="Ein Masterfilm plus Schnittfassungen für LinkedIn, Karriereseite und Stellenanzeigen — ein Dreh, der auf jedem Kanal arbeitet." data-es="Un film principal más versiones para LinkedIn, tu página de empleo y anuncios — un solo rodaje que trabaja en cada canal.">One master film plus cuts for LinkedIn, your career page and job ads — a single shoot, working on every channel.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============ WORK ============ -->
<section class="sec" id="work" style="padding-top:0">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="Selected work" data-de="Ausgewählte Arbeiten" data-es="Trabajos seleccionados">Selected work</span>
      <h2 data-en="Employer branding films we've made." data-de="Employer-Branding-Filme von uns." data-es="Films de employer branding que hicimos.">Employer branding films we've made.</h2>
      <p data-en="Real culture on camera. Hit play." data-de="Echte Kultur vor der Kamera. Einfach auf Play drücken." data-es="Cultura real en cámara. Dale play.">Real culture on camera. Hit play.</p>
    </div>
    <VideoGallery cat="employer" lang={lang} limit={9} />
    <div style="text-align:center;margin-top:44px" class="reveal">
      <a href={p("projects")} class="btn btn-ghost" data-en="See all projects" data-de="Alle Projekte ansehen" data-es="Ver todos los proyectos">See all projects</a>
    </div>
  </div>
</section>

<!-- ============ STATS ============ -->
<section class="sec" style="padding-top:0">
  <div class="wrap">
    <div class="stats reveal">
      <div class="stat"><div class="num">187</div><div class="lbl" data-en="Brands trusted us" data-de="Marken vertrauen uns" data-es="Marcas confiaron en nosotros">Brands trusted us</div></div>
      <div class="stat"><div class="num">32</div><div class="lbl" data-en="Industries served" data-de="Branchen bedient" data-es="Industrias atendidas">Industries served</div></div>
      <div class="stat"><div class="num">2</div><div class="lbl" data-en="Weeks to your first draft" data-de="Wochen bis zum ersten Entwurf" data-es="Semanas hasta el primer borrador">Weeks to your first draft</div></div>
    </div>
  </div>
</section>

<!-- ============ FAQ ============ -->
<section class="sec" id="faq" style="padding-top:0">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="FAQ" data-de="FAQ" data-es="FAQ">FAQ</span>
      <h2 data-en="Employer branding video, answered." data-de="Employer-Branding-Video, beantwortet." data-es="Employer branding en video, respondido.">Employer branding video, answered.</h2>
    </div>
    <div class="faq reveal">
      <details>
        <summary data-en="What makes a good employer branding video?" data-de="Was macht ein gutes Employer-Branding-Video aus?" data-es="¿Qué hace bueno a un video de employer branding?">What makes a good employer branding video?</summary>
        <p data-en="Honesty. Real employees, real workplaces and a clear picture of who thrives at your company. A good film makes the right candidates think &ldquo;that could be me&rdquo; — and lets the wrong ones self-select out before they apply. Generic promises and stock footage do the opposite."
           data-de="Ehrlichkeit. Echte Mitarbeitende, echte Arbeitsplätze und ein klares Bild davon, wer in Ihrem Unternehmen aufblüht. Ein guter Film lässt die richtigen Kandidaten denken: &bdquo;Das könnte ich sein&ldquo; — und die falschen sortieren sich selbst aus, bevor sie sich bewerben. Generische Versprechen und Stock-Material bewirken das Gegenteil."
           data-es="Honestidad. Empleados reales, lugares de trabajo reales y una imagen clara de quién prospera en tu empresa. Un buen film hace que los candidatos correctos piensen &ldquo;ese podría ser yo&rdquo; — y que los demás se autodescarten antes de aplicar. Las promesas genéricas y el material de stock logran lo contrario.">Honesty. Real employees, real workplaces and a clear picture of who thrives at your company. A good film makes the right candidates think &ldquo;that could be me&rdquo; — and lets the wrong ones self-select out before they apply. Generic promises and stock footage do the opposite.</p>
      </details>
      <details>
        <summary data-en="Where should we use the video?" data-de="Wo sollten wir das Video einsetzen?" data-es="¿Dónde deberíamos usar el video?">Where should we use the video?</summary>
        <p data-en="Everywhere you meet candidates: LinkedIn, your career page, job ads, recruiting events and onboarding. We deliver one master film plus platform-ready cuts, so a single production works across every channel you hire on."
           data-de="Überall, wo Sie Kandidaten begegnen: auf LinkedIn, Ihrer Karriereseite, in Stellenanzeigen, an Recruiting-Events und im Onboarding. Wir liefern einen Masterfilm plus plattformgerechte Schnittfassungen — eine Produktion arbeitet auf jedem Kanal, über den Sie einstellen."
           data-es="Donde sea que encuentres candidatos: LinkedIn, tu página de empleo, anuncios de trabajo, eventos de reclutamiento y onboarding. Entregamos un film principal más versiones listas para cada plataforma — una sola producción trabaja en todos tus canales de contratación.">Everywhere you meet candidates: LinkedIn, your career page, job ads, recruiting events and onboarding. We deliver one master film plus platform-ready cuts, so a single production works across every channel you hire on.</p>
      </details>
      <details>
        <summary data-en="How long does production take?" data-de="Wie lange dauert die Produktion?" data-es="¿Cuánto tarda la producción?">How long does production take?</summary>
        <p data-en="You see a first draft within about two weeks of the shoot. We agree on the full timeline before we start — and we stick to it. One team owns it from concept to final cut, which keeps the schedule tight."
           data-de="Sie sehen den ersten Entwurf etwa zwei Wochen nach dem Dreh. Den gesamten Zeitplan vereinbaren wir vor dem Start — und wir halten ihn ein. Ein Team verantwortet alles, vom Konzept bis zum finalen Schnitt. Das hält den Zeitplan straff."
           data-es="Ves un primer borrador unas dos semanas después del rodaje. Acordamos el cronograma completo antes de empezar — y lo cumplimos. Un mismo equipo lo lleva del concepto al corte final, lo que mantiene los plazos ajustados.">You see a first draft within about two weeks of the shoot. We agree on the full timeline before we start — and we stick to it. One team owns it from concept to final cut, which keeps the schedule tight.</p>
      </details>
      <details>
        <summary data-en="Should we film our employees or hire actors?" data-de="Sollen wir Mitarbeitende filmen oder Schauspieler engagieren?" data-es="¿Filmamos a nuestros empleados o contratamos actores?">Should we film our employees or hire actors?</summary>
        <p data-en="Your employees. Authenticity is the whole point of employer branding, and candidates can spot actors instantly. Our directors are experienced at making non-actors feel comfortable on camera. Actors only make sense for specific staged scenes — and we'll tell you when that's the case."
           data-de="Ihre Mitarbeitenden. Authentizität ist der Kern von Employer Branding — und Kandidaten erkennen Schauspieler sofort. Unsere Regisseure haben viel Erfahrung darin, Laien vor der Kamera Sicherheit zu geben. Schauspieler sind nur für bestimmte inszenierte Szenen sinnvoll — und wir sagen Ihnen, wann das der Fall ist."
           data-es="Tus empleados. La autenticidad es la esencia del employer branding, y los candidatos detectan actores al instante. Nuestros directores tienen experiencia haciendo que personas sin experiencia se sientan cómodas frente a la cámara. Los actores solo tienen sentido para escenas puntuales — y te diremos cuándo es el caso.">Your employees. Authenticity is the whole point of employer branding, and candidates can spot actors instantly. Our directors are experienced at making non-actors feel comfortable on camera. Actors only make sense for specific staged scenes — and we'll tell you when that's the case.</p>
      </details>
    </div>
  </div>
</section>


<Testimonials lang={lang} cat="employer" />

<!-- ============ CTA / FORM ============ -->
<section class="cta" id="start" style="padding-top:0">
  <div class="wrap">
    <div class="cta-card reveal">
      <div>
        <span class="eyebrow" data-en="Let's talk" data-de="Sprechen wir" data-es="Hablemos">Let's talk</span>
        <h2 data-en="Tell us what you're working on." data-de="Erzählen Sie uns von Ihrem Projekt." data-es="Contanos en qué estás trabajando.">Tell us what you're working on.</h2>
        <p class="lead" data-en="Tell us your goal — we'll come back with three concept ideas, timing and a clear quote within 48 hours. Free, no obligation." data-de="Nennen Sie uns Ihr Ziel — wir melden uns innert 48 Stunden mit drei Konzeptideen, Timing und einem klaren Angebot. Kostenlos und unverbindlich." data-es="Contanos tu objetivo — volvemos en 48 horas con tres ideas de concepto, tiempos y un presupuesto claro. Gratis y sin compromiso.">Tell us your goal — we'll come back with three concept ideas, timing and a clear quote within 48 hours. Free, no obligation.</p>
        <ul>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="First draft within two weeks" data-de="Erster Entwurf in zwei Wochen" data-es="Primer borrador en dos semanas">First draft within two weeks</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="One partner, brief to delivery" data-de="Ein Partner, vom Brief bis zur Auslieferung" data-es="Un partner, de principio a fin">One partner, brief to delivery</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="Multilingual delivery" data-de="Mehrsprachige Auslieferung" data-es="Entrega multilingüe">Multilingual delivery</span></li>
        </ul>
      </div>
      <div>
        <div class="lead-form-mount"></div>
        <p class="form-note" data-en="We'll reply within one business day. No spam, ever." data-de="Wir antworten innerhalb eines Werktags. Kein Spam." data-es="Respondemos en un día hábil. Nunca spam.">We'll reply within one business day. No spam, ever.</p>
        <p class="book-call-note"><span data-en="Prefer to talk it through?" data-de="Lieber direkt sprechen?" data-es="¿Preferís hablarlo directamente?">Prefer to talk it through?</span> <a class="book-call" href="/book/" target="_blank" rel="noopener" data-en="Book a free 15-min call →" data-de="Gratis 15-Min-Call buchen →" data-es="Reservá una llamada gratis de 15 min →">Book a free 15-min call →</a></p>
      </div>
    </div>
  </div>
</section>
</Base>
