---
import Base from '../../../../layouts/Base.astro';
import Testimonials from '../../../../components/Testimonials.astro';
import VideoGallery from '../../../../components/VideoGallery.astro';
import { langPaths, localePath } from '../../../../i18n.js';
export const getStaticPaths = langPaths;
const { lang } = Astro.params;
const p = (s) => localePath(lang, s);
const title = {"en":"Brand Video Production Zurich — Campaign-Ready Films | Viven","de":"Markenfilm-Produktion Zürich — Kampagnenfähige Filme | Viven","es":"Producción de videos de marca en Zúrich | Viven"};
const description = {"en":"Brand films that build trust in seconds and perform across paid, social and web. Made in Zurich for Siemens, Porsche and FIFA — first draft in two weeks.","de":"Markenfilme, die in Sekunden Vertrauen schaffen und auf Paid, Social und Web performen. Aus Zürich für Siemens, Porsche und FIFA — erster Entwurf in zwei Wochen.","es":"Films de marca que generan confianza en segundos y funcionan en paid, social y web. Hechos en Zúrich para Siemens, Porsche y FIFA — primer borrador en dos semanas."};
---
<Base lang={lang} slug="services/brand-video" active="services" activeSub="brand" title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={"{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"Service\",\"@id\":\"https://www.viven.ch/services/brand-video/#service\",\"name\":\"Brand Video Production\",\"serviceType\":\"Brand video production\",\"url\":\"https://www.viven.ch/services/brand-video/\",\"provider\":{\"@id\":\"https://www.viven.ch/#organization\"},\"areaServed\":[\"CH\",\"Europe\"],\"description\":\"High-impact brand films that build trust in seconds and perform across paid media, social and web — concept, production and post end to end from Zurich. Produced for brands including Siemens, Porsche and FIFA.\"},{\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.viven.ch/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Services\",\"item\":\"https://www.viven.ch/services/\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Brand Videos\",\"item\":\"https://www.viven.ch/services/brand-video/\"}]},{\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"How much does a brand video cost?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"It depends on concept, cast, locations and shooting days — a single-location film costs less than a multi-day campaign shoot. Because we run everything end to end, you get a fixed, transparent quote before production starts. No surprises, no hidden extras.\"}},{\"@type\":\"Question\",\"name\":\"How long should a brand video be?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Most hero films land between 60 and 90 seconds — long enough to build emotion, short enough to hold attention. From the hero film we cut 6, 15 and 30-second versions so every channel gets the length it needs.\"}},{\"@type\":\"Question\",\"name\":\"How long does production take?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"We agree on the timeline before we start — and we stick to it. You see a first draft within two weeks of the shoot, and most brand films go from brief to delivery in a few weeks, not months.\"}},{\"@type\":\"Question\",\"name\":\"Do we get versions for every channel?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Every brand film ships with cutdowns and aspect ratios for paid, social and web — 16:9, 9:16 and 1:1 — plus subtitles in English, German and Spanish if you need them.\"}}]}]}"}></script>
<!-- ============ PAGE HERO ============ -->
<section class="page-hero has-video">
  <div class="hero-bg" data-vimeo="1036676730"><img class="reel" src="https://i.vimeocdn.com/video/1958442291-bb4f937055c9aca037fa835e3d08a50d56dbefeeaa2ac17a382f1c3a66954c63-d_960?region=us" width="1600" height="900" alt="" fetchpriority="high" decoding="async" /><div class="grain"></div></div>
  <div class="hero-overlay"></div>
  <div class="wrap">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href={p("")} data-en="Home" data-de="Home" data-es="Inicio">Home</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href={p("services")} data-en="Services" data-de="Leistungen" data-es="Servicios">Services</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span data-en="Brand Videos" data-de="Markenfilme" data-es="Videos de marca">Brand Videos</span>
    </nav>
    <span class="eyebrow" data-en="Brand video production" data-de="Markenfilm-Produktion" data-es="Producción de videos de marca">Brand video production</span>
    <h1 data-en='Brand films that <span class="hl">carry the campaign.</span>'
        data-de='Markenfilme, die <span class="hl">die Kampagne tragen.</span>'
        data-es='Films de marca que <span class="hl">sostienen la campaña.</span>'>
      Brand films that <span class="hl">carry the campaign.</span>
    </h1>
    <p class="lead"
       data-en="A great brand film builds trust in seconds and performs across paid, social and web. We've made them for Siemens, Porsche and FIFA — measured on results, not applause."
       data-de="Ein starker Markenfilm schafft in Sekunden Vertrauen und performt auf Paid, Social und Web. Wir haben sie für Siemens, Porsche und die FIFA produziert — gemessen an Ergebnissen, nicht an Applaus."
       data-es="Un gran film de marca genera confianza en segundos y funciona en paid, social y web. Los hemos hecho para Siemens, Porsche y la FIFA — medidos por resultados, no por aplausos.">
      A great brand film builds trust in seconds and performs across paid, social and web. We've made them for Siemens, Porsche and FIFA — measured on results, not applause.
    </p>
    <div class="hero-cta">
      <a href={p("contact")} class="btn btn-primary" data-en="Start a project" data-de="Projekt starten" data-es="Iniciar proyecto">Start a project</a>
      <a href="#work" class="btn btn-ghost" data-en="See brand films" data-de="Markenfilme ansehen" data-es="Ver films de marca">See brand films</a>
    </div>
  </div>
</section>

<!-- ============ WHAT YOU GET ============ -->
<section class="sec" id="what-you-get" style="padding-top:40px">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="What you get" data-de="Was Sie erhalten" data-es="Qué recibes">What you get</span>
      <h2 data-en="One film. Every channel. Clear results." data-de="Ein Film. Jeder Kanal. Klare Ergebnisse." data-es="Un film. Cada canal. Resultados claros.">One film. Every channel. Clear results.</h2>
      <p data-en="A brand film is an investment. Here's what it buys." data-de="Ein Markenfilm ist eine Investition. Das bekommen Sie dafür." data-es="Un film de marca es una inversión. Esto es lo que obtienes.">A brand film is an investment. Here's what it buys.</p>
    </div>
    <div class="value-grid">
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg></div>
        <h3 data-en="Campaign-ready hero film" data-de="Kampagnenfähiger Hero-Film" data-es="Film principal listo para campaña">Campaign-ready hero film</h3>
        <p data-en="One flagship film built around a single clear message — ready to lead your campaign on TV, web and paid media." data-de="Ein Flaggschiff-Film mit einer klaren Botschaft — bereit, Ihre Kampagne auf TV, Web und Paid Media anzuführen." data-es="Un film insignia construido alrededor de un mensaje claro — listo para liderar tu campaña en TV, web y paid media.">One flagship film built around a single clear message — ready to lead your campaign on TV, web and paid media.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg></div>
        <h3 data-en="Cutdowns for every channel" data-de="Cutdowns für jeden Kanal" data-es="Cutdowns para cada canal">Cutdowns for every channel</h3>
        <p data-en="6, 15 and 30-second versions in 16:9, 9:16 and 1:1 — one shoot, a full campaign toolkit." data-de="6-, 15- und 30-Sekunden-Versionen in 16:9, 9:16 und 1:1 — ein Dreh, ein komplettes Kampagnen-Toolkit." data-es="Versiones de 6, 15 y 30 segundos en 16:9, 9:16 y 1:1 — un rodaje, un kit de campaña completo.">6, 15 and 30-second versions in 16:9, 9:16 and 1:1 — one shoot, a full campaign toolkit.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2 15 8.5 22 9.3 17 14 18.5 21 12 17.5 5.5 21 7 14 2 9.3 9 8.5 12 2z"/></svg></div>
        <h3 data-en="Cinema-grade craft" data-de="Handwerk auf Kino-Niveau" data-es="Oficio de nivel cine">Cinema-grade craft</h3>
        <p data-en="Feature-film discipline on set and in post. Our founder was the first Swiss producer to bring an original feature film to Netflix." data-de="Spielfilm-Disziplin am Set und in der Post. Unser Gründer war der erste Schweizer Produzent, der einen Original-Spielfilm zu Netflix brachte." data-es="Disciplina de largometraje en el set y en la post. Nuestro fundador fue el primer productor suizo en llevar una película original a Netflix.">Feature-film discipline on set and in post. Our founder was the first Swiss producer to bring an original feature film to Netflix.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg></div>
        <h3 data-en="Measured on results" data-de="An Ergebnissen gemessen" data-es="Medido por resultados">Measured on results</h3>
        <p data-en="We plan for outcomes, not applause. A Viven brand film drove 3× more website visits for Siemens." data-de="Wir planen für Ergebnisse, nicht für Applaus. Ein Viven-Markenfilm brachte Siemens 3× mehr Website-Besuche." data-es="Planificamos para resultados, no para aplausos. Un film de marca de Viven logró 3× más visitas web para Siemens.">We plan for outcomes, not applause. A Viven brand film drove 3× more website visits for Siemens.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============ SELECTED WORK ============ -->
<section class="sec" id="work" style="padding-top:0">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="Selected work" data-de="Ausgewählte Arbeiten" data-es="Trabajos seleccionados">Selected work</span>
      <h2 data-en="Brand films we've made." data-de="Markenfilme aus unserer Produktion." data-es="Films de marca que hemos hecho.">Brand films we've made.</h2>
      <p data-en="A few recent brand films. Hit play." data-de="Ein paar aktuelle Markenfilme. Einfach auf Play drücken." data-es="Algunos films de marca recientes. Dale play.">A few recent brand films. Hit play.</p>
    </div>
    <VideoGallery cat="brand" lang={lang} limit={9} />
    <div style="text-align:center;margin-top:44px" class="reveal">
      <a href={p("projects")} class="btn btn-ghost" data-en="See all projects" data-de="Alle Projekte ansehen" data-es="Ver todos los proyectos">See all projects</a>
    </div>
  </div>
</section>

<!-- ============ STATS ============ -->
<section class="sec" style="padding-top:0;padding-bottom:0">
  <div class="wrap">
    <div class="stats reveal">
      <div class="stat"><div class="num">187</div><div class="lbl" data-en="Brands trusted us" data-de="Marken vertrauen uns" data-es="Marcas confiaron en nosotros">Brands trusted us</div></div>
      <div class="stat"><div class="num">3×</div><div class="lbl" data-en="More website visits for Siemens" data-de="Mehr Website-Besuche für Siemens" data-es="Más visitas web para Siemens">More website visits for Siemens</div></div>
      <div class="stat"><div class="num">47</div><div class="lbl" data-en="Five-star Google reviews" data-de="Fünf-Sterne-Google-Bewertungen" data-es="Reseñas de 5 estrellas en Google">Five-star Google reviews</div></div>
    </div>
  </div>
</section>

<!-- ============ FAQ ============ -->
<section class="sec" id="faq">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="FAQ" data-de="FAQ" data-es="FAQ">FAQ</span>
      <h2 data-en="Brand video questions, answered." data-de="Antworten auf Ihre Markenfilm-Fragen." data-es="Preguntas sobre videos de marca, respondidas.">Brand video questions, answered.</h2>
    </div>
    <div class="faq reveal">
      <details>
        <summary data-en="How much does a brand video cost?" data-de="Was kostet ein Markenfilm?" data-es="¿Cuánto cuesta un video de marca?">How much does a brand video cost?</summary>
        <p data-en="It depends on concept, cast, locations and shooting days — a single-location film costs less than a multi-day campaign shoot. Because we run everything end to end, you get a fixed, transparent quote before production starts. No surprises, no hidden extras."
           data-de="Das hängt von Konzept, Cast, Locations und Drehtagen ab — ein Film an einer Location kostet weniger als ein mehrtägiger Kampagnendreh. Da alles über einen Partner kommt, erhalten Sie vor Produktionsstart ein fixes, transparentes Angebot. Keine Überraschungen, keine versteckten Kosten."
           data-es="Depende del concepto, el casting, las locaciones y los días de rodaje — un film en una sola locación cuesta menos que un rodaje de campaña de varios días. Como lo hacemos nosotros de principio a fin, recibes un presupuesto fijo y transparente antes de empezar la producción. Sin sorpresas ni extras ocultos.">It depends on concept, cast, locations and shooting days — a single-location film costs less than a multi-day campaign shoot. Because we run everything end to end, you get a fixed, transparent quote before production starts. No surprises, no hidden extras.</p>
      </details>
      <details>
        <summary data-en="How long should a brand video be?" data-de="Wie lang sollte ein Markenfilm sein?" data-es="¿Cuánto debe durar un video de marca?">How long should a brand video be?</summary>
        <p data-en="Most hero films land between 60 and 90 seconds — long enough to build emotion, short enough to hold attention. From the hero film we cut 6, 15 and 30-second versions so every channel gets the length it needs."
           data-de="Die meisten Hero-Filme liegen zwischen 60 und 90 Sekunden — lang genug für Emotion, kurz genug für Aufmerksamkeit. Aus dem Hero-Film schneiden wir 6-, 15- und 30-Sekunden-Versionen, damit jeder Kanal die richtige Länge erhält."
           data-es="La mayoría de los films principales duran entre 60 y 90 segundos — suficiente para construir emoción y lo bastante corto para mantener la atención. Del film principal cortamos versiones de 6, 15 y 30 segundos para que cada canal tenga la duración que necesita.">Most hero films land between 60 and 90 seconds — long enough to build emotion, short enough to hold attention. From the hero film we cut 6, 15 and 30-second versions so every channel gets the length it needs.</p>
      </details>
      <details>
        <summary data-en="How long does production take?" data-de="Wie lange dauert die Produktion?" data-es="¿Cuánto tarda la producción?">How long does production take?</summary>
        <p data-en="We agree on the timeline before we start — and we stick to it. You see a first draft within two weeks of the shoot, and most brand films go from brief to delivery in a few weeks, not months."
           data-de="Wir vereinbaren den Zeitplan, bevor wir starten — und halten ihn ein. Den ersten Entwurf sehen Sie innerhalb von zwei Wochen nach dem Dreh, und die meisten Markenfilme gehen in wenigen Wochen vom Briefing zur Auslieferung, nicht in Monaten."
           data-es="Acordamos el cronograma antes de empezar — y lo cumplimos. Ves un primer borrador dentro de las dos semanas posteriores al rodaje, y la mayoría de los films de marca van del brief a la entrega en semanas, no meses.">We agree on the timeline before we start — and we stick to it. You see a first draft within two weeks of the shoot, and most brand films go from brief to delivery in a few weeks, not months.</p>
      </details>
      <details>
        <summary data-en="Do we get versions for every channel?" data-de="Erhalten wir Versionen für jeden Kanal?" data-es="¿Recibimos versiones para cada canal?">Do we get versions for every channel?</summary>
        <p data-en="Yes. Every brand film ships with cutdowns and aspect ratios for paid, social and web — 16:9, 9:16 and 1:1 — plus subtitles in English, German and Spanish if you need them."
           data-de="Ja. Jeder Markenfilm wird mit Cutdowns und Formaten für Paid, Social und Web geliefert — 16:9, 9:16 und 1:1 — plus Untertitel auf Deutsch, Englisch und Spanisch, wenn Sie sie brauchen."
           data-es="Sí. Cada film de marca se entrega con cutdowns y formatos para paid, social y web — 16:9, 9:16 y 1:1 — además de subtítulos en inglés, alemán y español si los necesitas.">Yes. Every brand film ships with cutdowns and aspect ratios for paid, social and web — 16:9, 9:16 and 1:1 — plus subtitles in English, German and Spanish if you need them.</p>
      </details>
    </div>
  </div>
</section>

<Testimonials lang={lang} cat="brand" />

<!-- ============ CTA / FORM ============ -->
<section class="cta" id="start" style="padding-top:0">
  <div class="wrap">
    <div class="cta-card reveal">
      <div>
        <span class="eyebrow" data-en="Let's talk" data-de="Sprechen wir" data-es="Hablemos">Let's talk</span>
        <h2 data-en="Tell us what you're working on." data-de="Erzählen Sie uns von Ihrem Projekt." data-es="Contanos en qué estás trabajando.">Tell us what you're working on.</h2>
        <p class="lead" data-en="Tell us your goal — we'll come back with three concept ideas, timing and a clear quote within 48 hours. Free, no obligation." data-de="Nennen Sie uns Ihr Ziel — wir melden uns innert 48 Stunden mit drei Konzeptideen, Timing und einem klaren Angebot. Kostenlos und unverbindlich." data-es="Contanos tu objetivo — volvemos en 48 horas con tres ideas de concepto, tiempos y un presupuesto claro. Gratis y sin compromiso.">Tell us your goal — we'll come back with three concept ideas, timing and a clear quote within 48 hours. Free, no obligation.</p>
        <ul>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="First draft within two weeks" data-de="Erster Entwurf in zwei Wochen" data-es="Primer borrador en dos semanas">First draft within two weeks</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="One partner, brief to delivery" data-de="Ein Partner, vom Brief bis zur Auslieferung" data-es="Un partner, de principio a fin">One partner, brief to delivery</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="Multilingual delivery" data-de="Mehrsprachige Auslieferung" data-es="Entrega multilingüe">Multilingual delivery</span></li>
        </ul>
      </div>
      <div>
        <div class="lead-form-mount"></div>
        <p class="form-note" data-en="We'll reply within one business day. No spam, ever." data-de="Wir antworten innerhalb eines Werktags. Kein Spam." data-es="Respondemos en un día hábil. Nunca spam.">We'll reply within one business day. No spam, ever.</p>
        <p class="book-call-note"><span data-en="Prefer to talk it through?" data-de="Lieber direkt sprechen?" data-es="¿Preferís hablarlo directamente?">Prefer to talk it through?</span> <a class="book-call" href="https://meetings.hubspot.com/sofia-trevino?uuid=76bf013f-3825-4341-8a95-fee769f70c49" target="_blank" rel="noopener" data-en="Book a free 15-min call →" data-de="Gratis 15-Min-Call buchen →" data-es="Reservá una llamada gratis de 15 min →">Book a free 15-min call →</a></p>
      </div>
    </div>
  </div>
</section>
</Base>
