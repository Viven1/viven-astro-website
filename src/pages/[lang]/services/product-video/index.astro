---
import Base from '../../../../layouts/Base.astro';
import Testimonials from '../../../../components/Testimonials.astro';
import VideoGallery from '../../../../components/VideoGallery.astro';
import { langPaths, localePath } from '../../../../i18n.js';
export const getStaticPaths = langPaths;
const { lang } = Astro.params;
const p = (s) => localePath(lang, s);
const title = {"en":"Product Video Production Zurich — Launch & E-Com Films | Viven","de":"Produktvideo-Produktion Zürich — Launch- & E-Com-Filme | Viven","es":"Producción de videos de producto en Zúrich | Viven"};
const description = {"en":"Product films and launch videos that turn features into desire and clicks into buyers. Produced in Zurich for ON, V-Zug and Franke — one accountable team, end to end.","de":"Produktfilme und Launch-Videos, die Features in Begehren verwandeln und Klicks in Käufer. Produziert in Zürich für ON, V-Zug und Franke — alles über einen Partner.","es":"Films de producto y videos de lanzamiento que convierten características en deseo y clics en compradores. Producidos en Zúrich para ON, V-Zug y Franke."};
---
<Base lang={lang} slug="services/product-video" active="services" activeSub="product" title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={"{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"Service\",\"@id\":\"https://www.viven.ch/services/product-video/#service\",\"name\":\"Product Video Production\",\"serviceType\":\"Product video production\",\"url\":\"https://www.viven.ch/services/product-video/\",\"provider\":{\"@id\":\"https://www.viven.ch/#organization\"},\"areaServed\":[\"CH\",\"Europe\"],\"description\":\"Product films and launch videos that turn features into desire and clicks into buyers — studio and location production, end to end from Zurich. Produced for brands including ON, V-Zug and Franke.\"},{\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.viven.ch/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Services\",\"item\":\"https://www.viven.ch/services/\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Product Videos\",\"item\":\"https://www.viven.ch/services/product-video/\"}]},{\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What drives the cost of a product video?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The number of products and variants, studio versus location, motion design and the formats you need. Because we run production and post end to end, we scope precisely and quote a fixed price before we shoot.\"}},{\"@type\":\"Question\",\"name\":\"Which formats do I get for e-commerce?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"A hero film for your product page, plus 9:16 and 1:1 cutdowns for social ads, short loops for listings and stills pulled from the shoot. Every deliverable is exported to the specs of your platforms.\"}},{\"@type\":\"Question\",\"name\":\"Studio or on location — which is better?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Studio gives you total control over light and detail — ideal for tabletop and macro work. Location adds context and emotion — the product in real life. Many launches combine both; we plan and produce either, end to end.\"}},{\"@type\":\"Question\",\"name\":\"Can you hit our launch date?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes — the timeline is agreed before we start and built backwards from your launch. You see a first draft within two weeks of the shoot, with fixed review rounds so delivery never slips.\"}}]}]}"}></script>
<!-- ============ PAGE HERO ============ -->
<section class="page-hero has-video">
  <div class="hero-bg" data-vimeo="1036770815"><img class="reel" src="https://i.vimeocdn.com/video/1958555996-86d40228a251525ada5424e9f42bbcf061e63e78d1671a0a07173a610ea9b332-d_960?region=us" width="1600" height="900" alt="" fetchpriority="high" decoding="async" /><div class="grain"></div></div>
  <div class="hero-overlay"></div>
  <div class="wrap">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href={p("")} data-en="Home" data-de="Home" data-es="Inicio">Home</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href={p("services")} data-en="Services" data-de="Leistungen" data-es="Servicios">Services</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span data-en="Product Videos" data-de="Produktvideos" data-es="Videos de producto">Product Videos</span>
    </nav>
    <span class="eyebrow" data-en="Product video production" data-de="Produktvideo-Produktion" data-es="Producción de videos de producto">Product video production</span>
    <h1 data-en='Product films that turn features <span class="hl">into desire.</span>'
        data-de='Produktfilme, die Features <span class="hl">in Begehren verwandeln.</span>'
        data-es='Films de producto que convierten características <span class="hl">en deseo.</span>'>
      Product films that turn features <span class="hl">into desire.</span>
    </h1>
    <p class="lead"
       data-en="Product films and launch videos that make people want what you make — and click buy. Built for e-commerce, launches and retail, produced end to end from Zurich."
       data-de="Produktfilme und Launch-Videos, die Lust auf Ihr Produkt machen — und zum Kauf führen. Gebaut für E-Commerce, Launches und Retail, komplett aus Zürich, end to end produziert."
       data-es="Films de producto y videos de lanzamiento que hacen que la gente quiera lo que haces — y haga clic en comprar. Hechos para e-commerce, lanzamientos y retail, producidos de principio a fin en Zúrich.">
      Product films and launch videos that make people want what you make — and click buy. Built for e-commerce, launches and retail, produced end to end from Zurich.
    </p>
    <div class="hero-cta">
      <a href={p("contact")} class="btn btn-primary" data-en="Start a project" data-de="Projekt starten" data-es="Iniciar proyecto">Start a project</a>
      <a href="#work" class="btn btn-ghost" data-en="See product films" data-de="Produktfilme ansehen" data-es="Ver films de producto">See product films</a>
    </div>
  </div>
</section>

<!-- ============ WHAT YOU GET ============ -->
<section class="sec" id="what-you-get" style="padding-top:40px">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="What you get" data-de="Was Sie erhalten" data-es="Qué recibes">What you get</span>
      <h2 data-en="Films that make people click buy." data-de="Filme, die zum Kauf führen." data-es="Films que llevan al clic de compra.">Films that make people click buy.</h2>
      <p data-en="From unboxing to launch day — everything your product needs to sell." data-de="Vom Unboxing bis zum Launch-Tag — alles, was Ihr Produkt zum Verkaufen braucht." data-es="Del unboxing al día de lanzamiento — todo lo que tu producto necesita para vender.">From unboxing to launch day — everything your product needs to sell.</p>
    </div>
    <div class="value-grid">
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg></div>
        <h3 data-en="Launch-ready product film" data-de="Launch-fertiger Produktfilm" data-es="Film de producto listo para lanzar">Launch-ready product film</h3>
        <p data-en="A hero film that makes your product the star — timed and built for launch day." data-de="Ein Hero-Film, der Ihr Produkt zum Star macht — geplant und gebaut für den Launch-Tag." data-es="Un film principal que convierte tu producto en la estrella — pensado y producido para el día del lanzamiento.">A hero film that makes your product the star — timed and built for launch day.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg></div>
        <h3 data-en="E-commerce formats" data-de="E-Commerce-Formate" data-es="Formatos para e-commerce">E-commerce formats</h3>
        <p data-en="Cutdowns, loops and aspect ratios for product pages, social ads and marketplaces — built to convert clicks into buyers." data-de="Cutdowns, Loops und Formate für Produktseiten, Social Ads und Marktplätze — gebaut, um Klicks in Käufer zu verwandeln." data-es="Cutdowns, loops y formatos para páginas de producto, social ads y marketplaces — hechos para convertir clics en compradores.">Cutdowns, loops and aspect ratios for product pages, social ads and marketplaces — built to convert clicks into buyers.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg></div>
        <h3 data-en="Studio &amp; location, end to end" data-de="Studio &amp; Location, end to end" data-es="Estudio y locación, de principio a fin">Studio &amp; location, end to end</h3>
        <p data-en="From controlled tabletop precision to real-world context — we plan, shoot and finish one accountable team, end to end." data-de="Von kontrollierter Tabletop-Präzision bis zum echten Einsatzkontext — wir planen, drehen und finalisieren alles end to end." data-es="De la precisión tabletop controlada al contexto real — planificamos, rodamos y finalizamos todo de principio a fin.">From controlled tabletop precision to real-world context — we plan, shoot and finish one accountable team, end to end.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg></div>
        <h3 data-en="Features turned into desire" data-de="Features werden zu Begehren" data-es="Características convertidas en deseo">Features turned into desire</h3>
        <p data-en="We translate specs into a story people feel — what it does, why it matters, why now." data-de="Wir übersetzen Specs in eine Geschichte, die man fühlt — was es kann, warum es zählt, warum jetzt." data-es="Traducimos specs en una historia que se siente — qué hace, por qué importa, por qué ahora.">We translate specs into a story people feel — what it does, why it matters, why now.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============ SELECTED WORK ============ -->
<section class="sec" id="work" style="padding-top:0">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="Selected work" data-de="Ausgewählte Arbeiten" data-es="Trabajos seleccionados">Selected work</span>
      <h2 data-en="Product films we've made." data-de="Produktfilme aus unserer Produktion." data-es="Films de producto que hemos hecho.">Product films we've made.</h2>
      <p data-en="A few recent product films. Hit play." data-de="Ein paar aktuelle Produktfilme. Einfach auf Play drücken." data-es="Algunos films de producto recientes. Dale play.">A few recent product films. Hit play.</p>
    </div>
    <VideoGallery cat="product" lang={lang} limit={9} />
    <div style="text-align:center;margin-top:44px" class="reveal">
      <a href={p("projects")} class="btn btn-ghost" data-en="See all projects" data-de="Alle Projekte ansehen" data-es="Ver todos los proyectos">See all projects</a>
    </div>
  </div>
</section>

<!-- ============ STATS ============ -->
<section class="sec" style="padding-top:0;padding-bottom:0">
  <div class="wrap">
    <div class="stats reveal">
      <div class="stat"><div class="num">187</div><div class="lbl" data-en="Brands trusted us" data-de="Marken vertrauen uns" data-es="Marcas confiaron en nosotros">Brands trusted us</div></div>
      <div class="stat"><div class="num">3×</div><div class="lbl" data-en="More website visits for Siemens" data-de="Mehr Website-Besuche für Siemens" data-es="Más visitas web para Siemens">More website visits for Siemens</div></div>
      <div class="stat"><div class="num">47</div><div class="lbl" data-en="Five-star Google reviews" data-de="Fünf-Sterne-Google-Bewertungen" data-es="Reseñas de 5 estrellas en Google">Five-star Google reviews</div></div>
    </div>
  </div>
</section>

<!-- ============ FAQ ============ -->
<section class="sec" id="faq">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="FAQ" data-de="FAQ" data-es="FAQ">FAQ</span>
      <h2 data-en="Product video questions, answered." data-de="Antworten auf Ihre Produktvideo-Fragen." data-es="Preguntas sobre videos de producto, respondidas.">Product video questions, answered.</h2>
    </div>
    <div class="faq reveal">
      <details>
        <summary data-en="What drives the cost of a product video?" data-de="Was bestimmt die Kosten eines Produktvideos?" data-es="¿Qué determina el costo de un video de producto?">What drives the cost of a product video?</summary>
        <p data-en="The number of products and variants, studio versus location, motion design and the formats you need. Because we run production and post end to end, we scope precisely and quote a fixed price before we shoot."
           data-de="Die Anzahl der Produkte und Varianten, Studio oder Location, Motion Design und die benötigten Formate. Da Produktion und Post bei uns liegen, kalkulieren wir präzise und nennen einen Fixpreis vor dem Dreh."
           data-es="La cantidad de productos y variantes, estudio o locación, motion design y los formatos que necesitas. Como la la producción y la post las hacemos nosotros, calculamos con precisión y damos un precio fijo antes de rodar.">The number of products and variants, studio versus location, motion design and the formats you need. Because we run production and post end to end, we scope precisely and quote a fixed price before we shoot.</p>
      </details>
      <details>
        <summary data-en="Which formats do I get for e-commerce?" data-de="Welche Formate erhalte ich für E-Commerce?" data-es="¿Qué formatos recibo para e-commerce?">Which formats do I get for e-commerce?</summary>
        <p data-en="A hero film for your product page, plus 9:16 and 1:1 cutdowns for social ads, short loops for listings and stills pulled from the shoot. Every deliverable is exported to the specs of your platforms."
           data-de="Einen Hero-Film für Ihre Produktseite, dazu 9:16- und 1:1-Cutdowns für Social Ads, kurze Loops für Listings und Stills aus dem Dreh. Jedes Deliverable wird nach den Spezifikationen Ihrer Plattformen exportiert."
           data-es="Un film principal para tu página de producto, cutdowns 9:16 y 1:1 para social ads, loops cortos para listings y fotos extraídas del rodaje. Cada entregable se exporta según las especificaciones de tus plataformas.">A hero film for your product page, plus 9:16 and 1:1 cutdowns for social ads, short loops for listings and stills pulled from the shoot. Every deliverable is exported to the specs of your platforms.</p>
      </details>
      <details>
        <summary data-en="Studio or on location — which is better?" data-de="Studio oder Location — was ist besser?" data-es="¿Estudio o locación — qué es mejor?">Studio or on location — which is better?</summary>
        <p data-en="Studio gives you total control over light and detail — ideal for tabletop and macro work. Location adds context and emotion — the product in real life. Many launches combine both; we plan and produce either, end to end."
           data-de="Das Studio bietet volle Kontrolle über Licht und Detail — ideal für Tabletop- und Makroaufnahmen. Die Location liefert Kontext und Emotion — das Produkt im echten Leben. Viele Launches kombinieren beides; wir planen und produzieren beides end to end."
           data-es="El estudio da control total sobre la luz y el detalle — ideal para tomas tabletop y macro. La locación aporta contexto y emoción — el producto en la vida real. Muchos lanzamientos combinan ambos; planificamos y producimos los dos de principio a fin.">Studio gives you total control over light and detail — ideal for tabletop and macro work. Location adds context and emotion — the product in real life. Many launches combine both; we plan and produce either, end to end.</p>
      </details>
      <details>
        <summary data-en="Can you hit our launch date?" data-de="Schaffen Sie unseren Launch-Termin?" data-es="¿Pueden cumplir nuestra fecha de lanzamiento?">Can you hit our launch date?</summary>
        <p data-en="Yes — the timeline is agreed before we start and built backwards from your launch. You see a first draft within two weeks of the shoot, with fixed review rounds so delivery never slips."
           data-de="Ja — der Zeitplan wird vor dem Start vereinbart und rückwärts von Ihrem Launch geplant. Den ersten Entwurf sehen Sie innerhalb von zwei Wochen nach dem Dreh, mit fixen Feedback-Runden, damit die Auslieferung nie verrutscht."
           data-es="Sí — el cronograma se acuerda antes de empezar y se planifica hacia atrás desde tu lanzamiento. Ves un primer borrador dentro de las dos semanas posteriores al rodaje, con rondas de revisión fijas para que la entrega nunca se atrase.">Yes — the timeline is agreed before we start and built backwards from your launch. You see a first draft within two weeks of the shoot, with fixed review rounds so delivery never slips.</p>
      </details>
    </div>
  </div>
</section>


<Testimonials lang={lang} cat="product" />

<!-- ============ CTA / FORM ============ -->
<section class="cta" id="start" style="padding-top:0">
  <div class="wrap">
    <div class="cta-card reveal">
      <div>
        <span class="eyebrow" data-en="Let's talk" data-de="Sprechen wir" data-es="Hablemos">Let's talk</span>
        <h2 data-en="Tell us what you're working on." data-de="Erzählen Sie uns von Ihrem Projekt." data-es="Contanos en qué estás trabajando.">Tell us what you're working on.</h2>
        <p class="lead" data-en="Tell us your goal — we'll come back with three concept ideas, timing and a clear quote within 48 hours. Free, no obligation." data-de="Nennen Sie uns Ihr Ziel — wir melden uns innert 48 Stunden mit drei Konzeptideen, Timing und einem klaren Angebot. Kostenlos und unverbindlich." data-es="Contanos tu objetivo — volvemos en 48 horas con tres ideas de concepto, tiempos y un presupuesto claro. Gratis y sin compromiso.">Tell us your goal — we'll come back with three concept ideas, timing and a clear quote within 48 hours. Free, no obligation.</p>
        <ul>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="First draft within two weeks" data-de="Erster Entwurf in zwei Wochen" data-es="Primer borrador en dos semanas">First draft within two weeks</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="One partner, brief to delivery" data-de="Ein Partner, vom Brief bis zur Auslieferung" data-es="Un partner, de principio a fin">One partner, brief to delivery</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="Multilingual delivery" data-de="Mehrsprachige Auslieferung" data-es="Entrega multilingüe">Multilingual delivery</span></li>
        </ul>
      </div>
      <div>
        <div class="lead-form-mount"></div>
        <p class="form-note" data-en="We'll reply within one business day. No spam, ever." data-de="Wir antworten innerhalb eines Werktags. Kein Spam." data-es="Respondemos en un día hábil. Nunca spam.">We'll reply within one business day. No spam, ever.</p>
        <p class="book-call-note"><span data-en="Prefer to talk it through?" data-de="Lieber direkt sprechen?" data-es="¿Preferís hablarlo directamente?">Prefer to talk it through?</span> <a class="book-call" href="/book/" target="_blank" rel="noopener" data-en="Book a free 15-min call →" data-de="Gratis 15-Min-Call buchen →" data-es="Reservá una llamada gratis de 15 min →">Book a free 15-min call →</a></p>
      </div>
    </div>
  </div>
</section>
</Base>
