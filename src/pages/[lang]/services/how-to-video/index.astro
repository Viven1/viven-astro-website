---
import Base from '../../../../layouts/Base.astro';
import Testimonials from '../../../../components/Testimonials.astro';
import VideoGallery from '../../../../components/VideoGallery.astro';
import { langPaths, localePath } from '../../../../i18n.js';
export const getStaticPaths = langPaths;
const { lang } = Astro.params;
const p = (s) => localePath(lang, s);
const title = {"en":"How-To Video Production Zurich | Tutorials & Explainers — Viven","de":"How-To-Videoproduktion Zürich | Tutorials & Erklärfilme — Viven","es":"Producción de videos how-to Zúrich | Tutoriales — Viven"};
const description = {"en":"How-to and tutorial video production in Zurich. Explainer films that cut support tickets, speed up onboarding and make complex products simple in 60 seconds.","de":"How-To- und Tutorial-Videoproduktion in Zürich. Erklärfilme, die Support-Tickets senken, das Onboarding beschleunigen und Komplexes in 60 Sekunden einfach machen.","es":"Producción de videos how-to y tutoriales en Zúrich. Films explicativos que reducen tickets de soporte, aceleran el onboarding y simplifican lo complejo en 60 segundos."};
---
<Base lang={lang} slug="services/how-to-video" active="services" activeSub="howto" title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={"{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"Service\",\"@id\":\"https://www.viven.ch/services/how-to-video/#service\",\"name\":\"How-To and Tutorial Video Production\",\"serviceType\":\"How-to, tutorial and explainer video production\",\"description\":\"Tutorial and explainer films that reduce support tickets, boost activation and onboarding, and make complex products simple in 60 seconds. Produced in Zurich by Viven — trusted by UBS, Siemens, Porsche and ON.\",\"url\":\"https://www.viven.ch/services/how-to-video/\",\"provider\":{\"@id\":\"https://www.viven.ch/#organization\"},\"areaServed\":[\"CH\",\"Europe\"]},{\"@type\":\"BreadcrumbList\",\"@id\":\"https://www.viven.ch/services/how-to-video/#breadcrumbs\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.viven.ch/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Services\",\"item\":\"https://www.viven.ch/services/\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"How-To & Tutorials\",\"item\":\"https://www.viven.ch/services/how-to-video/\"}]},{\"@type\":\"FAQPage\",\"@id\":\"https://www.viven.ch/services/how-to-video/#faq\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Animation or live action — which is better for a how-to video?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"It depends on what you are explaining. Software and abstract processes usually work best with animation and screen capture. Physical products and people-driven services work best in live action. Many of our films combine both. We recommend based on your goal — not on our preference.\"}},{\"@type\":\"Question\",\"name\":\"How does pricing work for a series of tutorials?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"A series is significantly cheaper per video than one-offs. Concept, setup and design are built once, then reused across every episode — so the cost per video drops as the series grows. We quote series as a package with a clear per-video price.\"}},{\"@type\":\"Question\",\"name\":\"Is script writing included?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. One team runs it end to end — script, storyboard, shoot or animation, voiceover and final cut. You bring the product knowledge; we turn it into a script that explains it simply. You approve the script before production starts.\"}},{\"@type\":\"Question\",\"name\":\"Can you deliver in multiple languages and with subtitles?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. We deliver in English, German and Spanish as standard, with subtitles for every version. Additional language versions are straightforward, because voiceover and on-screen text are planned for localization from the start.\"}}]}]}"}></script>
<!-- ============ PAGE HERO ============ -->
<section class="page-hero has-video">
  <div class="hero-bg" data-vimeo="1026464530"><img class="reel" src="https://i.vimeocdn.com/video/1946266990-73dd9164ab7c5fa13e131b9bdbecade3bf9ec1358e75879bb90ce9cf3dc22f1c-d_960?region=us" width="1600" height="900" alt="" fetchpriority="high" decoding="async" /><div class="grain"></div></div>
  <div class="hero-overlay"></div>
  <div class="wrap">
    <div class="crumbs">
      <a href={p("")} data-en="Home" data-de="Home" data-es="Inicio">Home</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href={p("services")} data-en="Services" data-de="Leistungen" data-es="Servicios">Services</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span data-en="How-To &amp; Tutorials" data-de="How-To &amp; Tutorials" data-es="Tutoriales y How-To">How-To &amp; Tutorials</span>
    </div>
    <span class="eyebrow" data-en="How-to &amp; tutorial videos — Zurich, Switzerland" data-de="How-To- &amp; Tutorial-Videos — Zürich, Schweiz" data-es="Videos how-to y tutoriales — Zúrich, Suiza">How-to &amp; tutorial videos — Zurich, Switzerland</span>
    <h1 data-en='How-to videos that make complex <span class="hl">simple in 60 seconds.</span>'
        data-de='How-To-Videos, die Komplexes <span class="hl">in 60 Sekunden einfach machen.</span>'
        data-es='Videos how-to que hacen lo complejo <span class="hl">simple en 60 segundos.</span>'>
      How-to videos that make complex <span class="hl">simple in 60 seconds.</span>
    </h1>
    <p class="lead"
       data-en="Tutorial and explainer films that answer the question before it hits your support inbox. Fewer tickets, faster onboarding, more users who actually get it."
       data-de="Tutorial- und Erklärfilme, die die Frage beantworten, bevor sie in Ihrem Support-Postfach landet. Weniger Tickets, schnelleres Onboarding, mehr Nutzer, die es wirklich verstehen."
       data-es="Films tutoriales y explicativos que responden la pregunta antes de que llegue a tu bandeja de soporte. Menos tickets, onboarding más rápido, más usuarios que realmente lo entienden.">
      Tutorial and explainer films that answer the question before it hits your support inbox. Fewer tickets, faster onboarding, more users who actually get it.
    </p>
    <div class="hero-cta">
      <a href={p("contact")} class="btn btn-primary" data-en="Start a project" data-de="Projekt starten" data-es="Iniciar proyecto">Start a project</a>
      <a href="#work" class="btn btn-ghost" data-en="See the films" data-de="Filme ansehen" data-es="Ver los films">See the films</a>
    </div>
  </div>
</section>

<!-- ============ WHAT YOU GET ============ -->
<section class="sec" id="value">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="What you get" data-de="Was Sie bekommen" data-es="Qué obtienes">What you get</span>
      <h2 data-en="Explain it once. On video. Forever."
          data-de="Einmal erklären. Auf Video. Für immer."
          data-es="Explícalo una vez. En video. Para siempre.">Explain it once. On video. Forever.</h2>
      <p data-en="Every question your team answers twice should be a video. It works around the clock — and never loses patience."
         data-de="Jede Frage, die Ihr Team zweimal beantwortet, sollte ein Video sein. Es arbeitet rund um die Uhr — und verliert nie die Geduld."
         data-es="Cada pregunta que tu equipo responde dos veces debería ser un video. Trabaja las 24 horas — y nunca pierde la paciencia.">Every question your team answers twice should be a video. It works around the clock — and never loses patience.</p>
    </div>
    <div class="value-grid">
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
        <h3 data-en="Fewer support tickets" data-de="Weniger Support-Tickets" data-es="Menos tickets de soporte">Fewer support tickets</h3>
        <p data-en="Answer the top questions once, on video — and watch repeat tickets disappear from your queue." data-de="Beantworten Sie die häufigsten Fragen einmal per Video — und wiederkehrende Tickets verschwinden aus Ihrer Warteschlange." data-es="Responde las preguntas más frecuentes una vez, en video — y mira cómo los tickets repetidos desaparecen de tu cola.">Answer the top questions once, on video — and watch repeat tickets disappear from your queue.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
        <h3 data-en="Faster activation" data-de="Schnellere Aktivierung" data-es="Activación más rápida">Faster activation</h3>
        <p data-en="Users who see it done, do it. Onboarding videos move people from sign-up to first success in minutes." data-de="Wer es gesehen hat, macht es nach. Onboarding-Videos führen Nutzer in Minuten vom Sign-up zum ersten Erfolg." data-es="Los usuarios que lo ven hecho, lo hacen. Los videos de onboarding llevan a la gente del registro al primer éxito en minutos.">Users who see it done, do it. Onboarding videos move people from sign-up to first success in minutes.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.7c.6.5 1 1.3 1 2.1h6c0-.8.4-1.6 1-2.1A7 7 0 0 0 12 2z"/></svg></div>
        <h3 data-en="Complex made simple" data-de="Komplexes einfach gemacht" data-es="Lo complejo, simple">Complex made simple</h3>
        <p data-en="We turn hard-to-explain products into a story anyone gets in 60 seconds — the same skill that opened new markets for Meteomatics." data-de="Wir verwandeln erklärungsbedürftige Produkte in eine Geschichte, die jeder in 60 Sekunden versteht — dieselbe Stärke, die Meteomatics neue Märkte erschloss." data-es="Convertimos productos difíciles de explicar en una historia que cualquiera entiende en 60 segundos — la misma habilidad que abrió nuevos mercados para Meteomatics.">We turn hard-to-explain products into a story anyone gets in 60 seconds — the same skill that opened new markets for Meteomatics.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4z"/></svg></div>
        <h3 data-en="Script to screen, end to end" data-de="Vom Skript zum Film, end to end" data-es="Del guion a la pantalla, de principio a fin">Script to screen, end to end</h3>
        <p data-en="Script, animation or live action, voiceover, subtitles — one team, one timeline, first draft in about two weeks." data-de="Skript, Animation oder Realfilm, Voiceover, Untertitel — ein Team, ein Zeitplan, erster Entwurf in rund zwei Wochen." data-es="Guion, animación o acción real, voz en off, subtítulos — un solo equipo, un solo cronograma, primer borrador en unas dos semanas.">Script, animation or live action, voiceover, subtitles — one team, one timeline, first draft in about two weeks.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============ WORK ============ -->
<section class="sec" id="work" style="padding-top:0">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="Selected work" data-de="Ausgewählte Arbeiten" data-es="Trabajos seleccionados">Selected work</span>
      <h2 data-en="How-to films we've made." data-de="How-To-Filme von uns." data-es="Films how-to que hicimos.">How-to films we've made.</h2>
      <p data-en="Complex products, explained simply. Hit play." data-de="Komplexe Produkte, einfach erklärt. Einfach auf Play drücken." data-es="Productos complejos, explicados de forma simple. Dale play.">Complex products, explained simply. Hit play.</p>
    </div>
    <VideoGallery cat="howto" lang={lang} limit={9} />
    <div style="text-align:center;margin-top:44px" class="reveal">
      <a href={p("projects")} class="btn btn-ghost" data-en="See all projects" data-de="Alle Projekte ansehen" data-es="Ver todos los proyectos">See all projects</a>
    </div>
  </div>
</section>

<!-- ============ STATS ============ -->
<section class="sec" style="padding-top:0">
  <div class="wrap">
    <div class="stats reveal">
      <div class="stat"><div class="num">60s</div><div class="lbl" data-en="To make complex simple" data-de="Um Komplexes einfach zu machen" data-es="Para simplificar lo complejo">To make complex simple</div></div>
      <div class="stat"><div class="num">2</div><div class="lbl" data-en="Weeks to your first draft" data-de="Wochen bis zum ersten Entwurf" data-es="Semanas hasta el primer borrador">Weeks to your first draft</div></div>
      <div class="stat"><div class="num">187</div><div class="lbl" data-en="Brands trusted us" data-de="Marken vertrauen uns" data-es="Marcas confiaron en nosotros">Brands trusted us</div></div>
    </div>
  </div>
</section>

<!-- ============ FAQ ============ -->
<section class="sec" id="faq" style="padding-top:0">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="FAQ" data-de="FAQ" data-es="FAQ">FAQ</span>
      <h2 data-en="How-to video, answered." data-de="How-To-Video, beantwortet." data-es="Videos how-to, respondido.">How-to video, answered.</h2>
    </div>
    <div class="faq reveal">
      <details>
        <summary data-en="Animation or live action — which is better?" data-de="Animation oder Realfilm — was ist besser?" data-es="¿Animación o acción real — qué es mejor?">Animation or live action — which is better?</summary>
        <p data-en="It depends on what you're explaining. Software and abstract processes usually work best with animation and screen capture. Physical products and people-driven services work best in live action. Many of our films combine both. We recommend based on your goal — not on our preference."
           data-de="Das hängt davon ab, was Sie erklären. Software und abstrakte Prozesse funktionieren meist am besten mit Animation und Screen Capture. Physische Produkte und Dienstleistungen mit Menschen wirken am besten im Realfilm. Viele unserer Filme kombinieren beides. Wir empfehlen nach Ihrem Ziel — nicht nach unserer Vorliebe."
           data-es="Depende de lo que estés explicando. El software y los procesos abstractos suelen funcionar mejor con animación y captura de pantalla. Los productos físicos y los servicios con personas funcionan mejor en acción real. Muchos de nuestros films combinan ambos. Recomendamos según tu objetivo — no según nuestra preferencia.">It depends on what you're explaining. Software and abstract processes usually work best with animation and screen capture. Physical products and people-driven services work best in live action. Many of our films combine both. We recommend based on your goal — not on our preference.</p>
      </details>
      <details>
        <summary data-en="How does pricing work for a series?" data-de="Wie funktioniert die Preisgestaltung bei einer Serie?" data-es="¿Cómo funciona el precio de una serie?">How does pricing work for a series?</summary>
        <p data-en="A series is significantly cheaper per video than one-offs. Concept, setup and design are built once, then reused across every episode — so the cost per video drops as the series grows. We quote series as a package with a clear per-video price."
           data-de="Eine Serie ist pro Video deutlich günstiger als Einzelproduktionen. Konzept, Setup und Design entstehen einmal und werden für jede Folge wiederverwendet — die Kosten pro Video sinken also mit der Länge der Serie. Serien offerieren wir als Paket mit einem klaren Preis pro Video."
           data-es="Una serie es bastante más económica por video que las producciones individuales. El concepto, el setup y el diseño se crean una vez y se reutilizan en cada episodio — así el coste por video baja a medida que crece la serie. Cotizamos las series como paquete, con un precio claro por video.">A series is significantly cheaper per video than one-offs. Concept, setup and design are built once, then reused across every episode — so the cost per video drops as the series grows. We quote series as a package with a clear per-video price.</p>
      </details>
      <details>
        <summary data-en="Is script writing included?" data-de="Ist das Skript inklusive?" data-es="¿El guion está incluido?">Is script writing included?</summary>
        <p data-en="Yes. One team runs it end to end — script, storyboard, shoot or animation, voiceover and final cut. You bring the product knowledge; we turn it into a script that explains it simply. You approve the script before production starts."
           data-de="Ja. Ein Team steuert alles — Skript, Storyboard, Dreh oder Animation, Voiceover und finaler Schnitt. Sie bringen das Produktwissen mit; wir machen daraus ein Skript, das es einfach erklärt. Das Skript geben Sie frei, bevor die Produktion startet."
           data-es="Sí. Un mismo equipo lo lleva de principio a fin — guion, storyboard, rodaje o animación, voz en off y corte final. Tú aportas el conocimiento del producto; nosotros lo convertimos en un guion que lo explica de forma simple. Apruebas el guion antes de que empiece la producción.">Yes. One team runs it end to end — script, storyboard, shoot or animation, voiceover and final cut. You bring the product knowledge; we turn it into a script that explains it simply. You approve the script before production starts.</p>
      </details>
      <details>
        <summary data-en="Can you deliver in multiple languages and with subtitles?" data-de="Liefern Sie mehrsprachig und mit Untertiteln?" data-es="¿Entregan en varios idiomas y con subtítulos?">Can you deliver in multiple languages and with subtitles?</summary>
        <p data-en="Yes. We deliver in English, German and Spanish as standard, with subtitles for every version. Additional language versions are straightforward, because voiceover and on-screen text are planned for localization from the start."
           data-de="Ja. Wir liefern standardmässig auf Deutsch, Englisch und Spanisch — mit Untertiteln für jede Version. Weitere Sprachversionen sind unkompliziert, weil Voiceover und Bildschirmtexte von Anfang an für die Lokalisierung geplant werden."
           data-es="Sí. Entregamos en inglés, alemán y español de forma estándar, con subtítulos para cada versión. Las versiones en otros idiomas son sencillas, porque la voz en off y los textos en pantalla se planifican para localización desde el inicio.">Yes. We deliver in English, German and Spanish as standard, with subtitles for every version. Additional language versions are straightforward, because voiceover and on-screen text are planned for localization from the start.</p>
      </details>
    </div>
  </div>
</section>

<Testimonials lang={lang} cat="howto" />

<!-- ============ CTA / FORM ============ -->
<section class="cta" id="start" style="padding-top:0">
  <div class="wrap">
    <div class="cta-card reveal">
      <div>
        <span class="eyebrow" data-en="Let's talk" data-de="Sprechen wir" data-es="Hablemos">Let's talk</span>
        <h2 data-en="Tell us what you're working on." data-de="Erzählen Sie uns von Ihrem Projekt." data-es="Contanos en qué estás trabajando.">Tell us what you're working on.</h2>
        <p class="lead" data-en="Tell us your goal — we'll come back with three concept ideas, timing and a clear quote within 48 hours. Free, no obligation." data-de="Nennen Sie uns Ihr Ziel — wir melden uns innert 48 Stunden mit drei Konzeptideen, Timing und einem klaren Angebot. Kostenlos und unverbindlich." data-es="Contanos tu objetivo — volvemos en 48 horas con tres ideas de concepto, tiempos y un presupuesto claro. Gratis y sin compromiso.">Tell us your goal — we'll come back with three concept ideas, timing and a clear quote within 48 hours. Free, no obligation.</p>
        <ul>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="First draft within two weeks" data-de="Erster Entwurf in zwei Wochen" data-es="Primer borrador en dos semanas">First draft within two weeks</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="One partner, brief to delivery" data-de="Ein Partner, vom Brief bis zur Auslieferung" data-es="Un partner, de principio a fin">One partner, brief to delivery</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="Multilingual delivery" data-de="Mehrsprachige Auslieferung" data-es="Entrega multilingüe">Multilingual delivery</span></li>
        </ul>
      </div>
      <div>
        <div class="lead-form-mount"></div>
        <p class="form-note" data-en="We'll reply within one business day. No spam, ever." data-de="Wir antworten innerhalb eines Werktags. Kein Spam." data-es="Respondemos en un día hábil. Nunca spam.">We'll reply within one business day. No spam, ever.</p>
        <p class="book-call-note"><span data-en="Prefer to talk it through?" data-de="Lieber direkt sprechen?" data-es="¿Preferís hablarlo directamente?">Prefer to talk it through?</span> <a class="book-call" href="https://meetings.hubspot.com/sofia-trevino?uuid=76bf013f-3825-4341-8a95-fee769f70c49" target="_blank" rel="noopener" data-en="Book a free 15-min call →" data-de="Gratis 15-Min-Call buchen →" data-es="Reservá una llamada gratis de 15 min →">Book a free 15-min call →</a></p>
      </div>
    </div>
  </div>
</section>
</Base>
