---
import Base from '../../../layouts/Base.astro';
import Testimonials from '../../../components/Testimonials.astro';
import CalcBanner from '../../../components/CalcBanner.astro';
import { langPaths, localePath } from '../../../i18n.js';
export const getStaticPaths = langPaths;
const { lang } = Astro.params;
const p = (s) => localePath(lang, s);
const title = {"en":"Video Production Services Zurich — Brand to Social | Viven","de":"Videoproduktion Leistungen Zürich — Marke bis Social | Viven","es":"Servicios de producción de video en Zúrich | Viven"};
const description = {"en":"Brand, product, employer-branding, how-to, social and corporate video — one Zurich production partner, one accountable team, end to end. Trusted by 187 brands.","de":"Marken-, Produkt-, Employer-Branding-, How-To-, Social- und Corporate-Videos — ein Produktionspartner in Zürich, alles über einen Partner. 187 Marken vertrauen uns.","es":"Videos de marca, producto, employer branding, tutoriales, social y corporativos — un solo partner de producción en Zúrich. 187 marcas confían en nosotros."};
---
<Base lang={lang} slug="services" active="services" title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={"{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"ItemList\",\"@id\":\"https://www.viven.ch/services/#services\",\"name\":\"Video production services by Viven\",\"description\":\"Video production services offered by Viven AG in Zurich, Switzerland: brand, product, employer-branding, how-to, social media and corporate video.\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Brand Video Production\",\"url\":\"https://www.viven.ch/services/brand-video/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Product Video Production\",\"url\":\"https://www.viven.ch/services/product-video/\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Employer Branding Video\",\"url\":\"https://www.viven.ch/services/employer-branding/\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"How-To & Tutorial Video\",\"url\":\"https://www.viven.ch/services/how-to-video/\"},{\"@type\":\"ListItem\",\"position\":5,\"name\":\"Social Media Video\",\"url\":\"https://www.viven.ch/services/social-media-video/\"},{\"@type\":\"ListItem\",\"position\":6,\"name\":\"Corporate & Event Video\",\"url\":\"https://www.viven.ch/services/corporate-video/\"}]},{\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.viven.ch/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Services\",\"item\":\"https://www.viven.ch/services/\"}]}]}"}></script>
<!-- ============ PAGE HERO ============ -->
<section class="page-hero">
  <div class="wrap">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href={p("")} data-en="Home" data-de="Home" data-es="Inicio">Home</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span data-en="Services" data-de="Leistungen" data-es="Servicios">Services</span>
    </nav>
    <span class="eyebrow" data-en="Our services" data-de="Unsere Leistungen" data-es="Nuestros servicios">Our services</span>
    <h1 data-en='Every video your brand needs. <span class="hl">One partner.</span>'
        data-de='Jedes Video, das Ihre Marke braucht. <span class="hl">Ein Partner.</span>'
        data-es='Cada video que tu marca necesita. <span class="hl">Un solo partner.</span>'>
      Every video your brand needs. <span class="hl">One partner.</span>
    </h1>
    <p class="lead"
       data-en="From brand films to social series — strategy, production and post, end to end from Zurich. Trusted by UBS, Siemens, Porsche and ON."
       data-de="Von Markenfilmen bis Social-Serien — Strategie, Produktion und Post, end to end aus Zürich. Im Einsatz für UBS, Siemens, Porsche und ON."
       data-es="De films de marca a series para redes — estrategia, producción y post, de principio a fin en Zúrich. Con la confianza de UBS, Siemens, Porsche y ON.">
      From brand films to social series — strategy, production and post, end to end from Zurich. Trusted by UBS, Siemens, Porsche and ON.
    </p>
    <div class="hero-cta">
      <a href={p("contact")} class="btn btn-primary" data-en="Start a project" data-de="Projekt starten" data-es="Iniciar proyecto">Start a project</a>
    </div>
  </div>
</section>

<!-- ============ SERVICES ============ -->
<section class="sec" id="services" style="padding-top:40px">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="What we make" data-de="Was wir machen" data-es="Qué hacemos">What we make</span>
      <h2 data-en="Six services. One team, end to end." data-de="Sechs Leistungen. Ein Team, end to end." data-es="Seis servicios. Un solo equipo, de principio a fin.">Six services. One team, end to end.</h2>
      <p data-en="Strategy, production and post under one roof — so nothing gets lost between agencies." data-de="Strategie, Produktion und Post unter einem Dach — damit nichts zwischen Agenturen verloren geht." data-es="Estrategia, producción y post bajo un mismo techo — para que nada se pierda entre agencias.">Strategy, production and post under one roof — so nothing gets lost between agencies.</p>
    </div>
    <div class="services three">
      <a href={p("services/brand-video")} class="service reveal">
        <div class="thumb g-blue"></div>
        <div class="body">
          <span class="tag" data-en="Brand Videos" data-de="Markenfilme" data-es="Videos de marca">Brand Videos</span>
          <h3 data-en="Films that carry the campaign" data-de="Filme, die die Kampagne tragen" data-es="Films que sostienen la campaña">Films that carry the campaign</h3>
          <p data-en="High-impact brand films made to perform across paid media, social and your website." data-de="Wirkungsstarke Markenfilme für Paid Media, Social und Ihre Website." data-es="Films de marca de alto impacto para paid media, social y tu web.">High-impact brand films made to perform across paid media, social and your website.</p>
          <span class="more" data-en="Learn more →" data-de="Mehr erfahren →" data-es="Ver más →">Learn more →</span>
        </div>
      </a>
      <a href={p("services/product-video")} class="service reveal">
        <div class="thumb g-pink"></div>
        <div class="body">
          <span class="tag" data-en="Product Videos" data-de="Produktvideos" data-es="Videos de producto">Product Videos</span>
          <h3 data-en="Make products sell themselves" data-de="Produkte, die sich selbst verkaufen" data-es="Productos que se venden solos">Make products sell themselves</h3>
          <p data-en="Product films and launch videos that turn features into desire — and clicks into buyers." data-de="Produktfilme und Launch-Videos, die Features in Begehren verwandeln — und Klicks in Käufer." data-es="Films de producto y lanzamientos que convierten características en deseo — y clics en compradores.">Product films and launch videos that turn features into desire — and clicks into buyers.</p>
          <span class="more" data-en="Learn more →" data-de="Mehr erfahren →" data-es="Ver más →">Learn more →</span>
        </div>
      </a>
      <a href={p("services/employer-branding")} class="service reveal">
        <div class="thumb g-acid"></div>
        <div class="body">
          <span class="tag" data-en="Employer Branding" data-de="Employer Branding" data-es="Employer Branding">Employer Branding</span>
          <h3 data-en="Recruitment &amp; culture films" data-de="Recruiting- &amp; Kulturfilme" data-es="Films de cultura y reclutamiento">Recruitment &amp; culture films</h3>
          <p data-en="Show why people love working for you — and attract the talent you actually want." data-de="Zeigen Sie, warum Menschen gerne bei Ihnen arbeiten — und ziehen Sie die richtigen Talente an." data-es="Muestra por qué la gente ama trabajar contigo — y atrae el talento que realmente quieres.">Show why people love working for you — and attract the talent you actually want.</p>
          <span class="more" data-en="Learn more →" data-de="Mehr erfahren →" data-es="Ver más →">Learn more →</span>
        </div>
      </a>
      <a href={p("services/how-to-video")} class="service reveal">
        <div class="thumb g-teal"></div>
        <div class="body">
          <span class="tag" data-en="How-To &amp; Tutorials" data-de="How-To &amp; Tutorials" data-es="Tutoriales y How-To">How-To &amp; Tutorials</span>
          <h3 data-en="Explain anything simply" data-de="Alles einfach erklären" data-es="Explicar cualquier cosa, simple">Explain anything simply</h3>
          <p data-en="Explainer and tutorial videos that make complex offers easy to say yes to." data-de="Erklär- und Tutorial-Videos, die komplexe Angebote leicht verständlich machen." data-es="Videos explicativos y tutoriales que hacen fácil decir que sí a ofertas complejas.">Explainer and tutorial videos that make complex offers easy to say yes to.</p>
          <span class="more" data-en="Learn more →" data-de="Mehr erfahren →" data-es="Ver más →">Learn more →</span>
        </div>
      </a>
      <a href={p("services/social-media-video")} class="service reveal">
        <div class="thumb g-violet"></div>
        <div class="body">
          <span class="tag" data-en="Social Media" data-de="Social Media" data-es="Redes sociales">Social Media</span>
          <h3 data-en="Scroll-stopping content" data-de="Content, der den Scroll stoppt" data-es="Contenido que frena el scroll">Scroll-stopping content</h3>
          <p data-en="Short-form video series built for reach, engagement and conversion on every platform." data-de="Short-Form-Videoserien für Reichweite, Engagement und Conversion auf jeder Plattform." data-es="Series de video corto para alcance, engagement y conversión en cada plataforma.">Short-form video series built for reach, engagement and conversion on every platform.</p>
          <span class="more" data-en="Learn more →" data-de="Mehr erfahren →" data-es="Ver más →">Learn more →</span>
        </div>
      </a>
      <a href={p("services/corporate-video")} class="service reveal">
        <div class="thumb g-amber"></div>
        <div class="body">
          <span class="tag" data-en="Corporate &amp; Events" data-de="Corporate &amp; Events" data-es="Corporativo y eventos">Corporate &amp; Events</span>
          <h3 data-en="Communication &amp; event content" data-de="Kommunikation &amp; Event-Content" data-es="Comunicación y eventos">Communication &amp; event content</h3>
          <p data-en="Corporate communication, internal and event content that keeps your audience close." data-de="Unternehmenskommunikation, interne und Event-Inhalte, die Ihr Publikum binden." data-es="Comunicación corporativa, contenido interno y de eventos que mantiene cerca a tu audiencia.">Corporate communication, internal and event content that keeps your audience close.</p>
          <span class="more" data-en="Learn more →" data-de="Mehr erfahren →" data-es="Ver más →">Learn more →</span>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- ============ PROCESS ============ -->
<section class="sec" id="process" style="padding-top:0">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="How we work" data-de="So arbeiten wir" data-es="Cómo trabajamos">How we work</span>
      <h2 data-en="Feature-film discipline. Business-first thinking." data-de="Spielfilm-Disziplin. Business-first-Denken." data-es="Disciplina de cine. Mentalidad de negocio.">Feature-film discipline. Business-first thinking.</h2>
      <p data-en="We agree on the timeline before we start. And we stick to it." data-de="Wir vereinbaren den Zeitplan, bevor wir starten. Und wir halten ihn ein." data-es="Acordamos el cronograma antes de empezar. Y lo cumplimos.">We agree on the timeline before we start. And we stick to it.</p>
    </div>
    <div class="process">
      <div class="step reveal">
        <div class="n">1</div>
        <h3 data-en="Creative development" data-de="Kreativentwicklung" data-es="Desarrollo creativo">Creative development</h3>
        <p data-en="We start with your goal, not with a camera. Audience, emotion, action — the brief drives everything." data-de="Wir starten mit Ihrem Ziel, nicht mit der Kamera. Zielgruppe, Emotion, Aktion — das Briefing bestimmt alles." data-es="Empezamos con tu objetivo, no con una cámara. Audiencia, emoción, acción — el brief define todo.">We start with your goal, not with a camera. Audience, emotion, action — the brief drives everything.</p>
      </div>
      <div class="step reveal">
        <div class="n">2</div>
        <h3 data-en="Pre-production" data-de="Pre-Production" data-es="Preproducción">Pre-production</h3>
        <p data-en="Casting, crewing, storyboarding and scheduling — everything planned before a single shot." data-de="Casting, Crew, Storyboard und Zeitplan — alles geplant, bevor eine Aufnahme entsteht." data-es="Casting, equipo, storyboard y calendario — todo planificado antes de la primera toma.">Casting, crewing, storyboarding and scheduling — everything planned before a single shot.</p>
      </div>
      <div class="step reveal">
        <div class="n">3</div>
        <h3 data-en="Production" data-de="Produktion" data-es="Producción">Production</h3>
        <p data-en="On set with the efficiency and discipline of a feature film crew — every minute accounted for." data-de="Am Set mit der Effizienz und Disziplin einer Spielfilm-Crew — jede Minute zählt." data-es="En el set con la eficiencia y disciplina de un equipo de cine — cada minuto cuenta.">On set with the efficiency and discipline of a feature film crew — every minute accounted for.</p>
      </div>
      <div class="step reveal">
        <div class="n">4</div>
        <h3 data-en="Post-production" data-de="Post-Production" data-es="Postproducción">Post-production</h3>
        <p data-en="Expert editing, sound design and finishing that merge craft with your brand identity." data-de="Professioneller Schnitt, Sound Design und Finishing — Handwerk trifft Markenidentität." data-es="Edición experta, diseño de sonido y acabado que unen oficio e identidad de marca.">Expert editing, sound design and finishing that merge craft with your brand identity.</p>
      </div>
    </div>
    <div style="text-align:center;margin-top:44px" class="reveal">
      <a href={p("why-viven")} class="btn btn-ghost" data-en="Why brands choose Viven" data-de="Warum Marken Viven wählen" data-es="Por qué las marcas eligen Viven">Why brands choose Viven</a>
    </div>
  </div>
</section>


<Testimonials lang={lang} />

<CalcBanner lang={lang} />

<!-- ============ CTA / FORM ============ -->
<section class="cta" id="start" style="padding-top:0">
  <div class="wrap">
    <div class="cta-card reveal">
      <div>
        <span class="eyebrow" data-en="Let's talk" data-de="Sprechen wir" data-es="Hablemos">Let's talk</span>
        <h2 data-en="Tell us what you're working on." data-de="Erzählen Sie uns von Ihrem Projekt." data-es="Contanos en qué estás trabajando.">Tell us what you're working on.</h2>
        <p class="lead" data-en="Tell us your goal — we'll come back with timing and a clear quote within 48 hours. Free, no obligation." data-de="Nennen Sie uns Ihr Ziel — wir melden uns innert 48 Stunden mit Timing und einem klaren Angebot. Kostenlos und unverbindlich." data-es="Contanos tu objetivo — volvemos en 48 horas con tiempos y un presupuesto claro. Gratis y sin compromiso.">Tell us your goal — we'll come back with timing and a clear quote within 48 hours. Free, no obligation.</p>
        <ul>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="First draft within two weeks" data-de="Erster Entwurf in zwei Wochen" data-es="Primer borrador en dos semanas">First draft within two weeks</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="One partner, brief to delivery" data-de="Ein Partner, vom Brief bis zur Auslieferung" data-es="Un partner, de principio a fin">One partner, brief to delivery</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="Multilingual delivery" data-de="Mehrsprachige Auslieferung" data-es="Entrega multilingüe">Multilingual delivery</span></li>
        </ul>
      </div>
      <div>
        <div class="lead-form-mount"></div>
        <p class="form-note" data-en="We'll reply within one business day. No spam, ever." data-de="Wir antworten innerhalb eines Werktags. Kein Spam." data-es="Respondemos en un día hábil. Nunca spam.">We'll reply within one business day. No spam, ever.</p>
        <p class="book-call-note"><span data-en="Prefer to talk it through?" data-de="Lieber direkt sprechen?" data-es="¿Preferís hablarlo directamente?">Prefer to talk it through?</span> <a class="book-call" href="/book/" target="_blank" rel="noopener" data-en="Book a free 15-min call →" data-de="Gratis 15-Min-Call buchen →" data-es="Reservá una llamada gratis de 15 min →">Book a free 15-min call →</a></p>
      </div>
    </div>
  </div>
</section>
</Base>
