---
import Base from '../../../../layouts/Base.astro';
import Testimonials from '../../../../components/Testimonials.astro';
import VideoGallery from '../../../../components/VideoGallery.astro';
import { langPaths, localePath } from '../../../../i18n.js';
export const getStaticPaths = langPaths;
const { lang } = Astro.params;
const p = (s) => localePath(lang, s);
const title = {"en":"Corporate Video Production Zurich — Communication & Event Films | Viven","de":"Corporate-Video-Produktion Zürich — Kommunikations- & Eventfilme | Viven","es":"Producción de video corporativo en Zúrich | Viven"};
const description = {"en":"Corporate communication films, keynotes and event coverage people actually watch. Made in Zurich for UBS, FIFA and Philips — first draft in two weeks.","de":"Corporate-Kommunikationsfilme, Keynotes und Event-Coverage, die man wirklich anschaut. Aus Zürich für UBS, FIFA und Philips — erster Entwurf in zwei Wochen.","es":"Films de comunicación corporativa, keynotes y cobertura de eventos que la gente realmente mira. Hechos en Zúrich para UBS, FIFA y Philips — primer borrador en dos semanas."};
---
<Base lang={lang} slug="services/corporate-video" active="services" activeSub="corporate" title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={"{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"Service\",\"@id\":\"https://www.viven.ch/services/corporate-video/#service\",\"name\":\"Corporate Video & Event Production\",\"serviceType\":\"Corporate video production\",\"url\":\"https://www.viven.ch/services/corporate-video/\",\"provider\":{\"@id\":\"https://www.viven.ch/#organization\"},\"areaServed\":[\"CH\",\"Europe\"],\"description\":\"Corporate communication films, internal content, keynotes and event coverage — concept, production and post end to end from Zurich. Produced for brands including UBS, FIFA and Philips.\"},{\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.viven.ch/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Services\",\"item\":\"https://www.viven.ch/services/\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Corporate & Events\",\"item\":\"https://www.viven.ch/services/corporate-video/\"}]},{\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"How much does a corporate video cost?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"It depends on scope — a single-camera interview film costs less than a multi-day event production. Most Viven projects range from CHF 4,000 to 80,000, and you always get a fixed, transparent quote before we start.\"}},{\"@type\":\"Question\",\"name\":\"Can you cover our event end to end?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. We plan the coverage with you, film with a multi-camera crew, and deliver an aftermovie plus short social clips — often with first highlights ready the next day.\"}},{\"@type\":\"Question\",\"name\":\"Do you also produce internal communication videos?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Absolutely — leadership messages, town halls, onboarding and culture films. The same craft as our external work, tailored to what your teams actually watch.\"}},{\"@type\":\"Question\",\"name\":\"Can you deliver versions for global teams?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Subtitles and language versions in English, German and Spanish are standard, and additional languages are straightforward — one production serves every office.\"}}]}]}"}></script>
<!-- ============ PAGE HERO ============ -->
<section class="page-hero has-video">
  <div class="hero-bg" data-vimeo="866300150" data-mp4="/assets/heroes/866300150.mp4"><img class="reel" src="https://i.vimeocdn.com/video/1726523339-967ecd0879ef814aa9c3570031b0b6fb9e543b2afd034cfb1c5bcdcac08585fa-d_960?region=us" width="1600" height="900" alt="" fetchpriority="high" decoding="async" /><div class="grain"></div></div>
  <div class="hero-overlay"></div>
  <div class="wrap">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href={p("")} data-en="Home" data-de="Home" data-es="Inicio">Home</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href={p("services")} data-en="Services" data-de="Leistungen" data-es="Servicios">Services</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span data-en="Corporate &amp; Events" data-de="Corporate &amp; Events" data-es="Corporativo y eventos">Corporate &amp; Events</span>
    </nav>
    <span class="eyebrow" data-en="Corporate video &amp; event production" data-de="Corporate-Video- &amp; Event-Produktion" data-es="Producción de video corporativo y eventos">Corporate video &amp; event production</span>
    <h1 data-en='Corporate films that <span class="hl">keep your audience close.</span>'
        data-de='Corporate Filme, die <span class="hl">Ihr Publikum binden.</span>'
        data-es='Films corporativos que <span class="hl">mantienen cerca a tu audiencia.</span>'>
      Corporate films that <span class="hl">keep your audience close.</span>
    </h1>
    <p class="lead"
       data-en="From leadership messages to keynotes and event aftermovies — corporate content people actually watch. Made for UBS, FIFA and Philips."
       data-de="Von Führungsbotschaften über Keynotes bis zu Event-Aftermovies — Corporate Content, den man wirklich anschaut. Produziert für UBS, FIFA und Philips."
       data-es="De mensajes de liderazgo a keynotes y aftermovies de eventos — contenido corporativo que la gente realmente mira. Hecho para UBS, FIFA y Philips.">
      From leadership messages to keynotes and event aftermovies — corporate content people actually watch. Made for UBS, FIFA and Philips.
    </p>
    <div class="hero-cta">
      <a href={p("contact")} class="btn btn-primary" data-en="Start a project" data-de="Projekt starten" data-es="Iniciar proyecto">Start a project</a>
      <a href="#work" class="btn btn-ghost" data-en="See corporate films" data-de="Corporate Filme ansehen" data-es="Ver films corporativos">See corporate films</a>
    </div>
  </div>
</section>

<!-- ============ WHAT YOU GET ============ -->
<section class="sec" id="what-you-get" style="padding-top:40px">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="What you get" data-de="Was Sie erhalten" data-es="Qué recibes">What you get</span>
      <h2 data-en="Every message. Every audience. One partner." data-de="Jede Botschaft. Jedes Publikum. Ein Partner." data-es="Cada mensaje. Cada audiencia. Un solo partner.">Every message. Every audience. One partner.</h2>
      <p data-en="Corporate video is how modern companies talk — to their people and their market. Here's what we produce." data-de="Corporate Video ist, wie moderne Unternehmen kommunizieren — mit ihren Leuten und ihrem Markt. Das produzieren wir." data-es="El video corporativo es cómo hablan las empresas modernas — con su gente y su mercado. Esto es lo que producimos.">Corporate video is how modern companies talk — to their people and their market. Here's what we produce.</p>
    </div>
    <div class="value-grid">
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
        <h3 data-en="Communication films" data-de="Kommunikationsfilme" data-es="Films de comunicación">Communication films</h3>
        <p data-en="Company stories, leadership messages and milestone films that carry your message with credibility." data-de="Unternehmensgeschichten, Führungsbotschaften und Meilenstein-Filme, die Ihre Botschaft glaubwürdig transportieren." data-es="Historias de empresa, mensajes de liderazgo y films de hitos que llevan tu mensaje con credibilidad.">Company stories, leadership messages and milestone films that carry your message with credibility.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/></svg></div>
        <h3 data-en="Events &amp; keynotes" data-de="Events &amp; Keynotes" data-es="Eventos y keynotes">Events &amp; keynotes</h3>
        <p data-en="Multi-camera event films, keynotes and aftermovies — with social-ready highlights, often by the next day." data-de="Multi-Kamera-Eventfilme, Keynotes und Aftermovies — mit Social-Highlights, oft schon am nächsten Tag." data-es="Films de eventos multicámara, keynotes y aftermovies — con highlights para redes, a menudo al día siguiente.">Multi-camera event films, keynotes and aftermovies — with social-ready highlights, often by the next day.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/></svg></div>
        <h3 data-en="Internal &amp; culture content" data-de="Interner &amp; Kultur-Content" data-es="Contenido interno y de cultura">Internal &amp; culture content</h3>
        <p data-en="Onboarding, town halls and culture films your teams actually watch to the end." data-de="Onboarding, Town Halls und Kulturfilme, die Ihre Teams wirklich bis zum Ende anschauen." data-es="Onboarding, town halls y films de cultura que tus equipos realmente miran hasta el final.">Onboarding, town halls and culture films your teams actually watch to the end.</p>
      </div>
      <div class="value reveal">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m5 13 4 4L19 7"/></svg></div>
        <h3 data-en="Delivery-ready package" data-de="Lieferfertiges Paket" data-es="Paquete listo para publicar">Delivery-ready package</h3>
        <p data-en="Subtitles, language versions and formats for intranet, LinkedIn and event screens — ready to publish." data-de="Untertitel, Sprachversionen und Formate für Intranet, LinkedIn und Event-Screens — bereit zur Veröffentlichung." data-es="Subtítulos, versiones de idioma y formatos para intranet, LinkedIn y pantallas de evento — listos para publicar.">Subtitles, language versions and formats for intranet, LinkedIn and event screens — ready to publish.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============ SELECTED WORK ============ -->
<section class="sec" id="work" style="padding-top:0">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="Selected work" data-de="Ausgewählte Arbeiten" data-es="Trabajos seleccionados">Selected work</span>
      <h2 data-en="Corporate films we've made." data-de="Corporate Filme aus unserer Produktion." data-es="Films corporativos que hemos hecho.">Corporate films we've made.</h2>
      <p data-en="A few recent corporate and event productions. Hit play." data-de="Ein paar aktuelle Corporate- und Event-Produktionen. Einfach auf Play drücken." data-es="Algunas producciones corporativas y de eventos recientes. Dale play.">A few recent corporate and event productions. Hit play.</p>
    </div>
    <VideoGallery cat="corporate" lang={lang} limit={9} />
    <div style="text-align:center;margin-top:44px" class="reveal">
      <a href={p("projects")} class="btn btn-ghost" data-en="See all projects" data-de="Alle Projekte ansehen" data-es="Ver todos los proyectos">See all projects</a>
    </div>
  </div>
</section>

<!-- ============ STATS ============ -->
<section class="sec" style="padding-top:0;padding-bottom:0">
  <div class="wrap">
    <div class="stats reveal">
      <div class="stat"><div class="num">187</div><div class="lbl" data-en="Brands trusted us" data-de="Marken vertrauen uns" data-es="Marcas confiaron en nosotros">Brands trusted us</div></div>
      <div class="stat"><div class="num">3×</div><div class="lbl" data-en="More website visits for Siemens" data-de="Mehr Website-Besuche für Siemens" data-es="Más visitas web para Siemens">More website visits for Siemens</div></div>
      <div class="stat"><div class="num">47</div><div class="lbl" data-en="Five-star Google reviews" data-de="Fünf-Sterne-Google-Bewertungen" data-es="Reseñas de 5 estrellas en Google">Five-star Google reviews</div></div>
    </div>
  </div>
</section>

<!-- ============ FAQ ============ -->
<section class="sec" id="faq">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow" data-en="FAQ" data-de="FAQ" data-es="FAQ">FAQ</span>
      <h2 data-en="Corporate video questions, answered." data-de="Antworten auf Ihre Corporate-Video-Fragen." data-es="Preguntas sobre video corporativo, respondidas.">Corporate video questions, answered.</h2>
    </div>
    <div class="faq reveal">
      <details>
        <summary data-en="How much does a corporate video cost?" data-de="Was kostet ein Corporate Video?" data-es="¿Cuánto cuesta un video corporativo?">How much does a corporate video cost?</summary>
        <p data-en="It depends on scope — a single-camera interview film costs less than a multi-day event production. Most Viven projects range from CHF 4,000 to 80,000, and you always get a fixed, transparent quote before we start."
           data-de="Das hängt vom Umfang ab — ein Interviewfilm mit einer Kamera kostet weniger als eine mehrtägige Eventproduktion. Die meisten Viven-Projekte liegen zwischen CHF 4'000 und 80'000, und Sie erhalten immer ein fixes, transparentes Angebot, bevor wir starten."
           data-es="Depende del alcance — un film de entrevista a una cámara cuesta menos que una producción de evento de varios días. La mayoría de los proyectos de Viven van de CHF 4.000 a 80.000, y siempre recibís un presupuesto fijo y transparente antes de empezar.">It depends on scope — a single-camera interview film costs less than a multi-day event production. Most Viven projects range from CHF 4,000 to 80,000, and you always get a fixed, transparent quote before we start.</p>
      </details>
      <details>
        <summary data-en="Can you cover our event end to end?" data-de="Können Sie unser Event komplett begleiten?" data-es="¿Pueden cubrir nuestro evento de principio a fin?">Can you cover our event end to end?</summary>
        <p data-en="Yes. We plan the coverage with you, film with a multi-camera crew, and deliver an aftermovie plus short social clips — often with first highlights ready the next day."
           data-de="Ja. Wir planen die Berichterstattung mit Ihnen, drehen mit einer Multi-Kamera-Crew und liefern einen Aftermovie plus kurze Social Clips — erste Highlights oft schon am nächsten Tag."
           data-es="Sí. Planificamos la cobertura con vos, filmamos con un equipo multicámara y entregamos un aftermovie más clips cortos para redes — a menudo con los primeros highlights listos al día siguiente.">Yes. We plan the coverage with you, film with a multi-camera crew, and deliver an aftermovie plus short social clips — often with first highlights ready the next day.</p>
      </details>
      <details>
        <summary data-en="Do you also produce internal communication videos?" data-de="Produzieren Sie auch interne Kommunikationsvideos?" data-es="¿También producen videos de comunicación interna?">Do you also produce internal communication videos?</summary>
        <p data-en="Absolutely — leadership messages, town halls, onboarding and culture films. The same craft as our external work, tailored to what your teams actually watch."
           data-de="Unbedingt — Führungsbotschaften, Town Halls, Onboarding- und Kulturfilme. Dasselbe Handwerk wie bei unserer externen Arbeit, zugeschnitten auf das, was Ihre Teams wirklich anschauen."
           data-es="Por supuesto — mensajes de liderazgo, town halls, onboarding y films de cultura. El mismo oficio que nuestro trabajo externo, adaptado a lo que tus equipos realmente miran.">Absolutely — leadership messages, town halls, onboarding and culture films. The same craft as our external work, tailored to what your teams actually watch.</p>
      </details>
      <details>
        <summary data-en="Can you deliver versions for global teams?" data-de="Liefern Sie Versionen für globale Teams?" data-es="¿Entregan versiones para equipos globales?">Can you deliver versions for global teams?</summary>
        <p data-en="Yes. Subtitles and language versions in English, German and Spanish are standard, and additional languages are straightforward — one production serves every office."
           data-de="Ja. Untertitel und Sprachversionen auf Deutsch, Englisch und Spanisch sind Standard, weitere Sprachen sind unkompliziert — eine Produktion bedient jeden Standort."
           data-es="Sí. Los subtítulos y versiones en inglés, alemán y español son estándar, y otros idiomas son sencillos — una producción sirve para todas las oficinas.">Yes. Subtitles and language versions in English, German and Spanish are standard, and additional languages are straightforward — one production serves every office.</p>
      </details>
    </div>
  </div>
</section>


<Testimonials lang={lang} cat="corporate" />

<!-- ============ CTA / FORM ============ -->
<section class="cta" id="start" style="padding-top:0">
  <div class="wrap">
    <div class="cta-card reveal">
      <div>
        <span class="eyebrow" data-en="Let's talk" data-de="Sprechen wir" data-es="Hablemos">Let's talk</span>
        <h2 data-en="Tell us what you're working on." data-de="Erzählen Sie uns von Ihrem Projekt." data-es="Contanos en qué estás trabajando.">Tell us what you're working on.</h2>
        <p class="lead" data-en="Tell us your goal — we'll come back with three concept ideas, timing and a clear quote within 48 hours. Free, no obligation." data-de="Nennen Sie uns Ihr Ziel — wir melden uns innert 48 Stunden mit drei Konzeptideen, Timing und einem klaren Angebot. Kostenlos und unverbindlich." data-es="Contanos tu objetivo — volvemos en 48 horas con tres ideas de concepto, tiempos y un presupuesto claro. Gratis y sin compromiso.">Tell us your goal — we'll come back with three concept ideas, timing and a clear quote within 48 hours. Free, no obligation.</p>
        <ul>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="First draft within two weeks" data-de="Erster Entwurf in zwei Wochen" data-es="Primer borrador en dos semanas">First draft within two weeks</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="One partner, brief to delivery" data-de="Ein Partner, vom Brief bis zur Auslieferung" data-es="Un partner, de principio a fin">One partner, brief to delivery</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 13 4 4L19 7"/></svg><span data-en="Multilingual delivery" data-de="Mehrsprachige Auslieferung" data-es="Entrega multilingüe">Multilingual delivery</span></li>
        </ul>
      </div>
      <div>
        <div class="lead-form-mount"></div>
        <p class="form-note" data-en="We'll reply within one business day. No spam, ever." data-de="Wir antworten innerhalb eines Werktags. Kein Spam." data-es="Respondemos en un día hábil. Nunca spam.">We'll reply within one business day. No spam, ever.</p>
        <p class="book-call-note"><span data-en="Prefer to talk it through?" data-de="Lieber direkt sprechen?" data-es="¿Preferís hablarlo directamente?">Prefer to talk it through?</span> <a class="book-call" href="/book/" target="_blank" rel="noopener" data-en="Book a free 15-min call →" data-de="Gratis 15-Min-Call buchen →" data-es="Reservá una llamada gratis de 15 min →">Book a free 15-min call →</a></p>
      </div>
    </div>
  </div>
</section>
</Base>
