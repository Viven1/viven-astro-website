---
import Base from '../../../layouts/Base.astro';
import CaseStudy from '../../../components/CaseStudy.astro';
import projects from '../../../data/projects.json';
const project = projects.find((x) => x.slug === "de/project/singularity");
const lang = "de";
const SITE = "https://www.viven.ch";
const title = {"de": "Singularity — Sci-Fi Spielfilm | Viven"};
const description = {"de": "In einer von Maschinen beherrschten Zukunft machen sich zwei Teenager auf eine lebensgefährliche Reise, um die letzte Bastion der Menschheit zu finden."};
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VideoObject',
      name: project.headline,
      description: description[lang],
      thumbnailUrl: SITE + project.stills[0],
      embedUrl: 'https://player.vimeo.com/video/' + project.vimeo,
      uploadDate: "2017-11-01",
      publisher: { '@id': SITE + '/#organization' },
    },
    {
      '@type': 'CreativeWork',
      name: project.headline,
      about: project.client,
      inLanguage: lang,
      creator: { '@id': SITE + '/#organization' },
      url: SITE + "/de/project/singularity/",
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: SITE + '/' + lang + '/projects/' },
        { '@type': 'ListItem', position: 3, name: project.headline, item: SITE + "/de/project/singularity/" },
      ],
    },
  ],
};
---
<Base lang={lang} slug="projects" active="projects" singleLang={true} switchSlug="projects" canonicalPath={"/de/project/singularity/"} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(ld)}></script>
  <CaseStudy project={project} lang={lang} />
</Base>
