---
import Base from '../../layouts/Base.astro';
import CaseStudy from '../../components/CaseStudy.astro';
import projects from '../../data/projects.json';
const project = projects.find((x) => x.slug === "de/devenir-ein-interaktives-erlebnis-von-merkle");
const lang = "de";
const SITE = "https://www.viven.ch";
const title = {"de": "Devenir: Ein interaktives Erlebnis von Merkle | Viven"};
const description = {"de": "Merkle schuf ein einzigartiges Erlebnis: Ein revolutionäres Spiel, bei dem die Spieler das Geschehen nur mit der Kraft ihrer Gedanken steuern."};
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VideoObject',
      name: project.headline,
      description: description[lang],
      thumbnailUrl: SITE + project.stills[0],
      embedUrl: 'https://player.vimeo.com/video/' + project.vimeo,
      uploadDate: "2022-04-01T00:00:00+00:00",
      publisher: { '@id': SITE + '/#organization' },
    },
    {
      '@type': 'CreativeWork',
      name: project.headline,
      about: project.client,
      inLanguage: lang,
      creator: { '@id': SITE + '/#organization' },
      url: SITE + "/de/devenir-ein-interaktives-erlebnis-von-merkle/",
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: SITE + '/' + lang + '/projects/' },
        { '@type': 'ListItem', position: 3, name: project.headline, item: SITE + "/de/devenir-ein-interaktives-erlebnis-von-merkle/" },
      ],
    },
  ],
};
---
<Base lang={lang} slug="projects" active="projects" singleLang={true} switchSlug="projects" canonicalPath={"/de/devenir-ein-interaktives-erlebnis-von-merkle/"} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(ld)}></script>
  <CaseStudy project={project} lang={lang} />
</Base>
