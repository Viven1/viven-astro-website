---
// Página de localización: Videoproduktion Genf — keyword local (Ubersuggest: 40/mes, dificultad 17).
import Base from '../../layouts/Base.astro';
const lang = "de";
const d = {"title": "Videoproduktion Genf – Firmenvideos & Imagefilme | Viven", "description": "Videoproduktion in Genf für internationale Organisationen, Banken und Luxusmarken. Zürcher Crew oder lokales Team, Fixpreis, erster Schnitt in 2 Wochen.", "h1": "Videoproduktion Genf", "lead": "Viven ist eine Schweizer Videoproduktion, die regelmässig in Genf dreht. Wir produzieren Firmenvideos, Kampagnenfilme und Eventvideos für Organisationen rund um den Genfersee — von Privatbanken und Uhrenmarken bis zu NGOs und internationalen Organisationen. Crew und Equipment reisen ohne versteckte Zusatzkosten aus Zürich an, oder wir besetzen Ihren Dreh mit erfahrener Crew aus der Romandie. Den ersten Schnitt sehen Sie nach rund zwei Wochen.", "sections": [{"h2": "So produzieren wir in Genf", "html": "<p>Genf ist für unser Team kein Auswärtsspiel, sondern Routine. Sie wählen das Setup, das zu Projekt und Budget passt:</p><ul><li><strong>Zürcher Crew vor Ort:</strong> Unser Kernteam reist mit Equipment nach Genf — die Reisekosten stehen transparent in der Fixofferte, nicht als Überraschung auf der Schlussrechnung.</li><li><strong>Lokale Crew aus der Romandie:</strong> Für mehrtägige oder wiederkehrende Produktionen arbeiten wir mit bewährten Freelancern aus der Westschweiz, geführt von unserer Regie — lokale Nähe, gleichbleibende Qualität.</li></ul><p>In beiden Fällen führt eine feste Produktionsleitung Ihr Projekt vom Briefing bis zur Abgabe, und wir scouten Locations — von der Palexpo bis zum Büro am See — vor dem Drehtag, nicht erst am Drehtag. Braucht Ihre Produktion eine Messe-Akkreditierung, Drehgenehmigungen im Hotel oder Zugang zu geschützten Büroetagen, klären wir das gemeinsam in der Vorbereitungswoche.</p>"}, {"h2": "Video für Genfs internationales Umfeld", "html": "<p>Kaum eine Stadt bündelt so viele globale Zielgruppen wie Genf. Zwischen internationalen Organisationen, Privatbanken und der Uhrenindustrie treffen Publika aufeinander, die sehr unterschiedliche Tonalitäten verlangen — vom nüchternen Erklärvideo bis zum emotionalen Markenfilm. Wir produzieren für genau dieses Umfeld:</p><ul><li><strong>NGOs und internationale Organisationen,</strong> deren Missions- und Kampagnenfilme vor Geldgebern, Delegierten und Presse überzeugen müssen.</li><li><strong>Private Banking und Vermögensverwaltung,</strong> wo Diskretion am Set und saubere Freigabeprozesse so wichtig sind wie das Bild.</li><li><strong>Uhren- und Luxusbranche,</strong> inklusive Launchfilmen und Social Cut-downs, getaktet auf Messen wie Watches &amp; Wonders.</li><li><strong>Kongresse und Corporate Events</strong> in der Palexpo, im CICG oder im Hotel — Keynotes, Highlight-Reels, Speaker-Interviews.</li></ul><p>Wir haben für UBS, Siemens, Porsche, ON, FIFA und Philips gedreht — dieser Anspruch reist bei jedem Genfer Projekt mit.</p>"}, {"h2": "Französisch für die Romandie, Englisch für die Welt", "html": "<p>In Genf laufen Französisch und Englisch parallel — Ihr Video sollte beides können. Interviews führen und inszenieren wir intern auf Englisch, Deutsch und Spanisch; französische Untertitel und komplette französische Sprachversionen liefern wir über muttersprachliche Partner — übersetzt für den Westschweizer Markt, nicht bloss konvertiert. Jedes Projekt kommt mit Untertiteldateien und Social-Formaten, damit ein einziger Dreh Ihr Romand-Publikum, Ihren internationalen Hauptsitz und Ihre globalen Kanäle abdeckt. Auf Wunsch koordinieren wir zudem französische Voiceover-Aufnahmen mit Sprecherinnen und Sprechern aus der Romandie.</p><p>Und wenn Ihre Stakeholder auf Französisch abnehmen, planen wir das von Anfang an in den Freigabeprozess ein — statt es am Schluss anzuhängen.</p>"}, {"h2": "Budget, Timing und der nächste Schritt", "html": "<p>Genfer Projekte bewegen sich bei Viven zwischen CHF 4'000 für ein fokussiertes Interview- oder Eventvideo und CHF 80'000 für mehrtägige Markenkampagnen — immer als Fixofferte, nie nach offenem Aufwand. Den ersten Schnitt prüfen Sie rund zwei Wochen nach dem Dreh.</p><p>Gegründet wurde Viven vom Produzenten des ersten Schweizer Spielfilms auf Netflix — dieser filmische Hintergrund prägt Licht, Bildsprache und Schnitt auch bei Corporate-Projekten. Sagen Sie uns, was Ihr Video in Genf erreichen soll, und Sie erhalten innert weniger Tage ein konkretes Konzept mit Offerte. Viele Kundenbeziehungen beginnen mit einem klar umrissenen Pilotprojekt — ein Interviewtag, ein Hauptfilm — und wachsen, sobald Prozess und Resultat überzeugt haben.</p>"}]};
const title = { "de": d.title };
const description = { "de": d.description };
const langUrls = { "de": "/de/videoproduktion-genf/", "es": "/es/produccion-de-video-ginebra/", "en": "/en/video-production-geneva/" };
const SITE = 'https://www.viven.ch';
const ld = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: d.h1, description: d.description,
  provider: { '@id': SITE + '/#organization' },
  areaServed: { '@type': 'City', name: 'Geneva' },
  serviceType: 'Video production',
  url: SITE + '/de/videoproduktion-genf/',
});
---
<Base lang={lang} slug="videoproduktion-genf" active="services" title={title} description={description} singleLang={true} switchSlug="services" langUrls={langUrls}>
  <script type="application/ld+json" slot="jsonld" set:html={ld}></script>
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow">Genf — Schweiz</span>
      <h1 class="rsrc-h1">{d.h1}</h1>
      <p class="lead">{d.lead}</p>
    </div>
  </section>
  <section class="section">
    <div class="wrap rsrc-body">
      {d.sections.map((sec) => (
        <div class="rsrc-sec">
          <h2>{sec.h2}</h2>
          <div set:html={sec.html}></div>
        </div>
      ))}
      <div class="rsrc-ctabox">
        <div>
          <div class="rsrc-ctat">Ein Video in Genf geplant?</div>
          <p class="rsrc-ctas">Erzählen Sie uns von Ihrem Projekt — klare Offerte, meist innert eines Arbeitstages.</p>
        </div>
        <div class="rsrc-ctabtns">
          <a class="btn btn-primary" href="/de/contact/">Projekt starten</a>
          <a class="btn btn-ghost" href="/book/" target="_blank" rel="noopener">📅 15-Min-Call buchen</a>
        </div>
      </div>
      <p class="rsrc-linkout">Fragen Sie sich, was das kosten würde? Unser <a href="/de/videoproduktion-kosten-rechner/">Kostenrechner für Videos</a>.</p>
    </div>
  </section>
  <style is:global>
    .rsrc-h1{font-size:clamp(28px,4.4vw,44px)!important}
    .rsrc-linkout{margin:18px 0 0;padding:14px 18px;border:1px solid var(--line);border-radius:13px;background:var(--navy-800);color:var(--muted);font-size:14.5px;line-height:1.6}
    .rsrc-linkout a{color:var(--acid);font-weight:600;text-decoration:none}
    .rsrc-linkout a:hover{text-decoration:underline}
    .rsrc-body{max-width:820px}
    .rsrc-sec{margin-bottom:30px}
    .rsrc-sec h2{font-size:clamp(19px,2.6vw,24px);margin-bottom:12px}
    .rsrc-sec p{color:var(--muted);font-size:15.5px;line-height:1.75;margin-bottom:12px}
    .rsrc-sec ul{margin:0 0 12px 20px;color:var(--muted);font-size:15.5px;line-height:1.75}
    .rsrc-sec li{margin-bottom:6px}
    .rsrc-sec strong{color:var(--text)}
    .rsrc-ctabox{display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;border:1px solid var(--line-strong);background:var(--navy-800);border-radius:18px;padding:26px 28px;margin:40px 0 8px}
    .rsrc-ctat{font-family:'Space Grotesk';font-weight:700;font-size:20px;margin-bottom:6px}
    .rsrc-ctas{color:var(--muted);font-size:14px;max-width:460px;margin:0}
    .rsrc-ctabtns{display:flex;gap:10px;flex-wrap:wrap}
  </style>
</Base>
