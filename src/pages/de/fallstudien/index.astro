<Base lang={lang} slug="fallstudien" active="projects" singleLang={true} langUrls={{"en": "/en/case-studies/", "de": "/de/fallstudien/", "es": "/es/casos-de-exito/"}} title={title} description={description}>
<section class="page-hero"><div class="wrap"><div class="post-wrap">
  <span class="eyebrow">Fallstudien</span>
  <h1>Ausgewählte Arbeiten im Detail.</h1>
