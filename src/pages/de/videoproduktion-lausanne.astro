---
// Página de localización: Videoproduktion Lausanne — Olympic Capital, EPFL, Konzernsitze.
import Base from '../../layouts/Base.astro';
const lang = "de";
const d = {"title": "Videoproduktion Lausanne – Sport, Wissenschaft & Corporate Film | Viven", "description": "Videoproduktion in Lausanne, Olympic Capital mit EPFL und internationalen Konzernsitzen. Zürcher Crew oder lokales Team, Fixpreis, erster Schnitt in 2 Wochen.", "h1": "Videoproduktion Lausanne", "lead": "Viven ist eine Schweizer Videoproduktion, die Firmen- und Kampagnenfilme für Lausannes ungewöhnliche Mischung aus globalem Sport, Wissenschaft und Wirtschaft produziert. Als Olympic Capital beherbergt Lausanne das IOC und Dutzende internationale Sportverbände; die EPFL bildet das Zentrum einer schnell wachsenden Deep-Tech- und Life-Sciences-Szene; und mehrere multinationale Konzerne führen ihre globalen Geschäfte von hier aus, darunter Philip Morris International, für die wir bereits einen Markenfilm produziert haben. Crew und Equipment reisen ohne versteckte Zusatzkosten aus Zürich an, oder wir besetzen Ihren Dreh mit erfahrener Crew aus der Romandie. Den ersten Schnitt sehen Sie nach rund zwei Wochen.", "sections": [{"h2": "So produzieren wir in Lausanne", "html": "<p>Lausanne ist für unser Team kein Auswärtsspiel, sondern Routine. Sie wählen das Setup, das zu Projekt und Budget passt:</p><ul><li><strong>Zürcher Crew vor Ort:</strong> Unser Kernteam reist mit Equipment nach Lausanne — die Reisekosten stehen transparent in der Fixofferte, nicht als Überraschung auf der Schlussrechnung.</li><li><strong>Lokale Crew aus der Romandie:</strong> Für mehrtägige oder wiederkehrende Produktionen arbeiten wir mit bewährten Freelancern aus der Westschweiz, geführt von unserer Regie — lokale Nähe, gleichbleibende Qualität.</li></ul><p>Eine feste Produktionsleitung führt Ihr Projekt vom Briefing bis zur Abgabe, und wir scouten Locations — Olympic House, Campusgelände am See, EPFL-Labore, Kongressetagen — vor dem Drehtag, nicht erst am Drehtag. Braucht Ihre Produktion eine Verbandsakkreditierung, Campuszugang oder Drehgenehmigungen in geschützten Anlagen, klären wir das gemeinsam in der Vorbereitungswoche.</p>"}, {"h2": "Video für Lausannes Sport-, Wissenschafts- und Wirtschaftsszene", "html": "<p>Kaum eine Stadt verbindet ein olympisches Ökosystem mit einem Deep-Tech-Forschungscampus. Wir produzieren Video für beide Publika:</p><ul><li><strong>Internationale Sportverbände,</strong> von Highlight-Reels und Athletenporträts bis zu Kongress-Keynotes und Kampagnenfilmen, die auf globalen Broadcast-Kanälen funktionieren müssen.</li><li><strong>EPFL-Spinouts und Deep-Tech-Startups,</strong> bei denen Investoren- und Produkterklärvideos komplexe Wissenschaft wirklich verständlich machen müssen — nicht nur schön aussehen.</li><li><strong>Regionale Hauptsitze multinationaler Konzerne,</strong> darunter Philip Morris International, für die wir Markenfilme produziert haben, die wissenschaftliche Positionierung internationalen Publika vermitteln.</li><li><strong>Kongresse und Konferenzen</strong> im Beaulieu, im SwissTech Convention Center oder im Hotel — Keynote-Mitschnitte, Highlight-Reels, Delegierten-Interviews.</li></ul><p>Wir haben zudem für UBS, Siemens, Porsche, ON und FIFA gedreht — dieser Anspruch reist bei jedem Lausanner Projekt mit.</p>"}, {"h2": "Französisch für die Romandie, Englisch für die Welt", "html": "<p>In Lausanne laufen Französisch und Englisch parallel — olympische Verbände und EPFL-Forschungsgruppen agieren international, während lokale Teams und Stakeholder auf Französisch arbeiten. Interviews führen und inszenieren wir intern auf Englisch, Deutsch und Spanisch; französische Untertitel und komplette französische Sprachversionen liefern wir über muttersprachliche Partner — übersetzt für den Westschweizer Markt, nicht bloss konvertiert. Jedes Projekt kommt mit Untertiteldateien und Social-Formaten, damit ein einziger Dreh Ihr Romand-Publikum, Ihren internationalen Verband oder Hauptsitz und Ihre globalen Kanäle abdeckt.</p><p>Und wenn Ihre Stakeholder auf Französisch abnehmen, planen wir das von Anfang an in den Freigabeprozess ein — statt es am Schluss anzuhängen.</p>"}, {"h2": "Budget, Timing und der nächste Schritt", "html": "<p>Lausanner Projekte bewegen sich bei Viven zwischen CHF 4'000 für ein fokussiertes Interview- oder Eventvideo und CHF 80'000 für mehrtägige Markenkampagnen — immer als Fixofferte, nie nach offenem Aufwand. Den ersten Schnitt prüfen Sie rund zwei Wochen nach dem Dreh.</p><p>Gegründet wurde Viven vom Produzenten des ersten Schweizer Spielfilms auf Netflix — dieser filmische Hintergrund prägt Licht, Bildsprache und Schnitt bei Corporate- ebenso wie bei Sportinhalten. Sagen Sie uns, was Ihr Video in Lausanne erreichen soll, und Sie erhalten innert weniger Tage ein konkretes Konzept mit Offerte. Viele Kundenbeziehungen beginnen mit einem klar umrissenen Pilotprojekt — ein Interviewtag, ein Hauptfilm — und wachsen, sobald Prozess und Resultat überzeugt haben.</p>"}]};
const title = { "de": d.title };
const description = { "de": d.description };
const langUrls = { "de": "/de/videoproduktion-lausanne/", "en": "/en/video-production-lausanne/", "es": "/es/produccion-de-video-lausana/" };
const SITE = 'https://www.viven.ch';
const ld = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: d.h1, description: d.description,
  provider: { '@id': SITE + '/#organization' },
  areaServed: { '@type': 'City', name: 'Lausanne' },
  serviceType: 'Video production',
  url: SITE + '/de/videoproduktion-lausanne/',
});
---
<Base lang={lang} slug="videoproduktion-lausanne" active="services" title={title} description={description} singleLang={true} switchSlug="services" langUrls={langUrls}>
  <script type="application/ld+json" slot="jsonld" set:html={ld}></script>
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow">Lausanne — Schweiz</span>
      <h1 class="rsrc-h1">{d.h1}</h1>
      <p class="lead">{d.lead}</p>
    </div>
  </section>
  <section class="section">
    <div class="wrap rsrc-body">
      {d.sections.map((sec) => (
        <div class="rsrc-sec">
          <h2>{sec.h2}</h2>
          <div set:html={sec.html}></div>
        </div>
      ))}
      <div class="rsrc-ctabox">
        <div>
          <div class="rsrc-ctat">Ein Video in Lausanne geplant?</div>
          <p class="rsrc-ctas">Erzählen Sie uns von Ihrem Projekt — klare Offerte, meist innert eines Arbeitstages.</p>
        </div>
        <div class="rsrc-ctabtns">
          <a class="btn btn-primary" href="/de/contact/">Projekt starten</a>
          <a class="btn btn-ghost" href="/book/" target="_blank" rel="noopener">📅 15-Min-Call buchen</a>
        </div>
      </div>
      <p class="rsrc-linkout">Fragen Sie sich, was das kosten würde? Unser <a href="/de/videoproduktion-kosten-rechner/">Kostenrechner für Videos</a>.</p>
    </div>
  </section>
  <style is:global>
    .rsrc-h1{font-size:clamp(28px,4.4vw,44px)!important}
    .rsrc-linkout{margin:18px 0 0;padding:14px 18px;border:1px solid var(--line);border-radius:13px;background:var(--navy-800);color:var(--muted);font-size:14.5px;line-height:1.6}
    .rsrc-linkout a{color:var(--acid);font-weight:600;text-decoration:none}
    .rsrc-linkout a:hover{text-decoration:underline}
    .rsrc-body{max-width:820px}
    .rsrc-sec{margin-bottom:30px}
    .rsrc-sec h2{font-size:clamp(19px,2.6vw,24px);margin-bottom:12px}
    .rsrc-sec p{color:var(--muted);font-size:15.5px;line-height:1.75;margin-bottom:12px}
    .rsrc-sec ul{margin:0 0 12px 20px;color:var(--muted);font-size:15.5px;line-height:1.75}
    .rsrc-sec li{margin-bottom:6px}
    .rsrc-sec strong{color:var(--text)}
    .rsrc-ctabox{display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;border:1px solid var(--line-strong);background:var(--navy-800);border-radius:18px;padding:26px 28px;margin:40px 0 8px}
    .rsrc-ctat{font-family:'Space Grotesk';font-weight:700;font-size:20px;margin-bottom:6px}
    .rsrc-ctas{color:var(--muted);font-size:14px;max-width:460px;margin:0}
    .rsrc-ctabtns{display:flex;gap:10px;flex-wrap:wrap}
  </style>
</Base>
