---
import Base from '../../../layouts/Base.astro';
import Testimonials from '../../../components/Testimonials.astro';
import { localePath } from '../../../i18n.js';
const lang = "de";
const p = (s) => localePath(lang, s);
const title = {"de":"Unsere Kunden | Viven"};
const description = {"de":"Von UBS und Siemens bis FIFA und Porsche: die Marken, die ihre Videoproduktion in der Schweiz Viven anvertrauen."};
---
<Base lang={lang} slug="kunden" active="" singleLang={true} langUrls={{"en": "/en/clients/", "de": "/de/kunden/", "es": "/es/clientes/"}} title={title} description={description}>
<section class="page-hero"><div class="wrap"><div class="post-wrap">
  <span class="eyebrow">Unsere Kunden</span>
  <h1>Marken, die Viven vertrauen.</h1>
  <p class="lead">Globale Marken, Schweizer Marktführer und ambitionierte Scale-ups — über 100 Produktionen, ausschliesslich 5-Sterne-Bewertungen.</p>
</div></div></section>
<section class="sec" style="padding-top:20px"><div class="wrap">
  <div class="cl-wall">
      <div class="cl-name reveal">UBS</div>
      <div class="cl-name reveal">Siemens</div>
      <div class="cl-name reveal">Netflix</div>
      <div class="cl-name reveal">FIFA</div>
      <div class="cl-name reveal">Porsche</div>
      <div class="cl-name reveal">Philips</div>
      <div class="cl-name reveal">ON</div>
      <div class="cl-name reveal">KPMG</div>
      <div class="cl-name reveal">V-ZUG</div>
      <div class="cl-name reveal">Kanebo Sensai</div>
      <div class="cl-name reveal">SV Group</div>
      <div class="cl-name reveal">Carvolution</div>
      <div class="cl-name reveal">Meteomatics</div>
      <div class="cl-name reveal">SIGG</div>
      <div class="cl-name reveal">Franke</div>
      <div class="cl-name reveal">Merkle</div>
      <div class="cl-name reveal">PMI Science</div>
      <div class="cl-name reveal">ANYbotics</div>
      <div class="cl-name reveal">Stadtspital Zürich</div>
      <div class="cl-name reveal">LEM</div>
      <div class="cl-name reveal">Vidby</div>
      <div class="cl-name reveal">Kyan Health</div>
      <div class="cl-name reveal">Nile</div>
      <div class="cl-name reveal">Sevensense</div>
      <div class="cl-name reveal">NCCR Robotics</div>
      <div class="cl-name reveal">TomFit</div>
      <div class="cl-name reveal">Villa Málaga</div>
      <div class="cl-name reveal">Himmelfahrtskommando</div>
  </div>
  <p style="text-align:center;margin-top:34px">Die Arbeiten hinter den Namen sehen? <a class="book-call" href={p('projects')}>Unsere Projekte ansehen →</a></p>
</div></section>
<Testimonials lang={lang} />
<style is:global>
.cl-wall{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:14px}
.cl-name{border:1px solid rgba(255,255,255,.12);border-radius:14px;padding:26px 12px;text-align:center;font-weight:800;font-size:17px;letter-spacing:.4px;opacity:.92;transition:.25s}
.cl-name:hover{border-color:var(--acid,#ddf98f);opacity:1;transform:translateY(-2px)}
@media(max-width:640px){.cl-wall{grid-template-columns:repeat(2,1fr)}.cl-name{font-size:14.5px;padding:18px 8px}}
</style>
</Base>
