---
import Base from '../../../layouts/Base.astro';
import Testimonials from '../../../components/Testimonials.astro';
import CalcBanner from '../../../components/CalcBanner.astro';
const lang = "de";
const title = {"de":"Blog — Insights zur Videoproduktion | Viven"};
const description = {"de":"Praxisnahe Guides zu Marken-, Produkt- und Employer-Branding-Video — von Viven, Videoproduktion aus Zürich."};

// Todos los posts se auto-descubren de su propio contenido — nada de cards a mano
// (esas quedaban desincronizadas: mismo thumbnail en 2 posts distintos, pedido
// explícito de arreglar: "como puede ser que la mayoria de blogs en aleman
// tengan la misma imagen"). El fallback a la imagen del JSON-LD cubre los posts
// viejos que no tienen <img> inline en el cuerpo.
// Kategorie-Filter (expliziter Wunsch: "el blog sigue sin filtros, es
// necesario que la gente entienda que puede leer"): die Kategorie kommt aus
// demselben Eyebrow, das jeder Post schon über dem Titel hat — kein neues
// Feld nötig. Die wenigen Posts ohne erkennbares Eyebrow landen in
// "Weiteres" statt zu verschwinden.
const CAT_DEFS = [
  { key: 'brand', label: 'Markenfilm', match: /markenfilm/i },
  { key: 'product', label: 'Produktvideo', match: /produktvideo/i },
  { key: 'employer', label: 'Employer Branding', match: /employer branding/i },
  { key: 'howto', label: 'How-To & Tutorial', match: /how-to/i },
  { key: 'social', label: 'Social Media', match: /social media/i },
  { key: 'corporate', label: 'Corporate & Events', match: /corporate/i },
  { key: 'industry', label: 'Branchen-Insight', match: /branchen-?insight|brancheneinblick/i },
];
const OTHER_CAT = { key: 'other', label: 'Weiteres' };
function categorize(eyebrow) {
  for (const c of CAT_DEFS) if (c.match.test(eyebrow)) return c;
  return OTHER_CAT;
}
const rawPosts = import.meta.glob('./*/index.astro', { query: '?raw', import: 'default', eager: true });
const autoPosts = Object.entries(rawPosts).map(([path, raw]) => {
  const slug = path.split('/')[1];
  const jstr = (re) => { const m = String(raw).match(re); if (!m) return ''; try { return JSON.parse(m[1]); } catch { return ''; } };
  const title = String(jstr(/const title = \{"[a-z]{2}":("(?:[^"\\]|\\.)*")\}/) || slug).replace(/ \| Viven$/, '');
  const desc = String(jstr(/const description = \{"[a-z]{2}":("(?:[^"\\]|\\.)*")\}/) || '');
  const imgMatch = String(raw).match(/<img src="([^"]+)"/) || String(raw).match(/image\\":\\"([^\\]+)/);
  const img = (imgMatch && imgMatch[1]) || '/projects/siemens-shaping-the-future-together-employer-branding-campaign/02-RORES_clean_VIVEN.00_13_13_20.Still042.jpg';
  const date = (String(raw).match(/datePublished[^0-9]{0,6}([0-9]{4}-[0-9]{2}-[0-9]{2}[0-9T:.+]*)/) || [])[1] || '';
  const eyebrowMatch = String(raw).match(/class="eyebrow">([^<]*)</);
  const cat = categorize(eyebrowMatch ? eyebrowMatch[1] : '');
  return { slug, title, desc, img, date, cat: cat.key };
}).sort((a, b) => (b.date || '').localeCompare(a.date || ''));
const catCounts = {};
autoPosts.forEach((p) => { catCounts[p.cat] = (catCounts[p.cat] || 0) + 1; });
const chips = [...CAT_DEFS, OTHER_CAT].filter((c) => catCounts[c.key] > 0);
---
<Base lang={lang} slug="blog" active="blog" singleLang={true} title={title} description={description}>
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow">Blog</span>
      <h1>Video, das wirkt, <span class="hl">erklärt.</span></h1>
      <p class="lead">Praxisnahe Guides zu Marken-, Produkt- und Employer-Branding-Video — von Viven, Videoproduktion aus Zürich.</p>
    </div>
  </section>
  <div class="blog-filters-shell">
    <div class="wrap">
      <div class="blog-filters-label">Nach Kategorie filtern</div>
      <div class="blog-filters-row" id="blog-filters">
        <button class="chip active" data-cat="all" type="button">Alle <span class="n">{autoPosts.length}</span></button>
        {chips.map((c) => (
          <button class="chip" data-cat={c.key} type="button">{c.label} <span class="n">{catCounts[c.key]}</span></button>
        ))}
      </div>
    </div>
  </div>
  <section class="sec" style="padding-top:24px">
    <div class="wrap">
      <p class="blog-result-count" id="blog-result-count"></p>
      <div class="blog-grid" id="blog-grid">
      {autoPosts.map((post) => (
        <a href={'/de/blog/' + post.slug + '/'} class="blog-card reveal" data-cat={post.cat}>
          <div class="blog-card-img"><img src={post.img} loading="lazy" decoding="async" width="480" height="270" alt={post.title} /></div>
          <div class="blog-card-body"><h3>{post.title}</h3><p>{post.desc}</p><span class="more">Weiterlesen →</span></div>
        </a>
      ))}
      </div>
      <p class="blog-empty" id="blog-empty" hidden>Noch keine Posts in dieser Kategorie.</p>
    </div>
  </section>
<CalcBanner lang={lang} />
<Testimonials lang={lang} />
<script>
  const chips = [...document.querySelectorAll('#blog-filters .chip')];
  const cards = [...document.querySelectorAll('#blog-grid .blog-card')];
  const resultCount = document.getElementById('blog-result-count');
  const empty = document.getElementById('blog-empty');
  const total = cards.length;
  function apply(cat, label) {
    let shown = 0;
    cards.forEach((card) => {
      const match = cat === 'all' || card.dataset.cat === cat;
      card.hidden = !match;
      if (match) shown++;
    });
    resultCount.textContent = cat === 'all' ? `Zeigt alle ${total} Beiträge` : `Zeigt ${shown} von ${total} Beiträgen in "${label}"`;
    empty.hidden = shown !== 0;
  }
  chips.forEach((chip) => chip.addEventListener('click', () => {
    chips.forEach((c) => c.classList.remove('active'));
    chip.classList.add('active');
    apply(chip.dataset.cat, chip.textContent.replace(/\s*\d+\s*$/, '').trim());
  }));
  apply('all', 'Alle');
</script>
</Base>
