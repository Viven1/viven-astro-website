---
// Production services / line production para productoras que ruedan en Suiza.
// URL EN = la del sitio viejo (Google ya la conocía; el redirect a /services/ se quitó).
import Base from '../../layouts/Base.astro';
const lang = "de";
const d = {"title": "Produktionsservices Schweiz – Filmproduktion Zürich | Viven", "description": "Produktionsservices in der Schweiz: erfahrene Crew, Drehbewilligungen, Casting und komplette Logistik ab Zürich. Ein Kontakt, klares Budget in CHF.", "h1": "Produktionsservices in der Schweiz — Ihre lokale Filmproduktion in Zürich", "lead": "Wenn Sie einen Dreh in die Schweiz bringen, ist Viven Ihr lokaler Produktionspartner vor Ort. Von unserem Sitz an der Zeughausstrasse 31 in Zürich stellen wir erfahrene Crew, Kamera- und Lichtpakete, Drehbewilligungen, Casting und die komplette Logistik für ausländische Produktionsfirmen, Agenturen und Marken — ein Ansprechpartner, ein transparentes Budget in CHF und ein Team, das für UBS, Siemens, Porsche und die FIFA produziert hat.", "sections": [{"h2": "Ihre lokale Produktionsfirma in der Schweiz", "html": "<p>Viven AG ist eine Filmproduktion in Zürich, die als Schweizer Einheit Ihrer Produktion arbeitet: Ihre Kreation, Ihre Regie, unsere Umsetzung vor Ort. Wir haben für <strong>UBS, Siemens, Porsche, ON, FIFA, Philips und Kanebo</strong> produziert — die Kanebo-Kampagnen kamen aus Japan, wir wissen also genau, wie man eine lokale Unit in eine internationale Pipeline einbindet: klare Reportinglinien, Deliverables passend zu Ihrem Post-Workflow, keine Reibungsverluste. Gründer Sebastian Cepeda produzierte den ersten Schweizer Spielfilm auf Netflix — diese Disziplin in Planung, Budget und Setführung prägt jeden Filmproduktion-Service, den wir übernehmen. Wir drehen in der ganzen Schweiz und in Europa.</p>"}, {"h2": "Erfahrene lokale Crew und Equipment, drehbereit", "html": "<p>Sie schicken das Briefing; wir besetzen den Dreh mit Department Heads, mit denen wir jede Woche arbeiten.</p><ul><li><strong>Crew:</strong> erfahrene DOP, Gaffer und Tonmeister als Kernteam, ergänzt durch Kameraassistenz, Grip und Produktionsassistenz nach Bedarf.</li><li><strong>Kamera:</strong> Sony-FX6-Pakete mit Cine-Optiken.</li><li><strong>Licht und Bewegung:</strong> LED-Lichtpakete und DJI-Ronin-Stabilisierung.</li><li><strong>Transport:</strong> Produktions-Van inklusive — Equipment und Crew bewegen sich als eine Einheit.</li></ul><p>Alles wird als ein Paket offeriert. Sie jagen nicht über Zeitzonen hinweg Verleihern, Versicherungen und Freelancern hinterher — wir verantworten die ganze Linie, mit einem Setup, das für Werbung, Corporate-Formate und dokumentarische Projekte gleichermassen funktioniert.</p>"}, {"h2": "Drehbewilligungen, Locations und Casting", "html": "<p>Die Schweiz belohnt Vorbereitung: Städte, Verkehrsbetriebe und geschützte Landschaften haben eigene Bewilligungsregeln, und Vorlaufzeiten entscheiden, ob Ihr Zeitplan hält. Wir kümmern uns um <strong>Drehbewilligungen</strong> in Zürich und in Städten im ganzen Land und scouten und sichern Locations passend zu Ihren Boards — urbane Strassen und Dächer, Seeufer, Alpenpässe und Gipfel sowie Studios, wenn Sie kontrollierte Bedingungen brauchen. Zudem übernehmen wir das <strong>lokale Casting</strong>, von professionellen Schauspielern bis zu Real People, inklusive Releases und Nutzungsrechten — sauber dokumentiert. Auf Wunsch erhalten Sie vorab Scouting-Fotos und Optionen pro Motiv, damit Sie Entscheidungen aus der Distanz sicher treffen können.</p>"}, {"h2": "Komplette Logistik und zweisprachiger Fixer für ausländische Teams", "html": "<p>Line Production heisst: Die unglamouröse Arbeit ist erledigt, bevor Ihr Team landet.</p><ul><li>Transport, Unterkünfte und Per Diems für Cast und Crew</li><li>Produktionsversicherung und Risikodokumentation</li><li>Drehpläne, Dispositionen und Umzüge zwischen Locations</li><li>Ein <strong>zweisprachiger Producer und Fixer</strong>, der Ihr Team von der Vorbereitung bis zum Drehschluss begleitet</li></ul><p>Wir produzieren auf Englisch, Deutsch und Spanisch — zwischen Ihrer Agentur, dem Kunden und einem Schweizer Locationgeber geht nichts verloren. Und Sie erhalten <strong>einen Ansprechpartner und ein transparentes Budget in CHF</strong>: aufgeschlüsselt, realistisch, am Set verteidigt.</p>"}, {"h2": "Optionale Postproduktion in Zürich — und so starten Sie", "html": "<p>Wenn Sie in der Schweiz finalisieren möchten, bieten wir Schnitt, Color Grading und VFX im Haus, dazu Untertitel auf Englisch, Deutsch und Spanisch. Bleibt die Post bei Ihrem Team, liefern wir organisiertes, gesichertes Material mit Kamera- und Tonreports direkt nach Drehschluss. So bleibt Ihre Timeline auch dann stabil, wenn zwischen Ihnen und Zürich mehrere Zeitzonen liegen.</p><p>Schicken Sie uns Ihr Skript, Treatment oder Ihre Shotlist samt Drehfenster. Innert weniger Tage erhalten Sie ein realistisches CHF-Budget, einen Crew-Plan und eine Einschätzung der Bewilligungen — und ein Produktionsbüro in Zürich, das Ihren Dreh wie den eigenen behandelt.</p>"}]};
const title = { "de": d.title };
const description = { "de": d.description };
const langUrls = {"en": "/en/video-production-services-zurich/", "de": "/de/produktionsservices-schweiz/", "es": "/es/servicios-de-produccion-audiovisual-suiza/"};
const SITE = 'https://www.viven.ch';
const ld = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: d.h1, description: d.description,
  provider: { '@id': SITE + '/#organization' },
  areaServed: { '@type': 'Country', name: 'Switzerland' },
  serviceType: 'Film and video production services',
  url: SITE + '/de/produktionsservices-schweiz/',
});
---
<Base lang={lang} slug="produktionsservices-schweiz" active="services" title={title} description={description} singleLang={true} switchSlug="services" langUrls={langUrls}>
  <script type="application/ld+json" slot="jsonld" set:html={ld}></script>
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow">Produktionsservices — Schweiz</span>
      <h1 class="rsrc-h1">{d.h1}</h1>
      <p class="lead">{d.lead}</p>
    </div>
  </section>
  <section class="section">
    <div class="wrap rsrc-body">
      {d.sections.map((sec) => (
        <div class="rsrc-sec">
          <h2>{sec.h2}</h2>
          <div set:html={sec.html}></div>
        </div>
      ))}
      <div class="rsrc-ctabox">
        <div>
          <div class="rsrc-ctat">Dreh in der Schweiz geplant?</div>
          <p class="rsrc-ctas">Senden Sie uns Skript oder Treatment und Ihr Drehfenster — klares CHF-Budget, meist innert zwei Arbeitstagen.</p>
        </div>
        <div class="rsrc-ctabtns">
          <a class="btn btn-primary" href="/de/contact/">Gespräch starten</a>
          <a class="btn btn-ghost" href="/book/" target="_blank" rel="noopener">📅 15-Min-Call buchen</a>
        </div>
      </div>
      <p class="rsrc-linkout">Fragen Sie sich, was das kosten würde? Unser <a href="/de/videoproduktion-kosten-rechner/">Kostenrechner für Videos</a>.</p>
    </div>
  </section>
  <style is:global>
    .rsrc-linkout{margin:18px 0 0;padding:14px 18px;border:1px solid var(--line);border-radius:13px;background:var(--navy-800);color:var(--muted);font-size:14.5px;line-height:1.6}
    .rsrc-linkout a{color:var(--acid);font-weight:600;text-decoration:none}
    .rsrc-linkout a:hover{text-decoration:underline}
    .rsrc-h1{font-size:clamp(28px,4.4vw,44px)!important}
    .rsrc-body{max-width:820px}
    .rsrc-sec{margin-bottom:30px}
    .rsrc-sec h2{font-size:clamp(19px,2.6vw,24px);margin-bottom:12px}
    .rsrc-sec p{color:var(--muted);font-size:15.5px;line-height:1.75;margin-bottom:12px}
    .rsrc-sec ul{margin:0 0 12px 20px;color:var(--muted);font-size:15.5px;line-height:1.75}
    .rsrc-sec li{margin-bottom:6px}
    .rsrc-sec strong{color:var(--text)}
    .rsrc-ctabox{display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;border:1px solid var(--line-strong);background:var(--navy-800);border-radius:18px;padding:26px 28px;margin:40px 0 8px}
    .rsrc-ctat{font-family:'Space Grotesk';font-weight:700;font-size:20px;margin-bottom:6px}
    .rsrc-ctas{color:var(--muted);font-size:14px;max-width:460px;margin:0}
    .rsrc-ctabtns{display:flex;gap:10px;flex-wrap:wrap}
  </style>
</Base>
