<Base lang={lang} slug={slug} active="projects" singleLang={true} langUrls={{"en":"/en/case-study-how-viven-helped-siemens-switzerland-amplify-their-employer-branding/","de":"/de/case-study-wie-viven-siemens-schweiz-dabei-half-sein-employer-branding-zu-staerken/","es":"/es/caso-de-exito-como-viven-ayudo-a-siemens-a-ampliar-su-marca-de-empleador/"}} title={title} description={description}>
