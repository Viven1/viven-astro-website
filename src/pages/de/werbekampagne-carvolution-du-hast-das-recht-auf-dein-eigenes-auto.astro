---
import Base from '../../layouts/Base.astro';
import CaseStudy from '../../components/CaseStudy.astro';
import projects from '../../data/projects.json';
const project = projects.find((x) => x.slug === "de/werbekampagne-carvolution-du-hast-das-recht-auf-dein-eigenes-auto");
const lang = "de";
const SITE = "https://www.viven.ch";
const title = {"de": "Werbekampagne Carvolution - \"Du hast das Recht auf dein eigenes Auto\" | Viven"};
const description = {"de": "\"Du hast das Recht auf dein eigenes Auto, mach mit bei Carvolution\", bricht mit den üblichen Werbemethoden, indem es die eigenen Mitarbeiter des Unternehmens "};
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VideoObject',
      name: project.headline,
      description: description[lang],
      thumbnailUrl: SITE + project.stills[0],
      embedUrl: 'https://player.vimeo.com/video/' + project.vimeo,
      uploadDate: "2021-03-01",
      publisher: { '@id': SITE + '/#organization' },
    },
    {
      '@type': 'CreativeWork',
      name: project.headline,
      about: project.client,
      inLanguage: lang,
      creator: { '@id': SITE + '/#organization' },
      url: SITE + "/de/werbekampagne-carvolution-du-hast-das-recht-auf-dein-eigenes-auto/",
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: SITE + '/' + lang + '/projects/' },
        { '@type': 'ListItem', position: 3, name: project.headline, item: SITE + "/de/werbekampagne-carvolution-du-hast-das-recht-auf-dein-eigenes-auto/" },
      ],
    },
  ],
};
---
<Base lang={lang} slug="projects" active="projects" singleLang={true} switchSlug="projects" canonicalPath={"/de/werbekampagne-carvolution-du-hast-das-recht-auf-dein-eigenes-auto/"} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(ld)}></script>
  <CaseStudy project={project} lang={lang} />
</Base>
