---
// Página de localización: Videoproduktion Basel — hub farmacéutico/life-sciences.
import Base from '../../layouts/Base.astro';
const lang = "de";
const d = {"title": "Videoproduktion Basel – Life Sciences & Corporate Film | Viven", "description": "Videoproduktion in Basel für Pharma-, Life-Sciences- und Industrieunternehmen. Zürcher Crew oder lokales Team, Fixpreis, erster Schnitt in 2 Wochen.", "h1": "Videoproduktion Basel", "lead": "Viven ist eine Schweizer Videoproduktion, die regelmässig in Basel dreht — Standort einiger der grössten Pharma- und Life-Sciences-Unternehmen der Welt, mit einer langen Chemietradition und der globalen Kreativszene der Art Basel. Wir produzieren Firmenvideos, interne Kommunikation und Kampagnenfilme für Organisationen, bei denen Präzision genauso zählt wie Bildsprache. Crew und Equipment reisen ohne versteckte Zusatzkosten aus Zürich an — in unter einer Stunde mit dem Zug — oder wir besetzen Ihren Dreh mit erfahrener lokaler Crew. Den ersten Schnitt sehen Sie nach rund zwei Wochen.", "sections": [{"h2": "So produzieren wir in Basel", "html": "<p>Basel liegt unter einer Stunde von unserem Zürcher Standort entfernt — ein Tagesausflug taucht selten als eigene Position auf Ihrer Rechnung auf. Sie wählen das Setup, das zu Ihrem Projekt passt:</p><ul><li><strong>Zürcher Crew vor Ort:</strong> Unser Kernteam reist mit Equipment nach Basel — die Reisekosten stehen transparent in der Fixofferte, nicht als Überraschung auf der Schlussrechnung.</li><li><strong>Lokale Crew:</strong> Für mehrtägige oder wiederkehrende Produktionen arbeiten wir mit bewährten Freelancern aus der Region, geführt von unserer Regie — lokale Verfügbarkeit, gleichbleibende Qualität.</li></ul><p>Eine feste Produktionsleitung führt Ihr Projekt vom Briefing bis zur Abgabe, und wir scouten Locations — Labore, Campusgelände, Messehallen, Büros am Rhein — vor dem Drehtag, nicht erst am Drehtag. Braucht Ihre Produktion Zutrittsfreigaben, Badges oder Drehgenehmigungen in geschützten Anlagen, klären wir das gemeinsam in der Vorbereitungswoche.</p>"}, {"h2": "Video für Basels Life-Sciences- und Kreativwirtschaft", "html": "<p>Kaum eine Schweizer Stadt verbindet ein derart technisches Publikum mit einem derart designaffinen. Wir produzieren Video, das in beiden Welten trägt:</p><ul><li><strong>Pharma und Life Sciences,</strong> wo Botschaften rechtliche und medizinische Prüfung überstehen müssen, ohne an Klarheit zu verlieren — interne Schulungen, R&amp;D-Storytelling, Investoren- und Kongressinhalte.</li><li><strong>Chemie- und Industrieunternehmen,</strong> bei denen Prozess- und Sicherheitskommunikation genauso wichtig ist wie der Markenfilm.</li><li><strong>Art Basel und die Kreativbranche,</strong> wo visuelle Handwerkskunst und Timing die gesamte Botschaft tragen.</li><li><strong>Kongresse und Messen</strong> in der Messe Basel — Keynote-Mitschnitte, Ausstellerfilme, Highlight-Reels.</li></ul><p>Unsere eigene Arbeit im Gesundheitsbereich — darunter Spital- und Workplace-Wellbeing-Filme für das Stadtspital Zürich und Kyan Health — zeigt, dass wir mit klinischen Umgebungen, Patient:innen-Einwilligung und Freigabeprozessen vertraut sind. Wir haben zudem für UBS, Siemens, Porsche, ON, FIFA und Philips gedreht — dieser Anspruch reist bei jedem Basler Projekt mit.</p>"}, {"h2": "Deutsche Präzision, englische Lieferung", "html": "<p>Basel lebt im Alltag auf Baseldytsch, im Sitzungszimmer auf Hochdeutsch oder Englisch — und Pharma- und Life-Sciences-Content muss meist direkt an ein globales Hauptquartier gehen, unabhängig vom Drehort. Wir führen Regie und drehen intern auf Deutsch, Englisch und Spanisch, damit Fach- und Wissenschaftsbegriffe über den gesamten Prozess korrekt bleiben, statt nachträglich in der Übersetzung neu interpretiert zu werden. Jedes Projekt kommt mit Untertiteldateien und plattformgerechten Cut-downs für interne Portale, Kongress-Screens und Social-Kanäle.</p><p>Läuft Ihre Freigabe über ein globales Medical- oder Legal-Team, planen wir diese zusätzliche Prüfschicht von Anfang an in den Zeitplan ein — statt sie als Verzögerung zu behandeln.</p>"}, {"h2": "Budget, Timing und der nächste Schritt", "html": "<p>Basler Projekte bewegen sich bei Viven zwischen CHF 4'000 für ein fokussiertes Interview- oder Eventvideo und CHF 80'000 für mehrtägige Corporate- oder Kampagnenarbeit — immer als Fixofferte, nie nach offenem Aufwand. Den ersten Schnitt prüfen Sie rund zwei Wochen nach dem Dreh.</p><p>Gegründet wurde Viven vom Produzenten des ersten Schweizer Spielfilms auf Netflix — dieser filmische Hintergrund prägt Licht, Bildsprache und Schnitt auch bei den technischsten Corporate-Projekten. Sagen Sie uns, was Ihr Video in Basel erreichen soll, und Sie erhalten innert weniger Tage ein konkretes Konzept mit Offerte. Viele Kundenbeziehungen beginnen mit einem klar umrissenen Pilotprojekt — ein Interviewtag, ein internes Schulungsvideo — und wachsen, sobald Prozess und Resultat überzeugt haben.</p>"}]};
const title = { "de": d.title };
const description = { "de": d.description };
const langUrls = { "de": "/de/videoproduktion-basel/", "en": "/en/video-production-basel/", "es": "/es/produccion-de-video-basilea/" };
const SITE = 'https://www.viven.ch';
const ld = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: d.h1, description: d.description,
  provider: { '@id': SITE + '/#organization' },
  areaServed: { '@type': 'City', name: 'Basel' },
  serviceType: 'Video production',
  url: SITE + '/de/videoproduktion-basel/',
});
---
<Base lang={lang} slug="videoproduktion-basel" active="services" title={title} description={description} singleLang={true} switchSlug="services" langUrls={langUrls}>
  <script type="application/ld+json" slot="jsonld" set:html={ld}></script>
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow">Basel — Schweiz</span>
      <h1 class="rsrc-h1">{d.h1}</h1>
      <p class="lead">{d.lead}</p>
    </div>
  </section>
  <section class="section">
    <div class="wrap rsrc-body">
      {d.sections.map((sec) => (
        <div class="rsrc-sec">
          <h2>{sec.h2}</h2>
          <div set:html={sec.html}></div>
        </div>
      ))}
      <div class="rsrc-ctabox">
        <div>
          <div class="rsrc-ctat">Ein Video in Basel geplant?</div>
          <p class="rsrc-ctas">Erzählen Sie uns von Ihrem Projekt — klare Offerte, meist innert eines Arbeitstages.</p>
        </div>
        <div class="rsrc-ctabtns">
          <a class="btn btn-primary" href="/de/contact/">Projekt starten</a>
          <a class="btn btn-ghost" href="/book/" target="_blank" rel="noopener">📅 15-Min-Call buchen</a>
        </div>
      </div>
    </div>
  </section>
  <style is:global>
    .rsrc-h1{font-size:clamp(28px,4.4vw,44px)!important}
    .rsrc-body{max-width:820px}
    .rsrc-sec{margin-bottom:30px}
    .rsrc-sec h2{font-size:clamp(19px,2.6vw,24px);margin-bottom:12px}
    .rsrc-sec p{color:var(--muted);font-size:15.5px;line-height:1.75;margin-bottom:12px}
    .rsrc-sec ul{margin:0 0 12px 20px;color:var(--muted);font-size:15.5px;line-height:1.75}
    .rsrc-sec li{margin-bottom:6px}
    .rsrc-sec strong{color:var(--text)}
    .rsrc-ctabox{display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;border:1px solid var(--line-strong);background:var(--navy-800);border-radius:18px;padding:26px 28px;margin:40px 0 8px}
    .rsrc-ctat{font-family:'Space Grotesk';font-weight:700;font-size:20px;margin-bottom:6px}
    .rsrc-ctas{color:var(--muted);font-size:14px;max-width:460px;margin:0}
    .rsrc-ctabtns{display:flex;gap:10px;flex-wrap:wrap}
  </style>
</Base>
