---
import Base from '../../layouts/Base.astro';
import CaseStudy from '../../components/CaseStudy.astro';
import projects from '../../data/projects.json';
const project = projects.find((x) => x.slug === "de/stadtspital-zurich-mis-spital-mis-laebe-employer-branding-social-media");
const lang = "de";
const SITE = "https://www.viven.ch";
const title = {"de": "Stadtspital Zurich — Mis Spital. Mis Läbe. | Viven"};
const description = {"de": "Tauch ein in das Leben von Fachleuten aus dem Gesundheitswesen, die das Stadtspital Zürich nicht nur zu einem Arbeitsplatz machen, sondern auch zu einem Leben"};
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VideoObject',
      name: project.headline,
      description: description[lang],
      thumbnailUrl: SITE + project.stills[0],
      embedUrl: 'https://player.vimeo.com/video/' + project.vimeo,
      uploadDate: "2023-11-01T00:00:00+00:00",
      publisher: { '@id': SITE + '/#organization' },
    },
    {
      '@type': 'CreativeWork',
      name: project.headline,
      about: project.client,
      inLanguage: lang,
      creator: { '@id': SITE + '/#organization' },
      url: SITE + "/de/stadtspital-zurich-mis-spital-mis-laebe-employer-branding-social-media/",
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: SITE + '/' + lang + '/projects/' },
        { '@type': 'ListItem', position: 3, name: project.headline, item: SITE + "/de/stadtspital-zurich-mis-spital-mis-laebe-employer-branding-social-media/" },
      ],
    },
  ],
};
---
<Base lang={lang} slug="projects" active="projects" singleLang={true} switchSlug="projects" canonicalPath={"/de/stadtspital-zurich-mis-spital-mis-laebe-employer-branding-social-media/"} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(ld)}></script>
  <CaseStudy project={project} lang={lang} />
</Base>
