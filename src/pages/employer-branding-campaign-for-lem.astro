---
import Base from '../layouts/Base.astro';
import CaseStudy from '../components/CaseStudy.astro';
import projects from '../data/projects.json';
const project = projects.find((x) => x.slug === "employer-branding-campaign-for-lem");
const lang = "en";
const SITE = "https://www.viven.ch";
const title = {"en": "Employer-Branding-Campaign for LEM | Viven"};
const description = {"en": "LEM partnered with UNIVERSUM and Viven to create an engaging employer branding video, showcasing its culture and innovative spirit to attract top talent."};
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VideoObject',
      name: project.headline,
      description: description[lang],
      thumbnailUrl: SITE + project.stills[0],
      embedUrl: 'https://player.vimeo.com/video/' + project.vimeo,
      uploadDate: "2022-08-01",
      publisher: { '@id': SITE + '/#organization' },
    },
    {
      '@type': 'CreativeWork',
      name: project.headline,
      about: project.client,
      inLanguage: lang,
      creator: { '@id': SITE + '/#organization' },
      url: SITE + "/employer-branding-campaign-for-lem/",
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: SITE + '/' + lang + '/projects/' },
        { '@type': 'ListItem', position: 3, name: project.headline, item: SITE + "/employer-branding-campaign-for-lem/" },
      ],
    },
  ],
};
---
<Base lang={lang} slug="projects" active="projects" singleLang={true} switchSlug="projects" canonicalPath={"/employer-branding-campaign-for-lem/"} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(ld)}></script>
  <CaseStudy project={project} lang={lang} />
</Base>
