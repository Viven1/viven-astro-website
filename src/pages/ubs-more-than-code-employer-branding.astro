---
import Base from '../layouts/Base.astro';
import CaseStudy from '../components/CaseStudy.astro';
import projects from '../data/projects.json';
const project = projects.find((x) => x.slug === "ubs-more-than-code-employer-branding");
const lang = "en";
const SITE = "https://www.viven.ch";
const title = {"en":"UBS More Than Code Employer Branding Campaign | Viven"};
const description = {"en":"This social media video invites young engineering students to explore the exciting world of technology at UBS through the Technological Internship Program."};
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VideoObject',
      name: project.headline,
      description: description[lang],
      thumbnailUrl: SITE + project.stills[0],
      embedUrl: 'https://player.vimeo.com/video/' + project.vimeo,
      uploadDate: '2024-01-01',
      publisher: { '@id': SITE + '/#organization' },
    },
    {
      '@type': 'CreativeWork',
      name: project.headline,
      about: project.client,
      inLanguage: lang,
      creator: { '@id': SITE + '/#organization' },
      url: SITE + "/ubs-more-than-code-employer-branding/",
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: SITE + '/' + lang + '/projects/' },
        { '@type': 'ListItem', position: 3, name: project.headline, item: SITE + "/ubs-more-than-code-employer-branding/" },
      ],
    },
  ],
};
---
<Base lang={lang} slug="projects" active="projects" singleLang={true} switchSlug="projects" canonicalPath={"/ubs-more-than-code-employer-branding/"} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(ld)}></script>
  <CaseStudy project={project} lang={lang} />
</Base>
