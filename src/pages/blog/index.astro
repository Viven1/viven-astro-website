<script>
(function(){
  var grid = document.getElementById('post-grid');
  var cards = Array.prototype.slice.call(grid.querySelectorAll('.post-card'));
  var filterBar = document.querySelector('.blog-filters');
  var emptyMsg = document.getElementById('blog-empty');
  var currentTopic = 'all';

  function currentLang(){
    var l = document.documentElement.lang;
    return l === 'de' ? 'de' : 'en'; // ES has no posts yet — fall back to EN
  }

  function applyFilters(){
    var lang = currentLang();
    var visible = 0;
    cards.forEach(function(c){
      var matchesTopic = currentTopic === 'all' || c.dataset.cat === currentTopic;
      var matchesLang = c.dataset.postlang === lang;
      var show = matchesTopic && matchesLang;
      c.style.display = show ? '' : 'none';
      if(show) visible++;
    });
    emptyMsg.hidden = visible > 0;
  }

  if(filterBar){
    filterBar.querySelectorAll('button').forEach(function(btn){
      btn.addEventListener('click', function(){
        filterBar.querySelectorAll('button').forEach(function(b){ b.classList.remove('active'); });
        btn.classList.add('active');
        currentTopic = btn.dataset.filter;
        applyFilters();
      });
    });
  }

  var mo = new MutationObserver(applyFilters);
  mo.observe(document.documentElement, {attributes:true, attributeFilter:['lang']});
  applyFilters();
})();
</script>

