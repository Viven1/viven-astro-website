---
import Base from '../layouts/Base.astro';
import CaseStudy from '../components/CaseStudy.astro';
import projects from '../data/projects.json';
const project = projects.find((x) => x.slug === "kyan-health-making-mental-well-being-a-superpower-at-work");
const lang = "en";
const SITE = "https://www.viven.ch";
const title = {"en":"Kyan Health — Mental Well-Being as a Superpower | Viven"};
const description = {"en":"In today’s rapidly evolving job market, where time is of the essence, prioritizing self-care and maintaining a healthy work-life balance have become increa"};
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VideoObject',
      name: project.headline,
      description: description[lang],
      thumbnailUrl: SITE + project.stills[0],
      embedUrl: 'https://player.vimeo.com/video/' + project.vimeo,
      uploadDate: '2024-01-01',
      publisher: { '@id': SITE + '/#organization' },
    },
    {
      '@type': 'CreativeWork',
      name: project.headline,
      about: project.client,
      inLanguage: lang,
      creator: { '@id': SITE + '/#organization' },
      url: SITE + "/kyan-health-making-mental-well-being-a-superpower-at-work/",
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: SITE + '/' + lang + '/projects/' },
        { '@type': 'ListItem', position: 3, name: project.headline, item: SITE + "/kyan-health-making-mental-well-being-a-superpower-at-work/" },
      ],
    },
  ],
};
---
<Base lang={lang} slug="projects" active="projects" singleLang={true} switchSlug="projects" canonicalPath={"/kyan-health-making-mental-well-being-a-superpower-at-work/"} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(ld)}></script>
  <CaseStudy project={project} lang={lang} />
</Base>
