      <!-- datos -->
      <div class="q">
        <div class="qh" data-en="Your details — so we can match the brief to your call" data-de="Ihre Angaben — damit wir das Briefing Ihrem Call zuordnen können" data-es="Tus datos — para conectar el brief con tu llamada">Your details — so we can match the brief to your call</div>
        <div class="bf-row2" style="margin-top:12px">
          <div class="bf"><label data-en="First name" data-de="Vorname" data-es="Nombre">First name</label><input type="text" name="first_name" autocomplete="given-name" required /></div>
          <div class="bf"><label data-en="Last name" data-de="Nachname" data-es="Apellido">Last name</label><input type="text" name="last_name" autocomplete="family-name" required /></div>
        </div>
        <div class="bf"><label data-en="Email" data-de="E-Mail" data-es="Email">Email</label><input type="email" name="email" autocomplete="email" required /></div>
        <div class="bf"><label data-en="Videos you like as reference? (links, optional)" data-de="Referenz-Videos, die Ihnen gefallen? (Links, optional)" data-es="¿Videos de referencia que te gusten? (links, opcional)">References (optional)</label><input name="references" placeholder="youtube.com/…, vimeo.com/…" /></div>
        <div class="bf"><label data-en="Anything else? (optional)" data-de="Sonst noch etwas? (optional)" data-es="¿Algo más? (opcional)">Anything else? (optional)</label><textarea name="extra"></textarea></div>
      </div>

      <input type="text" name="company_url" style="position:absolute;left:-9999px" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <button class="btn btn-primary submit" type="submit" data-en="Send brief →" data-de="Briefing senden →" data-es="Enviar brief →">Send brief →</button>
      <div class="berr" id="brief-err" data-en="Something went wrong — try again or email info@viven.ch" data-de="Etwas ist schiefgelaufen — bitte erneut versuchen oder info@viven.ch" data-es="Algo salió mal — probá de nuevo o escribí a info@viven.ch">Something went wrong.</div>
    </form>

    <p class="brief-alt" data-en="Prefer to talk? " data-de="Lieber sprechen? " data-es="¿Preferís hablar? ">Prefer to talk? <a href="/book/" target="_blank" rel="noopener" data-en="Book a 15-min call →" data-de="15-Min-Call buchen →" data-es="Agendá 15 min →">Book a 15-min call →</a></p>
  </div>

  <div class="brief-card brief-ok" id="brief-ok" hidden>
    <div class="big">✅</div>
    <h1 data-en="Got it — thank you!" data-de="Erhalten — danke!" data-es="¡Recibido — gracias!">Got it — thank you!</h1>
    <p class="lead" id="brief-ok-lead-call" data-en="Perfect — now we can come well prepared. See you on the call!" data-de="Perfekt — so kommen wir bestens vorbereitet. Bis zum Call!" data-es="Perfecto — así llegamos bien preparados. ¡Nos vemos en la llamada!" hidden>Perfect — now we can come well prepared. See you on the call!</p>
    <p class="lead" id="brief-ok-lead-tool" data-en="It's yours now — brief your team with it, get quotes elsewhere, whatever's useful. Want us to take a shot at pricing it too?" data-de="Es gehört jetzt Ihnen — briefen Sie Ihr Team damit, holen Sie andere Angebote ein, ganz wie es passt. Sollen wir Ihnen auch einen Preis dazu schicken?" data-es="Ya es tuyo — usalo para brief a tu equipo, pedí otras cotizaciones, lo que te sirva. ¿Querés que también te pasemos un precio?" hidden>It's yours now — brief your team with it, get quotes elsewhere, whatever's useful. Want us to take a shot at pricing it too?</p>
    <div class="brief-actions primary no-print" id="brief-cta-tool" hidden>
      <button type="button" id="brief-quote-btn">📩 <span data-en="Yes, send me a quote" data-de="Ja, schickt mir ein Angebot" data-es="Sí, mandame una cotización">Yes, send me a quote</span></button>
      <a href="/book/" target="_blank" rel="noopener">📅 <span data-en="Book a 15-min call" data-de="15-Min-Call buchen" data-es="Agendar 15 min">Book a 15-min call</span></a>
    </div>
    <div class="brief-email-msg no-print" id="brief-quote-msg"></div>
    <div class="brief-actions no-print">
      <button type="button" id="brief-print">🖨️ <span data-en="Print / Save as PDF" data-de="Drucken / Als PDF speichern" data-es="Imprimir / Guardar como PDF">Print / Save as PDF</span></button>
      <button type="button" id="brief-email-btn">✉️ <span data-en="Email me a copy" data-de="Kopie per E-Mail senden" data-es="Enviarme una copia por email">Email me a copy</span></button>
    </div>
    <div class="brief-email-msg no-print" id="brief-email-msg"></div>
    <div class="brief-summary" id="brief-summary"></div>
    <p class="brief-alt no-print">
      <a href="/" id="brief-back-link" data-en="← Back to viven.ch" data-de="← Zurück zu viven.ch" data-es="← Volver a viven.ch">← Back to viven.ch</a>
      &nbsp;·&nbsp;
      <a href="/" id="brief-work-link" data-en="See our work →" data-de="Unsere Arbeiten ansehen →" data-es="Ver nuestro trabajo →">See our work →</a>
    </p>
  </div>
</div>

<script is:inline define:vars={{ SB_URL, SB_KEY }}>
  var qs = new URLSearchParams(location.search);
  var lang = ['en','de','es'].includes(qs.get('lang')) ? qs.get('lang') : 'en';
  var leadId = qs.get('lead') || null;
  var topic = qs.get('topic') || '';
  document.documentElement.lang = lang;

  // dos versiones del mensaje final: "nos vemos en la llamada" solo si ya reservó un call
  // (llega acá con ?lead=<id> desde booking-create) — si es alguien que encontró /brief/ como tool suelto,
  // sin call agendado, el brief es SUYO para usar como quiera; no le prometemos que le vamos a escribir
  // solos — le ofrecemos pedir cotización o agendar, a que decida él
  document.getElementById(leadId ? 'brief-ok-lead-call' : 'brief-ok-lead-tool').hidden = false;
  if (!leadId) document.getElementById('brief-cta-tool').hidden = false;

  // aplicar idioma a todo lo que tenga data-<lang> (re-invocable desde el switcher)
  function applyLang(){
    document.querySelectorAll('[data-en],[data-de],[data-es]').forEach(function(el){
      var t = el.getAttribute('data-' + lang);
      if (t) el.textContent = t;
    });
    document.documentElement.lang = lang;
    document.querySelectorAll('#brief-langs button').forEach(function(b){ b.classList.toggle('on', b.getAttribute('data-lang') === lang); });
    // el logo y los links de "volver"/"ver más" no son un callejón sin salida — llevan al home/portfolio del idioma actual
    var home = '/' + lang + '/';
    var work = '/' + lang + '/projects/';
    ['brief-home-link', 'brief-back-link'].forEach(function(id){ var a = document.getElementById(id); if (a) a.href = home; });
    var w = document.getElementById('brief-work-link'); if (w) w.href = work;
  }
  applyLang();
  document.querySelectorAll('#brief-langs button').forEach(function(b){
    b.addEventListener('click', function(){
      lang = b.getAttribute('data-lang');
      applyLang();
      var u = new URL(location.href); u.searchParams.set('lang', lang); history.replaceState(null, '', u);
    });
  });

  // pre-seleccionar el objetivo según el tema del email (data-topic en las opciones de goal)
  if (topic) {
    var pre = document.querySelector('.q[data-key="goal"] .opt[data-topic="' + topic + '"]');
    if (pre) pre.classList.add('sel');
  }

  var form = document.getElementById('brief-form');
  var bar = document.getElementById('bprog-bar');
  var errBox = document.getElementById('brief-err');

  function updateProgress(){
    var qBlocks = form.querySelectorAll('.q[data-key]');
    var done = 0;
    qBlocks.forEach(function(q){ if (q.querySelector('.opt.sel')) done++; });
    // +1 por nombre+apellido, +1 por email válido
    var total = qBlocks.length + 2;
    if (form.first_name.value.trim() && form.last_name.value.trim()) done++;
    if (form.email.value.trim() && /\S+@\S+\.\S+/.test(form.email.value)) done++;
    bar.style.width = Math.round(done / total * 100) + '%';
  }

  // manejar clicks en las opciones (single o multi)
  form.querySelectorAll('.q[data-key]').forEach(function(q){
    var multi = q.getAttribute('data-multi') === '1';
    q.querySelectorAll('.opt').forEach(function(opt){
      opt.addEventListener('click', function(){
        if (multi) {
          opt.classList.toggle('sel');
        } else {
          q.querySelectorAll('.opt').forEach(function(o){ o.classList.remove('sel'); });
          opt.classList.add('sel');
        }
        updateProgress();
      });
    });
  });
  form.email.addEventListener('input', updateProgress);
  form.first_name.addEventListener('input', updateProgress);
  form.last_name.addEventListener('input', updateProgress);
  updateProgress();

  function collect(q){
    var vals = [];
    q.querySelectorAll('.opt.sel').forEach(function(o){ vals.push(o.getAttribute('data-val')); });
    return vals;
  }

  // resumen legible (idioma del usuario) para el print/PDF y el email — misma fuente que ve el usuario en pantalla
  function buildSummaryPairs(){
    var pairs = [];
    form.querySelectorAll('.q[data-key]').forEach(function(q){
      var qh = q.querySelector('.qh');
      if (!qh) return;
      var vals = [];
      q.querySelectorAll('.opt.sel').forEach(function(o){
        var txt = [];
        o.querySelectorAll('span').forEach(function(s){
          if (s.classList.contains('em') || s.classList.contains('tick')) return;
          if (s.textContent.trim()) txt.push(s.textContent.trim());
        });
        if (txt.length) vals.push(txt.join(' '));
      });
      pairs.push([qh.textContent.trim(), vals.length ? vals.join(', ') : '—']);
    });
    return pairs;
  }
  function escapeHtml(s){
    return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }
  var L_REF = { en: 'References', de: 'Referenzen', es: 'Referencias' };
  var L_NOTES = { en: 'Anything else', de: 'Sonstiges', es: 'Otros comentarios' };
  var L_SENT = { en: '✓ Sent — check your inbox', de: '✓ Gesendet — E-Mails prüfen', es: '✓ Enviado — revisá tu bandeja' };
  var L_FAIL = { en: 'Could not send — try again later', de: 'Konnte nicht gesendet werden — später erneut versuchen', es: 'No se pudo enviar — probá más tarde' };
  var L_DOCTITLE = { en: 'Project Brief', de: 'Projekt-Briefing', es: 'Brief de proyecto' };
  var L_QUOTE_OK = { en: '✓ Got it — we’ll send you a quote shortly.', de: '✓ Alles klar — wir schicken Ihnen in Kürze ein Angebot.', es: '✓ Listo — te mandamos una cotización pronto.' };
  var L_QUOTE_FAIL = { en: 'Could not send — try again or book a call instead', de: 'Konnte nicht gesendet werden — bitte erneut versuchen oder Call buchen', es: 'No se pudo enviar — probá de nuevo o agendá una llamada' };
  var LOCALE = { en: 'en-GB', de: 'de-CH', es: 'es-AR' };
  // mismo wordmark navy+acid que usan las ofertas y propuestas del dashboard — para que el
  // brief se vea y se sienta como un documento real de VIVEN, no una captura de la web
  var VIVEN_MARK = '<svg viewBox="125 126 1020 288" fill="#ddf98f" xmlns="http://www.w3.org/2000/svg"><path d="M756.66,346.9l114.7-80.57c-37.87-83.92-102.57-60.93-102.57-60.93l-71.71,57.88v65.56c0,38.77,25.21,75.91,62.34,80.84h68.27l35.95-40.9-107,.1C756.66,371,756.7,346.56,756.66,346.9Zm.06-108.77s55.51-13.37,55.51,34.2l-55.51,39C757,310.8,756.72,238.13,756.72,238.13Z"/><path d="M270.4,255.39l-32.57,61.44L179,197.28l-54.41,44.41,22.58,22.58,74.76,149.91,106.6-198H237.09ZM431.78,125.83H372.19v49.22h59.59Zm1,71.45-82.54,67.36,22.95,22.95v78.47l-32.57,38.86H465.37l-32.58-38.86Zm704.72,207.64-32.58-38.86V286.85c0-43.67-29.24-84-71.06-89.57l-50.34,41.08L962.06,195.8l-57.37,47,22.58,22.95V366.06L894.7,404.92h124.73l-32.57-38.86V248.73h11.85a46.75,46.75,0,0,1,46.63,47V404.92ZM621.28,255.39l-32.57,61.44L529.86,197.28l-54.41,44.41L498,264.27,572.8,414.18l106.6-198H588Z"/></svg>';
  function renderSummary(data){
    var rows = data.pairs.map(function(p){ return '<tr><td class="bs-k">' + escapeHtml(p[0]) + '</td><td class="bs-v">' + escapeHtml(p[1]) + '</td></tr>'; }).join('');
    if (data.references) rows += '<tr><td class="bs-k">' + (L_REF[lang] || L_REF.en) + '</td><td class="bs-v">' + escapeHtml(data.references) + '</td></tr>';
    if (data.extra) rows += '<tr><td class="bs-k">' + (L_NOTES[lang] || L_NOTES.en) + '</td><td class="bs-v">' + escapeHtml(data.extra) + '</td></tr>';
    var date = new Date().toLocaleDateString(LOCALE[lang] || 'en-GB', { day: '2-digit', month: 'long', year: 'numeric' });
    document.getElementById('brief-summary').innerHTML =
      '<div class="bs-doc"><div class="bs-band"><div class="bs-brand">' + VIVEN_MARK + '<div class="bs-fp">Film<br>Production</div></div>' +
      '<div class="bs-doctitle"><div class="bs-dt-label">' + (L_DOCTITLE[lang] || L_DOCTITLE.en) + '</div><div class="bs-dt-date">' + date + '</div></div></div>' +
      '<div class="bs-client"><div class="bs-client-name">' + escapeHtml(data.name) + '</div><div class="bs-client-email">' + escapeHtml(data.to) + '</div></div>' +
      '<table class="bs-table">' + rows + '</table>' +
      '<div class="bs-foot"><b>VIVEN AG</b> — Video Production · Zürich, Switzerland<br>viven.ch · info@viven.ch</div></div>';
  }
  var lastBrief = null;
  document.getElementById('brief-print').addEventListener('click', function(){ window.print(); });
  document.getElementById('brief-email-btn').addEventListener('click', function(){
    if (!lastBrief) return;
    var btn = document.getElementById('brief-email-btn');
    var msg = document.getElementById('brief-email-msg');
    btn.disabled = true; msg.textContent = '';
    fetch(SB_URL + '/functions/v1/brief-email', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'apikey': SB_KEY, 'Authorization': 'Bearer ' + SB_KEY },
      body: JSON.stringify(lastBrief)
    }).then(function(r){ return r.ok; }).catch(function(){ return false; }).then(function(ok){
      msg.textContent = ok ? (L_SENT[lang] || L_SENT.en) : (L_FAIL[lang] || L_FAIL.en);
      btn.disabled = false;
    });
  });
  // "Sí, mandame una cotización" (solo tool suelto, sin call) — el trigger briefs_autolead
  // YA crea/liga el lead por email en el submit original de más arriba; si acá insertáramos
  // directo en leads, duplicaría el contacto. En vez de eso mandamos OTRO brief (mismo insert
  // seguro que ya usa el form), el trigger lo liga al MISMO lead por email (sin duplicar), y el
  // "extra" deja bien claro que esta vez sí pidió cotización — para que Sebastián/Sofia lo vean
  document.getElementById('brief-quote-btn').addEventListener('click', function(){
    if (!lastBrief) return;
    var btn = document.getElementById('brief-quote-btn');
    var msg = document.getElementById('brief-quote-msg');
    btn.disabled = true; msg.textContent = '';
    var full = (lastBrief.name || '').trim();
    var first = full.split(' ')[0] || null;
    var last = full.split(' ').slice(1).join(' ') || null;
    var row = {
      lang: lang, name: full || null, first_name: first, last_name: last, email: lastBrief.to,
      extra: '🔔 QUIERE COTIZACIÓN (pidió precio desde el brief-tool) — ' + lastBrief.pairs.map(function(p){ return p[0] + ': ' + p[1]; }).join(' · ')
    };
    fetch(SB_URL + '/rest/v1/briefs', {
      method: 'POST',
      headers: { 'apikey': SB_KEY, 'Authorization': 'Bearer ' + SB_KEY, 'Content-Type': 'application/json', 'Prefer': 'return=minimal' },
      body: JSON.stringify(row)
    }).then(function(r){ return r.ok; }).catch(function(){ return false; }).then(function(ok){
      msg.textContent = ok ? (L_QUOTE_OK[lang] || L_QUOTE_OK.en) : (L_QUOTE_FAIL[lang] || L_QUOTE_FAIL.en);
      if (!ok) btn.disabled = false;
    });
  });

  form.addEventListener('submit', function(e){
    e.preventDefault();
    if (form.company_url.value) return; // honeypot
    errBox.style.display = 'none';

    var goal = collect(form.querySelector('.q[data-key="goal"]'))[0] || '';
    var distribution = collect(form.querySelector('.q[data-key="distribution"]')).join(', ');
    var timeline = collect(form.querySelector('.q[data-key="timeline"]'))[0] || '';
    var budget = collect(form.querySelector('.q[data-key="budget"]'))[0] || '';

    // respuestas profundas → answers (jsonb); si la columna no existe todavía, van al extra
    var answers = {
      audience: collect(form.querySelector('.q[data-key="audience"]')),
      quantity: collect(form.querySelector('.q[data-key="quantity"]'))[0] || null,
      formats: collect(form.querySelector('.q[data-key="formats"]')),
      languages: collect(form.querySelector('.q[data-key="languages"]')),
      oncamera: collect(form.querySelector('.q[data-key="oncamera"]')),
      locations: collect(form.querySelector('.q[data-key="locations"]')),
      action: collect(form.querySelector('.q[data-key="action"]'))[0] || null,
      feeling: collect(form.querySelector('.q[data-key="feeling"]')),
      destination: collect(form.querySelector('.q[data-key="destination"]'))[0] || null,
      references: form.references.value.trim() || null
    };
    var first = form.first_name.value.trim();
    var last = form.last_name.value.trim();
    var references = form.references.value.trim();
    var extra = form.extra.value.trim();
    // sesión web del visitante (la crea site.js al navegar el sitio; mismo sessionStorage,
    // mismo origen) — conecta el brief con su historial: páginas vistas, landing, videos
    var sessionId = null;
    try { sessionId = sessionStorage.getItem('viven-session'); } catch (e) {}
    var row = {
      lead_id: leadId, lang: lang, session_id: sessionId,
      name: (first + ' ' + last).trim() || null, first_name: first || null, last_name: last || null,
      email: form.email.value.trim(),
      goal: goal, distribution: distribution || null,
      timeline: timeline || null, budget: budget || null,
      extra: extra || null,
      answers: answers
    };
    lastBrief = { to: row.email, name: row.name, lang: lang, pairs: buildSummaryPairs(), references: references || null, extra: extra || null };

    function showSuccess(){
      document.getElementById('brief-form-card').hidden = true;
      document.getElementById('brief-ok').hidden = false;
      // el documento respira: el wrap pasa de 660px (ancho de formulario) a 960px
      var w = document.querySelector('.brief-wrap'); if (w) w.classList.add('wide');
      renderSummary(lastBrief);
      window.scrollTo(0, 0);
    }

    var btn = form.querySelector('button.submit'); btn.disabled = true;
    fetch(SB_URL + '/rest/v1/briefs', {
      method: 'POST',
      headers: { 'apikey': SB_KEY, 'Authorization': 'Bearer ' + SB_KEY, 'Content-Type': 'application/json', 'Prefer': 'return=minimal' },
      body: JSON.stringify(row)
    }).then(function(r){
      if (r.ok) { showSuccess(); return; }
      // columna answers/first_name/last_name/session_id ausente (SQL 0027/0047/0056 sin correr) → plegar al extra y reintentar
      var flat = Object.keys(answers).map(function(k){ var v = answers[k]; if (Array.isArray(v)) v = v.join(', '); return v ? k + ': ' + v : ''; }).filter(Boolean).join(' · ');
      delete row.answers; delete row.first_name; delete row.last_name; delete row.session_id;
      row.extra = ((row.extra || '') + (flat ? '\n[brief] ' + flat : '')).trim() || null;
      return fetch(SB_URL + '/rest/v1/briefs', {
        method: 'POST',
        headers: { 'apikey': SB_KEY, 'Authorization': 'Bearer ' + SB_KEY, 'Content-Type': 'application/json', 'Prefer': 'return=minimal' },
        body: JSON.stringify(row)
      }).then(function(r2){
        if (r2.ok) { showSuccess(); }
        else { btn.disabled = false; errBox.style.display = 'block'; }
      });
    }).catch(function(){ btn.disabled = false; errBox.style.display = 'block'; });
  });
</script>
</body>
</html>
