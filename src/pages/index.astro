---
// Raíz "/" — redirige al idioma del visitante (preferencia guardada > navegador > EN).
// noindex; x-default apunta a /en/.
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Viven — Video Production Zurich</title>
<meta name="robots" content="noindex,follow" />
<link rel="canonical" href="https://www.viven.ch/en/" />
<link rel="alternate" hreflang="en" href="https://www.viven.ch/en/" />
<link rel="alternate" hreflang="de" href="https://www.viven.ch/de/" />
<link rel="alternate" hreflang="es" href="https://www.viven.ch/es/" />
<link rel="alternate" hreflang="x-default" href="https://www.viven.ch/en/" />
<script>
  (function () {
    var lang = 'en';
    try { var s = localStorage.getItem('viven-lang'); if (s) lang = s; else {
      var n = (navigator.language || 'en').slice(0, 2);
      lang = n === 'de' ? 'de' : (n === 'es' ? 'es' : 'en');
    } } catch (e) {}
    location.replace('/' + lang + '/');
  })();
</script>
<meta http-equiv="refresh" content="0;url=/en/" />
</head>
<body>
<p style="font-family:sans-serif;background:#0f1826;color:#f4f6fb;margin:0;padding:40px;text-align:center">
  <a href="/en/" style="color:#ddf98f">Continue to Viven →</a>
</p>
</body>
</html>
