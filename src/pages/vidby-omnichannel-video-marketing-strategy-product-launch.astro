---
import Base from '../layouts/Base.astro';
import CaseStudy from '../components/CaseStudy.astro';
import projects from '../data/projects.json';
const project = projects.find((x) => x.slug === "vidby-omnichannel-video-marketing-strategy-product-launch");
const lang = "en";
const SITE = "https://www.viven.ch";
const title = {"en": "Vidby — Omnichannel video marketing strategy | Viven"};
const description = {"en": "Vidby's compelling omnichannel video marketing strategy opens up a world where language is no longer a barrier and provides an inspiring glimpse into the futu"};
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'VideoObject',
      name: project.headline,
      description: description[lang],
      thumbnailUrl: SITE + project.stills[0],
      embedUrl: 'https://player.vimeo.com/video/' + project.vimeo,
      uploadDate: "2023-02-01T00:00:00+00:00",
      publisher: { '@id': SITE + '/#organization' },
    },
    {
      '@type': 'CreativeWork',
      name: project.headline,
      about: project.client,
      inLanguage: lang,
      creator: { '@id': SITE + '/#organization' },
      url: SITE + "/vidby-omnichannel-video-marketing-strategy-product-launch/",
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' + lang + '/' },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: SITE + '/' + lang + '/projects/' },
        { '@type': 'ListItem', position: 3, name: project.headline, item: SITE + "/vidby-omnichannel-video-marketing-strategy-product-launch/" },
      ],
    },
  ],
};
---
<Base lang={lang} slug="projects" active="projects" singleLang={true} switchSlug="projects" canonicalPath={"/vidby-omnichannel-video-marketing-strategy-product-launch/"} title={title} description={description}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(ld)}></script>
  <CaseStudy project={project} lang={lang} />
</Base>
