      co3Menu('<button data-c="person">👤 Persona en esta empresa</button><button data-c="offer">🧾 Oferta</button><button data-c="prop">🌐 Propuesta</button>',
        (mn) => mn.querySelectorAll('button').forEach((cb) => cb.addEventListener('click', (ev) => {
          ev.stopPropagation(); mn.hidden = true;
          const c = cb.dataset.c;
          co3Close(true);   // los flujos existentes navegan a otro tab — cerrar el modal pero conservar coCur (lo leen)
          if (c === 'person') coNewPerson();
          else coNewOfferProp(c === 'offer' ? 'offer' : 'prop');
        })));
    });
    $('co3-dots').addEventListener('click', (e) => {
      e.stopPropagation();
      if (!menu.hidden) { menu.hidden = true; return; }
      co3Menu('<button data-act="web">🌐 Abrir sitio web</button><hr /><button data-act="del" class="danger">🗑 Borrar empresa</button>',
        (mn) => mn.querySelectorAll('button').forEach((b) => b.addEventListener('click', async (ev) => {
          ev.stopPropagation(); mn.hidden = true;
          if (b.dataset.act === 'web') window.open(web, '_blank', 'noopener');
          if (b.dataset.act === 'del') { await deleteCompany(); if (!coCur) co3Close(); }   // deleteCompany confirma y anula coCur si borró
        })));
    });

    co3RenderLeft(domain);
    co3RenderRight(domain);   // los composers de nota/task viven en la columna derecha (igual que la persona)
    co3LoadTimeline(domain);
    co3RenderEnrich(domain);
    // AUTO-disparo (solo la primera vez, sin tocar nada): si nunca se enriqueció y le
    // faltan campos clave, corre solo — no hace falta que Sebastián toque el botón.
    if (!isRefresh && !m.enriched_at && !m.industry && !m.employees) co3RunEnrich(domain);

    co3Modal.classList.add('open');
    co3Modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  /* --- columna izquierda: MISMO patrón que la persona (▾ SECCIÓN en mayúsculas + filas label→valor),
         con inline-edit al click en los campos de la empresa --- */
  function co3RenderLeft(domain){
    const box = $('co3-l'); if (!box || co3Cur !== domain) return;
    const m = coMeta[domain] || {};
    const data = co3Data(domain);
    const mo = coMoney(data);
    const nDeals = data.contacts.reduce((a, l) => a + dealsForLead(l.id).length, 0);
    const row = (k, v, edit, fkey) => '<div class="ab-row"><span class="ab-k">' + k + '</span>' +
      '<span class="ab-v' + (edit ? ' co3-fld' : '') + '"' + (edit ? ' data-f="' + fkey + '" title="Clic para editar" style="cursor:pointer"' : '') + '>' +
      (v || '—') + '</span></div>';
    const sec = (t, rows, open) => '<details class="ab-sec lm-fold"' + (open ? ' open' : '') + '><summary class="ab-h">' + t + '</summary>' + rows + '</details>';
    box.innerHTML =
      sec('Sobre la empresa',
        CO_FIELDS.map(([k, l]) => row(l, m[k] ? esc(String(m[k])) : '', true, k)).join('') +
        row('Dominio', esc(domain)), true) +
      sec('Negocio',
        row('En juego', mo.open ? fmtChf(mo.open) : '') +
        row('Ganado', mo.won ? '<span style="color:#7ed957">' + fmtChf(mo.won) + '</span>' : '') +
        row('Proyectos', String(nDeals)), true) +
      (!coMeta[domain] ? '<p class="muted-note" style="margin-top:12px;font-size:11px">Empresa agrupada por dominio: al editar un campo se crea su ficha en la base.</p>' : '');
    box.querySelectorAll('.co3-fld').forEach((el) => el.addEventListener('click', () => co3EditField(domain, el)));
  }
  function co3EditField(domain, el){
    if (el.querySelector('input')) return;
    const f = el.dataset.f; const cur = String((coMeta[domain] || {})[f] || '');
    el.innerHTML = '<input class="ed-inp" value="' + esc(cur) + '" style="width:100%;font-size:12.5px;padding:5px 7px" />';
    const inp = el.querySelector('input'); inp.focus(); inp.select();
    let done = false;
    const finish = async (save) => {
      if (done) return; done = true;
      const v = inp.value.trim();
      if (save && v !== cur){
        if (await coSaveMeta(domain, { [f]: v || null })) toast('Empresa guardada');
        co3Open(domain, true); renderCompaniesList();   // nombre/industria/ciudad afectan header, subline y lista
        return;
      }
      co3RenderLeft(domain);
    };
    inp.addEventListener('keydown', (e) => { if (e.key === 'Enter') finish(true); else if (e.key === 'Escape') finish(false); });
    inp.addEventListener('blur', () => finish(true));
  }

  /* --- notas/tasks de la empresa: viven como BLOQUES de la columna derecha (igual que la persona);
         la nota/task se guarda en la ficha del contacto elegido --- */
  function co3ContactOpts(){
    const data = co3Data(co3Cur);
    return data.contacts.map((l, i) => '<option value="' + esc(String(l.id)) + '"' + (i === 0 ? ' selected' : '') + '>' + esc(l.name || l.email) + '</option>').join('');
  }
  // compat: los flujos viejos llamaban al composer del centro — ahora re-renderiza la columna derecha
  function co3RenderComposer(){ if (co3Cur) co3RenderRight(co3Cur); }

  /* --- timeline agregada de toda la empresa: emails + hilos de notas + tasks + ofertas ganadas --- */
  async function co3LoadTimeline(domain){
    const box = $('co3-tl'); if (!box || co3Cur !== domain) return;
    const data = co3Data(domain);
    const ids = data.contacts.map((l) => String(l.id));
    if (!ids.length){
      co3Events = []; co3Tasks = [];
      co3RenderChips();
      box.innerHTML = '<p class="muted-note">Sin contactos — la actividad de sus personas va a aparecer acá.</p>';
      return;
    }
    const nameOf = (id) => { const l = data.contacts.find((c) => String(c.id) === String(id)); return l ? (l.name || l.email) : ''; };
    const q = (t) => t.then((x) => (x && !x.error && x.data) || []).catch(() => []);
    const [emails, notes, tasks] = await Promise.all([
      q(supabase.from('email_log').select('*').in('lead_id', ids).order('created_at', { ascending: false }).limit(120)),
      q(supabase.from('lead_notes').select('*').in('lead_id', ids).order('created_at', { ascending: false }).limit(120)),
      q(supabase.from('lead_tasks').select('*').in('lead_id', ids).order('created_at', { ascending: false }).limit(120)),
    ]);
    if (co3Cur !== domain) return;   // cambió de empresa mientras cargaba
    co3Tasks = tasks;
    const ev = [];
    emails.forEach((e2) => ev.push({ t: e2.created_at, ty: 'email', chip: ['email', e2.direction === 'in' ? '📥 Recibido' : '✉️ Enviado'], title: '<b>' + esc(e2.subject || '(sin asunto)') + '</b>', meta: [esc(e2.sender_label || ''), 'con ' + esc(nameOf(e2.lead_id))].filter(Boolean).join(' · '), body: String(e2.body || '').replace(/<[^>]+>/g, ' ') }));
    // notas en HILOS estilo chat (mismo modelo que la Ficha V2: parent_id → nota raíz, un evento por hilo)
    const thrMap = new Map();
    notes.filter((n) => !n.parent_id).forEach((n) => thrMap.set(n.id, { root: n, replies: [] }));
    notes.filter((n) => n.parent_id).forEach((n) => { const t2 = thrMap.get(n.parent_id); if (t2) t2.replies.push(n); else thrMap.set(n.id, { root: n, replies: [] }); });
    thrMap.forEach((t2) => {
      t2.replies.sort((a, b) => new Date(a.created_at) - new Date(b.created_at));
      const last = t2.replies.length ? t2.replies[t2.replies.length - 1] : t2.root;
      ev.push({ t: last.created_at, ty: 'nota', chip: ['nota', t2.replies.length ? '💬 Hilo (' + (t2.replies.length + 1) + ')' : '📝 Nota'], thread: t2, who: nameOf(t2.root.lead_id), nid: t2.root.id, nleadid: t2.root.lead_id, nauthor: t2.root.author || '', nbody: t2.root.body || '' });
    });
    tasks.forEach((t) => ev.push({ t: t.created_at, ty: 'task', task: t, chip: ['task', t.done ? '✅ Task hecha' : '⏳ Task'], meta: [t.due_date ? '📅 ' + t.due_date + (t.due_time ? ' · 🕒 ' + t.due_time : '') : '', t.assignee ? teamName(t.assignee) : '', nameOf(t.lead_id)].filter(Boolean).join(' · ') }));
    data.contacts.forEach((l) => offersForLead(l.id).filter((o) => o.status === 'won').forEach((o) => ev.push({ t: o.updated_at || o.created_at, ty: 'sys', chip: ['sys', '🏆 Ganada'], title: '<b>' + esc(o.title || 'Oferta') + '</b> · ' + fmtChf(offerNet(o)), meta: nameOf(l.id) })));
    ev.sort((a, b) => new Date(b.t) - new Date(a.t));
    co3Events = ev;
    co3RenderChips();
    co3RenderTl();
    co3RenderRight(domain);   // las tasks abiertas del rail derecho salen de esta carga
  }
  function co3RenderChips(){
    const CH = [['all', 'Todo'], ['email', '✉️ Emails'], ['nota', '📝 Notas'], ['task', '✅ Tasks'], ['sys', '🏆 Ganadas']];
    $('co3-chips').innerHTML = CH.map(([k, l]) => { const n = k === 'all' ? co3Events.length : co3Events.filter((e) => e.ty === k).length;
      return '<button data-f="' + k + '" class="' + (co3Filter === k ? 'on' : '') + '">' + l + (n ? ' ' + n : '') + '</button>'; }).join('');
    $('co3-chips').querySelectorAll('button').forEach((b) => b.addEventListener('click', () => { co3Filter = b.dataset.f; co3RenderChips(); co3RenderTl(); }));
  }
  function co3RenderTl(){
    const box = $('co3-tl'); if (!box) return;
    const list = co3Filter === 'all' ? co3Events : co3Events.filter((e) => e.ty === co3Filter);
    if (!list.length) { box.innerHTML = '<p class="muted-note">Sin actividad todavía — los emails, notas y tasks de sus contactos van a aparecer acá.</p>'; return; }
    const when = (t) => lm2FmtDT(t) + ' · hace ' + timeAgo(t);
    const replyLink = (i) => '<div class="lm-note-m"><button class="lm-reply-btn co3-nreply" data-i="' + i + '" type="button">↩ Responder</button><div class="co3-nreply-box" hidden style="width:100%"></div></div>';
    // mismos componentes que la ficha de persona: emails = .lm-email (click expande),
    // notas = .lm-note con respuestas .lm-reply, tasks = .lm-task con checkbox
    box.innerHTML = list.map((e, i) => {
      if (e.thread){
        const msg = (n, isRep) => '<div class="lm-note' + (isRep ? ' lm-reply' : '') + '" style="border-bottom:0;padding:' + (isRep ? '6px 0 2px 10px' : '4px 0 0') + '">' +
          '<div class="lm-note-b">' + esc(n.body || '') + '</div>' +
          '<div class="lm-note-m">' + esc(n.author || '¿?') + ' · hace ' + timeAgo(n.created_at) + '</div></div>';
        return '<div class="lm-email" style="cursor:default">' +
          '<div class="lm-email-h"><span class="lm-email-subj">' + e.chip[1] + (e.who ? ' <span style="font-weight:400;color:var(--muted-2)">en ' + esc(e.who) + '</span>' : '') + '</span><span class="lm-email-meta">' + when(e.t) + '</span></div>' +
          msg(e.thread.root, false) + e.thread.replies.map((n) => msg(n, true)).join('') + replyLink(i) + '</div>';
      }
      if (e.ty === 'task'){
        const t = e.task || {};
        return '<div class="lm-task' + (t.done ? ' done' : '') + '"><input type="checkbox" class="co3-tk" data-id="' + esc(String(t.id)) + '"' + (t.done ? ' checked' : '') + '/>' +
          '<div class="lm-task-txt"><div>' + esc(t.title || '') + '</div>' +
          '<div class="lm-task-meta">' + (e.meta || '') + ' · ' + when(e.t) + '</div></div></div>';
      }
      if (e.ty === 'email'){
        const inbound = /Recibido/.test(e.chip[1]);
        return '<div class="lm-email' + (inbound ? ' lm-email-in' : '') + '">' +
          '<div class="lm-email-h"><span class="lm-email-subj">' + (inbound ? '📥 ' : '') + e.title + '</span><span class="lm-email-meta">' + when(e.t) + '</span></div>' +
          (e.meta ? '<div class="lm-email-snip">' + e.meta + '</div>' : '') +
          '<div class="lm-email-body">' + esc(e.body || '') + (e.meta ? '<p class="muted-note" style="margin-top:8px">' + e.meta + '</p>' : '') + '</div></div>';
      }
      // sys (🏆 oferta ganada) y cualquier otro evento simple
      return '<div class="lm-note"><div class="lm-note-b">' + e.chip[1] + ' — ' + e.title + '</div>' +
        '<div class="lm-note-m">' + (e.meta ? e.meta + ' · ' : '') + when(e.t) + '</div></div>';
    }).join('');
    box.querySelectorAll('.lm-email').forEach((el) => { if (el.querySelector('.lm-email-body')) el.addEventListener('click', (e3) => { if (!e3.target.closest('button,textarea,a,input')) el.classList.toggle('open'); }); });
    box.querySelectorAll('.co3-tk').forEach((cb) => cb.addEventListener('change', async () => {
      await supabase.from('lead_tasks').update({ done: cb.checked, done_at: cb.checked ? new Date().toISOString() : null }).eq('id', cb.dataset.id);
      loadBell(); if (co3Cur) co3LoadTimeline(co3Cur);
    }));
    // ↩︎ responder a un hilo: la respuesta cuelga de la nota RAÍZ, en la ficha del mismo contacto (mismo modelo que lm2)
    box.querySelectorAll('.co3-nreply').forEach((a) => a.addEventListener('click', (e2) => {
      e2.preventDefault();
      const ev = list[Number(a.dataset.i)]; if (!ev || !ev.nid) return;
      box.querySelectorAll('.co3-nreply-box').forEach((f) => { f.hidden = true; f.innerHTML = ''; });
      const holder = a.parentElement.querySelector('.co3-nreply-box'); if (!holder) return;
      holder.hidden = false;
      holder.innerHTML =
        '<textarea class="co3-nreply-t" placeholder="Respondele a ' + esc(ev.nauthor || 'la nota') + '…" style="width:100%;min-height:60px;margin-top:6px;background:var(--navy-900);border:1px solid var(--line);border-radius:7px;color:var(--text);font:500 12.5px Inter,sans-serif;padding:6px 8px"></textarea>' +
        '<div style="display:flex;gap:6px;justify-content:flex-end;margin-top:5px">' +
          '<button class="btn btn-ghost small co3-nreply-x" type="button">Cancelar</button>' +
          '<button class="btn btn-primary small co3-nreply-ok" type="button">↩︎ Responder</button></div>';
      const ta = holder.querySelector('.co3-nreply-t'); ta.focus();
      holder.querySelector('.co3-nreply-x').addEventListener('click', () => { holder.hidden = true; holder.innerHTML = ''; });
      holder.querySelector('.co3-nreply-ok').addEventListener('click', async () => {
        const replyTxt = ta.value.trim(); if (!replyTxt) { toast('Escribí la respuesta'); return; }
        const okBtn = holder.querySelector('.co3-nreply-ok'); okBtn.disabled = true;
        const author = teamName(myEmail());
        const toEmail = (n) => teamEmailByName(String(n || '')) || (/sofia/i.test(n) ? 'sofia@viven.ch' : /sebastian/i.test(n) ? 'sebastian@viven.ch' : null);
        const partNames = [ev.nauthor, ...((ev.thread && ev.thread.replies) || []).map((n) => n.author || '')];
        const recipients = [...new Set(partNames.map(toEmail).filter(Boolean))].filter((e3) => e3 !== myEmail());
        const rootEmail = toEmail(ev.nauthor);
        const mention = (rootEmail && rootEmail !== myEmail()) ? rootEmail : (recipients[0] || null);
        let { error } = await supabase.from('lead_notes').insert({ lead_id: String(ev.nleadid), body: replyTxt, author, parent_id: Number(ev.nid), mention });
        if (error && /parent_id/.test(error.message || '')){
          const quote = (ev.nbody || '').slice(0, 60) + ((ev.nbody || '').length > 60 ? '…' : '');
          ({ error } = await supabase.from('lead_notes').insert({ lead_id: String(ev.nleadid), body: '↩︎ En respuesta a ' + (ev.nauthor || 'una nota') + ' («' + quote + '»): ' + replyTxt, author, mention }));
        }
        if (error) { toast('No se pudo: ' + error.message); okBtn.disabled = false; return; }
        recipients.forEach((to) => notifyUser(to, '💬 ' + author + ' respondió en un hilo — ' + (co3Data(co3Cur).name || ''), author + ' escribió:\n\n' + replyTxt, ev.nleadid));
        if (recipients.length) loadBell();
        toast('↩︎ Respuesta guardada' + (recipients.length ? ' · avisado a ' + recipients.map((e3) => teamName(e3)).join(', ') : ''));
        co3LoadTimeline(co3Cur);
      });
    }));
  }

  /* --- columna derecha: cards .lm-block IDÉNTICAS a las de la persona
         (👥 Contactos / 🧾 Ofertas y propuestas / 🤝 Proyectos / ✅ Tasks / 📝 Notas) --- */
  function co3RenderRight(domain){
    const box = $('co3-r'); if (!box || co3Cur !== domain) return;
    const data = co3Data(domain);
    const mo = coMoney(data);
    const ids = data.contacts.map((l) => String(l.id));
    const cdeals = data.contacts.flatMap((l) => dealsForLead(l.id)).sort((a, b) => new Date(b.created_at) - new Date(a.created_at));
    const props = (typeof propsAll !== 'undefined' ? propsAll : []).filter((p) => p.lead_id && ids.includes(String(p.lead_id)) && !p.is_template);
    const openTasks = (co3Tasks || []).filter((t) => !t.done);
    const stgB = (key) => { const s = STAGES.find((x) => x.key === stageOf(key)) || STAGES[0]; return '<span class="of-badge" style="color:' + s.color + ';border-color:' + s.color + '">' + s.label + '</span>'; };
    const ofB = (st2) => { const b = OFBADGE[st2] || OFBADGE.draft; return '<span class="of-badge" style="color:' + b[1] + ';border-color:' + b[1] + '">' + b[0] + '</span>'; };
    const blk = (title, inner, open) => '<details class="lm-block lm-fold"' + (open ? ' open' : '') + '><summary class="lm-block-h">' + title + '</summary>' + inner + '</details>';
    const hasContacts = data.contacts.length > 0;
    box.innerHTML =
      blk('👥 Contactos <span class="count">(' + data.contacts.length + ')</span>',
        (hasContacts ? data.contacts.map((l) => '<button class="lm-deal co3-ct" data-id="' + esc(String(l.id)) + '" type="button" style="margin-bottom:8px">' +
          '<span class="lm-deal-t">' + esc(l.name || l.email) + (l.job_title ? '<span style="display:block;font-size:11px;font-weight:400;color:var(--muted)">' + esc(l.job_title) + '</span>' : '') + '</span>' +
          '<span class="lm-deal-b"><span style="font-size:11.5px;color:var(--muted-2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + esc(l.email || '') + '</span>' + stgB(l.status) + '</span></button>').join('')
          : '<p class="muted-note">Sin contactos todavía.</p>') +
        '<button class="btn btn-ghost xs" id="co3-add-person" type="button" style="margin-top:4px">➕ Nueva persona en esta empresa</button>', true) +
      blk('🧾 Ofertas y propuestas <span class="count">(' + (mo.offers.length + props.length) + ')</span>',
        (mo.offers.length || props.length ?
          mo.offers.map((o) => '<div class="lm-deal-wrap"><button class="lm-deal co3-of" data-oid="' + esc(String(o.id)) + '" type="button"><span class="lm-deal-t">' + esc(o.title || '(sin título)') + '</span><span class="lm-deal-b"><b>' + fmtM(offerNet(o)) + '</b>' + ofB(o.status) + '</span></button></div>').join('') +
          props.map((p) => '<div class="lm-deal-wrap"><button class="lm-deal co3-pp" data-pid="' + esc(String(p.id)) + '" type="button"><span class="lm-deal-t">🌐 ' + esc(p.title || '(propuesta)') + '</span></button></div>').join('')
          : '<p class="muted-note">Sin ofertas ligadas todavía.</p>') +
        '<div class="lm-mk"><button class="btn btn-ghost xs" id="co3-add-offer" type="button">➕ Hacer oferta</button><button class="btn btn-primary xs" id="co3-add-prop" type="button">🌐 Hacer propuesta</button></div>', true) +
      blk('🤝 Proyectos <span class="count">(' + cdeals.length + ')</span>',
        (cdeals.length ? cdeals.map((d) => { const v = stageOf(d.stage) === 'perdido' ? dealLostValue(d) : dealValue(d);
          return '<div class="lm-dealrow"><div class="lm-dealrow-t">' + esc(d.title || '(proyecto)') + '<b>' + (v ? fmtChf(v) : '—') + '</b></div>' + stgB(d.stage) + '</div>'; }).join('')
          : '<p class="muted-note">Sin proyectos todavía.</p>'), true) +
      blk('✅ Tasks <span class="count">(' + openTasks.length + ')</span>',
        (hasContacts ?
          '<div class="lm-taskadd"><input id="co3-task-t" placeholder="Nueva task…"/>' +
          '<div class="lm-taskadd-row"><select id="co3-task-l" title="Contacto de la empresa al que se liga la task">' + co3ContactOpts() + '</select>' +
          '<input id="co3-task-d" type="date" title="Vence (fecha)"/><input id="co3-task-h" type="time" title="Hora (opcional)"/>' +
          '<select id="co3-task-a">' + teamOptions('', 'Responsable') + '</select>' +
          '<button class="btn btn-ghost xs" id="co3-task-save" type="button">+ Task</button></div></div>'
          : '<p class="muted-note">Creá una persona primero para poder dejar tasks.</p>') +
        '<div id="co3-task-list">' + (openTasks.length ? openTasks.slice(0, 8).map((t) => {
          const nm = (data.contacts.find((c) => String(c.id) === String(t.lead_id)) || {});
          return '<div class="lm-task"><input type="checkbox" class="co3-tk" data-id="' + esc(String(t.id)) + '"/>' +
            '<div class="lm-task-txt"><div>' + esc(t.title) + '</div><div class="lm-task-meta">' + [t.due_date ? '📅 ' + t.due_date + (t.due_time ? ' · 🕒 ' + t.due_time : '') : '', t.assignee ? esc(teamName(t.assignee)) : '', esc(nm.name || nm.email || '')].filter(Boolean).join(' · ') + '</div></div></div>';
        }).join('') : '<p class="muted-note">Nada pendiente.</p>') + '</div>', true) +
      blk('📝 Notas',
        (hasContacts ?
          '<textarea id="co3-note-b" placeholder="Agregar una nota sobre esta empresa… (contexto, objeción, próximo paso)"></textarea>' +
          '<div class="lm-noteadd"><select id="co3-note-l" title="La nota queda en la ficha de este contacto">' + co3ContactOpts() + '</select>' +
          '<select id="co3-note-m">' + teamOptions('', 'Avisar a…') + '</select>' +
          '<button class="btn btn-primary xs" id="co3-note-save" type="button">Guardar nota</button></div>' +
          '<p class="muted-note" style="margin-top:8px">Las notas de todos los contactos se ven en la actividad (centro).</p>'
          : '<p class="muted-note">Creá una persona (➕ Crear) para poder dejar notas.</p>'), true);
    box.querySelectorAll('.co3-ct').forEach((b) => b.addEventListener('click', () => { co3Close(); openLead(b.dataset.id); }));
    box.querySelectorAll('.co3-of').forEach((b) => b.addEventListener('click', () => { co3Close(); gotoTab('offers'); openOffer(b.dataset.oid); }));
