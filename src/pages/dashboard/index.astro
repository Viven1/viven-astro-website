  /* ---------- Realtime: leads nuevos aparecen solos (gratis, sin polling) ---------- */
  let rtSubscribed = false;
  function subscribeRealtime(){
    if (rtSubscribed) return;
    rtSubscribed = true;
    supabase.channel('leads-live')
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'leads' }, (payload) => {
        const r = payload.new;
        if (allLeads.some((l) => l.id === r.id)) return;
        allLeads.unshift(r);
        renderLeads();
        renderAnalytics(lastViews, allLeads);
        // manual = lo cargamos nosotros desde Personas — no es una novedad, sin toast
        if (r.channel !== 'manual') toast('🎬 Nuevo lead: ' + (r.name || r.email));
      })
      .on('postgres_changes', { event: 'UPDATE', schema: 'public', table: 'leads' }, (payload) => {
        const i = allLeads.findIndex((l) => l.id === payload.new.id);
        if (i > -1) { allLeads[i] = payload.new; renderLeads(); renderAnalytics(lastViews, allLeads); }
      })
      .on('postgres_changes', { event: '*', schema: 'public', table: 'lead_tasks' }, () => { loadBell(); })
      .subscribe();
  }
  function toast(msg){
    let t = document.getElementById('dash-toast');
    if (!t) {
      t = document.createElement('div'); t.id = 'dash-toast';
      t.style.cssText = 'position:fixed;bottom:24px;right:24px;z-index:9999;background:var(--acid);color:#142033;font-weight:700;font-family:Space Grotesk;padding:14px 20px;border-radius:12px;box-shadow:0 12px 40px -10px rgba(0,0,0,.6);transition:.3s;opacity:0;transform:translateY(10px)';
      document.body.appendChild(t);
    }
    t.textContent = msg;
    requestAnimationFrame(() => { t.style.opacity = '1'; t.style.transform = 'none'; });
    clearTimeout(t._h);
    t._h = setTimeout(() => { t.style.opacity = '0'; t.style.transform = 'translateY(10px)'; }, 6000);
  }

  /* ================= CAMPANA: tareas y avisos (mobile/desktop/tablet) ================= */
  let bellItems = [], bellBound = false;
  function leadName(id){ const l = allLeads.find((x) => String(x.id) === String(id)); return l ? (l.name || l.email) : 'Lead'; }
  const startOfToday = () => { const d = new Date(); d.setHours(0, 0, 0, 0); return d; };
  const bellDismissed = new Set(JSON.parse(localStorage.getItem('bellDismissed') || '[]'));
  function dismissBellItem(k){
    bellDismissed.add(k);
    localStorage.setItem('bellDismissed', JSON.stringify([...bellDismissed].slice(-300)));
    // y a la BASE: descartada acá = descartada en todos tus dispositivos, para siempre
    supabase.from('bell_dismissed').upsert({ user_email: meEmail || '', key: k }).then(() => {}, () => {});
    bellItems = bellItems.filter((i) => (i.kind + ':' + i.id) !== k);
    renderBell();
  }
  async function loadBell(){
    if (!bellBound){ bellBound = true;
      $('bell-btn').addEventListener('click', (e) => { e.stopPropagation(); toggleBell(); });
      $('bell-x').addEventListener('click', (e) => { e.stopPropagation(); $('bell-panel').hidden = true; });
      $('bell-panel').addEventListener('click', (e) => e.stopPropagation());
      document.addEventListener('click', () => { $('bell-panel').hidden = true; });
      $('bell-push').addEventListener('click', (e) => { e.stopPropagation(); enablePush(); });
      refreshPushBtn();
    }
    try {
      const [tq, nq, bq, dq] = await Promise.all([
        supabase.from('lead_tasks').select('*').eq('done', false).order('due_date', { ascending: true }).limit(60),
        supabase.from('lead_notes').select('*').not('mention', 'is', null).order('created_at', { ascending: false }).limit(30),
        supabase.from('briefs').select('id,lead_id,email,goal,created_at').order('created_at', { ascending: false }).limit(10),
        supabase.from('bell_dismissed').select('key').limit(1000)
      ]);
      if (dq && !dq.error) (dq.data || []).forEach((d) => bellDismissed.add(d.key));
      const tasks = (tq && !tq.error && tq.data) || [];
      const notes = (nq && !nq.error && nq.data) || [];
      const briefs = (bq && !bq.error && bq.data) || [];
      const mine = (t) => !meEmail || !t.assignee || String(t.assignee).toLowerCase() === meEmail; // sin asignar o para mí
      const t0 = startOfToday(), tEnd = new Date(t0.getTime() + 86400000);
      bellItems = [];
      const nowTs = Date.now();
      tasks.filter(mine).forEach((t) => {
        const due = t.due_date ? new Date(t.due_date + 'T' + (t.due_time || '00:00') + ':00') : null;
        let bucket = 'later', overdue = false;
        if (due) { if (t.due_time ? due.getTime() < nowTs : due < t0) { bucket = 'overdue'; overdue = true; } else if (due < tEnd) bucket = 'today'; else bucket = 'later'; }
        else bucket = 'nodate';
        bellItems.push({ kind: 'task', id: t.id, lead_id: t.lead_id, title: t.title, due, time: t.due_time || '', bucket, overdue, at: t.created_at });
      });
      // notas donde me mencionaron a mí (últimas 24-72h no filtramos, mostramos como aviso)
      notes.filter((n) => meEmail && String(n.mention || '').toLowerCase() === meEmail).slice(0, 8).forEach((n) => {
        bellItems.push({ kind: 'mention', id: n.id, lead_id: n.lead_id, title: (n.body || '').slice(0, 80), due: null, bucket: 'mention', overdue: false, at: n.created_at });
      });
      // ya estamos live con Sofia — @viven.ch es tráfico real entre nosotros, no test.
      // Las notificaciones siempre muestran todo, sin filtrar nada.
      const bellSkip = () => false;
      // leads nuevos sin contactar (últimas 72h) — lo mismo que llega por push. 'manual' = lo
      // cargamos nosotros mismos desde Personas → no es una novedad, no hace falta avisarnos
      const cutoff = Date.now() - 72 * 36e5;
      (allLeads || []).filter((l) => isNew(l.status) && !/^claude-/.test(l.session_id || '') && l.channel !== 'manual' && Date.parse(l.created_at) > cutoff && !bellSkip(l.email))
        .slice(0, 8).forEach((l) => {
          bellItems.push({ kind: 'lead', id: 'l' + l.id, lead_id: l.id, title: '🎬 Lead nuevo: ' + (l.name || l.email || ''), due: null, bucket: 'newlead', overdue: false, at: l.created_at });
        });
      // 🔔 EVENTOS DE NEGOCIO (últimos 7 días): videollamadas, briefs, ganadas
      const evCut = Date.now() - 7 * 864e5;
      const fmtDT = (iso) => new Date(iso).toLocaleString('es-CH', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
      (upBookings || []).filter((b) => !bellSkip(b.email)).slice(0, 6).forEach((b) => {
        bellItems.push({ kind: 'event', id: 'bk' + b.id, lead_id: b.lead_id, title: '📅 Videollamada: ' + (b.name || b.email || '') + ' · ' + fmtDT(b.start_at), due: null, bucket: 'event', overdue: false, at: b.created_at || b.start_at });
      });
      briefs.filter((b) => Date.parse(b.created_at) > evCut && !bellSkip(b.email)).slice(0, 6).forEach((b) => {
        const lid = b.lead_id || ((allLeads || []).find((l) => l.email && b.email && l.email.toLowerCase() === b.email.toLowerCase()) || {}).id;
        bellItems.push({ kind: 'event', id: 'br' + b.id, lead_id: lid, title: '📋 Brief recibido: ' + (b.email || '') + (b.goal ? ' · ' + b.goal : ''), due: null, bucket: 'event', overdue: false, at: b.created_at });
      });
      (offersList || []).filter((o) => o.status === 'won' && !o.archived && !o.is_template && Date.parse(o.updated_at) > evCut && !bellSkip((leadById(o.lead_id) || {}).email)).slice(0, 6).forEach((o) => {
        bellItems.push({ kind: 'event', id: 'ow' + o.id, lead_id: o.lead_id, title: '🏆 Oferta ganada: ' + (o.title || '') + ' · ' + fmtM(offerNet(o)), due: null, bucket: 'event', overdue: false, at: o.updated_at });
      });
      acceptedProps().filter((p) => Date.parse(p.accepted_at || p.updated_at) > evCut && !bellSkip((leadById(p.lead_id) || {}).email)).slice(0, 6).forEach((p) => {
        bellItems.push({ kind: 'event', id: 'pw' + p.id, lead_id: p.lead_id, title: '🏆 Propuesta aceptada: ' + (p.title || '') + (Number(p.accepted_total) ? ' · ' + fmtM(p.accepted_total) : ''), due: null, bucket: 'event', overdue: false, at: p.accepted_at || p.updated_at });
      });
      (dealsList || []).filter((d) => stageOf(d.stage) === 'ganado' && d.won_at && Date.parse(d.won_at) > evCut && !bellSkip((leadById(d.lead_id) || {}).email)).forEach((d) => {
        const l = leadById(d.lead_id) || {};
        bellItems.push({ kind: 'event', id: 'dw' + d.id, lead_id: d.lead_id, title: '🎉 Deal ganado: ' + (d.title || l.name || l.email || '') + ' · ' + fmtM(dealValue(d)), due: null, bucket: 'event', overdue: false, at: d.won_at });
      });
      bellItems = bellItems.filter((i) => !bellDismissed.has(i.kind + ':' + i.id));
      renderBell();
    } catch (e) { /* si no corrió el SQL 0010, la campana queda vacía */ renderBell(); }
  }
  function renderBell(){
    const badge = $('bell-badge');
    const urgent = bellItems.filter((i) => i.bucket === 'overdue' || i.bucket === 'today' || i.bucket === 'mention' || i.bucket === 'newlead' || i.bucket === 'event').length;
    if (urgent > 0) { badge.hidden = false; badge.textContent = urgent > 99 ? '99+' : urgent; } else badge.hidden = true;
    const order = { newlead: 0, event: 1, overdue: 2, today: 3, mention: 4, later: 5, nodate: 6 };
    const labels = { newlead: ['🎬 Leads nuevos', false], event: ['🔔 Novedades', false], overdue: ['⚠️ Vencidas', true], today: ['📅 Para hoy', false], mention: ['💬 Te mencionaron', false], later: ['🕒 Próximas', false], nodate: ['📌 Sin fecha', false] };
    const list = $('bell-list');
    if (!bellItems.length) { list.innerHTML = '<div class="bell-empty">Nada pendiente 🎉<br>Las tareas que crees en un lead aparecen acá.</div>'; return; }
    const grouped = {};
    bellItems.forEach((i) => { (grouped[i.bucket] = grouped[i.bucket] || []).push(i); });
    const fmtDue = (i) => i.due ? (i.due.toLocaleDateString('es-CH', { day: '2-digit', month: 'short' }) + (i.time ? ' ' + i.time : '')) : '';
    let html = '';
    Object.keys(grouped).sort((a, b) => (order[a] ?? 9) - (order[b] ?? 9)).forEach((b) => {
      const [lbl, od] = labels[b] || [b, false];
      html += '<div class="bell-grp' + (od ? ' od' : '') + '">' + lbl + ' (' + grouped[b].length + ')</div>';
      grouped[b].forEach((i) => {
        html += '<div class="bell-row"><button class="bell-item" data-lead="' + esc(i.lead_id) + '" type="button"><span class="bi-t">' + (i.kind === 'mention' ? '💬 ' : '') + esc(i.title || '(sin título)') + '</span><span class="bi-s">' + esc(leadName(i.lead_id)) + (i.due ? ' · <span class="bi-due' + (i.overdue ? ' od' : '') + '">' + fmtDue(i) + '</span>' : '') + '</span>' + (i.at ? '<span class="bi-at">hace ' + timeAgo(i.at) + '</span>' : '') + '</button>' +
          '<button class="bell-dis" data-k="' + esc(i.kind + ':' + i.id) + '" type="button" title="Descartar esta notificación" aria-label="Descartar">✕</button></div>';
      });
    });
    list.innerHTML = html;
    list.querySelectorAll('.bell-item').forEach((b) => b.addEventListener('click', () => { $('bell-panel').hidden = true; gotoTab('leads'); openLead(b.dataset.lead); }));
    list.querySelectorAll('.bell-dis').forEach((b) => b.addEventListener('click', (e) => { e.stopPropagation(); dismissBellItem(b.dataset.k); }));
  }
  function toggleBell(){ const p = $('bell-panel'); const willOpen = p.hidden; document.querySelectorAll('.bell-panel').forEach((x) => x.hidden = true); p.hidden = !willOpen; if (willOpen) loadBell(); }
  // re-evaluar cada 2 min: cuando una task cruza su hora, el badge salta solo
  setInterval(() => { const dv = $('dash-view'); if (dv && !dv.hidden && !document.hidden) loadBell(); }, 120000);
  /* Analytics/Home mostraban una FOTO fija del momento en que cargó la página (sin
     recargar, el número no se movía nunca) — eso hacía parecer "raro" cualquier
     comparación. A pedido de Sebastián (con Sofia usando el dashboard al mismo tiempo,
     lo que cambia una la tiene que ver la otra rápido): se refresca cada 2 min, en
     TODOS los tabs (no solo Home) — mientras la pestaña esté visible — y siempre se
     ve hace cuánto es el dato, para no confundir una foto vieja con el vivo. */
  setInterval(() => { const dv = $('dash-view'); if (dv && !dv.hidden && !document.hidden) loadAll(); }, 120000);
  setInterval(() => {
    const el = $('data-fresh'); if (!el || !window.__vvLoadedAt) return;
    const s2 = Math.round((Date.now() - window.__vvLoadedAt) / 1000);
    el.textContent = s2 < 60 ? 'actualizado hace ' + s2 + 's' : 'actualizado hace ' + Math.round(s2 / 60) + ' min';
