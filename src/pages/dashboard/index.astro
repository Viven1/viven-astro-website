  /* ================= CRM: alta manual + importar CSV (como HubSpot) ================= */
  // escribe filas en chunks; si a la tabla le falta una columna, la saca de todas y reintenta
  async function sbWriteRowsResilient(table, rows, conflict){
    const stripped = new Set(); const out = [];
    for (let i = 0; i < rows.length; i += 50){
      const chunk = rows.slice(i, i + 50);
      for (let a = 0; a < 8; a++){
        const clean = chunk.map((r) => { const c = { ...r }; stripped.forEach((k) => delete c[k]); return c; });
        const q = conflict ? supabase.from(table).upsert(clean, { onConflict: conflict }).select() : supabase.from(table).insert(clean).select();
        const { data, error } = await q;
        if (!error){ out.push(...(data || [])); break; }
        const m = /Could not find the '([^']+)' column/.exec(error.message || '');
        if (m && !stripped.has(m[1])){ stripped.add(m[1]); continue; }
        throw error;
      }
    }
    return { rows: out, stripped: [...stripped] };
  }
  // CSV con comillas, comas o punto y coma (Excel suizo exporta con ';')
  function parseCSV(text){
    text = String(text || '').replace(/^\uFEFF/, '');
    const nl = text.indexOf('\n');
    const first = nl > -1 ? text.slice(0, nl) : text;
    const delim = (first.match(/;/g) || []).length > (first.match(/,/g) || []).length ? ';' : ',';
    const rows = []; let row = [], cur = '', inQ = false;
    for (let i = 0; i < text.length; i++){
      const ch = text[i];
      if (inQ){ if (ch === '"'){ if (text[i + 1] === '"'){ cur += '"'; i++; } else inQ = false; } else cur += ch; }
      else if (ch === '"') inQ = true;
      else if (ch === delim){ row.push(cur); cur = ''; }
      else if (ch === '\n'){ row.push(cur); cur = ''; if (row.some((c) => c.trim() !== '')) rows.push(row); row = []; }
      else if (ch !== '\r') cur += ch;
    }
    row.push(cur); if (row.some((c) => c.trim() !== '')) rows.push(row);
    return rows;
  }
