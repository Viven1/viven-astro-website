  async function abLoad(){
    const [tq, hq, lq] = await Promise.all([
      supabase.from('ab_tests').select('*').order('created_at', { ascending: false }),
      supabase.from('ab_hits').select('test_id,bucket,session_id').limit(50000),
      supabase.from('leads').select('id,ab,status').not('ab', 'is', null).limit(5000),
    ]);
    if (tq.error){ $('ab-list').innerHTML = '<p class="muted-note">⚠️ Falta correr el SQL <b>0030</b> en Supabase para activar los A/B tests.</p>'; return; }
    abTests = tq.data || [];
    const hits = (hq && !hq.error && hq.data) || [];
    const abLeads = (lq && !lq.error && lq.data) || [];
    // exposiciones únicas por test/bucket
    const exp = {};
    hits.filter((h) => !/^claude-/.test(h.session_id || '')).forEach((h) => { const k = h.test_id + ':' + h.bucket; (exp[k] = exp[k] || new Set()).add(h.session_id || Math.random()); });
    abExp = exp; abLeadsCache = abLeads;
    renderAbList(exp, abLeads);
