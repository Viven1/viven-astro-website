        (function(){ const sc = scMap.get(r.id) || { score: 0, tier: { t: '', c: 'var(--muted)' }, factors: [] }; return '<td><span class="lt-score" style="color:' + sc.tier.c + ';border-color:' + sc.tier.c + '" title="AI lead score ' + sc.score + '/100\n' + esc(sc.factors.join('\n')) + '">' + (sc.tier.t === 'Hot' ? '🔥 ' : '') + sc.score + '</span></td>'; })() +
