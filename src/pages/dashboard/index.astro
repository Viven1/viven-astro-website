  /* ============ FICHA V2 (test) — estilo HubSpot/Keap ============
     Una timeline unificada (emails+notas+tasks+briefs+web+etapas), composer con
     pestañas, próximo paso siempre visible, y el negocio en tarjetas a la derecha.
     Acciones raras → menú ⋯. Editar/IA/reseña siguen en la clásica por ahora. */
  const modal2 = $('lead-modal2');
  let lm2Lead = null, lm2Filter = 'all', lm2Events = [], lm2Tab = 'nota';
  const lm2Mobile = () => window.matchMedia('(max-width:960px)').matches;
  let lm2CompCollapsed = false; // móvil: el composer arranca plegado (una barra) para descomprimir la ficha
  function closeLead2(){ modal2.classList.remove('open'); modal2.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; lm2Lead = null; currentLead = null; }
  modal2.querySelectorAll('[data-close2]').forEach((el) => el.addEventListener('click', closeLead2));
  $('lm-try-v2') && $('lm-try-v2').addEventListener('click', () => {
    localStorage.setItem('vv_ficha2', '1');
    const id = currentLead && currentLead.id;
    closeLead();
    if (id) openLeadV2(id);
    toast('✨ Ficha nueva activada — «⋯ → Volver a la clásica» para deshacer');
  });

  function lm2FmtDT(d){ return d ? new Date(d).toLocaleString('es-CH', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) : ''; }

  function openLeadV2(id){
    const r = allLeads.find((l) => String(l.id) === String(id));
    if (!r) return;
    lm2Lead = r; currentLead = r; lm2Filter = 'all';
    const ldom = leadDomain(r);
    const company = (ldom && companyName(ldom)) || r.company || '';
    const first = r.first_name || (r.name || '').trim().split(/\s+/)[0] || '';
    const last = r.last_name || (r.name || '').trim().split(/\s+/).slice(1).join(' ') || '';
    const cur = stageOf(r.status);
    const lost = cur === 'perdido';
    const linear = STAGES.filter((s) => s.key !== 'perdido');
    const curIdx = linear.findIndex((s) => s.key === cur);
    const pipe = '<div class="lm2-pipe">' + linear.map((s, i) =>
      '<span class="' + (lost ? '' : i < curIdx ? 'done' : i === curIdx ? 'cur' : '') + '" data-st="' + s.key + '" title="Pasar a ' + s.label + '">' + s.label + '</span>').join('') + '</div>' +
      (lost ? '<span class="lm2-lost" title="' + esc(r.lost_reason || '') + '">Perdido</span>' : '');
    // orden de navegación ←→: la misma lista filtrada que ve Personas
    const order = filteredLeads().map((l) => String(l.id));
    const oi = order.indexOf(String(r.id));
    $('lm2-hd').innerHTML =
      '<button class="lm2-back" id="lm2-back" type="button" title="Volver a todos los contactos">← Personas</button>' +
      '<div class="lm2-nav"><button id="lm2-nav-prev" title="Contacto anterior"' + (oi <= 0 ? ' disabled' : '') + '>‹</button>' +
        (oi > -1 ? '<span class="lm2-nav-n">' + (oi + 1) + '/' + order.length + '</span>' : '') +
        '<button id="lm2-nav-next" title="Contacto siguiente"' + (oi < 0 || oi >= order.length - 1 ? ' disabled' : '') + '>›</button></div>' +
      '<div class="lm2-avatar">' + esc(((first[0] || '?') + (last[0] || '')).toUpperCase()) + '</div>' +
      '<div class="lm2-who"><div class="nm">' + esc(r.name || '(sin nombre)') + '<span class="lm-score" id="lm2-score"></span></div>' +
      '<div class="sub">' + esc([r.job_title, company, r.email].filter(Boolean).join(' · ')) + '</div></div>' +
      pipe +
      '<div class="lm2-actions">' +
        '<a class="btn btn-primary small" href="mailto:' + esc(r.email) + '" style="text-decoration:none">✉️ Email</a>' +
        (r.phone ? '<a class="btn btn-ghost small" href="tel:' + esc((r.phone || '').replace(/[^\d+]/g, '')) + '" style="text-decoration:none">📞</a>' : '') +
        '<button class="btn btn-ghost small" id="lm2-crear" type="button">➕<span class="lbl"> Crear</span> ▾</button>' +
        '<button class="btn btn-ghost small" id="lm2-dots" type="button" title="Más acciones">⋯</button>' +
        '<div class="lm2-menu" id="lm2-menu" hidden></div>' +
      '</div>';
    // score: mismo pill que la clásica (renderLeadScore escribe en lm-score → lo copio a mano)
    try { renderLeadScore(r); const s0 = $('lm-score'); const s2 = $('lm2-score'); if (s0 && s2) { s2.textContent = s0.textContent; s2.title = s0.title; s2.style.cssText = s0.style.cssText; } } catch (e) {}
    // móvil: el pipeline de etapas scrollea horizontal — centrar la etapa actual para que no quede cortada
    if (lm2Mobile()){ const curSp = $('lm2-hd').querySelector('.lm2-pipe .cur'); if (curSp && curSp.scrollIntoView) curSp.scrollIntoView({ inline: 'center', block: 'nearest' }); }
    $('lm2-back').addEventListener('click', () => { closeLead2(); gotoTab('leads'); });
    $('lm2-nav-prev') && $('lm2-nav-prev').addEventListener('click', () => oi > 0 && openLeadV2(order[oi - 1]));
    $('lm2-nav-next') && $('lm2-nav-next').addEventListener('click', () => oi < order.length - 1 && openLeadV2(order[oi + 1]));
    // etapa: clic en el pipeline = mismo flujo que el select de la clásica
    $('lm2-hd').querySelectorAll('.lm2-pipe span').forEach((sp) => sp.addEventListener('click', async () => {
      const key = sp.dataset.st; if (key === cur) return;
      const top = latestDealOf(r.id);
      const ok = top ? await setDealStage(top.id, key) : await setLeadStage(r.id, key);
      if (ok) { toast('Etapa → ' + (STAGES.find((s) => s.key === key) || {}).label); openLeadV2(r.id); }
    }));
    // popover compartido (⋯ y ➕ Crear): se re-arma el contenido en cada apertura
    const menu = $('lm2-menu');
    function lm2Menu(html, wire){
      menu.innerHTML = html; menu.hidden = false;
      wire(menu);
      setTimeout(() => document.addEventListener('click', () => { menu.hidden = true; }, { once: true }), 0);
    }
    $('lm2-dots').addEventListener('click', (e) => {
      e.stopPropagation();
      if (!menu.hidden) { menu.hidden = true; return; }
      lm2Menu(
        (r.phone ? '<button data-act="wa">💬 WhatsApp</button>' : '') +
        // acciones que antes obligaban a saltar a la clásica — nativas en V2 para no romper el flujo
        '<button data-act="enrich">✨ Enriquecer con IA</button>' +
        (stageOf(r.status) === 'ganado' ? '<button data-act="review">⭐ Pedir reseña</button>' : '') +   // misma regla que la clásica: solo ganados
        '<button data-act="replied">✉️ Respondió</button>' +
        (r.gclid ? '<button data-act="ads">' + (r.ads_exclude ? '🚫 Ads: excluido — incluir' : '🎯 Ads: se envía — excluir') + '</button>' : '') +
        '<button data-act="classic">🧰 Abrir ficha clásica (editar, IA, reseña…)</button>' +
        '<button data-act="volver">↩️ Volver a la ficha clásica (siempre)</button>' +
        '<hr /><button data-act="del" class="danger">🗑 Borrar contacto</button>',
        (m) => m.querySelectorAll('button').forEach((b) => b.addEventListener('click', async (ev) => {
          ev.stopPropagation(); m.hidden = true;
          const act = b.dataset.act;
          if (act === 'wa') window.open('https://wa.me/' + (r.phone || '').replace(/[^\d+]/g, '').replace(/^\+/, ''), '_blank');
          if (act === 'enrich') lm2RunEnrich(r);
          if (act === 'review') {
            // mismo flujo que $('lm-review') de la clásica: confirmar → edge function review-request
            if (!confirm('¿Mandar AHORA el pedido de reseña de Google a ' + (r.name || r.email) + '?\n\nSolo si el proyecto ya está entregado.')) return;
            try {
              const { data, error } = await supabase.functions.invoke('review-request', { body: { lead_id: r.id } });
              if (error || data?.error) throw new Error(data?.error || error?.message || 'sin respuesta');
              toast('⭐ Pedido de reseña enviado a ' + data.sent_to);
              lm2LoadTimeline(r);   // la nota del envío aparece en la timeline (el loadNotes de la clásica no existe acá)
            } catch (e) { toast('No se pudo: ' + (e.message || e)); }
          }
          if (act === 'replied') {
            // mismo flujo que $('lm-replied'): marcar respuesta y frenar las secuencias activas
            try {
              const { error } = await supabase.from('leads').update({ last_reply_at: new Date().toISOString() }).eq('id', r.id);
              if (error){ toast(/column/.test(error.message || '') ? '⚠️ Falta correr el SQL 0042' : '⚠️ ' + error.message); return; }
              const { error: e2 } = await supabase.from('automation_runs').update({ status: 'stopped' }).eq('lead_id', r.id).eq('status', 'active');
              toast(e2 ? '✉️ Marcado (⚠️ no se pudieron frenar los workflows: falta SQL 0043)' : '✉️ Marcado como respondió — fuera de todas las secuencias automáticas');
            } catch (e) { toast('⚠️ ' + (e && e.message || e)); }
          }
          if (act === 'ads') {
            // mismo flujo que $('lm-ads-x'): incluir/excluir de las conversiones que van a Google Ads
            const nv = !r.ads_exclude;
            const { error } = await supabase.from('leads').update({ ads_exclude: nv }).eq('id', r.id);
            if (error){ toast(/column/.test(error.message || '') ? 'Falta correr el SQL 0036 (columna ads_exclude)' : 'No se pudo: ' + error.message); return; }
            r.ads_exclude = nv;
            const i = allLeads.findIndex((l) => String(l.id) === String(r.id)); if (i > -1) allLeads[i].ads_exclude = nv;
            toast(nv ? 'Este lead NO se reporta a Google Ads (spam/test)' : 'Este lead vuelve a reportarse a Google Ads');
          }
          if (act === 'classic') { closeLead2(); openLeadClassic(r.id); }
          if (act === 'volver') { localStorage.removeItem('vv_ficha2'); closeLead2(); openLeadClassic(r.id); toast('Ficha clásica de nuevo como default'); }
          if (act === 'del') {
            if (!confirm('¿Borrar definitivamente el contacto "' + (r.name || r.email) + '"? Esta acción no se puede deshacer.')) return;
            const { error } = await supabase.from('leads').delete().eq('id', r.id);
            if (error) { alert('No se pudo borrar: ' + error.message); return; }
            allLeads = allLeads.filter((l) => l.id !== r.id);
            closeLead2(); renderLeads();
          }
        })));
    });
    $('lm2-crear').addEventListener('click', (e) => {
      e.stopPropagation();
      if (!menu.hidden) { menu.hidden = true; return; }
      lm2Menu('<button data-c="offer">🧾 Oferta</button><button data-c="prop">🌐 Propuesta</button><button data-c="deal">🤝 Proyecto</button><button data-c="task">✅ Task</button>',
        (m) => m.querySelectorAll('button').forEach((cb) => cb.addEventListener('click', async (ev) => {
