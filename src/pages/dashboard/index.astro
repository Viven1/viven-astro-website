  /* ================= AUTOMATIZACIONES (constructor si→entonces) ================= */
  let auCur = null, auList = [], auSteps = { a: [], b: [] };
  const AU_STAGE_L = { contactado: 'Contactado', videocall: 'Video call', propuesta: 'Propuesta', ganado: 'Ganado', perdido: 'Perdido' };
  function auTriggerLabel(a){
    const c = a.trigger_config || {};
    let t = a.trigger === 'stage' ? 'Al llegar a ' + (AU_STAGE_L[c.stage] || c.stage) : a.trigger === 'inactivity' ? 'Inactivo ' + (c.days || 7) + ' días' : 'Lead nuevo' + (c.source === 'calculator' ? ' (calculadora)' : c.source === 'form' ? ' (formulario)' : '');
    if (c.lang && c.lang !== 'any') t += ' · ' + c.lang.toUpperCase();
    return t;
  }
  /* ================= slice verde: CAPA DE LECTURA de performance por workflow =================
     Números 100% derivados de datos que YA existen (automation_runs + outbox + leads).
     NO instrumenta el motor de envío (está pausado) ni cambia el modelo — sólo lee y muestra:
     el valor "¿funciona esta secuencia? ¿trae plata?" del mockup aprobado, sin lo riesgoso.
     Nota aperturas: el webhook resend-events HOY sólo estampa opens de offers/newsletter,
     NO de outbox/workflows — por eso mostramos inscriptos/llegaron, no % de apertura fake. */
  const auChf = (n) => 'CHF ' + Math.round(+n || 0).toLocaleString('de-CH');
  // fila resumen (el add clave): inscriptos ahora / completaron / frenados / borradores / ganados+CHF
  function wfpChips(s){
    if (!s.active && !s.done && !s.stopped && !s.drafts && !s.won)
      return '<span class="wfp-empty">Sin datos todavía — nadie inscripto (el motor automático está en pausa).</span>';
    const c = [];
    c.push('<span class="wfp-chip">👥 <b>' + s.active + '</b> inscriptos ahora</span>');
    c.push('<span class="wfp-chip">✅ <b>' + s.done + '</b> completaron</span>');
    if (s.stopped) c.push('<span class="wfp-chip">⏹ <b>' + s.stopped + '</b> frenados (respondió/avanzó)</span>');
    if (s.drafts) c.push('<span class="wfp-chip">📤 <b>' + s.drafts + '</b> borradores esperando ok</span>');
    if (s.won) c.push('<span class="wfp-chip win">🏆 <b>' + s.won + '</b> ganados · ' + auChf(s.chf) + ' atribuidos</span>');
    return '<div class="wfp-sum">' + c.join('') + '</div>';
  }
  // A/B de CAMINOS que por fin MIDE: exposiciones = inscriptos por variante,
  // conversiones = ganados por variante → REUSA abStats() (mismo z-test de dos proporciones
  // del tab A/B) y sugiere ganador SÓLO a ≥95%, igual que aquel tab.
  function wfpAbBlock(a, rs, wonIds){
    const V = (v) => {
      const rv = rs.filter((r) => r.variant === v);
      const leads = [...new Set(rv.map((r) => String(r.lead_id)))];
      return { enr: rv.length, done: rv.filter((r) => r.status === 'done').length,
        stop: rv.filter((r) => r.status === 'stopped').length,
        won: leads.filter((id) => wonIds.has(id)).length };
    };
    const A = V('a'), B = V('b');
    const st = abStats(A.enr, A.won, B.enr, B.won);   // ← mismo helper que el tab A/B
    const bWins = st.cb > st.ca, aWins = st.ca > st.cb, confPct = Math.round(st.conf * 100);
    const total = A.enr + B.enr;
    const cell = (side, d, win) =>
      '<div class="wfp-var' + (win ? ' win' : '') + '"><div class="k">' + (side === 'a' ? '🅰 Camino A' : '🅱 Camino B') + (win ? ' 🏆' : '') + '</div>' +
      '<div class="nums"><div><b>' + d.enr + '</b>inscr.</div><div><b>' + d.done + '</b>compl.</div><div><b>' + d.stop + '</b>resp/av.</div><div><b>' + d.won + '</b>ganados</div><div><b>' + (d.enr ? Math.round(d.won / d.enr * 100) : 0) + '%</b>conv.</div></div></div>';
    let verdict;
    if (st.conf >= 0.95 && (bWins || aWins)){
      const winner = bWins ? '🅱' : '🅰';
      verdict = '<div class="wfp-verdict"><span class="conf" style="color:#7ed957">' + confPct + '%</span>' +
        '<span>🏆 <b style="color:#7ed957">sugerencia: quedarse con ' + winner + '</b> — gana en ganados con ' + confPct + '% de confianza (mismo umbral 95% que el tab A/B).</span></div>';
    } else if (total < 6){
      verdict = '<div class="wfp-verdict"><span class="conf" style="color:var(--muted-2)">—</span>' +
        '<span class="wfp-empty">Muestra chica todavía — hacen falta más inscriptos para comparar los caminos.</span></div>';
    } else {
      verdict = '<div class="wfp-verdict"><span class="conf" style="color:#f0c060">' + (confPct > 0 ? confPct + '%' : '—') + '</span>' +
        '<span class="wfp-empty">Todavía no hay ganador claro (umbral 95%, como el tab A/B). Juntando señal.</span></div>';
    }
    return '<div class="wfp-ab"><div class="wfp-ab-grid">' + cell('a', A, aWins && st.conf >= 0.95) + cell('b', B, bWins && st.conf >= 0.95) + '</div>' + verdict + '</div>';
  }
  // franja de pasos (modesta): por cada paso de steps_a, cuántos runs ya lo PASARON (step_idx > i).
  // Sin % de apertura: el webhook aún no marca opens de workflows (ver nota arriba).
  function wfpStepStrip(a, rs){
    const steps = a.steps_a || [];
    if (!steps.length) return '';
    const rsA = a.ab_split > 0 ? rs.filter((r) => r.variant === 'a') : rs;  // camino A (o único)
    const hasEmail = steps.some((s) => s.type === 'email' || s.type === 'ai_email');
    const cells = [];
    steps.forEach((st, i) => {
      const meta = AU_TYPE_META[st.type] || { ic: '•' };
      const reached = rsA.filter((r) => (r.step_idx || 0) > i).length;
      const raw = st.type === 'email' ? (st.subject || 'email') : st.type === 'ai_email' ? 'email IA' :
        st.type === 'wait' ? ((st.days || 1) + ' días') : st.type === 'task' ? (st.title || 'tarea') :
        st.type === 'push' ? 'push team' : ('→ ' + (st.value || 'etapa'));
      cells.push('<div class="wfp-step"><div class="t">' + meta.ic + ' ' + esc(String(raw).slice(0, 22)) + '</div>' +
        '<div class="n"><b>' + reached + '</b> llegaron</div></div>');
      if (i < steps.length - 1) cells.push('<span class="wfp-arrow">→</span>');
    });
    return '<div class="wfp-steps">' + cells.join('') + '</div>' +
      (hasEmail ? '<div class="wfp-note">ⓘ aperturas por paso: follow-up — el webhook de Resend todavía no marca aperturas de emails de workflow (sólo newsletter/ofertas).</div>' : '');
  }
