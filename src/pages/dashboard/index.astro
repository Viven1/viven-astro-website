  async function loadCompanyActivity(contacts){
    const box = $('co-activity'); if (!box) return;
    const ids = contacts.map((l) => String(l.id));
    if (!ids.length) { box.innerHTML = '<p class="muted-note">Sin contactos.</p>'; return; }
    const nmeOf = (id) => { const l = contacts.find((c) => String(c.id) === String(id)); return l ? (l.name || l.email) : ''; };
    try {
      const [tq, nq] = await Promise.all([
        supabase.from('lead_tasks').select('*').in('lead_id', ids).eq('done', false).order('due_date', { ascending: true }).limit(8),
        supabase.from('lead_notes').select('*').in('lead_id', ids).order('created_at', { ascending: false }).limit(6)
      ]);
      const tasks = (tq && !tq.error && tq.data) || [], notes = (nq && !nq.error && nq.data) || [];
      const fmtDue = (d) => d ? new Date(d).toLocaleDateString('es-CH', { day: '2-digit', month: 'short' }) : '';
      let html = '';
      html += '<div class="co-act-h">✅ Tareas abiertas <span>(' + tasks.length + ')</span></div>';
      html += tasks.length ? tasks.map((t) => { const overdue = t.due_date && new Date(t.due_date) < new Date(new Date().toDateString());
        return '<div class="co-act-item"><span class="co-act-t">' + esc(t.title) + '<span class="co-act-who">' + esc(nmeShort(nmeOf(t.lead_id))) + (t.assignee ? ' · ' + esc(teamName(t.assignee)) : '') + '</span></span>' + (t.due_date ? '<span class="co-act-due' + (overdue ? ' od' : '') + '">' + fmtDue(t.due_date) + '</span>' : '') + '</div>'; }).join('') : '<p class="muted-note" style="margin:2px 0 10px">Ninguna.</p>';
      html += '<div class="co-act-h" style="margin-top:12px">📝 Notas recientes <span>(' + notes.length + ')</span></div>';
      html += notes.length ? notes.map((n) => '<div class="co-act-note"><div class="co-act-nb">' + esc((n.body || '').slice(0, 160)) + ((n.body || '').length > 160 ? '…' : '') + '</div><div class="co-act-who">' + esc(nmeShort(nmeOfNote(n, contacts))) + ' · ' + new Date(n.created_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short' }) + '</div></div>').join('') : '<p class="muted-note" style="margin:2px 0">Ninguna.</p>';
      box.innerHTML = html;
    } catch (e) { box.innerHTML = '<p class="muted-note">No se pudo cargar la actividad (¿SQL 0010?).</p>'; }
  }
  function nmeShort(s){ return (s || '').split(/\s+/)[0] || s || ''; }
  function nmeOfNote(n, contacts){ const l = contacts.find((c) => String(c.id) === String(n.lead_id)); return l ? (l.name || l.email) : ''; }
  function editCompany(){
