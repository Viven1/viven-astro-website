  /* quién firma/envía — configurable (Sofia o Sebastian). Se guarda en el navegador. */
  const SENDERS = {
    sofia:     { name: 'Sofia Treviño',   book: 'https://meetings.hubspot.com/sofia-trevino?uuid=76bf013f-3825-4341-8a95-fee769f70c49' },
    sebastian: { name: 'Sebastian Cepeda', book: 'https://meetings.hubspot.com/sofia-trevino?uuid=76bf013f-3825-4341-8a95-fee769f70c49' },
  };
  let sender = localStorage.getItem('viven_sender') || 'sofia';
  const briefUrl = (r) => 'https://www.viven.ch/brief/?lead=' + encodeURIComponent(r.id) + '&lang=' + (['en', 'de', 'es'].includes(r.lang) ? r.lang : 'en') + '&topic=' + detectTopic(r.message);

  // customProof: frase personalizada de la IA (opcional). Si no viene, usa la estática.
  // La estructura (saludo, 2 CTAs, brief, firma) SIEMPRE la controla el código — la IA solo cambia el hook.
  function buildDraft(r, customProof){
    const lang = ['en', 'de', 'es'].includes(r.lang) ? r.lang : 'en';
    const first = esc0(r.first_name || (r.name || '').trim().split(/\s+/)[0] || '');
    const proof = customProof || PROOF[lang][detectTopic(r.message)];
    const S = SENDERS[sender] || SENDERS.sofia;
    const BOOK_URL = S.book;
    const SIGN = S.name + '\nViven — viven.ch · +41 43 508 33 81';
    if (lang === 'de') return 'Guten Tag ' + first + '\n\n' +
      'Vielen Dank für Ihre Anfrage — gerne helfen wir weiter.\n\n' +
      'Zur Einordnung: ' + proof + '.\n\n' +
      'Damit es schnell geht, wählen Sie einfach, was für Sie leichter ist:\n\n' +
      '① 15-Min-Call buchen: ' + BOOK_URL + '\n' +
      '② Oder Ihr Briefing in 2 Minuten ausfüllen: ' + briefUrl(r) + '\n\n' +
      'So oder so bekommen Sie ein fixes Angebot mit Timing — der erste Entwurf ist in der Regel ca. zwei Wochen nach Start fertig.\n\n' +
      'Freundliche Grüsse\n' + SIGN;
    if (lang === 'es') return 'Hola ' + first + ':\n\n' +
      'Gracias por escribirnos — nos encantaría ayudarte.\n\n' +
      'Para que nos ubiques: ' + proof + '.\n\n' +
      'Para avanzar rápido, elegí lo que te resulte más fácil:\n\n' +
      '① Agendá una llamada de 15 min: ' + BOOK_URL + '\n' +
      '② O completá tu brief en 2 minutos: ' + briefUrl(r) + '\n\n' +
      'En cualquier caso te mandamos una propuesta con presupuesto fijo y tiempos — el primer borrador suele estar listo unas dos semanas después de arrancar.\n\n' +
      'Saludos,\n' + SIGN;
    return 'Hi ' + first + ',\n\n' +
      'Thanks for reaching out — we’d love to help.\n\n' +
      'For context: ' + proof + '.\n\n' +
      'To move fast, pick whichever is easier for you:\n\n' +
      '① Book a 15-min call: ' + BOOK_URL + '\n' +
      '② Or send us your brief in 2 minutes: ' + briefUrl(r) + '\n\n' +
      'Either way you’ll get a fixed quote with timing — the first draft is typically ready about two weeks after we start.\n\n' +
      'Best,\n' + SIGN;
  }
  /* nombre sin HTML para el draft (texto plano) */
  const esc0 = (s) => String(s ?? '').replace(/[<>]/g, '');

  const SUBJECTS = {
    en: 'Your video project — Viven',
    de: 'Ihr Videoprojekt — Viven',
    es: 'Tu proyecto de video — Viven'
  };

  function openLead(id){
    const r = allLeads.find((l) => String(l.id) === String(id));
    if (!r) return;
    currentLead = r;
    $('lm-name').textContent = r.name || '(sin nombre)';
    $('lm-email').textContent = r.email;
    $('lm-email').href = 'mailto:' + r.email;
    $('lm-date').textContent = new Date(r.created_at).toLocaleString('es-CH', { day: '2-digit', month: 'long', hour: '2-digit', minute: '2-digit' });
    const fields = [
      ['Canal', r.channel || '—'],
      ['Idioma', (r.lang || '—').toUpperCase()],
      ['Estado', r.status || '—'],
      ['Página de entrada', r.landing_path || '—'],
      ['Campaña (UTM)', r.utm_campaign || '—'],
      ['Fuente (UTM)', r.utm_source || '—'],
      ['GCLID (Google Ads)', r.gclid || '—'],
      ['Próximo follow-up', r.next_follow_up_at
        ? new Date(r.next_follow_up_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short' }) + (r.follow_up_count ? ' · #' + (r.follow_up_count + 1) : '')
        : (r.status === 'contacted' || r.status === 'contactado' ? 'programando…' : '—')],
      ['Sesión', r.session_id ? r.session_id.slice(0, 13) + '…' : '—']
    ];
    $('lm-details').innerHTML = fields.map(([k, v]) =>
      '<div class="detail"><div class="k">' + k + '</div><div class="v">' + esc(v) + '</div></div>'
    ).join('');
    $('lm-message').textContent = r.message || '(sin mensaje)';
    $('lm-sender').value = sender;
    const draft = buildDraft(r);
    $('lm-draft').value = draft;
    updateMailto();
    $('lm-status-note').textContent = 'El borrador usa el idioma del lead (' + (r.lang || 'en').toUpperCase() + ') y se adapta a su mensaje.';
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function updateMailto(){
    if (!currentLead) return;
    const lang = ['en', 'de', 'es'].includes(currentLead.lang) ? currentLead.lang : 'en';
    $('lm-mailto').href = 'mailto:' + currentLead.email +
      '?subject=' + encodeURIComponent(SUBJECTS[lang]) +
      '&body=' + encodeURIComponent($('lm-draft').value);
  }
  $('lm-draft').addEventListener('input', updateMailto);
  function closeLead(){
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    currentLead = null;
  }
  modal.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', closeLead));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modal.classList.contains('open')) closeLead(); });

  $('lm-copy').addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText($('lm-draft').value);
      $('lm-copy').textContent = '✓ Copiado';
    } catch (e) {
      $('lm-draft').select();
      document.execCommand('copy');
      $('lm-copy').textContent = '✓ Copiado';
    }
    setTimeout(() => { $('lm-copy').textContent = '📋 Copiar'; }, 1600);
  });

  /* 📨 Enviar el borrador aprobado al lead (Edge Function send-outreach → Resend, desde info@viven.ch) */
  $('lm-send').addEventListener('click', async () => {
    if (!currentLead) return;
    const lang = ['en', 'de', 'es'].includes(currentLead.lang) ? currentLead.lang : 'en';
    const body = $('lm-draft').value.trim();
    if (!body) return;
    if (!confirm('¿Enviar este email a ' + currentLead.email + '? Sale desde info@viven.ch.')) return;
    const btn = $('lm-send'), prev = btn.textContent; btn.disabled = true; btn.textContent = '📨 Enviando…';
    try {
      const { data, error } = await supabase.functions.invoke('send-outreach', {
        body: { to: currentLead.email, subject: SUBJECTS[lang], body, lead_id: currentLead.id, mark_contacted: true, fromName: (SENDERS[sender] || SENDERS.sofia).name }
      });
      if (error || !data || !data.ok) throw new Error(data?.error || error?.message || 'sin respuesta');
      currentLead.status = 'contactado';
      $('lm-status-note').textContent = '✓ Enviado a ' + currentLead.email + ' — el lead pasó a Contactado.';
      renderLeads();
      setTimeout(closeLead, 1200);
    } catch (e) {
      $('lm-status-note').textContent = 'No se pudo enviar (¿deployaste send-outreach?): ' + e.message;
    } finally { btn.disabled = false; btn.textContent = prev; }
  });

  /* Selector de remitente (Sofia / Sebastian): guarda la preferencia y regenera el borrador */
  $('lm-sender').addEventListener('change', () => {
    sender = $('lm-sender').value;
    localStorage.setItem('viven_sender', sender);
    if (currentLead) { $('lm-draft').value = buildDraft(currentLead); updateMailto(); }
  });

  /* ✨ Sugerencia con IA (Edge Function ai-suggest → Claude). Reemplaza el borrador. */
  $('lm-ai').addEventListener('click', async () => {
    if (!currentLead) return;
    const btn = $('lm-ai'), prev = btn.textContent;
    btn.disabled = true; btn.textContent = '✨ Pensando…';
    try {
      const { data, error } = await supabase.functions.invoke('ai-suggest', {
        body: { lead: currentLead, lang: currentLead.lang || 'es' }
      });
      if (error) throw new Error(data?.error || error?.message || 'sin respuesta');
      // La IA devuelve SOLO la frase personalizada (proof). El resto lo arma buildDraft → las CTAs y el brief nunca se pierden.
      let aiProof = (data && data.proof || '').trim();
      // Si vino un email entero (versión vieja de ai-suggest, con saludo/firma/CTA) NO lo insertamos como frase.
      const looksLikeFullEmail = /\n|hola|guten tag|hi\b|saludos|grüsse|best,|\[tu nombre\]|agendá|book|brief/i.test(aiProof);
      if (data && data.suggestion && !data.proof) {
        throw new Error('La función ai-suggest está desactualizada. Redeployala: supabase functions deploy ai-suggest --no-verify-jwt');
      }
      if (!aiProof) throw new Error(data?.error || 'sin respuesta');
      if (looksLikeFullEmail || aiProof.length > 240) {
        throw new Error('La IA devolvió un texto raro (no una frase corta). Probá de nuevo o redeployá ai-suggest.');
      }
      // limpiar comillas/punto final por las dudas
      aiProof = aiProof.replace(/^["'«»]+|["'«».]+$/g, '').trim();
      $('lm-draft').value = buildDraft(currentLead, aiProof);
      updateMailto();
      $('lm-status-note').textContent = '✨ Frase personalizada con IA — las CTAs y el brief se mantienen. Revisalo antes de enviar.';
    } catch (e) {
      $('lm-status-note').textContent = 'No se pudo generar con IA (¿deployaste la función ai-suggest?): ' + e.message;
    } finally {
      btn.disabled = false; btn.textContent = prev;
    }
  });

  $('lm-delete').addEventListener('click', async () => {
    if (!currentLead) return;
    if (!confirm('¿Borrar definitivamente el lead de "' + (currentLead.name || currentLead.email) + '"? Esta acción no se puede deshacer.')) return;
    const { error } = await supabase.from('leads').delete().eq('id', currentLead.id);
    if (error) { alert('No se pudo borrar: ' + error.message); return; }
    allLeads = allLeads.filter((l) => l.id !== currentLead.id);
