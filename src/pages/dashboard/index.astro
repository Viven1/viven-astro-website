  /* ---- significancia estadística: z-test de dos proporciones ----
     Φ(z) = CDF normal estándar vía la aproximación racional de Zelen & Severo
     (Abramowitz-Stegun 7.1.26). La confianza a dos colas = 1 - 2·(1-Φ(|z|)). */
  function abPhi(z){
    const t = 1 / (1 + 0.2316419 * Math.abs(z));
    const d = 0.3989422804014327 * Math.exp(-z * z / 2);
    let p = d * t * (0.319381530 + t * (-0.356563782 + t * (1.781477937 + t * (-1.821255978 + t * 1.330274429))));
    p = 1 - p;
    return z >= 0 ? p : 1 - p;
  }
  function abStats(ea, la, eb, lb){
    const ca = ea ? la / ea : 0, cb = eb ? lb / eb : 0;
    let z = 0, conf = 0;
    if (ea > 0 && eb > 0){
      const p = (la + lb) / (ea + eb);
      const se = Math.sqrt(p * (1 - p) * (1 / ea + 1 / eb));
      if (se > 0){ z = (cb - ca) / se; conf = 1 - 2 * (1 - abPhi(Math.abs(z))); }
    }
    conf = Math.max(0, Math.min(1, conf));
    return { ca, cb, z, conf };
  }
  // sesiones necesarias POR VARIANTE para detectar el uplift observado (o ~30% relativo por defecto)
  function abNeededPerVar(ca, cb){
    const base = ca > 0 ? ca : 0.02;
    let delta = Math.abs(cb - ca);
    if (delta < 1e-9) delta = base * 0.30;
    return Math.ceil(16 * base * (1 - base) / (delta * delta));
  }
  // texto corto del cambio para el lado A/B de la tarjeta
  function abVariantTxt(changes, side){
    if (!changes || !changes.length) return side === 'a' ? 'Página original' : 'Sin cambios';
    const c = changes[0];
    const raw = side === 'a' ? c.from : c.to;
    if (c.type === 'src' || c.type === 'attr'){ const f = String(raw || '').split('/').pop(); return (side === 'a' ? 'Imagen/media original' : 'Nuevo: ') + (side === 'b' ? (f || raw) : ''); }
    let s = String(raw || '').trim();
    if (changes.length > 1) s += ' (+' + (changes.length - 1) + ' cambio más)';
    return '"' + s.slice(0, 160) + (s.length > 160 ? '…' : '') + '"';
  }
