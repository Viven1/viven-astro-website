  /* ================= SERVICIOS: catálogo de precios editable =================
     Tabla services (SQL 0025). Si no existe o está vacía → RATECARD hardcodeado.
     El catálogo de las ofertas sale SIEMPRE de acá (CATALOG). */
  let servicesList = [], servicesBuilt = false, svFilter = 'active', svDragId = null;
  const CATALOG = () => {
    const act = (servicesList || []).filter((x) => x.active !== false);
    if (!act.length) return RATECARD;
    const m = {};
    PHASES.forEach((p) => { m[p] = []; });
    act.forEach((x) => {
      const ph = PHASES.includes(x.phase) ? x.phase : 'Production';
      m[ph].push({ name: x.name || '', unit: x.unit || 'Fix', price: Number(x.price) || 0, cost: Number(x.cost) || 0 });
    });
    Object.keys(m).forEach((k) => { if (!m[k].length) delete m[k]; });
    return m;
  };
