    $('lm-message').textContent = r.message || '(sin mensaje)';
    renderEnrichment(r);
    renderBriefBlock(r);
    $('lm-sender').value = sender;
    const draft = buildDraft(r);
    $('lm-draft').value = draft;
    updateMailto();
    $('lm-status-note').textContent = 'El borrador usa el idioma del lead (' + (r.lang || 'en').toUpperCase() + ') y se adapta a su mensaje.';
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    loadJourney(r);
    loadEmailLog(r);
  }

  /* ================= 📧 EMAILS: hilo unificado de todo lo que se le mandó al lead ================= */
  async function loadEmailLog(r){
    const box = $('lm-emails'), n = $('lm-emails-n'); if (!box) return;
    try {
      const { data, error } = await supabase.from('email_log').select('*').eq('lead_id', String(r.id)).order('created_at', { ascending: false }).limit(100);
      if (error) throw error;
      renderEmailThread(data || []);
      if (n) n.textContent = data && data.length ? '(' + data.length + ')' : '';
    } catch (e) {
      box.innerHTML = '<p class="muted-note">Corré el SQL 0044 para activar el hilo de emails.</p>';
      if (n) n.textContent = '';
    }
  }
  function renderEmailThread(rows){
    const box = $('lm-emails'); if (!box) return;
