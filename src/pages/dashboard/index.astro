          return '<button class="co-tr co-contact" data-id="' + esc(l.id) + '" type="button"><span class="co-td-name">' + esc(l.name || l.email) + (l.job_title ? '<span class="co-role">' + esc(l.job_title) + '</span>' : '') + '</span><span class="co-td-mail">' + esc(l.email) + '</span><span><span class="of-badge" style="color:' + (stg.color || 'var(--muted)') + ';border-color:' + (stg.color || 'var(--line-strong)') + '">' + esc(stg.label || l.status || '') + '</span></span></button>'; }).join('') + '</div>'
