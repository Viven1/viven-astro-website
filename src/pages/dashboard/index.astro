    { key: 'booking_confirmation', label: '📅 Booking — confirmación de call', wired: true, vars: ['first_name', 'when', 'duration'], defaults: {
      en: { subject: 'Your call with Viven is booked — {{when}}', body: 'Your {{duration}}-minute call is confirmed for {{when}} (Zurich time). The Google Calendar invite is on its way too.\n\nJoin with Google Meet using the link in the calendar invite.\n\nOne more thing: fill in the 2-min brief so we come prepared.' },
      de: { subject: 'Ihr Call mit Viven ist gebucht — {{when}}', body: 'Ihr {{duration}}-Minuten-Call ist bestätigt: {{when}} (Zürich). Die Google-Kalender-Einladung ist ebenfalls unterwegs.\n\nMit Google Meet beitreten über den Link in der Kalendereinladung.\n\nNoch etwas: Mit dem kurzen Projekt-Briefing (2 Min.) kommen wir bestens vorbereitet.' },
      es: { subject: 'Tu llamada con Viven está reservada — {{when}}', body: 'Tu llamada de {{duration}} minutos está confirmada: {{when}} (hora de Zúrich). La invitación de Google Calendar también va en camino.\n\nEntrar con Google Meet usando el link de la invitación del calendario.\n\nUna cosa más: completá el brief de 2 min para que lleguemos preparados.' },
    } },
    { key: 'review_request', label: '⭐ Pedido de reseña Google', wired: false, vars: ['first_name'], defaults: {
      en: { subject: 'How was working with Viven? 🌟', body: 'Hi {{first_name}},\n\nIt was a pleasure producing your video — we hope it\'s already working hard for you.\n\nIf you have 60 seconds, a short Google review would mean a lot to our small team (and helps other companies find us).\n\nThank you — and see you on the next project!\nSebastian & the Viven team' },
      de: { subject: 'Wie war die Zusammenarbeit mit Viven? 🌟', body: 'Guten Tag {{first_name}},\n\nEs war uns eine Freude, Ihr Video zu produzieren — wir hoffen, es arbeitet bereits fleissig für Sie.\n\nWenn Sie 60 Sekunden haben: Eine kurze Google-Bewertung würde unserem kleinen Team enorm helfen.\n\nHerzlichen Dank — bis zum nächsten Projekt!\nSebastian & das Viven-Team' },
      es: { subject: '¿Cómo fue trabajar con Viven? 🌟', body: 'Hola {{first_name}}:\n\nFue un placer producir tu video — esperamos que ya esté trabajando duro para vos.\n\nSi tenés 60 segundos, una reseña corta en Google ayuda muchísimo a nuestro equipo.\n\n¡Gracias — y hasta el próximo proyecto!\nSebastian y el equipo de Viven' },
    } },
  ];
  let tmplRows = {};       // 'key|lang' → fila de email_templates
  let tmplCurKey = null, tmplCurLang = 'en';
  async function tmplInit(){
    tmplRows = {};
    try {
      const { data, error } = await supabase.from('email_templates').select('*');
      if (error) throw error;
      (data || []).forEach((r) => { tmplRows[r.key + '|' + r.lang] = r; });
    } catch (e) { /* tabla pendiente (SQL 0062) — todo queda "original" */ }
    $('tmpl-list').innerHTML = TMPL_TOUCHPOINTS.map((t) => {
      const badges = ['en', 'de', 'es'].map((lg) => {
        const has = !!tmplRows[t.key + '|' + lg];
        return '<span class="pill" style="margin-right:6px;' + (has ? 'background:rgba(126,217,87,.18);color:#7ed957' : 'background:rgba(255,255,255,.06);color:var(--muted)') + '">' + lg.toUpperCase() + (has ? ' ✏️ editada' : ' · original') + '</span>';
      }).join('');
      return '<div class="of-card"><div class="of-card-open" data-tk="' + t.key + '">' +
        '<div class="of-card-main"><div class="of-card-title">' + esc(t.label) + '</div>' +
        '<div class="of-card-sub">' + badges + (t.wired ? '' : ' <span class="muted-note">— edición lista, envío server-side pendiente</span>') + '</div></div></div></div>';
    }).join('') || '<p class="muted-note">Sin touchpoints.</p>';
    $('tmpl-list').querySelectorAll('[data-tk]').forEach((c) => c.addEventListener('click', () => tmplOpen(c.dataset.tk)));
  }
  function tmplSwitchLang(lg){
    tmplCurLang = lg;
    $('tmpl-ed-langs').querySelectorAll('.tmpl-lang-btn').forEach((b) => b.classList.toggle('btn-primary', b.dataset.lg === lg));
    const row = tmplRows[tmplCurKey + '|' + lg];
    // sin fila guardada en email_templates → precargar el texto REAL que se manda hoy
    // (TMPL_TOUCHPOINTS[].defaults), no un campo en blanco — el badge "editada/original"
    // sigue reflejando solo si hay fila en la DB, no qué texto se ve acá.
    const t = TMPL_TOUCHPOINTS.find((x) => x.key === tmplCurKey);
    const def = (t && t.defaults && t.defaults[lg]) || { subject: '', body: '' };
    $('tmpl-ed-subject').value = row ? row.subject : def.subject;
    $('tmpl-ed-body').value = row ? row.body : def.body;
    $('tmpl-ed-restore').hidden = !row;
    $('tmpl-ed-preview').style.display = 'none';
  }
  function tmplOpen(key){
    tmplCurKey = key;
    const t = TMPL_TOUCHPOINTS.find((x) => x.key === key);
    $('tmpl-ed-title').textContent = t.label;
    $('tmpl-ed-vars').innerHTML = 'Variables disponibles: ' + t.vars.map((v) => '<code>{{' + v + '}}</code>').join(' · ') + ' — el resto del email (logo, botones, firma) es estructura fija.';
    $('tmpl-ed-langs').innerHTML = ['en', 'de', 'es'].map((lg) => '<button type="button" class="btn btn-ghost small tmpl-lang-btn" data-lg="' + lg + '">' + lg.toUpperCase() + '</button>').join('');
    $('tmpl-ed-langs').querySelectorAll('.tmpl-lang-btn').forEach((b) => b.addEventListener('click', () => tmplSwitchLang(b.dataset.lg)));
    $('tmpl-editor').hidden = false;
    tmplSwitchLang('en');
    $('tmpl-editor').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
  const TMPL_SAMPLE = { first_name: 'Alex', name: 'Alex Muster', company: 'Acme AG', range: "CHF 8'000 – 14'000", calc_range: "CHF 8'000 – 14'000", when: 'Montag, 14. Juli, 10:00', duration: '15' };
  $('tmpl-ed-preview-btn') && $('tmpl-ed-preview-btn').addEventListener('click', () => {
    const tok = (s) => String(s || '').replace(/\{\{(\w+)\}\}/g, (m, k) => (TMPL_SAMPLE[k] !== undefined ? TMPL_SAMPLE[k] : m));
    const subj = tok($('tmpl-ed-subject').value);
    const bodyHtml = tok($('tmpl-ed-body').value).trim().split(/\n{2,}/).map((p) => '<p style="margin:0 0 10px">' + esc(p).replace(/\n/g, '<br>') + '</p>').join('');
    $('tmpl-ed-preview').innerHTML = '<p class="muted-note">Asunto</p><p><b>' + esc(subj) + '</b></p><p class="muted-note" style="margin-top:10px">Cuerpo</p>' + (bodyHtml || '<p class="muted-note">(vacío)</p>');
    $('tmpl-ed-preview').style.display = 'block';
  });
  $('tmpl-ed-save') && $('tmpl-ed-save').addEventListener('click', async () => {
    const subject = $('tmpl-ed-subject').value.trim(), body = $('tmpl-ed-body').value.trim();
    if (!subject || !body){ toast('Completá asunto y cuerpo'); return; }
    const { error } = await supabase.from('email_templates').upsert({ key: tmplCurKey, lang: tmplCurLang, subject, body, updated_at: new Date().toISOString() });
    if (error){ toast('⚠️ ' + error.message + ' (¿corriste la SQL 0062?)'); return; }
    tmplRows[tmplCurKey + '|' + tmplCurLang] = { key: tmplCurKey, lang: tmplCurLang, subject, body };
    $('tmpl-ed-restore').hidden = false;
    toast('💾 Guardado'); tmplInit();
  });
  $('tmpl-ed-restore') && $('tmpl-ed-restore').addEventListener('click', async () => {
    if (!confirm('¿Restaurar el original? Se borra tu edición para ' + tmplCurLang.toUpperCase() + '.')) return;
    await supabase.from('email_templates').delete().eq('key', tmplCurKey).eq('lang', tmplCurLang);
    delete tmplRows[tmplCurKey + '|' + tmplCurLang];
    toast('↺ Restaurado'); tmplSwitchLang(tmplCurLang); tmplInit();
  });
  $('tmpl-ed-close') && $('tmpl-ed-close').addEventListener('click', () => { $('tmpl-editor').hidden = true; });

  /* =========================================================================
     👤 MI PERFIL (SQL 0064 team_profiles) — Task C. Foto + firma del usuario
     LOGUEADO (meEmail) — no un admin de todo el team. Foto vía Supabase
     Storage bucket "team-avatars" (crear a mano una vez, ver migración 0064).
     ========================================================================= */
  let profileAvatarPendingUrl = null;
  function profileRenderAvatar(url, name){
    const el = $('profile-avatar-preview'); if (!el) return;
    if (url) { el.style.background = 'transparent'; el.innerHTML = '<img src="' + esc(url) + '" style="width:100%;height:100%;object-fit:cover" />'; }
    else { const nm = name || meEmail || '?'; el.style.background = avColorG(nm); el.innerHTML = esc((nm[0] || '?').toUpperCase()); }
  }
  function profileRenderSignPreview(){
    $('profile-sign-preview').textContent = $('profile-signature').value.trim() || '(sin firma configurada — el compositor sigue usando el nombre elegido con el toggle Sofia/Sebastian)';
  }
  function profileInit(){
    $('profile-who').textContent = meEmail ? 'Editando el perfil de: ' + meEmail : '⚠️ No se detectó tu email de sesión — entrá de nuevo si esto persiste.';
    const p = profileFor(meEmail) || {};
    $('profile-name').value = p.name || '';
    $('profile-role').value = p.role || '';
    $('profile-phone').value = p.phone || '';
    $('profile-signature').value = p.signature_text || '';
    profileAvatarPendingUrl = p.avatar_url || null;
    profileRenderAvatar(p.avatar_url, p.name);
    profileRenderSignPreview();
  }
  $('profile-signature') && $('profile-signature').addEventListener('input', profileRenderSignPreview);
  $('profile-avatar-btn') && $('profile-avatar-btn').addEventListener('click', () => $('profile-avatar-file').click());
  $('profile-avatar-file') && $('profile-avatar-file').addEventListener('change', async (e) => {
    const file = e.target.files[0]; if (!file) return;
    if (!meEmail){ toast('Sin sesión detectada'); return; }
    try {
      const safeName = file.name.replace(/[^a-z0-9.\-_]/gi, '_');
      const path = meEmail.toLowerCase().replace(/[^a-z0-9@._-]/gi, '_') + '/' + Date.now() + '-' + safeName;
      const { error } = await supabase.storage.from('team-avatars').upload(path, file, { upsert: true });
      if (error) throw error;
      const { data: pub } = supabase.storage.from('team-avatars').getPublicUrl(path);
      profileAvatarPendingUrl = pub && pub.publicUrl;
      profileRenderAvatar(profileAvatarPendingUrl, $('profile-name').value);
      toast('📷 Foto subida — tocá 💾 Guardar para confirmar');
    } catch (err) { toast('⚠️ ' + (err && err.message || err) + ' (¿existe el bucket público "team-avatars" en Supabase Storage?)'); }
  });
  $('profile-save') && $('profile-save').addEventListener('click', async () => {
    if (!meEmail){ toast('Sin sesión detectada'); return; }
    const patch = {
      email: meEmail, name: $('profile-name').value.trim() || null, role: $('profile-role').value.trim() || null,
      phone: $('profile-phone').value.trim() || null, signature_text: $('profile-signature').value.trim() || null,
      avatar_url: profileAvatarPendingUrl || null, updated_at: new Date().toISOString(),
    };
    const { error } = await supabase.from('team_profiles').upsert(patch);
    if (error){ toast('⚠️ ' + error.message + ' (¿corriste la SQL 0064?)'); return; }
    teamProfiles[meEmail.toLowerCase()] = patch;
    toast('💾 Perfil guardado');
  });

  /* ---------- Roles (SQL 0077) — gate de superadmin para el tab Cash Flow ----------
     La seguridad REAL la da RLS (public.is_superadmin()); esto es solo UX: si no
     sos superadmin, el nav item y el contenido del tab se sacan del DOM del todo
     (no solo hidden) apenas se resuelve el rol. */
  let isSuperadmin = false;
  async function checkRole(){
    isSuperadmin = false;
    if (meEmail){
      try {
        const { data } = await supabase.from('user_roles').select('role').eq('email', meEmail).maybeSingle();
        isSuperadmin = !!(data && data.role === 'superadmin');
      } catch (e) { isSuperadmin = false; }
    }
    // fix (2026-07-14, shell): Cash Flow ahora vive como sub-tab de "Sistema" en vez de
    // side-group propio — se oculta/saca el botón del segmentado + su contenido, no un
    // group entero. Ver sistemaSetSub() más arriba (defensivo: nunca aterriza ahí sin ser superadmin).
    const btn = $('sistema-seg-cashflow-btn'), tabEl = $('sistema-sub-cashflow');
    if (isSuperadmin){
      if (btn) btn.hidden = false;
    } else {
      if (btn) btn.remove();
      if (tabEl) tabEl.remove();
    }
  }

  /* ---------- Cash Flow (SQL 0077/0078/0079) ----------
     Proyección de liquidez de Viven AG, SOLO CHF, SOLO superadmin. Motor
     client-side: saldo actual (cashflow_bank_balance) + partidas manuales/Bexio
     (cashflow_entries) + recurrentes activos expandidos (cashflow_recurring_templates)
     + préstamos/leasing expandidos como cuota mensual (cashflow_loans), 12 meses
     hacia adelante. La MISMA lógica está portada a TS en la edge function
     cashflow-alert (cron diario, SQL 0079) para el aviso por email. */
  let cfBuilt = false, cfPeriod = 'monthly';
  let cfBalance = null, cfSettings = { min_balance_threshold_chf: 15000, alert_email: 'sebastian@viven.ch', enabled: true };
  let cfEntries = [], cfTemplates = [], cfLoans = [], cfEvents = [], cfMonths = [], cfWeeks = [];
  let cfRecEditing = null, cfLoanEditing = null;
  const cfCHF = (n) => 'CHF ' + Math.round(Number(n) || 0).toLocaleString('de-CH');

  function cfInit(){
    if (!isSuperadmin) return;   // no debería ser alcanzable sin esto (el nav item no existe), pero por las dudas
    if (!cfBuilt){
      cfBuilt = true;
      $('cf-entry-add').addEventListener('click', () => {
        const f = $('cf-entry-form'); f.hidden = !f.hidden;
        if (!f.hidden){ $('cf-entry-date').value = new Date().toISOString().slice(0, 10); f.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
      });
      $('cf-entry-cancel').addEventListener('click', () => { $('cf-entry-form').hidden = true; });
      $('cf-entry-save').addEventListener('click', cfSaveEntry);
      $('cf-rec-add').addEventListener('click', () => { cfRecEditing = null; cfOpenRecForm(); });
      $('cf-rec-cancel').addEventListener('click', () => { $('cf-rec-form').hidden = true; });
      $('cf-rec-save').addEventListener('click', cfSaveRec);
      $('cf-loan-add').addEventListener('click', () => { cfLoanEditing = null; cfOpenLoanForm(); });
      $('cf-loan-cancel').addEventListener('click', () => { $('cf-loan-form').hidden = true; $('cf-loan-actions').hidden = true; });
      $('cf-loan-save').addEventListener('click', cfSaveLoan);
      $('cf-cfg-balance-save').addEventListener('click', cfSaveBalance);
      $('cf-cfg-threshold-save').addEventListener('click', cfSaveThreshold);
    }
    cfLoad();
  }

  async function cfLoad(){
    const [balQ, setQ, entQ, tplQ, loanQ] = await Promise.all([
      supabase.from('cashflow_bank_balance').select('*').order('as_of_date', { ascending: false }).limit(1).maybeSingle(),
      supabase.from('cashflow_alert_settings').select('*').eq('id', 1).maybeSingle(),
      supabase.from('cashflow_entries').select('*').order('due_date', { ascending: true }),
      supabase.from('cashflow_recurring_templates').select('*').order('created_at', { ascending: false }),
      supabase.from('cashflow_loans').select('*').order('end_date', { ascending: true }),
    ]);
    const firstError = balQ.error || setQ.error || entQ.error || tplQ.error || loanQ.error;
    if (firstError){
      $('cf-table').innerHTML = '<p class="muted-note">⚠️ ' + esc(firstError.message) + ' (¿corriste las SQL 0077/0078?)</p>';
      return;
    }
    cfBalance = balQ.data || null;
    cfSettings = setQ.data || cfSettings;
    cfEntries = entQ.data || [];
    cfTemplates = tplQ.data || [];
    cfLoans = loanQ.data || [];
    $('cf-cfg-balance-cap').textContent = cfBalance ? ('Último registrado: ' + cfCHF(cfBalance.balance_chf) + ' (al ' + cfBalance.as_of_date + ')') : 'Todavía no cargaste un saldo — cargalo abajo en Configuración.';
    $('cf-cfg-threshold').value = cfSettings.min_balance_threshold_chf ?? 15000;
    cfProject();
    cfRenderKpis();
    cfRenderSeg();
    cfRenderChart();
    cfRenderTable();
    cfRenderRec();
    cfRenderLoans();
  }

  // expande entries + recurrentes + préstamos a una lista plana de eventos (fecha + delta),
  // horizonte de 12 meses desde hoy — es la base tanto de la tabla de detalle como de las
  // series semanal/mensual del gráfico y de los KPIs (runway / próximo mes en rojo)
  function cfExpandEvents(){
    const events = [];
    const today = new Date(); today.setHours(0, 0, 0, 0);
    const horizon = new Date(today); horizon.setMonth(horizon.getMonth() + 12);

    (cfEntries || []).forEach((e) => {
      const d = new Date(e.due_date + 'T00:00:00');
      if (d < today || d > horizon) return;
      events.push({ date: d, delta: e.kind === 'income' ? Number(e.amount_chf) : -Number(e.amount_chf), label: e.description, tag: e.source === 'bexio' ? 'bexio' : 'manual' });
    });

    (cfTemplates || []).filter((t) => t.active).forEach((t) => {
      const s = new Date(t.start_date + 'T00:00:00');
      const endT = t.end_date ? new Date(t.end_date + 'T00:00:00') : null;
      for (let m = 0; m < 13; m++){
        const monthCursor = new Date(today.getFullYear(), today.getMonth() + m, 1);
        if (monthCursor > horizon) break;
        if (monthCursor.getFullYear() < s.getFullYear() || (monthCursor.getFullYear() === s.getFullYear() && monthCursor.getMonth() < s.getMonth())) continue;
        const occurs = t.frequency === 'monthly'
          || (t.frequency === 'quarterly' && ((monthCursor.getFullYear() * 12 + monthCursor.getMonth()) - (s.getFullYear() * 12 + s.getMonth())) % 3 === 0)
          || (t.frequency === 'yearly' && monthCursor.getMonth() === s.getMonth());
        if (!occurs) continue;
        const occDate = new Date(monthCursor.getFullYear(), monthCursor.getMonth(), t.day_of_month);
        if (occDate < today || occDate < s || occDate > horizon) continue;
        if (endT && occDate > endT) continue;
        events.push({ date: occDate, delta: t.kind === 'income' ? Number(t.amount_chf) : -Number(t.amount_chf), label: t.description, tag: 'rec' });
      }
    });

    (cfLoans || []).forEach((l) => {
      const s = new Date(l.start_date + 'T00:00:00');
      const e = new Date(l.end_date + 'T00:00:00');
      const day = Math.min(s.getDate(), 28);
      for (let m = 0; m < 13; m++){
        const monthCursor = new Date(today.getFullYear(), today.getMonth() + m, 1);
        if (monthCursor > horizon) break;
        const occDate = new Date(monthCursor.getFullYear(), monthCursor.getMonth(), day);
        if (occDate < today || occDate < s || occDate > e || occDate > horizon) continue;
        events.push({ date: occDate, delta: -Number(l.monthly_payment_chf), label: l.name, tag: 'loan' });
      }
    });

    events.sort((a, b) => a.date - b.date);
    return events;
  }

  function cfMonthlySeries(events){
    const today = new Date(); today.setHours(0, 0, 0, 0);
    let running = cfBalance ? Number(cfBalance.balance_chf) : 0;
    const months = [];
    for (let m = 0; m < 12; m++){
      const mStart = new Date(today.getFullYear(), today.getMonth() + m, 1);
      const mEnd = new Date(today.getFullYear(), today.getMonth() + m + 1, 1);
      const delta = events.filter((ev) => ev.date >= mStart && ev.date < mEnd).reduce((a, ev) => a + ev.delta, 0);
      running += delta;
      months.push({ label: mStart.toLocaleDateString('es-CH', { month: 'short', year: '2-digit' }), delta, balance: running });
    }
    return months;
  }
  function cfWeeklySeries(events){
    const today = new Date(); today.setHours(0, 0, 0, 0);
    let running = cfBalance ? Number(cfBalance.balance_chf) : 0;
    const dow = (today.getDay() + 6) % 7;   // 0 = lunes
    const weekStart0 = new Date(today); weekStart0.setDate(today.getDate() - dow);
    const horizon = new Date(today); horizon.setMonth(horizon.getMonth() + 12);
    const weeks = [];
    for (let w = 0; w < 53; w++){
      const wStart = new Date(weekStart0); wStart.setDate(weekStart0.getDate() + w * 7);
      if (wStart > horizon) break;
      const wEnd = new Date(wStart); wEnd.setDate(wStart.getDate() + 7);
      const delta = events.filter((ev) => ev.date >= wStart && ev.date < wEnd).reduce((a, ev) => a + ev.delta, 0);
      running += delta;
      weeks.push({ label: wStart.toLocaleDateString('es-CH', { day: '2-digit', month: 'short' }), delta, balance: running });
    }
    return weeks;
  }
  function cfProject(){
    cfEvents = cfExpandEvents();
    cfMonths = cfMonthlySeries(cfEvents);
    cfWeeks = cfWeeklySeries(cfEvents);
  }

  function cfRenderKpis(){
    const bal = cfBalance ? Number(cfBalance.balance_chf) : null;
    $('cf-k-balance').textContent = bal != null ? cfCHF(bal) : '—';
    const zeroIdx = cfMonths.findIndex((m) => m.balance < 0);
    const rw = $('cf-k-runway');
    if (zeroIdx === -1){ rw.textContent = '12+ meses'; rw.style.color = '#7ed957'; }
    else { rw.textContent = (zeroIdx + 1) + (zeroIdx === 0 ? ' mes' : ' meses'); rw.style.color = '#ff8b8b'; }
    const threshold = Number((cfSettings && cfSettings.min_balance_threshold_chf) || 0);
    const redIdx = cfMonths.findIndex((m) => m.balance < threshold);
    const rm = $('cf-k-redmonth');
    if (redIdx === -1){ rm.textContent = 'Ninguno ✅'; rm.style.color = '#7ed957'; }
    else { rm.textContent = cfMonths[redIdx].label; rm.style.color = '#ff8b8b'; }
    const today = new Date(), in30 = new Date(today.getTime() + 30 * 864e5);
    const todayS = today.toISOString().slice(0, 10), in30S = in30.toISOString().slice(0, 10);
    const out30 = (cfEntries || []).filter((e) => e.kind === 'expense' && e.due_date >= todayS && e.due_date <= in30S).reduce((a, e) => a + Number(e.amount_chf), 0);
    $('cf-k-out30').textContent = cfCHF(out30);
  }

