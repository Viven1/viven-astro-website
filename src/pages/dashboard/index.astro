      '</tr></thead><tbody>' +
      hist.map((g) => {
        const v = idx ? bl2GroupViews(g, idx) : null;
        let l7 = 0, p7 = 0;
        if (idx) g.rows.forEach((r) => { const s = idx.bySlug.get(r.slug); if (s) { l7 += s.last7; p7 += s.prev7; } });
        const trend = !idx ? '<span class="mut">…</span>'
          : l7 > p7 ? '<span class="bl2-trend up">▲ ' + bl2Fmt(l7) + ' esta semana</span>'
          : l7 < p7 ? '<span class="bl2-trend dn">▼ ' + bl2Fmt(l7) + ' esta semana</span>'
          : '<span class="bl2-trend dn">· ' + bl2Fmt(l7) + '</span>';
        const openId = (g.rows.find((r) => r.lang === 'en' && r.status === 'published') || g.pub[0] || g.main).id;
