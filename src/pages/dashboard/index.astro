  const CO_FIELDS = [['name', 'Nombre'], ['industry', 'Industria'], ['city', 'Ciudad'], ['employees', 'Empleados'], ['phone', 'Teléfono'], ['website', 'Web'], ['linkedin', 'LinkedIn'], ['notes', 'Notas']];
