        '<div class="bar"><i style="width:' + Math.min(100, confPct) + '%;background:#7ed957"></i></div></div>';
    } else {
      const needPer = abNeededPerVar(r.ca, r.cb), needTot = needPer * 2, total = r.ea + r.eb;
      let rate = 0;
      if (t.start_at){ const days = Math.max(0.5, (Date.now() - new Date(t.start_at)) / 864e5); rate = total / days; }
      const remaining = Math.max(0, needTot - total);
      const weeks = rate > 0 ? Math.ceil(remaining / (rate * 7)) : null;
      const eta = remaining <= 0 ? 'ya hay muestra suficiente — juntando la señal' : (weeks != null ? '~' + weeks + (weeks === 1 ? ' semana' : ' semanas') + ' al ritmo actual' : 'sin ritmo de tráfico todavía');
      verdict = '<div class="verdictbar wait"><span class="conf" style="color:#f0c060">' + (confPct > 0 ? confPct + '%' : '—') + '</span>' +
        '<div class="vtxt"><b>Todavía no hay nada que decidir.</b> ' + total + ' de ~' + needTot + ' sesiones necesarias para detectar una diferencia real. ' + eta + '.</div>' +
        '<div class="bar"><i style="width:' + Math.max(3, Math.min(100, confPct)) + '%;background:#f0c060"></i></div></div>';
    }
    const cell = (side, txt, e2, l2, conv) =>
      '<div class="ab-var' + (side === 'a' ? (aWins && r.eb ? ' win' : '') : (bWins ? ' win' : '')) + '">' +
