  }
  /* PROPUESTAS ACEPTADAS = plata ganada aunque no haya oferta ligada.
     Dedupe: si el deal/persona ya tiene una oferta GANADA, la propuesta no vuelve a sumar
     (accept-proposal marca won las ofertas del deal — sumar ambas sería contar doble). */
  let propsAll = [];
  const acceptedProps = () => (propsAll || []).filter((p) => p.status === 'accepted' && !p.archived && !p.is_template);
  const propNet = (p) => {
    if (Number(p.accepted_total)) return Number(p.accepted_total);
    const ts = (p.content && p.content.tiers) || [];
    const rec = ts.find((t) => t.recommended) || ts[0];
    return Number(rec && rec.price) || 0;
  };
  const propCovered = (p) => (offersList || []).some((o) => o.status === 'won' && !o.archived && !o.is_template && (
    (p.deal_id && String(o.deal_id || '') === String(p.deal_id)) ||
    (!p.deal_id && p.lead_id && String(o.lead_id || '') === String(p.lead_id))));
  const propsWonForLead = (lid) => acceptedProps().filter((p) => String(p.lead_id || '') === String(lid) && !propCovered(p)).reduce((a, p) => a + propNet(p), 0);
  const propsWonForDeal = (d) => acceptedProps().filter((p) => {
    if (propCovered(p)) return false;
    if (p.deal_id) return String(p.deal_id) === String(d.id);
    if (String(p.lead_id || '') !== String(d.lead_id)) return false;
    if (d.synthetic) return true;
    const first = firstDealOf(d.lead_id);
    return !!(first && String(first.id) === String(d.id));
  }).reduce((a, p) => a + propNet(p), 0);

  // REGLA DE VALOR ÚNICA (misma en board, Personas, Home y forecast):
  // ganadas si existen; si no, abiertas (borrador+enviada); las PERDIDAS nunca suman; fallback: valor estimado.
  const leadValue = (l) => {
    const ofs = offersForLead(l.id);
    const won = ofs.filter((o) => o.status === 'won').reduce((b, o) => b + offerNet(o), 0) + propsWonForLead(l.id);
    if (won) return won;
    const open = ofs.filter((o) => o.status === 'draft' || o.status === 'sent').reduce((b, o) => b + offerNet(o), 0);
    return open || Number(l.deal_value) || 0;
  };
  const leadsValue = (leads) => leads.reduce((a, l) => a + leadValue(l), 0);
  // valor PERDIDO: lo que estaba sobre la mesa cuando se perdió (ofertas incl. perdidas, o estimado)
  const leadLostValue = (l) => offersForLead(l.id).filter((o) => o.status !== 'tier').reduce((b, o) => b + offerNet(o), 0) || Number(l.deal_value) || 0;
  const leadsLostValue = (leads) => leads.reduce((a, l) => a + leadLostValue(l), 0);
  const fmtChf = (n) => n ? 'CHF ' + Math.round(n).toLocaleString('de-CH') : '—';

  /* ---------- DEALS (modelo HubSpot): la persona NO es el deal ----------
     Un contacto puede tener varios proyectos; cada deal vive en el board con su
     etapa. leads.status queda como ESPEJO del deal más reciente (compat con
     follow-ups, Personas y KPIs). Sin SQL 0022 → deals sintéticos (legado). */
  let dealsList = [], dealsReal = false, upBookings = [], bookingsHist = [];
  const synthDeal = (l) => ({ id: 'L' + l.id, synthetic: true, lead_id: l.id, title: null, stage: stageOf(l.status), deal_value: l.deal_value, lost_reason: l.lost_reason, archived: false, created_at: l.created_at, last_stage_at: l.last_stage_at, contacted_at: l.contacted_at, videocall_at: l.videocall_at, proposal_at: l.proposal_at, won_at: l.won_at, lost_at: l.lost_at });
  const leadById = (id) => (allLeads || []).find((l) => String(l.id) === String(id));
  const dealsForLead = (lid) => (dealsList || []).filter((d) => String(d.lead_id) === String(lid) && !d.archived);
  const latestDealOf = (lid) => dealsForLead(lid).slice().sort((a, b) => new Date(b.created_at) - new Date(a.created_at))[0] || null;
  const openDealOf = (lid) => dealsForLead(lid).filter((d) => !['ganado', 'perdido'].includes(stageOf(d.stage))).sort((a, b) => new Date(b.created_at) - new Date(a.created_at))[0] || null;
  const firstDealOf = (lid) => dealsForLead(lid).slice().sort((a, b) => new Date(a.created_at) - new Date(b.created_at))[0] || null;
  // ofertas de UN deal: por deal_id; las viejas sin deal_id caen en el PRIMER deal de la persona
  const offersForDeal = (d) => {
    if (d.synthetic) return offersForLead(d.lead_id);
    const first = firstDealOf(d.lead_id);
    return (offersList || []).filter((o) => !o.archived && !o.is_template && (
      o.deal_id ? String(o.deal_id) === String(d.id)
                : (o.lead_id && String(o.lead_id) === String(d.lead_id) && first && String(first.id) === String(d.id))));
  };
  // misma REGLA DE VALOR ÚNICA, por deal
  const dealValue = (d) => {
    const ofs = offersForDeal(d);
    const won = ofs.filter((o) => o.status === 'won').reduce((b, o) => b + offerNet(o), 0) + propsWonForDeal(d);
    if (won) return won;
    const open = ofs.filter((o) => o.status === 'draft' || o.status === 'sent').reduce((b, o) => b + offerNet(o), 0);
    return open || Number(d.deal_value) || 0;
  };
  const dealsValue = (ds) => ds.reduce((a, d) => a + dealValue(d), 0);
  const dealLostValue = (d) => offersForDeal(d).filter((o) => o.status !== 'tier').reduce((b, o) => b + offerNet(o), 0) || Number(d.deal_value) || 0;
  const dealsLostValue = (ds) => ds.reduce((a, d) => a + dealLostValue(d), 0);
  async function mirrorLeadStatus(lid){
    const lead = leadById(lid); const top = latestDealOf(lid);
    if (!lead || !top) return;
    const stage = stageOf(top.stage);
    if (stageOf(lead.status) === stage) return;
    lead.status = stage; lead.last_stage_at = new Date().toISOString();
    let { error } = await supabase.from('leads').update({ status: stage, last_stage_at: lead.last_stage_at }).eq('id', lid);
    if (error && /last_stage_at/.test(error.message || '')) await supabase.from('leads').update({ status: stage }).eq('id', lid);
  }
  // deal sintético tocado → materializarlo en la tabla (si el SQL 0022 ya corrió)
  async function ensureRealDeal(d){
    if (!d || !d.synthetic) return d || null;
    if (!dealsReal) return null;
    const row = { lead_id: d.lead_id, title: d.title, stage: stageOf(d.stage), deal_value: d.deal_value ?? null, lost_reason: d.lost_reason ?? null, created_at: d.created_at, last_stage_at: d.last_stage_at, contacted_at: d.contacted_at, videocall_at: d.videocall_at, proposal_at: d.proposal_at, won_at: d.won_at, lost_at: d.lost_at };
    const { data, error } = await supabase.from('deals').insert(row).select().single();
    if (error || !data) return null;
    const i = dealsList.findIndex((x) => x.id === d.id);
    if (i > -1) dealsList[i] = data; else dealsList.push(data);
    return data;
  }
  async function newDealForLead(lid, title, stage){
    if (!dealsReal) { toast('Corré el SQL 0022 (deals) para tener varios proyectos por persona'); return null; }
    const nowIso = new Date().toISOString();
    const row = { lead_id: lid, title: title || 'Nuevo proyecto', stage: stage || 'nuevo', last_stage_at: nowIso };
    const ts = STAGE_TS[stage]; if (ts) row[ts] = nowIso;
    const { data, error } = await supabase.from('deals').insert(row).select().single();
    if (error) { toast('No se pudo crear el deal: ' + error.message); return null; }
    dealsList.unshift(data);
    await mirrorLeadStatus(lid);
    renderLeads();
    return data;
  }
  // mueve UN deal de etapa (drag del board o select del contacto) + cascadas + espejo
  async function setDealStage(id, stage){
    let d = (dealsList || []).find((x) => String(x.id) === String(id));
    if (!d || stageOf(d.stage) === stage) return false;
    if (d.synthetic && !dealsReal) return setLeadStage(d.lead_id, stage);   // modo legado total
    let lostReason;
    if (stage === 'perdido') {
      lostReason = prompt('¿Por qué se perdió este deal? (opcional)', d.lost_reason || '');
      if (lostReason === null) return false;
    }
    if (d.synthetic) { const real = await ensureRealDeal(d); if (!real) return setLeadStage(d.lead_id, stage); d = real; }
    const prev = d.stage;
    const nowIso = new Date().toISOString();
    d.stage = stage; d.last_stage_at = nowIso;
    const patch = { stage, last_stage_at: nowIso };
    const tsCol = STAGE_TS[stage];
    if (tsCol && !d[tsCol]) { patch[tsCol] = nowIso; d[tsCol] = nowIso; }
    if (stage === 'perdido') { patch.lost_reason = lostReason || null; d.lost_reason = lostReason || null; }
    renderLeads();
    const { error } = await supabase.from('deals').update(patch).eq('id', d.id);
    if (error) { d.stage = prev; renderLeads(); toast('No se pudo mover: ' + error.message); return false; }
    const lead = leadById(d.lead_id);
    if (stage === 'perdido') {
      // solo las ofertas de ESTE deal (los otros proyectos de la persona no se tocan)
      for (const o of offersForDeal(d).filter((x) => x.status !== 'won' && x.status !== 'lost')) {
        const r2 = await supabase.from('offers').update({ status: 'lost', lost_reason: lostReason || null }).eq('id', o.id);
        if (r2.error && /lost_reason/.test(r2.error.message || '')) await supabase.from('offers').update({ status: 'lost' }).eq('id', o.id);
        o.status = 'lost'; o.lost_reason = lostReason || null;
      }
      if (lead) supabase.from('lead_notes').insert({ lead_id: String(lead.id), author: 'Pipeline', body: '❌ Deal perdido' + (d.title ? ' «' + d.title + '»' : '') + (lostReason ? ' — motivo: ' + lostReason : '') }).then(() => {}, () => {});
    }
    if (stage === 'ganado') {
      // QUIRÚRGICO por número de oferta: gana UNA, las demás se archivan (nada de
      // promover todos los borradores — para eso existen los A26xxxx)
      const open = offersForDeal(d).filter((x) => ['draft', 'sent', 'tier'].includes(x.status));
      if (open.length === 1) {
        await supabase.from('offers').update({ status: 'won' }).eq('id', open[0].id); open[0].status = 'won';
        toast('🏆 ' + (open[0].number || 'Oferta') + ' marcada como Ganada');
      } else if (open.length > 1) {
        const lista = open.map((o) => '  ' + (o.number || '#' + o.id) + ' — ' + (o.title || '(sin título)') + ' — ' + fmtM(offerNet(o))).join('\n');
        const ans = prompt('🏆 ¿QUÉ oferta ganó? Escribí su número — esa pasa a Ganada y las otras ' + (open.length - 1) + ' se ARCHIVAN:\n\n' + lista, open[0].number || '');
        if (ans && ans.trim()) {
          const q = ans.trim().toLowerCase();
          const win = open.find((o) => String(o.number || '').toLowerCase() === q || String(o.id) === q);
          if (win) {
            await supabase.from('offers').update({ status: 'won', archived: false }).eq('id', win.id); win.status = 'won'; win.archived = false;
            for (const o of open) {
              if (o.id === win.id) continue;
              await supabase.from('offers').update({ archived: true }).eq('id', o.id); o.archived = true;
            }
            toast('🏆 ' + (win.number || 'Oferta') + ' ganada · ' + (open.length - 1) + ' archivada(s)');
          } else {
            toast('No encontré «' + ans.trim() + '» — el deal quedó ganado pero no toqué ninguna oferta');
          }
        } else {
          toast('Deal ganado — elegí después la oferta ganadora abriéndola y poniéndola en Ganada');
        }
      }
    }
    // al avanzar/cerrar se cancela la secuencia vieja (la nueva se genera para la etapa nueva)
    if (['videocall', 'propuesta', 'ganado', 'perdido'].includes(stage)) {
      supabase.from('lead_followups').update({ status: 'canceled' }).eq('lead_id', String(d.lead_id)).in('status', ['draft', 'approved']);
    }
    await mirrorLeadStatus(d.lead_id);
    renderLeads();
    return true;
  }

  /* ---- Deals V2: estado propio del tab (búsqueda, filtro de estancados, vista board/lista) ---- */
  let dlSearch = '', dlStuck = false, dlSort = 'value', dlListStage = 'open';
  let dlView = localStorage.getItem('vv_deals_view') === 'lista' ? 'lista' : 'board';
  const DL_OPEN = ['nuevo', 'contactado', 'videocall', 'propuesta'];
  // próximo paso: cache de la task abierta más cercana por lead. UNA sola query .in() por ciclo de
  // loadAll: TTL de 60s (loadAll corre cada 120s y llama renderPipeline hasta 2 veces — la segunda
  // pasada y los re-renders por drag/filtros usan el cache; el flag busy evita fetches en paralelo).
  let dlTasksMap = {}, dlTasksAt = 0, dlTasksBusy = false;
  async function dlFetchNextTasks(ids){
    if (dlTasksBusy || !ids.length || Date.now() - dlTasksAt < 60000) return;
    dlTasksBusy = true;
    try {
      // due_time/assignee: los usa el Home ("Para hoy": tasks vencidas/de hoy mías) — el board solo lee title/due_date
      let { data, error } = await supabase.from('lead_tasks').select('lead_id,title,due_date,due_time,assignee')
        .eq('done', false).in('lead_id', ids).order('due_date', { ascending: true, nullsFirst: false }).limit(500);
      // resiliente: sin la migración de due_time (SQL 0012) cae al select viejo
      if (error && /due_time|assignee/.test(error.message || '')) ({ data, error } = await supabase.from('lead_tasks').select('lead_id,title,due_date')
        .eq('done', false).in('lead_id', ids).order('due_date', { ascending: true, nullsFirst: false }).limit(500));
      dlTasksAt = Date.now();
      if (!error){
        const m = {};
        (data || []).forEach((t) => { const k = String(t.lead_id); if (!m[k]) m[k] = t; });   // ya viene ordenado: la primera es la más cercana
        dlTasksMap = m;
        renderPipeline();   // re-pinta con los próximos pasos ya cargados (el TTL corta el loop)
        if (!$('tab-hoy').hidden) renderHome();   // Hoy también usa este cache (el TTL corta la recursión)
      }
    } catch (e) { /* best-effort: sin tabla de tasks el card cae al follow-up automático */ }
    finally { dlTasksBusy = false; }
  }
  // deals visibles del tab: TODOS los no archivados (ya no depende de los filtros de Personas) + su búsqueda propia
  function dlDeals(){
    return (dealsList || []).filter((d) => {
      if (d.archived) return false;
      if (dlSearch){
        const r = leadById(d.lead_id) || {};
        const hay = ((d.title || '') + ' ' + (r.name || '') + ' ' + (r.first_name || '') + ' ' + (r.email || '') + ' ' + (r.company || '') + ' ' + (companyName(leadDomain(r)) || '')).toLowerCase();
        if (hay.indexOf(dlSearch) === -1) return false;
      }
      return true;
    });
  }
  function renderPipeline(){
    // el refresh automático re-dibuja todo: cerrar el ⋯ para que no quede flotando sobre cards viejas
    const menu = $('dl-menu'); if (menu) menu.hidden = true;
    const rows = dlDeals();
    const now = Date.now();
    const isOpen = (d) => DL_OPEN.includes(stageOf(d.stage));
    // fix (2026-07-14, shell): los KPIs (Pipeline abierto/Ponderado/Ganado 30d/Win rate)
    // se fusionaron con los de Home — ahora viven en #hm-* y los pobla hmDealKpis()/
    // renderHome(), que corre siempre que se entra a Pipeline (ver gotoTab). Acá solo
    // queda in30, que sigue haciendo falta más abajo.
    const in30 = (iso) => iso && (now - Date.parse(iso)) <= 30 * 864e5;
    // contador del chip de estancados (sobre los abiertos que matchean la búsqueda, sin el propio filtro)
    const stuckN = rows.filter((d) => isOpen(d) && dealStageDays(d) > 14).length;
    const nEl = $('dl-stuck-n'); if (nEl) nEl.textContent = stuckN;
    const stuckBtn = $('dl-stuck'); if (stuckBtn) stuckBtn.classList.toggle('active', dlStuck);
    /* ---- toggle de vista ---- */
    const board = dlView !== 'lista';
    const bBtn = $('dl-view-board'), lBtn = $('dl-view-list');
    if (bBtn) bBtn.classList.toggle('on', board);
    if (lBtn) lBtn.classList.toggle('on', !board);
    const pipe = $('pipeline'), drops = $('pipe-drops'), list = $('deals-list');
    if (!board){
      if (pipe) { pipe.hidden = true; pipe.innerHTML = ''; }
      if (drops) { drops.hidden = true; drops.innerHTML = ''; }
      const pager = $('pipe-pager'); if (pager) pager.hidden = true;
      if (list) { list.hidden = false; renderDealsList(rows); }
      return;
    }
    if (list) { list.hidden = true; list.innerHTML = ''; }
    if (pipe) pipe.hidden = false;
    if (drops) drops.hidden = false;
    /* ---- board: solo las 4 columnas de trabajo; ganado/perdido son drop-zones abajo ---- */
    let open = rows.filter(isOpen);
    if (dlStuck) open = open.filter((d) => dealStageDays(d) > 14);
    $('leads-empty').hidden = open.length > 0;
    const byStage = {}; DL_OPEN.forEach((k) => byStage[k] = []);
    open.forEach((d) => byStage[stageOf(d.stage)].push(d));
    Object.values(byStage).forEach((a) => a.sort((x, y) => new Date(y.created_at) - new Date(x.created_at)));
    pipe.className = 'pipeline';
    pipe.innerHTML = STAGES.filter((s) => DL_OPEN.includes(s.key)).map((s) => {
      const n = byStage[s.key].length;
      const cards = byStage[s.key].map((d) => cardHTML(d, s)).join('') || '<div class="pipe-empty">Sin deals</div>';
      const val = dealsValue(byStage[s.key]);
      const wt = Math.round(val * s.prob);
      return '<div class="pipe-col" data-stage="' + s.key + '">' +
        '<div class="pipe-col-head"><span class="bar" style="background:' + s.color + '"></span><span class="st">' + s.label + '</span><span class="cnt">' + n + '</span></div>' +
        '<div class="pipe-col-sums"><span class="tot" style="color:' + s.color + '">' + fmtChf(val) + '</span><span class="wt">pond. ' + fmtChf(wt) + ' (' + Math.round(s.prob * 100) + '%)</span></div>' +
        '<div class="pipe-list">' + cards + '</div>' +
      '</div>';
    }).join('');
    // drop-zones de cierre con resumen 30d (soltar acá = mismo setDealStage que las columnas)
    const won30r = rows.filter((d) => stageOf(d.stage) === 'ganado' && in30(d.won_at || d.last_stage_at));
    const lost30r = rows.filter((d) => stageOf(d.stage) === 'perdido' && in30(d.lost_at || d.last_stage_at));
    if (drops) drops.innerHTML =
      '<div class="pipe-drop win" data-stage="ganado" title="Ver los ganados en la vista Lista">🏆 Soltá acá para GANADO<span class="pd-sum">últimos 30d: ' + won30r.length + ' · ' + fmtChf(dealsValue(won30r)) + '</span></div>' +
      '<div class="pipe-drop lose" data-stage="perdido" title="Ver los perdidos en la vista Lista">✖ PERDIDO<span class="pd-sum">últimos 30d: ' + lost30r.length + ' · ' + fmtChf(dealsLostValue(lost30r)) + '</span></div>';
    bindPipeline();
    pipePager();
    // próximo paso: task abierta más cercana por persona visible (1 query cacheada, ver dlFetchNextTasks)
    dlFetchNextTasks([...new Set(rows.map((d) => String(d.lead_id)).filter((x) => x && x !== 'undefined' && x !== 'null'))]);
  }
  /* ---- vista Lista: tabla con semáforo, próximo paso y última actividad ---- */
  function renderDealsList(rows){
    const cont = $('deals-list'); if (!cont) return;
    let ds = rows.slice();
    if (dlStuck) ds = ds.filter((d) => DL_OPEN.includes(stageOf(d.stage)) && dealStageDays(d) > 14);
    if (dlListStage === 'open') ds = ds.filter((d) => DL_OPEN.includes(stageOf(d.stage)));
    else if (dlListStage === 'ganado' || dlListStage === 'perdido') ds = ds.filter((d) => stageOf(d.stage) === dlListStage);
    const rowVal = (d) => stageOf(d.stage) === 'perdido' ? dealLostValue(d) : dealValue(d);
    const CMP = {
      value: (a, b) => rowVal(b) - rowVal(a),
      days: (a, b) => dealStageDays(b) - dealStageDays(a),
      recent: (a, b) => new Date(b.created_at) - new Date(a.created_at)
    };
    ds.sort(CMP[dlSort] || CMP.value);
    $('leads-empty').hidden = ds.length > 0;
    const chip = (k, l) => '<button class="dl-chip' + (dlListStage === k ? ' active' : '') + '" data-st="' + k + '" type="button">' + l + '</button>';
    // borrado en batch: solo deals REALES (no synthetic — esos no tienen fila en `deals`)
    const selectable = ds.filter((d) => !d.synthetic);
    const allChecked = selectable.length > 0 && selectable.every((d) => dlSelected.has(String(d.id)));
    const body = ds.map((d) => {
      const r = leadById(d.lead_id) || {};
      const s = STAGES.find((x) => x.key === stageOf(d.stage)) || STAGES[0];
      const val = rowVal(d);
      const days = dealStageDays(d);
      const dom = leadDomain(r);
      const co = (dom && companyName(dom)) || r.company || '';
      const ofs = offersForDeal(d);
