      intro: ppCur.intro, intro_sign: { name: s.name, role: s.role }, testimonials: ppCur.testimonials || DEFAULT_TESTIMONIALS,
      overview: { objective: ppCur.objective, outputs: ppCur.outputs, location: ppCur.location, timing: ppCur.timing, delivery: ppCur.delivery },
