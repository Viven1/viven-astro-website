  // delta de posición: BAJAR es mejorar (al revés que clicks/impresiones) — verde cuando mejora
  function seoPosDelta(cur, prev){
    const el = $('seo-k-pos-d'); if (!el) return;
    if (!prev && !cur){ el.textContent = '='; el.className = 'kdelta flat'; return; }
    if (!prev){ el.textContent = '▲ nuevo'; el.className = 'kdelta up'; return; }
    const diff = prev - cur;
    if (Math.abs(diff) < 0.15){ el.textContent = '='; el.className = 'kdelta flat'; return; }
    el.textContent = (diff > 0 ? '▲ mejoró ' : '▼ empeoró ') + Math.abs(diff).toFixed(1);
    el.className = 'kdelta ' + (diff > 0 ? 'up' : 'down');
  }

  function seoRenderKpis(data){
    const t = data.totals || {}, pt = data.prevTotals || {};
    const fmtN = (n) => (n || 0).toLocaleString('de-CH');
    $('seo-k-clicks').textContent = fmtN(t.clicks);
    $('seo-k-impr').textContent = fmtN(t.impressions);
    $('seo-k-ctr').textContent = ((t.ctr || 0) * 100).toFixed(1) + '%';
    $('seo-k-pos').textContent = (t.position || 0).toFixed(1);
    setDelta('seo-k-clicks-d', t.clicks, pt.clicks);
    setDelta('seo-k-impr-d', t.impressions, pt.impressions);
    setDelta('seo-k-ctr-d', t.ctr, pt.ctr);
    seoPosDelta(t.position || 0, pt.position || 0);
    const dClicks = pt.clicks ? ((t.clicks - pt.clicks) / pt.clicks * 100) : null;
    const verdict = $('seo-verdict');
    if (verdict) {
      verdict.innerHTML = '📈 <b>SEO en los últimos ' + (data.days || '') + ' días:</b> clicks ' +
        (dClicks == null ? 'sin período anterior para comparar' : ((dClicks >= 0 ? '+' : '') + dClicks.toFixed(0) + '% vs el período anterior')) +
        ' · ' + (data.queries || []).length + ' búsquedas distintas' +
        (data.cannibalization && data.cannibalization.length ? ' · ⚠ ' + data.cannibalization.length + ' casos de canibalización (ver abajo)' : '');
    }
  }

