  function loadBlog(id){ const b = blogsList.find((x) => String(x.id) === String(id)); if (b) fillBlogEditor(b); }

  // genera un artículo (nuevo, o versión localizada si pasás groupId+localize) y lo guarda en blogs
  async function generateBlog(opts){
    opts = opts || {};
    const topic = (opts.topic || $('bg-topic').value).trim();
    const lang = opts.lang || $('bg-lang').value;
    if (!topic){ toast('Escribí un tema o keyword'); return; }
    const btn = opts.btn || $('bg-gen'), prev = btn.textContent; btn.disabled = true; btn.textContent = '✨ Escribiendo…';
    $('bg-note').textContent = 'La IA está escribiendo el artículo (' + (LANGNAME[lang] || lang) + ')…';
    try {
      const { data, error } = await supabase.functions.invoke('ai-blog', { body: { topic, lang, localize: !!opts.localize } });
      if (error || !data || !data.body_html) throw new Error(data?.error || error?.message || 'sin respuesta');
      const row = { lang, topic, slug: data.slug, title: data.title, description: data.description, eyebrow: data.eyebrow, lead: data.lead, body_html: data.body_html, faq: data.faq || [], status: 'draft' };
      if (opts.groupId) row.group_id = opts.groupId;
      const ins = await supabase.from('blogs').insert(row).select().single();
      if (ins.error) throw new Error('generado, pero no se pudo guardar (¿SQL 0009?): ' + ins.error.message);
      await blogsLoad();
      fillBlogEditor(ins.data);
      $('bg-note').textContent = '✨ Listo — guardado en la lista. Revisá, editá y publicá.';
    } catch (e) { $('bg-note').textContent = 'No se pudo generar (¿deployaste ai-blog + crédito Anthropic?): ' + e.message; }
    finally { btn.disabled = false; btn.textContent = prev; }
  }
  function localizeBlog(id, targetLang){
