  // Al cambiar el lead ligado, la consulta/cliente/email SIGUEN al lead nuevo
  // (antes quedaban pegados al primero — mismo bug que tuvimos en ofertas).
  // Si editaste el texto a mano, pide confirmación antes de pisarlo.
  let ppPrevLeadId = null;
  async function ppLeadChange(){
    const lead = allLeads.find((l) => String(l.id) === String($('pp-lead').value));
    if (!lead) return;
    const prev = allLeads.find((l) => String(l.id) === String(ppPrevLeadId));
    // consulta del cliente: reemplaza si está vacía o si sigue siendo la del lead anterior
    const curI = $('pp-inquiry').value;
    const untouchedI = !curI.trim() || (prev && curI === (prev.message || ''));
    if (untouchedI || confirm('¿Reemplazar la consulta del cliente con el mensaje de "' + (lead.name || lead.email) + '"?'))
      $('pp-inquiry').value = lead.message || '';
    // nombre y email del cliente: siguen al lead salvo que los hayas escrito a mano
    const curN = $('pp-cname').value;
    if (!curN.trim() || (prev && (curN === (prev.name || '') || curN === clientNameFor(prev)))) $('pp-cname').value = clientNameFor(lead) || lead.name || '';
    const curE = $('pp-cemail').value;
    if (!curE.trim() || (prev && curE === (prev.email || ''))) $('pp-cemail').value = lead.email || '';
    if (lead.lang && ['en', 'de', 'es'].includes(lead.lang)) $('pp-lang').value = lead.lang;
    ppCur.lead_id = lead.id;
    ppPrevLeadId = lead.id;
  }
  async function generatePropAI(){
    const inquiry = $('pp-inquiry').value.trim();
    if (!inquiry){ toast('Pegá la consulta del cliente o ligá un lead'); return; }
    const btn = $('pp-ai'), prev = btn.textContent; btn.disabled = true; btn.textContent = '✨ Pensando…';
    $('pp-ai-note').textContent = 'La IA está armando la propuesta (intro, scope, 3 paquetes, add-ons)…';
    try {
      let brief = null;
      if ($('pp-lead').value){ const { data } = await supabase.from('briefs').select('*').eq('lead_id', String($('pp-lead').value)).order('created_at', { ascending: false }).limit(1); if (data && data[0]) brief = data[0]; }
      const { data, error } = await supabase.functions.invoke('ai-proposal', { body: { inquiry, brief, catalog: catalogFlat(), lang: $('pp-lang').value, client_name: $('pp-cname').value } });
      if (error || !data || !Array.isArray(data.tiers)) throw new Error(data?.error || error?.message || 'sin respuesta');
      if (!$('pp-title').value && data.title) $('pp-title').value = data.title;
      $('pp-intro').value = data.intro || '';
      const ov = data.overview || {}; $('pp-objective').value = ov.objective || ''; $('pp-outputs').value = (ov.outputs || []).join('\n'); $('pp-loc').value = ov.location || ''; $('pp-timing').value = ov.timing || ''; $('pp-delivery').value = ov.delivery || '';
      ppCur.scope = data.scope || []; renderScopeRows();
      ppCur.tiers = (data.tiers || []).map((t) => { const items = snapToCatalog(t.items || []); const price = items.reduce((a, it) => a + (Number(it.qty) || 0) * (Number(it.price) || 0), 0); return { name: t.name, subtitle: t.subtitle, price: Math.round(price), discount_pct: 0, recommended: !!t.recommended, includes: t.includes || [], items }; });
      renderTierRows();
      ppCur.addons = (data.addon_groups || []).flatMap((g) => g.items || []).map((it) => ({ name: it.name, note: it.note || '', price: Math.round((Number(it.qty) || 1) * (Number(it.price) || 0)) })); renderAddonRows();
      $('pp-ai-note').textContent = '✨ Propuesta generada — revisá todo, ajustá precios/textos, poné password y publicá.';
    } catch (e) { $('pp-ai-note').textContent = 'No se pudo generar (¿deployaste ai-proposal + crédito Anthropic?): ' + e.message; }
    finally { btn.disabled = false; btn.textContent = prev; }
  }
  function bindProposals(){
