      '</tr></thead><tbody>' + pool.map((p) => {
        const b = BDG[p.status] || BDG.draft, v = propVal(p), tiers = ((p.content || {}).tiers || []);
        // sub del título: qué es y desde cuándo está afuera (o cuándo se tocó por última vez)
        let sub = tiers.length + ' paquete' + (tiers.length === 1 ? '' : 's') + (p.published_at && p.status !== 'draft' ? ' · publicada ' + fmtD(p.published_at) : ' · editada ' + fmtD(p.updated_at));
        // perdida: el motivo a la vista, para aprender de por qué se pierden
        if (p.status === 'lost' && (p.lost_reason || leadLostReason(p.lead_id))) sub += ' · <span style="color:#ff8b8b">✕ ' + esc(p.lost_reason || leadLostReason(p.lead_id)) + '</span>';
        const firma = (p.status === 'accepted' && p.accepted_name) ? '<div class="lt-sub">✍️ Firmado por ' + esc(p.accepted_name) + (p.accepted_at ? ' · ' + new Date(p.accepted_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) : '') + (p.signed_ip ? ' · IP ' + esc(p.signed_ip) : '') + '</div>' : '';
        // "Esperando hace": semáforo desde published_at — el rojo es al que hay que hacerle follow-up hoy
        let wait = '<span class="lt-num">—</span>';
        if (p.status === 'sent' && (p.published_at || p.updated_at)){
          const d = ppDays(p.published_at || p.updated_at);
          wait = d > 8 ? '<span class="pp2-sem bad">' + d + 'd · ⚠ seguir</span>' : d >= 4 ? '<span class="pp2-sem mid">' + d + 'd</span>' : '<span class="pp2-sem ok">' + d + 'd</span>';
        } else if (p.status === 'accepted' && p.accepted_at && p.published_at){
          const n = Math.max(0, Math.round((Date.parse(p.accepted_at) - Date.parse(p.published_at)) / 86400000));
          wait = '<span class="pp2-eye" style="color:#7ed957">aceptó en ' + n + ' día' + (n === 1 ? '' : 's') + '</span>';
        }
        // "Interés": qué hizo el cliente con el link (last_view_at lo estampa get-proposal en cada vista)
        let eye = '<span class="lt-num">—</span>';
        if (p.status === 'sent' || p.status === 'accepted'){
          if (p.last_view_at) eye = '<span class="pp2-eye' + ((Date.now() - Date.parse(p.last_view_at)) < 86400000 ? ' hot' : '') + '">👁 vista hace ' + timeAgo(p.last_view_at) + '</span>';
          else if (Number(p.views) > 0) eye = '<span class="pp2-eye">👁 ' + p.views + ' vistas</span>';
          else if (p.status === 'sent' && p.published_at && ppDays(p.published_at) > 2) eye = '<span class="pp2-eye warn">👁 0 vistas — ¿le llegó el link?</span>';
        }
        const val = v ? '<span' + (p.status === 'accepted' ? ' style="color:#7ed957"' : '') + '>' + fmtM(v) + '</span><div class="lt-sub">' + (p.status === 'accepted' ? 'aceptado' : (tiers.find((t) => t.recommended) ? 'recomendado' : 'paquete 1')) + '</div>' : '<span class="lt-num">—</span>';
        return '<tr data-id="' + p.id + '">' +
          '<td><div class="lt-name">' + esc(p.title || '(sin título)') + '</div><div class="lt-sub">' + sub + '</div>' + firma + '</td>' +
