    return '<div class="pipe-card' + alarm + '" draggable="' + (PIPE_DRAG ? 'true' : 'false') + '" data-id="' + esc(String(d.id)) + '" data-lead="' + esc(String(d.lead_id)) + '" style="--stage:' + st.color + '">' +
      '<div class="pc-head"><div class="pc-name">' + esc(dealName) + '</div><button class="pc-dots" type="button" data-id="' + esc(String(d.id)) + '" title="Acciones">⋯</button></div>' +
      (who ? '<div class="pc-sub">' + esc(who) + '</div>' : '') +
      '<div class="pc-row"><span class="pc-amt">' + (total ? fmtChf(total) + est : '—') + '</span>' + dealDaysChip(days) + '</div>' +
