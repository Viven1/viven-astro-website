  function coEditField(domain, el){
    if (el.querySelector('input')) return; // ya está en edición
    const f = el.dataset.f; const cur = String((coMeta[domain] || {})[f] || '');
    el.innerHTML = '<input class="ed-inp" value="' + esc(cur) + '" style="width:100%;font-size:12.5px;padding:5px 7px" />';
    const inp = el.querySelector('input'); inp.focus(); inp.select();
    let done = false;
    // Enter guarda, Esc cancela; blur también guarda para no perder lo tipeado
    const finish = async (save) => {
      if (done) return; done = true;
      const v = inp.value.trim();
      if (save && v !== cur){
        if (await coSaveMeta(domain, { [f]: v || null })) toast('Empresa guardada');
        renderCompanyDetail(); renderCompaniesList(); // nombre/industria/ciudad afectan header, subline y lista
        return;
      }
      coRenderAbout(domain);
    };
    inp.addEventListener('keydown', (e) => { if (e.key === 'Enter') finish(true); else if (e.key === 'Escape') finish(false); });
    inp.addEventListener('blur', () => finish(true));
  }
  // guarda un patch parcial en companies (upsert por domain) y refresca coMeta — reemplaza al viejo saveCompanyMeta
