  // botón de factura: solo tiene sentido con la oferta ganada y ya guardada (con id real).
  // Guard con secuencia: si abrís otra oferta antes de que esta consulta vuelva,
  // el resultado viejo NO debe pisar curInvoice de la oferta que estás mirando ahora
  // (si no, "Marcar pagada" podía terminar marcando la factura de OTRA oferta).
  let invoiceReqSeq = 0;
  async function refreshInvoiceBtn(){
    const btn = $('of-invoice'), paidBtn = $('of-invoice-paid');
    if (!btn) return;
    if (!FEATURE_INVOICING){ btn.hidden = true; paidBtn.hidden = true; return; }
    const show = ofCur.status === 'won' && !!ofCur.id;
    btn.hidden = !show; paidBtn.hidden = true;
    if (!show) return;
    curInvoice = null;
    const seq = ++invoiceReqSeq;
    const forOfferId = ofCur.id;
    const { data } = await supabase.from('invoices').select('*').eq('offer_id', forOfferId).order('created_at', { ascending: false }).limit(1).maybeSingle();
    if (seq !== invoiceReqSeq || ofCur.id !== forOfferId) return;   // se abrió otra oferta mientras esperábamos
    curInvoice = data || null;
    if (curInvoice) {
      btn.textContent = (curInvoice.status === 'paid' ? '✅ ' : '🧾 ') + curInvoice.number;
      paidBtn.hidden = curInvoice.status === 'paid';
    } else {
      btn.textContent = '🧾 Generar factura';
    }
  }
  // banner rojo con el motivo de pérdida (oferta/propuesta) — para aprender a largo plazo
  function showLostNote(id, reason, isLost){
    const el = $(id); if (!el) return;
    el.hidden = !(isLost || reason);
    el.textContent = '✕ Perdida' + (reason ? ' — motivo: ' + reason : ' (sin motivo registrado)');
  }
  // dirección del cliente: completar los campos VACÍOS desde el lead ligado (y su empresa)
  function prefillClientBlock(){
    const lead = (allLeads || []).find((l) => String(l.id) === String(ofCur.lead_id));
    if (!lead) return;
    const co = coMeta[leadDomain(lead)] || null;
    const put = (id, v) => { const el = $(id); if (el && !el.value.trim() && v) el.value = v; };
    put('of-ccompany', lead.company || (co && co.name));
    put('of-cperson', lead.name || [lead.first_name, lead.last_name].filter(Boolean).join(' '));
    put('of-cemail', lead.email);
    put('of-cphone', lead.phone);
    put('of-caddr', co && co.address);
    put('of-czip', co && (co.zip_city || co.city));
  }
  // llena la consulta desde el lead ligado. force=true (cambio explícito de lead) reemplaza;
  // si vos editaste el texto a mano, pide confirmación antes de pisarlo.
  function prefillInquiry(force){
    const lead = (allLeads || []).find((l) => String(l.id) === String(ofCur.lead_id));
    $('of-ai-src').textContent = lead ? '· del lead ' + (lead.name || lead.email || lead.id) : '';
    if (!lead) return;
    const cur = $('of-inquiry').value;
    const untouched = !cur.trim() || cur === inquiryFromLead;   // sigue siendo lo auto-rellenado
    if (!untouched){
      if (!force) return;                                       // al abrir: no pisar texto propio
      if (!confirm('¿Reemplazar la consulta del cliente con el mensaje de "' + (lead.name || lead.email) + '"?')) return;
    }
    $('of-inquiry').value = lead.message || '';
    inquiryFromLead = lead.message || '';
  }
  // catálogo plano para pasarle a la IA (precios reales)
  const catalogFlat = () => { const c = CATALOG(); return Object.keys(c).flatMap((ph) => c[ph].map((it) => ({ phase: ph, name: it.name, unit: it.unit, price: it.price, cost: it.cost }))); };
  // si la IA usó un ítem del catálogo, forzamos SUS precio/costo exactos (que no drifteen)
  function snapToCatalog(items){
    const cat = catalogFlat();
    return items.map((it) => {
      const hit = cat.find((c) => c.name.toLowerCase() === String(it.name || '').toLowerCase() && c.phase === it.phase)
        || cat.find((c) => c.name.toLowerCase() === String(it.name || '').toLowerCase());
      return hit
        ? { phase: hit.phase, name: hit.name, qty: Number(it.qty) || 1, unit: hit.unit, price: hit.price, cost: hit.cost }
        : { phase: it.phase || 'Production', name: it.name, qty: Number(it.qty) || 1, unit: it.unit || 'Tag', price: Number(it.price) || 0, cost: Number(it.cost) || 0 };
    });
  }
  async function generateOfferAI(){
    const inquiry = $('of-inquiry').value.trim();
    if (!inquiry){ $('of-ai-note').textContent = 'Pegá la consulta del cliente primero (o ligá un lead).'; return; }
    const btn = $('of-ai-gen'), prev = btn.textContent; btn.disabled = true; btn.textContent = '✨ Pensando…';
    $('of-ai-note').textContent = '';
    try {
      // si hay lead ligado, traemos su brief para dar más contexto
      let brief = null;
      if (ofCur.lead_id){
        const lead4 = allLeads.find((l) => String(l.id) === String(ofCur.lead_id));
        const data = lead4 ? [await latestBriefFor(lead4)].filter(Boolean) : [];
        brief = (data && data[0]) || null;
      }
      const lead = (allLeads || []).find((l) => String(l.id) === String(ofCur.lead_id));
      // idioma: el de la OFERTA (③) manda; si no, brief/lead
      const lang = (['en', 'de', 'es'].includes($('of3-lang').value) && $('of3-lang').value) || (brief && brief.lang) || (lead && lead.lang) || 'es';
      const { data, error } = await supabase.functions.invoke('ai-offer', {
        body: { inquiry, brief, catalog: catalogFlat(), lang }
      });
      if (error) throw new Error(data?.error || error?.message || 'sin respuesta');
      if (data?.error) throw new Error(data.error);
      if (!data || !Array.isArray(data.items) || !data.items.length) throw new Error('la IA no devolvió posiciones');
      ofCur.items = snapToCatalog(data.items);
      if (data.title && !$('of-title').value.trim()) { $('of-title').value = data.title; ofCur.title = data.title; }
      if (lead && !$('of-client').value.trim()) { $('of-client').value = lead.name || ''; }
      // textos personales (intro/cierre) que la IA redacta desde el brief — editables en ③
      if (data.intro_text){ $('of3-intro').value = data.intro_text; ofCur.intro_text = data.intro_text; }
      if (data.closing_text){ $('of3-closing').value = data.closing_text; ofCur.closing_text = data.closing_text; }
      if (['en', 'de', 'es'].includes(lang)){ $('of3-lang').value = lang; ofCur.lang = lang; }
      renderRows();
      await saveOffer();
      $('of-ai-note').textContent = '✨ Oferta generada y guardada (' + ofCur.items.length + ' posiciones) — revisá y ajustá lo que haga falta.' + (data.summary ? ' ' + data.summary : '');
    } catch (e) {
      $('of-ai-note').textContent = 'No se pudo generar (¿deployaste ai-offer? ¿hay crédito Anthropic?): ' + e.message;
    } finally {
      btn.disabled = false; btn.textContent = prev;
    }
  }

  const phaseOf = (it) => it.phase || 'Production';
  function phaseSubtotal(ph){
    let net = 0, cost = 0;
    ofCur.items.forEach((it) => { if (phaseOf(it) === ph){ const q = Number(it.qty) || 0; net += q * (Number(it.price) || 0); cost += q * (Number(it.cost) || 0); } });
    return { net, cost };
  }
  function rowHTML(it, i, isFirst, isLast){
    const total = (Number(it.qty) || 0) * (Number(it.price) || 0);
    const margin = total - (Number(it.qty) || 0) * (Number(it.cost) || 0);
    return '<tr data-i="' + i + '">' +
      '<td><div class="of-name-wrap"><span class="of-drag" draggable="true" title="Arrastrar para reordenar (dentro de su fase)">⠿</span>' +
      '<input class="ofi" data-f="name" value="' + esc(it.name || '') + '"/></div></td>' +
      '<td><select class="ofi" data-f="phase">' + PHASES.map((p) => '<option' + (p === phaseOf(it) ? ' selected' : '') + '>' + p + '</option>').join('') + '</select></td>' +
      '<td class="num"><input class="ofi w" data-f="qty" type="number" step="0.25" value="' + (it.qty ?? 1) + '"/></td>' +
      '<td><input class="ofi w" data-f="unit" value="' + esc(it.unit || '') + '"/></td>' +
      '<td class="num"><input class="ofi w" data-f="price" type="number" step="10" value="' + (it.price ?? 0) + '"/></td>' +
      '<td class="num"><input class="ofi w" data-f="cost" type="number" step="10" value="' + (it.cost ?? 0) + '"/></td>' +
      '<td class="num">' + fmtM(total) + '</td>' +
      '<td class="num" style="color:' + (margin >= 0 ? '#7ed957' : '#ff8b8b') + '">' + fmtM(margin) + '</td>' +
      '<td class="of-row-actions">' +
        '<button class="of-up" type="button" data-i="' + i + '"' + (isFirst ? ' disabled' : '') + ' title="Subir (dentro de su fase)">▲</button>' +
        '<button class="of-down" type="button" data-i="' + i + '"' + (isLast ? ' disabled' : '') + ' title="Bajar (dentro de su fase)">▼</button>' +
        '<button class="of-del" type="button" data-i="' + i + '">✕</button>' +
