    $('of-cphone').value = ofCur.client_phone || '';
    $('of-cemail').value = ofCur.client_email || '';
    prefillClientBlock();
    showLostNote('of-lostr', ofCur.lost_reason || leadLostReason(ofCur.lead_id), ofCur.status === 'lost');
    prefillInquiry(false);
