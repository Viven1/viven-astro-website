<script is:inline define:vars={{ stillsPool, newsVideos, newsCases }}>window.STILLS_POOL = stillsPool; window.NEWS_VIDEOS = newsVideos; window.NEWS_CASES = newsCases;</script>
<script>
  import { createClient } from '@supabase/supabase-js';

  /* misma URL + publishable key que usa el sitio (públicas por diseño);
     los datos solo se pueden LEER tras login gracias a las policies RLS */
  const supabase = createClient(
    'https://lumoevaotokgqnpybkyf.supabase.co',
    'sb_publishable_ORGL5_FNZTXcGKwvjs-ymw_Y8DV_4ca'
  );

  // ---- perf instrumentation temporal (2026-07-14, reporte "tarda 30s en entrar") ----
  // best-effort: mide fases reales de carga y las manda a dash_perf_log (SQL 0083) +
  // console, para tener datos de la red/dispositivo real en vez de adivinar. Sacar
  // cuando ya no haga falta — no afecta nada del flujo normal si la insert falla.
  const __perfT0 = performance.now();
  const __perfMarks = {};
  function __perfMark(label){ __perfMarks[label] = Math.round(performance.now() - __perfT0); }
  function __perfTimed(label, p){
    const s = performance.now();
    return Promise.resolve(p).then(
      (r) => { __perfMarks[label] = Math.round(performance.now() - s); return r; },
      (e) => { __perfMarks[label] = 'ERR:' + Math.round(performance.now() - s); throw e; }
    );
  }
  let __perfReported = false;
  let __perfKind = 'initial_load';
  function __perfReport(kind){
    const snapshot = { ...__perfMarks, total: Math.round(performance.now() - __perfT0) };
    console.log('[perf ' + kind + ']', snapshot);
    try {
      supabase.from('dash_perf_log').insert({ email: meEmail || null, phases: { kind, ...snapshot }, ua: navigator.userAgent }).then(() => {}, () => {});
    } catch (e) { /* best-effort */ }
  }

  const $ = (id) => document.getElementById(id);
  const esc = (s) => String(s ?? '').replace(/[&<>"']/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  const fmtTime = (secs) => {
    if (!secs || secs <= 0) return '—';
    const m = Math.floor(secs / 60), s = Math.round(secs % 60);
    return m ? m + 'm ' + (s < 10 ? '0' : '') + s + 's' : s + 's';
  };
  const STATUSES = ['new', 'nuevo', 'contacted', 'contactado', 'qualified', 'won', 'cerrado', 'lost', 'perdido'];
  const THANKS = /^\/(thank-you|danke|gracias)\/?$/;
  let allLeads = [], statusFilter = 'all', searchTerm = '', channelFilter = null, landingFilter = null, insightsData = null, lastViews = [], leadsView = 'board', coMeta = {}, coCur = null, coBound = false, meEmail = '';
  // última actividad por lead (notas/tasks/propuestas/web) — se llena en loadAll
  let actNotes = {}, actTasks = {}, actProps = {}, actWeb = {};

  /* ---- helpers globales de avatar (mismo esquema que la tabla de Personas) ---- */
  const AV_COLORS_G = ['#8ab4ff', '#c58af9', '#7ed957', '#f0c060', '#ff8b5e', '#5ec7d1', '#e08ac5'];
  const avColorG = (n) => { let h = 0; const x = String(n || '?'); for (let i = 0; i < x.length; i++) h = (h * 31 + x.charCodeAt(i)) >>> 0; return AV_COLORS_G[h % AV_COLORS_G.length]; };

  /* ---- 👤 Mi perfil (SQL 0064 team_profiles) — cache client-side, keyed por email en minúscula.
     Fuente de verdad progresiva: si hay fila, pisa a los mapas hardcodeados SENDERS/TEAM. ---- */
  let teamProfiles = {};
  async function loadTeamProfiles(){
    try {
      const { data, error } = await supabase.from('team_profiles').select('*');
      if (!error && data) teamProfiles = Object.fromEntries(data.map((p) => [String(p.email || '').toLowerCase(), p]));
    } catch (e) { /* tabla pendiente (SQL 0064) — sigue con hardcode */ }
  }
  const profileFor = (email) => teamProfiles[String(email || '').toLowerCase()] || null;
  // mini-avatar: foto de team_profiles si hay, si no círculo con inicial (mismo patrón que Personas)
  function teamAvatarHtml(email, fallbackName){
    const p = profileFor(email);
    const nm = (p && p.name) || fallbackName || email || '?';
    const ini = esc((nm[0] || '?').toUpperCase());
    if (p && p.avatar_url) return '<img class="lt-av" src="' + esc(p.avatar_url) + '" alt="" style="object-fit:cover" />';
    return '<span class="lt-av" style="background:' + avColorG(nm) + '">' + ini + '</span>';
  }

  function show(view){
    $('login-view').hidden = view !== 'login';
    $('dash-view').hidden = view !== 'dash';
  }

  /* ---------- Navegación (sidebar) ---------- */
  // 'seo' y 'gads' ya no son tabs propios: viven como sub-tabs dentro de Analytics
  // fix (2026-07-14, reestructuración del shell — mockup bb59ab6d): de 17 tabs planos a
  // 8 destinos agrupados por intención; blog/news/magnets/seo viven dentro de 'contenido';
  // services/licenses/booking/ab/auto/tmpl/cashflow/profile viven dentro de 'sistema'.
  // fix (2026-07-15, pedido explícito: "me gustaba mas entrar y ver todo lo que paso y lo
  // que toca hacer, llamalo Hoy"): 'hoy' es ahora la portada por defecto (KPIs + Para hoy +
  // Señales + IA), separada de 'deals'/Pipeline que vuelve a ser un board puro. 'home' es
  // alias viejo de deep links → redirige a 'hoy'. Ver contenidoSetSub/sistemaSetSub más
  // abajo (mismo patrón que anaSetSub, ya probado con Analytics).
  const TABS = ['hoy', 'deals', 'leads', 'companies', 'agenda', 'offers', 'analytics', 'contenido', 'sistema'];
  // recarga Personas fresco desde la base — se llama al cambiar de tab, así un
  // contacto creado en OTRA sesión (vos, Sofia) aparece siempre en todos los
  // selects de "ligar a un contacto" (Ofertas, Propuestas, Licencias, Workflows,
  // Nurture…), no solo en el que ya tenías cargado en memoria al abrir el dashboard.
  async function refreshLeadsList(){
    try {
      const { data, error } = await supabase.from('leads').select('*').order('created_at', { ascending: false }).limit(2000);
      if (!error && data) allLeads = data;
    } catch (e) { /* si falla, seguimos con lo que ya había en memoria */ }
  }
  async function gotoTab(tab){
    // alias para deep links / botones viejos que apuntaban a tabs que ahora son
    // sub-tabs de 'contenido'/'sistema', o que se fusionaron en otro destino.
    if (tab === 'gads'){ anaSetSub('gads'); tab = 'analytics'; }
    if (tab === 'props') tab = 'offers';
    if (tab === 'home') tab = 'hoy';
    if (['blog', 'news', 'seo', 'magnets'].includes(tab)){ contenidoSetSub(tab); tab = 'contenido'; }
    if (['services', 'licenses', 'booking', 'ab', 'auto', 'tmpl', 'cashflow', 'profile'].includes(tab)){ sistemaSetSub(tab); tab = 'sistema'; }
    document.querySelectorAll('.side-item').forEach((x) => x.classList.toggle('active', x.dataset.tab === tab));
    // barra inferior móvil: marcar activo ("Más" queda activo si el tab está en la hoja)
    const SHEET_TABS = ['deals', 'companies', 'analytics', 'contenido', 'sistema'];
    document.querySelectorAll('.mob-nav [data-tab], .mob-sheet [data-tab]').forEach((b) => b.classList.toggle('active', b.dataset.tab === tab));
    const more = $('mob-more'); if (more) more.classList.toggle('active', SHEET_TABS.includes(tab));
    const sheet = $('mob-sheet'); if (sheet) sheet.hidden = true;
    TABS.forEach((k) => { const el = $('tab-' + k); if (el) el.hidden = k !== tab; });
    window.scrollTo(0, 0);
    await refreshLeadsList();
    if (tab === 'hoy') renderHome(); // KPIs + Para hoy/Señales/Agenda-mini/IA viven en Hoy (portada)
    if (tab === 'agenda'){ hmRenderAgenda(); hmRenderCalls(); }
    if (tab === 'companies') renderCompanies();
    if (tab === 'offers') { offersInit(); proposalsInit(); }
    if (tab === 'analytics') anaSetSub(anaSub); // re-aplica el sub-tab guardado y dispara su carga
    if (tab === 'contenido') contenidoSetSub(contenidoSub);
    if (tab === 'sistema') sistemaSetSub(sistemaSub);
    syncTabUrl();
  }
  // refleja tab (+ sub-tab si aplica) en la URL, SIN sumar entradas al historial
  // (replaceState, no pushState — así el botón "atrás" no navega tab por tab).
  // Pedido explícito: "poder tener varias ventanas a la vez abiertas del dashboard,
  // que cambie la url segun el lugar, asi tmb cuando hago refresh me mantengo" —
  // cada ventana/pestaña del navegador tiene su propia URL, así que F5 en CUALQUIERA
  // de ellas te deja donde estabas, y podés abrir varias en paralelo cada una en
  // un lugar distinto (sub-tab vive en localStorage, compartido entre pestañas del
  // mismo navegador — sigue siendo "la última que elegiste en cualquiera de ellas",
  // igual que ya pasaba antes de esto).
  function syncTabUrl(){
    const tab = TABS.find((k) => { const el = $('tab-' + k); return el && !el.hidden; });
    if (!tab) return;
    const sub = tab === 'analytics' ? anaSub : tab === 'contenido' ? contenidoSub : tab === 'sistema' ? sistemaSub : '';
    const qs = '?tab=' + tab + (sub ? '&sub=' + sub : '');
    try { history.replaceState(null, '', location.pathname + qs); } catch (e) {}
  }

