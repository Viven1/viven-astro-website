        if (coErr) { btn.disabled = false; btn.textContent = 'Guardar'; toast('No se pudo crear la empresa (¿SQL 0011?): ' + coErr.message); return; }
        if (co) coMeta[res.domain] = co;
      }
    }
    const patch = { first_name: first || null, last_name: last || null, name: (first + ' ' + last).trim() || r.name, job_title: $('ed-job').value.trim() || null, email, phone: $('ed-phone').value.trim() || null, company, company_domain, lang: $('ed-lang').value };
    const { error, stripped } = await updateLeadResilient(r.id, patch);
    if (error) { btn.disabled = false; btn.textContent = 'Guardar'; toast('No se pudo guardar: ' + error.message); return; }
    Object.assign(r, patch); const i = allLeads.findIndex((l) => l.id === r.id); if (i > -1) Object.assign(allLeads[i], patch);
    if (stripped.length) toast('Guardado, pero faltan columnas en la DB (' + stripped.join(', ') + '). Corré el SQL 0011.');
    else toast(company ? 'Guardado · empresa ' + company : 'Datos guardados');
    openLead(r.id); renderLeads();
  }
  // update de lead que sobrevive si falta una columna nueva (reintenta sin ella y avisa cuáles faltan)
  async function updateLeadResilient(id, patch){
    const p = { ...patch }; const stripped = [];
    for (let i = 0; i < 5; i++){
      const { error } = await supabase.from('leads').update(p).eq('id', id);
      if (!error) return { error: null, stripped };
      const m = /Could not find the '([^']+)' column|column "?([a-z_]+)"? .* does not exist/i.exec(error.message || '');
      const col = m && (m[1] || m[2]);
      if (col && col in p) { delete p[col]; stripped.push(col); continue; }
      return { error, stripped };
    }
    return { error: null, stripped };
  }
