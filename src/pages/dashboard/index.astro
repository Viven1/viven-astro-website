  function auWireFlow(){
    const flow = $('au-flow');
    flow.querySelectorAll('.au-ins').forEach((b) => b.addEventListener('click', () => {
      const sel = document.createElement('select'); sel.className = 'au-addsel'; sel.innerHTML = AU_TYPE_OPTS;
      const popup = document.createElement('div'); popup.className = 'au-ins-popup';
      const ok = document.createElement('button'); ok.className = 'btn btn-primary small'; ok.type = 'button'; ok.textContent = 'Agregar';
      popup.append(sel, ok);
      b.replaceWith(popup);
      ok.addEventListener('click', () => { auSteps[b.dataset.v].splice(+b.dataset.i, 0, { type: sel.value }); auOpenIdx = b.dataset.v + '-' + b.dataset.i; auRenderFlow(); });
    }));
    flow.querySelectorAll('.au-node-btn').forEach((btn) => btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const node = btn.closest('.au-node'); const v = node.dataset.v, i = +node.dataset.i, act = btn.dataset.act;
      if (act === 'edit') { auCollect(); auOpenIdx = auOpenIdx === (v + '-' + i) ? null : (v + '-' + i); auRenderFlow(); }
      else if (act === 'dup') { auCollect(); auSteps[v].splice(i + 1, 0, JSON.parse(JSON.stringify(auSteps[v][i]))); auRenderFlow(); }
      else if (act === 'del') { auCollect(); auSteps[v].splice(i, 1); if (auOpenIdx === v + '-' + i) auOpenIdx = null; auRenderFlow(); }
    }));
    flow.querySelectorAll('.au-node').forEach((node) => {
      node.addEventListener('dragstart', (e) => { auDrag = { v: node.dataset.v, i: +node.dataset.i }; node.classList.add('dragging'); e.dataTransfer.effectAllowed = 'move'; });
      node.addEventListener('dragend', () => { node.classList.remove('dragging'); auDrag = null; });
      node.addEventListener('dragover', (e) => { if (auDrag && auDrag.v === node.dataset.v) e.preventDefault(); });
      node.addEventListener('drop', (e) => {
        e.preventDefault(); if (!auDrag || auDrag.v !== node.dataset.v) return;
        auCollect(); const v = node.dataset.v; const to = +node.dataset.i;
        const arr = auSteps[v]; const [moved] = arr.splice(auDrag.i, 1);
        arr.splice(auDrag.i < to ? to - 1 : to, 0, moved);
        auOpenIdx = null; auRenderFlow();
      });
    });
    $('au-copy-ab') && $('au-copy-ab').addEventListener('click', () => { auCollect(); auSteps.b = JSON.parse(JSON.stringify(auSteps.a)); toast('📋 Camino A copiado a B'); auRenderFlow(); });
    flow.querySelectorAll('.au-fs-toggle').forEach((btn) => btn.addEventListener('click', (e) => {
      e.preventDefault(); e.stopPropagation();
      const wrap = btn.closest('.au-field-wrap');
      const fs = wrap.classList.toggle('au-fs');
      document.body.classList.toggle('au-fs-open', fs);
      btn.textContent = fs ? '✕ Cerrar' : '⤢ Expandir';
      if (fs) wrap.querySelector('textarea').focus();
    }));
  }
  function auCollect(){
    ['a', 'b'].forEach((v) => {
      const nodes = document.querySelectorAll('.au-node[data-v="' + v + '"]');
      const arr = [];
      nodes.forEach((el) => {
        const t = el.dataset.type;
        const cur = (auSteps[v] || [])[+el.dataset.i] || {};
        const q = (sel) => el.querySelector(sel);
        if (t === 'email') arr.push({ type: 'email', from: (q('.f-from') || {}).value || cur.from, subject: (q('.f-subject') || {}).value ?? cur.subject, body: (q('.f-body') || {}).value ?? cur.body });
        else if (t === 'ai_email') arr.push({ type: 'ai_email', from: (q('.f-from') || {}).value || cur.from, prompt: (q('.f-prompt') || {}).value ?? cur.prompt });
        else if (t === 'wait') arr.push({ type: 'wait', days: q('.f-days') ? (+q('.f-days').value || 1) : cur.days });
        else if (t === 'task') arr.push({ type: 'task', title: (q('.f-title') || {}).value ?? cur.title });
        else if (t === 'push') arr.push({ type: 'push', title: (q('.f-title') || {}).value ?? cur.title });
        else arr.push({ type: 'status', value: (q('.f-status') || {}).value ?? cur.value });
      });
      if (nodes.length) auSteps[v] = arr;
    });
