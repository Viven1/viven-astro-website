    { key: 'employer', re: /employer|recruit|talent|hiring|arbeitgeber|mitarbeiter|karriere|reclut|empleo|kultur|culture/i },
    { key: 'product',  re: /product|produkt|producto|launch|lancierung|lanzamiento|e-?com/i },
    { key: 'social',   re: /social|instagram|tiktok|linkedin|reels|shorts|redes/i },
    { key: 'event',    re: /event|keynote|kongress|congress|messe|evento|aftermovie|confer/i },
    { key: 'howto',    re: /tutorial|how.?to|explainer|erklär|explicativ|onboarding|schulung/i },
    { key: 'brand',    re: /brand|marke|marca|campaign|kampagne|campaña|image|corporate/i }
  ];
  const detectTopic = (msg) => (TOPICS.find((t) => t.re.test(msg || '')) || {}).key || 'general';

  const PROOF = {
    en: {
      employer: 'employer-branding films we made for UBS, Siemens and KPMG attract exactly the candidates our clients want',
