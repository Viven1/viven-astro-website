<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Viven — Dashboard</title>
<!-- Página privada: fuera de buscadores y del sitemap -->
<meta name="robots" content="noindex,nofollow" />
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%20viewBox%3D%220%200%2064%2064%22%3E%3Crect%20width%3D%2264%22%20height%3D%2264%22%20rx%3D%2214%22%20fill%3D%22%23142033%22/%3E%3Ctext%20x%3D%2232%22%20y%3D%2247%22%20font-family%3D%22Arial%2CHelvetica%2Csans-serif%22%20font-size%3D%2244%22%20font-weight%3D%22700%22%20fill%3D%22%23ddf98f%22%20text-anchor%3D%22middle%22%3Ev%3C/text%3E%3C/svg%3E" />
<meta name="theme-color" content="#0f1826" />
<link rel="stylesheet" href="/assets/site.css" />
<style>
  .dash-wrap{max-width:1220px;margin:0 auto;padding:32px 24px 80px}
  .dash-head{display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;margin-bottom:24px}
  .dash-head h1{font-size:clamp(24px,3.4vw,32px)}
  .dash-head h1 span{color:var(--acid)}
  .dash-sub{color:var(--muted-2);font-size:13px;margin-top:4px}
  .login-card{max-width:420px;margin:12vh auto 0;border:1px solid var(--line-strong);border-radius:20px;background:var(--navy-800);padding:40px}
  .login-card h1{font-size:26px;margin-bottom:6px}
  .login-card p{color:var(--muted);font-size:14px;margin-bottom:24px}

  /* tabs */
  .tabs{display:flex;gap:8px;margin-bottom:28px;border-bottom:1px solid var(--line);padding-bottom:0}
  .tab{background:none;border:0;border-bottom:2px solid transparent;color:var(--muted);font-family:'Space Grotesk';font-size:16px;font-weight:600;padding:12px 18px;cursor:pointer;transition:.25s;display:inline-flex;align-items:center;gap:8px}
  .tab:hover{color:var(--text)}
  .tab.active{color:var(--acid);border-bottom-color:var(--acid)}
  .tab .pill{background:rgba(221,249,143,.14);color:var(--acid);border-radius:100px;font-size:11.5px;padding:2px 9px;font-family:'Inter'}

  .kpis{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:28px}
  .kpis.four{grid-template-columns:repeat(4,1fr)}
  .kpi{border:1px solid var(--line);border-radius:var(--radius);background:linear-gradient(180deg,var(--navy-700),var(--navy-800));padding:20px}
  .kpi .n{font-family:'Space Grotesk';font-weight:700;font-size:30px;color:var(--acid);line-height:1.1;white-space:nowrap}
  .kpi .n small{font-size:16px;color:var(--muted)}
  .kpi .l{color:var(--muted);font-size:12.5px;margin-top:6px}

  .panel{border:1px solid var(--line);border-radius:var(--radius);background:var(--navy-800);padding:24px;margin-bottom:22px;overflow-x:auto}
  .panel h2{font-size:17px;margin-bottom:16px;display:flex;align-items:center;gap:10px}
  .panel h2 .count{font-size:12px;color:var(--muted-2);font-weight:500}
  .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:22px}

  /* daily chart */
  .chart{display:flex;align-items:flex-end;gap:3px;height:120px;padding-top:8px}
  .chart .col{flex:1;display:flex;flex-direction:column;justify-content:flex-end;height:100%;position:relative;border-radius:4px 4px 0 0;background:rgba(255,255,255,.03)}
  .chart .col .fill{background:var(--acid);opacity:.85;border-radius:4px 4px 0 0;min-height:2px;transition:.3s}
  .chart .col:hover .fill{opacity:1}
  .chart .col .tip{display:none;position:absolute;bottom:calc(100% + 6px);left:50%;transform:translateX(-50%);background:var(--navy-900);border:1px solid var(--line-strong);border-radius:8px;padding:5px 9px;font-size:11px;color:var(--text);white-space:nowrap;z-index:5}
  .chart .col:hover .tip{display:block}
  .chart-labels{display:flex;justify-content:space-between;color:var(--muted-2);font-size:11px;margin-top:8px}

  /* bar rows */
  .bars{display:grid;gap:9px}
  .bar-row{display:grid;grid-template-columns:minmax(90px,160px) 1fr 88px;align-items:center;gap:12px;font-size:13px}
  .bar-row .lbl{color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .bar-row .track{height:9px;border-radius:100px;background:rgba(255,255,255,.05);overflow:hidden}
  .bar-row .fill{height:100%;border-radius:100px;background:var(--acid);min-width:2px}
  .bar-row .val{text-align:right;color:var(--text);font-weight:600;font-size:12.5px;white-space:nowrap}
  .bar-row .val small{color:var(--muted-2);font-weight:400}

  /* chart with conversion dots */
  .chart .col .dot{position:absolute;left:50%;transform:translateX(-50%);width:7px;height:7px;border-radius:50%;background:#ff9ec9;box-shadow:0 0 0 2px var(--navy-800);z-index:3}
  .chart-legend{display:flex;gap:18px;margin-top:10px;font-size:11.5px;color:var(--muted-2)}
  .chart-legend i{display:inline-block;width:10px;height:10px;border-radius:3px;margin-right:6px;vertical-align:-1px}
  .chart-legend .s{background:var(--acid)}
  .chart-legend .c{border-radius:50%;background:#ff9ec9}

  /* insight banner */
  .insights{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:22px}
  .insight{border:1px solid var(--line);border-radius:var(--radius);background:linear-gradient(180deg,var(--navy-700),var(--navy-800));padding:18px 20px}
  .insight .t{font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted-2);margin-bottom:8px;display:flex;align-items:center;gap:7px}
  .insight .v{font-family:'Space Grotesk';font-weight:700;font-size:19px;color:var(--text);line-height:1.25}
  .insight .v em{color:var(--acid);font-style:normal}
  .insight .d{color:var(--muted);font-size:12.5px;margin-top:6px}
  @media(max-width:980px){.insights{grid-template-columns:1fr}}

  /* performance table (canales / páginas que traen leads) */
  .perf{width:100%;border-collapse:collapse;font-size:13px;min-width:520px}
  .perf th{text-align:left;color:var(--muted-2);font-size:10.5px;letter-spacing:.09em;text-transform:uppercase;padding:7px 10px;border-bottom:1px solid var(--line-strong)}
  .perf th.num,.perf td.num{text-align:right}
  .perf td{padding:10px;border-bottom:1px solid var(--line);vertical-align:middle}
  .perf tr:last-child td{border-bottom:0}
  .perf .rate-cell{display:flex;align-items:center;gap:9px;justify-content:flex-end}
  .perf .rate-bar{width:56px;height:7px;border-radius:100px;background:rgba(255,255,255,.06);overflow:hidden;flex-shrink:0}
  .perf .rate-bar i{display:block;height:100%;background:var(--acid);border-radius:100px}
  .perf .rate-num{font-weight:700;color:var(--text);min-width:42px;text-align:right}
  .perf .lead-n{font-weight:700;color:var(--acid)}
  .perf .lead-n.zero{color:var(--muted-2);font-weight:400}

  /* tables */
  table.dt{width:100%;border-collapse:collapse;font-size:13.5px;min-width:820px}
  .dt th{text-align:left;color:var(--muted-2);font-size:11px;letter-spacing:.1em;text-transform:uppercase;padding:8px 12px;border-bottom:1px solid var(--line-strong)}
  .dt td{padding:11px 12px;border-bottom:1px solid var(--line);color:var(--text);vertical-align:top}
  .dt tr:hover td{background:rgba(255,255,255,.02)}
  .dt td .sub{color:var(--muted-2);font-size:12px;display:block;margin-top:2px}
  .dt .msg{max-width:260px;color:var(--muted);font-size:13px}
  .badge{display:inline-block;padding:3px 10px;border-radius:100px;font-size:11.5px;font-weight:600;background:rgba(255,255,255,.08);color:var(--muted)}
  .b-paid_search{background:rgba(66,133,244,.18);color:#8ab4f8}
  .b-paid_social{background:rgba(24,119,242,.18);color:#7ba9e8}
  .b-organic{background:rgba(52,168,83,.18);color:#81c995}
  .b-ai{background:rgba(221,249,143,.16);color:var(--acid)}
  .b-social{background:rgba(255,110,180,.16);color:#ff9ec9}
  .b-referral{background:rgba(255,190,90,.16);color:#ffd28a}
  .b-email{background:rgba(160,110,255,.18);color:#c4a7ff}
  .gclid-dot{color:var(--acid);font-weight:700;font-size:12.5px}
  select.status{background:var(--navy-900);border:1px solid var(--line-strong);border-radius:8px;color:var(--text);font-family:inherit;font-size:12.5px;padding:6px 9px;cursor:pointer}

  /* toolbar */
  .toolbar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:18px;align-items:center}
  .toolbar input[type="search"]{flex:1;min-width:180px;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:100px;padding:9px 18px;color:var(--text);font-family:inherit;font-size:13.5px}
  .toolbar input[type="search"]:focus{outline:none;border-color:var(--acid)}
  .toolbar .fpill{background:transparent;border:1px solid var(--line-strong);color:var(--muted);font-family:inherit;font-size:12.5px;font-weight:600;padding:8px 15px;border-radius:100px;cursor:pointer;transition:.25s}
  .toolbar .fpill:hover{border-color:var(--acid);color:var(--acid)}
  .toolbar .fpill.active{background:var(--acid);border-color:var(--acid);color:#142033}

  .muted-note{color:var(--muted-2);font-size:13px}
  .btn.small{padding:9px 18px;font-size:13px}
  .dt tbody tr{cursor:pointer}

  /* ---------- Lead detail modal ---------- */
  .lead-modal{position:fixed;inset:0;z-index:300;display:none;align-items:flex-start;justify-content:center;padding:5vh 20px;overflow-y:auto}
  .lead-modal.open{display:flex}
  .lead-modal .backdrop{position:fixed;inset:0;background:rgba(9,15,26,.86);backdrop-filter:blur(8px)}
  .lead-card{position:relative;z-index:2;width:min(760px,100%);background:var(--navy-800);border:1px solid var(--line-strong);border-radius:20px;padding:32px;animation:pop .35s var(--ease)}
  @keyframes pop{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
  .lead-card .close{position:absolute;top:18px;right:18px;width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,.08);border:1px solid var(--line-strong);color:#fff;font-size:18px;cursor:pointer;display:grid;place-items:center;transition:.25s}
  .lead-card .close:hover{background:var(--acid);color:#142033}
  .lead-card h3{font-size:24px;margin-bottom:2px}
  .lead-card .email-line{color:var(--muted);font-size:14px;margin-bottom:22px}
  .lead-card .email-line a{color:var(--acid)}
  .detail-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px}
  .detail{background:var(--navy-900);border:1px solid var(--line);border-radius:12px;padding:12px 14px}
  .detail .k{font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted-2);margin-bottom:4px}
  .detail .v{font-size:13.5px;color:var(--text);word-break:break-all}
  .lead-msg{background:var(--navy-900);border:1px solid var(--line);border-radius:12px;padding:16px;color:var(--muted);font-size:14px;line-height:1.6;margin-bottom:24px;white-space:pre-wrap}
  .draft-head{display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:10px}
  .draft-head h4{font-size:15px;display:flex;align-items:center;gap:8px}
  .draft-head h4 span{color:var(--acid)}
  .draft-box{width:100%;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:12px;padding:16px;color:var(--text);font-family:inherit;font-size:13.5px;line-height:1.6;min-height:230px;resize:vertical}
  .draft-box:focus{outline:none;border-color:var(--acid)}
  .lead-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:16px;justify-content:space-between}
  .lead-actions .left{display:flex;gap:10px;flex-wrap:wrap}
  .btn-danger{background:transparent;border:1px solid rgba(255,120,120,.4);color:#ff9a9a}
  .btn-danger:hover{background:rgba(255,90,90,.12);border-color:#ff9a9a;transform:translateY(-2px)}
  @media(max-width:680px){.detail-grid{grid-template-columns:1fr 1fr}}
  [hidden]{display:none!important}
  @media(max-width:980px){.kpis,.kpis.four{grid-template-columns:repeat(2,1fr)}.grid-2{grid-template-columns:1fr}}
</style>
</head>
<body>

<!-- ============ LOGIN ============ -->
<div id="login-view" class="dash-wrap" hidden>
  <div class="login-card">
    <h1>Viven <span style="color:var(--acid)">Dashboard</span></h1>
    <p>Acceso privado. Inicia sesión con tu usuario.</p>
    <form id="login-form" class="lead-form">
      <div class="field"><label>Email</label><input type="email" name="email" required autocomplete="username" /></div>
      <div class="field"><label>Contraseña</label><input type="password" name="password" required autocomplete="current-password" /></div>
      <button type="submit">Entrar</button>
      <p class="form-error">Login incorrecto — revisa email y contraseña.</p>
    </form>
  </div>
</div>

<!-- ============ DASHBOARD ============ -->
<div id="dash-view" class="dash-wrap" hidden>
  <div class="dash-head">
    <div>
      <h1>Viven <span>Dashboard</span></h1>
      <p class="dash-sub" id="updated-at">Últimos 30 días</p>
    </div>
    <div style="display:flex;gap:10px">
      <button class="btn btn-ghost small" id="refresh-btn" type="button">↻ Actualizar</button>
      <button class="btn btn-ghost small" id="logout-btn" type="button">Salir</button>
    </div>
  </div>

  <div class="tabs">
    <button class="tab active" data-tab="leads" type="button">📥 Leads <span class="pill" id="tab-leads-count">0</span></button>
    <button class="tab" data-tab="analytics" type="button">📊 Analytics</button>
  </div>

  <!-- ============ TAB: LEADS ============ -->
  <div id="tab-leads">
    <div class="kpis four">
      <div class="kpi"><div class="n" id="kl-total">–</div><div class="l">Leads totales</div></div>
      <div class="kpi"><div class="n" id="kl-week">–</div><div class="l">Últimos 7 días</div></div>
      <div class="kpi"><div class="n" id="kl-new">–</div><div class="l">Sin contactar</div></div>
      <div class="kpi"><div class="n" id="kl-ads">–</div><div class="l">Desde Google Ads (GCLID)</div></div>
    </div>
    <div class="panel">
      <div class="toolbar">
        <input type="search" id="lead-search" placeholder="Buscar por nombre, email o mensaje…" />
        <button class="fpill active" data-status="all" type="button">Todos</button>
        <button class="fpill" data-status="new" type="button">Nuevos</button>
        <button class="fpill" data-status="contacted" type="button">Contactados</button>
        <button class="fpill" data-status="won" type="button">Ganados</button>
        <button class="btn btn-primary small" id="export-csv" type="button">⬇ Export CSV</button>
      </div>
      <table class="dt">
        <thead><tr><th>Fecha</th><th>Contacto</th><th>Mensaje</th><th>Origen</th><th>Idioma</th><th>Google Ads</th><th>Estado</th></tr></thead>
        <tbody id="leads-body"></tbody>
      </table>
      <p class="muted-note" id="leads-empty" hidden>No hay leads que coincidan. Envía el formulario del sitio para testear.</p>
    </div>
  </div>

  <!-- ============ TAB: ANALYTICS ============ -->
  <div id="tab-analytics" hidden>
    <div class="kpis">
      <div class="kpi"><div class="n" id="ka-sessions">–</div><div class="l">Sesiones (visitantes)</div></div>
      <div class="kpi"><div class="n" id="ka-views">–</div><div class="l">Páginas vistas</div></div>
      <div class="kpi"><div class="n" id="ka-time">–</div><div class="l">Tiempo medio en página</div></div>
      <div class="kpi"><div class="n" id="ka-conv">–</div><div class="l">Leads (conversiones)</div></div>
      <div class="kpi"><div class="n" id="ka-rate">–</div><div class="l">Tasa de conversión</div></div>
    </div>

    <!-- Titulares automáticos: qué está funcionando -->
    <div class="insights" id="insights"></div>

    <div class="panel">
      <h2>Tráfico y leads por día <span class="count">(últimos 30 días)</span></h2>
      <div class="chart" id="daily-chart"></div>
      <div class="chart-labels"><span id="chart-from"></span><span id="chart-to"></span></div>
      <div class="chart-legend"><span><i class="s"></i>Sesiones</span><span><i class="c"></i>Leads</span></div>
    </div>

    <div class="grid-2">
      <div class="panel">
        <h2>¿Qué canales traen leads? <span class="count">(sesiones → leads)</span></h2>
        <div style="overflow-x:auto"><table class="perf"><thead><tr><th>Canal</th><th class="num">Sesiones</th><th class="num">Leads</th><th class="num">Conversión</th></tr></thead><tbody id="perf-channel"></tbody></table></div>
      </div>
      <div class="panel">
        <h2>¿Qué páginas convierten? <span class="count">(entrada → leads)</span></h2>
        <div style="overflow-x:auto"><table class="perf"><thead><tr><th>Página de entrada</th><th class="num">Sesiones</th><th class="num">Leads</th><th class="num">Conversión</th></tr></thead><tbody id="perf-landing"></tbody></table></div>
      </div>
    </div>

    <div class="panel">
      <h2>Páginas más vistas <span class="count">(visitas · cuánto se quedan)</span></h2>
      <div class="bars" id="bars-pages"></div>
    </div>

    <div class="grid-2">
      <div class="panel">
        <h2>Dispositivos <span class="count">(páginas vistas)</span></h2>
        <div class="bars" id="bars-device"></div>
      </div>
      <div class="panel">
        <h2>Idiomas del navegador <span class="count">(sesiones)</span></h2>
        <div class="bars" id="bars-lang"></div>
      </div>
    </div>

    <p class="muted-note">Video stats: <span id="ka-videos">–</span> registros. (El tracking de qué % de cada video se mira se conecta en una próxima etapa.)</p>
  </div>
</div>

<!-- ============ LEAD DETAIL MODAL ============ -->
<div class="lead-modal" id="lead-modal" aria-hidden="true" role="dialog" aria-modal="true">
  <div class="backdrop" data-close></div>
  <div class="lead-card">
    <button class="close" type="button" data-close aria-label="Cerrar">&times;</button>
    <h3 id="lm-name"></h3>
    <p class="email-line"><a id="lm-email" href="#"></a> · <span id="lm-date"></span></p>
    <div class="detail-grid" id="lm-details"></div>
    <div class="lead-msg" id="lm-message"></div>
    <div class="draft-head">
      <h4>✍️ <span>Borrador de respuesta</span> (editable — generado según lo que pide)</h4>
      <div style="display:flex;gap:8px">
        <button class="btn btn-ghost small" id="lm-ai" type="button" title="Sugerencia personalizada con IA">✨ IA</button>
        <button class="btn btn-ghost small" id="lm-copy" type="button">📋 Copiar</button>
        <a class="btn btn-primary small" id="lm-mailto" href="#">✉️ Abrir en tu correo</a>
      </div>
    </div>
    <textarea class="draft-box" id="lm-draft"></textarea>
    <div class="lead-actions">
      <div class="left">
        <span class="muted-note" id="lm-status-note"></span>
      </div>
      <button class="btn btn-danger small" id="lm-delete" type="button">🗑 Borrar lead</button>
    </div>
  </div>
</div>

<script>
  import { createClient } from '@supabase/supabase-js';

  /* misma URL + publishable key que usa el sitio (públicas por diseño);
     los datos solo se pueden LEER tras login gracias a las policies RLS */
  const supabase = createClient(
    'https://lumoevaotokgqnpybkyf.supabase.co',
    'sb_publishable_ORGL5_FNZTXcGKwvjs-ymw_Y8DV_4ca'
  );

  const $ = (id) => document.getElementById(id);
  const esc = (s) => String(s ?? '').replace(/[&<>"']/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  const fmtTime = (secs) => {
    if (!secs || secs <= 0) return '—';
    const m = Math.floor(secs / 60), s = Math.round(secs % 60);
    return m ? m + 'm ' + (s < 10 ? '0' : '') + s + 's' : s + 's';
  };
  const STATUSES = ['new', 'nuevo', 'contacted', 'contactado', 'qualified', 'won', 'cerrado', 'lost', 'perdido'];
  const THANKS = /^\/(thank-you|danke|gracias)\/?$/;
  let allLeads = [], statusFilter = 'all', searchTerm = '';

  function show(view){
    $('login-view').hidden = view !== 'login';
    $('dash-view').hidden = view !== 'dash';
  }

  /* ---------- Tabs ---------- */
  document.querySelectorAll('.tab').forEach((t) => {
    t.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach((x) => x.classList.toggle('active', x === t));
      $('tab-leads').hidden = t.dataset.tab !== 'leads';
      $('tab-analytics').hidden = t.dataset.tab !== 'analytics';
    });
  });

  /* ---------- Login ---------- */
  $('login-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const f = e.target;
    f.classList.remove('has-error');
    const { error } = await supabase.auth.signInWithPassword({
      email: f.email.value.trim(),
      password: f.password.value
    });
    if (error) { f.classList.add('has-error'); return; }
    show('dash');
    loadAll();
  });
  $('logout-btn').addEventListener('click', async () => {
    await supabase.auth.signOut();
    show('login');
  });
  $('refresh-btn').addEventListener('click', loadAll);

  /* ---------- Data ---------- */
  const DAYS = 30;
  const since = () => new Date(Date.now() - DAYS * 864e5).toISOString();

  async function loadAll(){
    const [leadsQ, viewsQ, videosQ] = await Promise.all([
      supabase.from('leads').select('*').order('created_at', { ascending: false }).limit(1000),
      supabase.from('pageviews')
        .select('created_at,path,device,session_id,channel,referrer,lang,is_entry,duration')
        .gte('created_at', since()).limit(20000),
      supabase.from('video_stats').select('id', { count: 'exact', head: true })
    ]);
    if (leadsQ.error || viewsQ.error) {
      alert('Error cargando datos: ' + (leadsQ.error || viewsQ.error).message);
      return;
    }
    allLeads = leadsQ.data || [];
    renderLeads();
    renderAnalytics(viewsQ.data || [], allLeads);
    $('ka-videos').textContent = videosQ.count ?? 0;
    $('updated-at').textContent = 'Últimos 30 días · actualizado ' + new Date().toLocaleTimeString('es-CH', { hour: '2-digit', minute: '2-digit' });
    subscribeRealtime();
  }

  /* ---------- Realtime: leads nuevos aparecen solos (gratis, sin polling) ---------- */
  let rtSubscribed = false;
  function subscribeRealtime(){
    if (rtSubscribed) return;
    rtSubscribed = true;
    supabase.channel('leads-live')
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'leads' }, (payload) => {
        const r = payload.new;
        if (allLeads.some((l) => l.id === r.id)) return;
        allLeads.unshift(r);
        renderLeads();
        toast('🎬 Nuevo lead: ' + (r.name || r.email));
      })
      .on('postgres_changes', { event: 'UPDATE', schema: 'public', table: 'leads' }, (payload) => {
        const i = allLeads.findIndex((l) => l.id === payload.new.id);
        if (i > -1) { allLeads[i] = payload.new; renderLeads(); }
      })
      .subscribe();
  }
  function toast(msg){
    let t = document.getElementById('dash-toast');
    if (!t) {
      t = document.createElement('div'); t.id = 'dash-toast';
      t.style.cssText = 'position:fixed;bottom:24px;right:24px;z-index:9999;background:var(--acid);color:#142033;font-weight:700;font-family:Space Grotesk;padding:14px 20px;border-radius:12px;box-shadow:0 12px 40px -10px rgba(0,0,0,.6);transition:.3s;opacity:0;transform:translateY(10px)';
      document.body.appendChild(t);
    }
    t.textContent = msg;
    requestAnimationFrame(() => { t.style.opacity = '1'; t.style.transform = 'none'; });
    clearTimeout(t._h);
    t._h = setTimeout(() => { t.style.opacity = '0'; t.style.transform = 'translateY(10px)'; }, 6000);
  }

  /* ---------- LEADS ---------- */
  const isNew = (s) => s === 'new' || s === 'nuevo';
  $('lead-search').addEventListener('input', (e) => { searchTerm = e.target.value.toLowerCase(); renderLeads(); });
  document.querySelectorAll('.toolbar .fpill').forEach((p) => {
    p.addEventListener('click', () => {
      document.querySelectorAll('.toolbar .fpill').forEach((x) => x.classList.toggle('active', x === p));
      statusFilter = p.dataset.status;
      renderLeads();
    });
  });

  function filteredLeads(){
    return allLeads.filter((r) => {
      if (statusFilter === 'new' && !isNew(r.status)) return false;
      if (statusFilter === 'contacted' && !(r.status === 'contacted' || r.status === 'contactado')) return false;
      if (statusFilter === 'won' && !(r.status === 'won' || r.status === 'cerrado')) return false;
      if (searchTerm) {
        const hay = ((r.name || '') + ' ' + (r.email || '') + ' ' + (r.message || '')).toLowerCase();
        if (hay.indexOf(searchTerm) === -1) return false;
      }
      return true;
    });
  }

  function renderLeads(){
    const week = Date.now() - 7 * 864e5;
    $('kl-total').textContent = allLeads.length;
    $('tab-leads-count').textContent = allLeads.filter((r) => isNew(r.status)).length;
    $('kl-week').textContent = allLeads.filter((r) => new Date(r.created_at) > week).length;
    $('kl-new').textContent = allLeads.filter((r) => isNew(r.status)).length;
    $('kl-ads').textContent = allLeads.filter((r) => r.gclid).length;

    const rows = filteredLeads();
    $('leads-empty').hidden = rows.length > 0;
    $('leads-body').innerHTML = rows.map((r) => {
      const d = new Date(r.created_at);
      const date = d.toLocaleDateString('es-CH', { day: '2-digit', month: 'short' }) +
        '<span class="sub">' + d.toLocaleTimeString('es-CH', { hour: '2-digit', minute: '2-digit' }) + '</span>';
      const contact = '<strong>' + esc(r.name || '—') + '</strong><span class="sub">' + esc(r.email) + '</span>';
      const ch = (r.channel ? '<span class="badge b-' + esc(r.channel) + '">' + esc(r.channel) + '</span>' : '—') +
        (r.landing_path ? '<span class="sub">' + esc(r.landing_path) + '</span>' : '');
      const ads = r.gclid
        ? '<span class="gclid-dot" title="' + esc(r.gclid) + '">✓ GCLID</span>' +
          (r.utm_campaign ? '<span class="sub">' + esc(r.utm_campaign) + '</span>' : '')
        : '—';
      const opts = STATUSES.map((s) => '<option value="' + s + '"' + (r.status === s ? ' selected' : '') + '>' + s + '</option>').join('');
      return '<tr data-id="' + r.id + '">' +
        '<td>' + date + '</td>' +
        '<td>' + contact + '</td>' +
        '<td class="msg" title="' + esc(r.message) + '">' + esc((r.message || '—').slice(0, 120)) + '</td>' +
        '<td>' + ch + '</td>' +
        '<td>' + esc(r.lang || '—').toUpperCase() + '</td>' +
        '<td>' + ads + '</td>' +
        '<td><select class="status">' + opts + '</select></td>' +
      '</tr>';
    }).join('');

    document.querySelectorAll('#leads-body select.status').forEach((sel) => {
      sel.addEventListener('click', (e) => e.stopPropagation());
      sel.addEventListener('change', async () => {
        const id = sel.closest('tr').dataset.id;
        const { error } = await supabase.from('leads').update({ status: sel.value }).eq('id', id);
        sel.style.borderColor = error ? '#ff9a9a' : 'var(--acid)';
        setTimeout(() => { sel.style.borderColor = ''; }, 1200);
        const lead = allLeads.find((l) => String(l.id) === id);
        if (lead && !error) lead.status = sel.value;
        renderLeads();
      });
    });
    /* click en la fila → detalle del lead */
    document.querySelectorAll('#leads-body tr').forEach((tr) => {
      tr.addEventListener('click', () => openLead(tr.dataset.id));
    });
  }

  /* ---------- Lead detail + draft de respuesta ---------- */
  const modal = $('lead-modal');
  let currentLead = null;

  const TOPICS = [
    { key: 'employer', re: /employer|recruit|talent|hiring|arbeitgeber|mitarbeiter|karriere|reclut|empleo|kultur|culture/i },
    { key: 'product',  re: /product|produkt|producto|launch|lancierung|lanzamiento|e-?com/i },
    { key: 'social',   re: /social|instagram|tiktok|linkedin|reels|shorts|redes/i },
    { key: 'event',    re: /event|keynote|kongress|congress|messe|evento|aftermovie|confer/i },
    { key: 'howto',    re: /tutorial|how.?to|explainer|erklär|explicativ|onboarding|schulung/i },
