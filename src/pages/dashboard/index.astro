  /* ---------- Insights con IA (Edge Function ai-insights → Claude) ---------- */
  // genérico: se usa en Analytics, Leads y Ofertas con distintos resúmenes
  async function runInsights(btnId, bodyId, buildSummary, loadingMsg){
    const btn = $(btnId), body = $(bodyId);
    const summary = buildSummary();
    if (!summary) { body.innerHTML = '<p class="muted-note">Todavía no hay datos suficientes.</p>'; return; }
    const prev = btn.textContent; btn.disabled = true; btn.textContent = '✨ Analizando…';
    body.innerHTML = '<p class="ai-loading">' + (loadingMsg || 'La IA está analizando tus datos…') + '</p>';
    try {
      const { data, error } = await supabase.functions.invoke('ai-insights', { body: { summary, lang: 'es' } });
      if (error || !data || !Array.isArray(data.insights)) throw new Error(data?.error || error?.message || 'sin respuesta');
      body.innerHTML = data.insights.map((i) =>
        '<div class="ai-insight"><span class="ico">' + esc(i.icon || '💡') + '</span>' +
        '<div class="txt"><h4>' + esc(i.title || '') + '</h4><p>' + esc(i.detail || '') + '</p></div></div>'
      ).join('') || '<p class="muted-note">La IA no devolvió sugerencias.</p>';
    } catch (e) {
      body.innerHTML = '<p class="muted-note">No se pudo generar (¿deployaste ai-insights y hay crédito en Anthropic?): ' + esc(e.message) + '</p>';
    } finally { btn.disabled = false; btn.textContent = prev; }
  }

  // resumen del funnel de leads (conversión + tiempos entre etapas)
  function leadsSummary(){
    const set = (allLeads || []).filter((l) => inRange(l.created_at) && !/^claude-/.test(l.session_id || ''));
    if (!set.length) return null;
    const steps = [
      { k: 'leads', ts: (l) => l.created_at }, { k: 'contactado', ts: (l) => l.contacted_at },
      { k: 'videocall', ts: (l) => l.videocall_at }, { k: 'propuesta', ts: (l) => l.proposal_at }, { k: 'ganado', ts: (l) => l.won_at },
    ];
    const counts = steps.map((s) => set.filter((l) => s.ts(l)).length);
    const avgDays = (a, b) => { const ds = set.map((l) => { const x = Date.parse(b(l)), y = Date.parse(a(l)); return (x && y && x >= y) ? (x - y) / 864e5 : null; }).filter((v) => v != null); return ds.length ? +(ds.reduce((p, c) => p + c, 0) / ds.length).toFixed(1) : null; };
    const chan = {}; set.forEach((l) => { const c = l.channel || 'direct'; chan[c] = (chan[c] || 0) + 1; });
    const lost = set.filter((l) => l.lost_at).length;
    return {
      contexto: 'Funnel de leads de Viven (productora de video). Conversión y días promedio entre etapas.',
      periodo: rangeLabel(),
      leads: counts[0], contactados: counts[1], video_calls: counts[2], propuestas: counts[3], ganados: counts[4], perdidos: lost,
      conv_lead_a_contactado_pct: counts[0] ? Math.round(counts[1] / counts[0] * 100) : 0,
      conv_contactado_a_videocall_pct: counts[1] ? Math.round(counts[2] / counts[1] * 100) : 0,
      conv_videocall_a_propuesta_pct: counts[2] ? Math.round(counts[3] / counts[2] * 100) : 0,
      conv_propuesta_a_ganado_pct: counts[3] ? Math.round(counts[4] / counts[3] * 100) : 0,
      cierre_ganado_sobre_decididos_pct: (counts[4] + lost) ? Math.round(counts[4] / (counts[4] + lost) * 100) : 0,
      dias_lead_a_contactado: avgDays((l) => l.created_at, (l) => l.contacted_at),
      dias_contactado_a_videocall: avgDays((l) => l.contacted_at, (l) => l.videocall_at),
      dias_videocall_a_propuesta: avgDays((l) => l.videocall_at, (l) => l.proposal_at),
      dias_propuesta_a_ganado: avgDays((l) => l.proposal_at, (l) => l.won_at),
      canales: chan,
      sin_contactar: set.filter((l) => isNew(l.status)).length,
    };
  }

  // resumen de ofertas (conversión, semanas para cerrar, margen)
  function offersSummary(){
    if (!offersList || !offersList.length) return null;
    const won = offersList.filter((o) => o.status === 'won'), lost = offersList.filter((o) => o.status === 'lost'), open = offersList.filter((o) => o.status === 'sent');
    const dec = won.length + lost.length;
    const margins = offersList.map(offerMarginPct).filter((m) => isFinite(m));
    const closeW = won.map((o) => (Date.parse(o.updated_at) - Date.parse(o.created_at)) / 6048e5).filter((d) => d >= 0);
    return {
      contexto: 'Ofertas/presupuestos de Viven (productora de video). Precio al cliente vs costo interno.',
      ofertas_totales: offersList.length, enviadas_esperando: open.length, ganadas: won.length, perdidas: lost.length,
      conversion_ganadas_sobre_decididas_pct: dec ? Math.round(won.length / dec * 100) : 0,
      semanas_promedio_para_cerrar: closeW.length ? +(closeW.reduce((a, b) => a + b, 0) / closeW.length).toFixed(1) : null,
      valor_ganado_neto_chf: Math.round(won.reduce((a, o) => a + offerNet(o), 0)),
      margen_medio_pct: margins.length ? Math.round(margins.reduce((a, b) => a + b, 0) / margins.length) : null,
      ticket_medio_ganado_chf: won.length ? Math.round(won.reduce((a, o) => a + offerNet(o), 0) / won.length) : null,
    };
  }

  /* Insights de Analytics: automáticos, 1 vez por día por navegador (cache en localStorage).
     El ↻ fuerza una regeneración; si el invoke falla, no se reintenta solo hasta recargar. */
  const AI_AUTO_LS = 'vv_ai_insights';
  let aiAutoTried = false;
  function renderAiCards(list){
    $('ai-insights-body').innerHTML = list.map((i) =>
      '<div class="ai-insight"><span class="ico">' + esc(i.icon || '💡') + '</span>' +
      '<div class="txt"><h4>' + esc(i.title || '') + '</h4><p>' + esc(i.detail || '') + '</p></div></div>'
    ).join('') || '<p class="muted-note">La IA no devolvió sugerencias.</p>';
  }
  async function autoInsights(force){
    const today = new Date().toISOString().slice(0, 10);
    // cache del día: render instantáneo, cero llamadas
    if (!force){
      try {
        const c = JSON.parse(localStorage.getItem(AI_AUTO_LS) || 'null');
        if (c && c.date === today && Array.isArray(c.insights)){ renderAiCards(c.insights); return; }
      } catch (e) { /* cache corrupto → regenerar */ }
      if (aiAutoTried) return; // ya falló hoy en esta sesión: no martillar la función
    }
    if (!insightsData) return;
    aiAutoTried = true;
    const btn = $('ai-insights-btn'), body = $('ai-insights-body');
    btn.disabled = true;
    body.innerHTML = '<p class="ai-loading">La IA está analizando tu tráfico, canales y conversión…</p>';
    try {
      const summary = { ...insightsData, ...leadsSummary(), contexto: 'Tráfico web + funnel de leads de Viven.' };
      const { data, error } = await supabase.functions.invoke('ai-insights', { body: { summary, lang: 'es' } });
      if (error || !data || !Array.isArray(data.insights)) throw new Error(data?.error || error?.message || 'sin respuesta');
      try { localStorage.setItem(AI_AUTO_LS, JSON.stringify({ date: today, insights: data.insights })); } catch (e) { /* sin espacio */ }
      renderAiCards(data.insights);
    } catch (e) {
      body.innerHTML = '<p class="muted-note">No se pudo generar (¿deployaste ai-insights y hay crédito en Anthropic?): ' + esc(e.message) + '</p>';
    } finally { btn.disabled = false; }
  }
  $('ai-insights-btn').addEventListener('click', () => autoInsights(true));
  $('ai-leads-btn').addEventListener('click', () => runInsights('ai-leads-btn', 'ai-leads-body', leadsSummary,
    'La IA está analizando tu funnel de leads…'));
  $('ai-offers-btn').addEventListener('click', () => runInsights('ai-offers-btn', 'ai-offers-body', offersSummary,
    'La IA está analizando tus ofertas…'));

  /* ---------- Data ---------- */
  /* ---------- Ventana de tiempo (filtro global) ---------- */
  let rangeDays = 30;      // preset: 1 / 7 / 30 / 90 / 365
  let rangeDay = null;     // 'YYYY-MM-DD' → un día puntual (pisa el preset)
  const rangeStart = () => rangeDay ? new Date(rangeDay + 'T00:00:00').getTime() : Date.now() - rangeDays * 864e5;
  const rangeEnd = () => rangeDay ? new Date(rangeDay + 'T23:59:59.999').getTime() : Date.now();
  const inRange = (d) => { const t = new Date(d).getTime(); return t >= rangeStart() && t <= rangeEnd(); };
  const rangeLabel = () => rangeDay
    ? new Date(rangeDay + 'T00:00:00').toLocaleDateString('es-CH', { day: '2-digit', month: 'long', year: 'numeric' })
    : (rangeDays === 1 ? 'Hoy' : 'Últimos ' + rangeDays + ' días');
  // nº de días que muestra el gráfico diario (acotado para que el SVG no explote)
  const rangeSpanDays = () => rangeDay ? 1 : rangeDays;
  const since = () => new Date(rangeStart()).toISOString();
  const until = () => new Date(rangeEnd()).toISOString();

  // Supabase/PostgREST cappea cada response a un máximo de filas (Max Rows del
  // proyecto) SIN avisar, aunque el cliente pida .limit(20000) — un .select()
  // sin paginar sobre una tabla que ya superó ese tope devuelve un subconjunto
  // arbitrario (no hay .order()) y todo lo que se cuenta desde ahí (sesiones,
  // canales, páginas) queda subestimado en silencio. Paginar con .range() +
  // .order() es la única forma de traer TODAS las filas del rango.
  // fix (auditoría de performance 2026-07-14): antes paginaba SECUENCIAL (una página
  // esperaba a la anterior) — con ventanas de 30d que superan las 1000 filas (pageviews
  // ronda 2800 totales), esto eran 2-3 round trips uno atrás del otro. En red móvil esto
  // fue justo la query más lenta de loadAll() (~2.6s vs ~400-800ms del resto) y frenaba
  // TODO el Promise.all. Ahora: 1 query liviana de count (head:true, sin filas) + todas
  // las páginas en paralelo — mismo resultado, sin la cascada secuencial.
  async function fetchAllRows(table, cols, sinceIso, untilIso, dateCol){
    dateCol = dateCol || 'created_at';
    const PAGE = 1000;
    // fix urgente (2026-07-14, hangeaba loadAll entero): .select() SIEMPRE primero —
    // .gte()/.lte() no existen en el QueryBuilder crudo de supabase.from(table), solo
    // en el FilterBuilder que devuelve .select(). Llamarlos antes tiraba un TypeError
    // sincrónico que async convertía en promesa rechazada, sin catch en loadAll() →
    // Promise.all entero colgado para siempre, sin error visible.
    const { count, error: countErr } = await supabase.from(table).select(cols, { count: 'exact', head: true })
      .gte(dateCol, sinceIso).lte(dateCol, untilIso);
    if (countErr) return { data: null, error: countErr };
    const total = Math.min(count || 0, 200000); // mismo salvavidas de siempre
    if (!total) return { data: [], error: null };
    const pages = Math.ceil(total / PAGE);
    const results = await Promise.all(Array.from({ length: pages }, (_, i) =>
      supabase.from(table).select(cols)
        .gte(dateCol, sinceIso).lte(dateCol, untilIso)
        .order(dateCol, { ascending: true })
        .range(i * PAGE, i * PAGE + PAGE - 1)
    ));
    const err = results.find((r) => r.error);
    if (err) return { data: null, error: err.error };
    return { data: results.flatMap((r) => r.data || []), error: null };
  }

  // ventana ANTERIOR de igual longitud: pageviews para los ▲▼ de KPIs y la línea punteada
  // del gráfico. Se trae UNA vez por corrida de loadAll (misma Promise.all) y queda cacheada
  // en módulo para los re-render intermedios (realtime, cambio de sub-tab).
  let prevViews = [];
  let prevWin = { start: 0, end: 0 };

  async function loadAll(){
    // límites congelados ACÁ (rangeStart usa Date.now — llamarlo dos veces derivaría ventanas distintas)
    const winStart = rangeStart(), winEnd = rangeEnd(), winLen = winEnd - winStart;
    prevWin = { start: winStart - winLen, end: winStart - 1 };
    const [leadsQ, viewsQ, videosQ, offersQ, coQ, notesQ, tasksQ, propsQ, dealsQ, bookQ, bookHistQ, prevQ] = await Promise.all([
      __perfTimed('q_leads', supabase.from('leads').select('*').order('created_at', { ascending: false }).limit(2000)),
      __perfTimed('q_pageviews', fetchAllRows('pageviews', 'created_at,path,device,session_id,channel,referrer,lang,is_entry,duration', since(), until())),
      __perfTimed('q_videoplays', fetchAllRows('video_plays', '*', since(), until())),
      __perfTimed('q_offers', supabase.from('offers').select('*').order('updated_at', { ascending: false })),
      __perfTimed('q_companies', supabase.from('companies').select('*')),
      // para "última actividad" (best-effort: si faltan las tablas, queda vacío)
      __perfTimed('q_notes', supabase.from('lead_notes').select('lead_id,created_at').order('created_at', { ascending: false }).limit(1000)),
      __perfTimed('q_tasks', supabase.from('lead_tasks').select('lead_id,created_at,done_at').order('created_at', { ascending: false }).limit(1000)),
      __perfTimed('q_proposals', supabase.from('proposals').select('*').limit(1000)),
      __perfTimed('q_deals', supabase.from('deals').select('*').order('created_at', { ascending: false })),
      __perfTimed('q_bookings', supabase.from('bookings').select('*').gte('start_at', new Date().toISOString()).eq('status', 'confirmed').order('start_at').limit(8)),
      // histórico 30d (pedido explícito: trackear video calls booked por persona) — created_at
      // = cuándo se hizo la reserva, no cuándo es la call, así cuenta "booked" de verdad
      __perfTimed('q_bookingshist', supabase.from('bookings').select('host_email,created_at').gte('created_at', new Date(Date.now() - 30 * 864e5).toISOString())),
      // ventana anterior (solo columnas que usan los comparativos)
      __perfTimed('q_prevviews', fetchAllRows('pageviews', 'created_at,session_id,duration', new Date(winStart - winLen).toISOString(), new Date(winStart - 1).toISOString()))
    ]);
    __perfMark('queries_done');
    if (leadsQ.error || viewsQ.error) {
      alert('Error cargando datos: ' + (leadsQ.error || viewsQ.error).message);
      return;
    }
    allLeads = leadsQ.data || [];
    window.__vvLoadedAt = Date.now();
    lastViews = viewsQ.data || [];
    prevViews = (prevQ && !prevQ.error) ? (prevQ.data || []) : [];
    // ofertas: best-effort (si no corrió el SQL 0003 todavía, seguimos sin romper el dashboard)
    if (offersQ && !offersQ.error) offersList = offersQ.data || [];
    // DEALS (SQL 0022): la entidad REAL del pipeline (varios proyectos por persona).
    // Sin la tabla → 1 deal sintético por persona (modo legado, mismo comportamiento).
    upBookings = (bookQ && !bookQ.error) ? (bookQ.data || []) : [];
    bookingsHist = (bookHistQ && !bookHistQ.error) ? (bookHistQ.data || []) : [];
    dealsReal = !!(dealsQ && !dealsQ.error);
    dealsList = dealsReal ? (dealsQ.data || []) : [];
    const _withDeal = new Set(dealsList.map((d) => String(d.lead_id)));
