  function openLead(id){ if (ficha2On()) openLeadV2(id); else openLeadClassic(id); }
  function openLeadClassic(id){
    const r = allLeads.find((l) => String(l.id) === String(id));
    if (!r) return;
    currentLead = r;
    // empresa: nombre editable (companies) o derivado del dominio del email (como HubSpot)
    const ldom = leadDomain(r);
