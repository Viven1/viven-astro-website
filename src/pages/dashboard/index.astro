  async function abAnalyze(){
    let u = $('ab-url').value.trim();
    if (!u){ toast('Pegá la URL de la página'); return; }
    // vale cualquier forma: https://viven.ch/en/..., viven.ch/en/... o /en/... a secas
    if (!/^https?:\/\//i.test(u) && !u.startsWith('/')) u = 'https://' + u;
    let path;
    try { path = u.startsWith('/') ? u : new URL(u).pathname; } catch (e) { toast('URL inválida'); return; }
    if (!path.endsWith('/')) path += '/';
    $('ab-wiz-note').textContent = 'Analizando ' + path + '…';
    try {
      const res = await fetch(path, { headers: { Accept: 'text/html' } });
      if (!res.ok) throw new Error('HTTP ' + res.status + ' — ¿la página existe en este dominio?');
      const doc = new DOMParser().parseFromString(await res.text(), 'text/html');
      // páginas trilingües: el HTML trae EN + data-de/data-es — aplicamos el idioma REAL de la URL
      const plang = (path.match(/^\/(en|de|es)\//) || [])[1];
      if (plang && plang !== 'en') doc.querySelectorAll('[data-' + plang + ']').forEach((el) => { const t = el.getAttribute('data-' + plang); if (t) el.textContent = t; });
      abCands = [];
      const seen = new Set();
      // el selector nth-of-type asegura que site.js apunte al MISMO nodo (sel + idx dentro del sel)
      const push = (group, label, sel, idx, type, val, name) => {
        const v = String(val || '').trim(); if (!v) return;
        const key = sel + '#' + idx + '#' + type + '#' + (name || '');
        if (seen.has(key)) return; seen.add(key);
        abCands.push({ group, label, sel, idx, type, name: name || null, from: v });
      };
      // índice de un nodo entre todos los que matchean su selector (para {sel, idx})
      const idxOf = (sel, el) => { const all = [...doc.querySelectorAll(sel)]; return Math.max(0, all.indexOf(el)); };
      // ---- HERO ----
      const h1 = doc.querySelector('h1'); if (h1) push('Hero', 'H1', 'h1', 0, 'text', h1.textContent);
      const ld = doc.querySelector('.page-hero .lead') || doc.querySelector('.hero .lead') || doc.querySelector('.lead');
      if (ld){ const lsel = ld.closest('.page-hero') ? '.page-hero .lead' : (ld.closest('.hero') ? '.hero .lead' : '.lead'); push('Hero', 'Lead del hero', lsel, idxOf(lsel, ld), 'text', ld.textContent); }
      const hb = doc.querySelector('.hero-bg[data-mp4]'); if (hb) push('Hero', 'Video del hero (mp4)', '.hero-bg', idxOf('.hero-bg', hb), 'attr', hb.getAttribute('data-mp4'), 'data-mp4');
      // ---- SECCIONES: H2s, párrafos lead/intro de sección, títulos de cards ----
      doc.querySelectorAll('h2').forEach((h) => { const el = h; push('Secciones', 'H2 · ' + (el.textContent || '').trim().slice(0, 40), 'h2', idxOf('h2', el), 'text', el.textContent); });
      doc.querySelectorAll('section .lead, .section .lead, section > p.intro, .section-intro').forEach((p) => {
        if (p.closest('.page-hero') || p.closest('.hero')) return;
        const sel = p.classList.contains('lead') ? 'section .lead' : (p.classList.contains('intro') ? 'section > p.intro' : '.section-intro');
        push('Secciones', 'Párrafo de sección', sel, idxOf(sel, p), 'text', p.textContent);
      });
      doc.querySelectorAll('h3').forEach((h) => { const el = h; push('Secciones', 'Título card · ' + (el.textContent || '').trim().slice(0, 32), 'h3', idxOf('h3', el), 'text', el.textContent); });
      // ---- CTAs de TODA la página: botones + links de acción prominentes ----
      const ctaSel = 'a.btn-primary, a.btn-ghost, .btn-primary, .btn-secondary, a.cta, .cta-banner a';
      doc.querySelectorAll(ctaSel).forEach((b2) => {
        const txt = (b2.textContent || '').trim(); if (!txt) return;
        // selector estable por tag+clase principal
        const tag = b2.tagName.toLowerCase();
        const cls = b2.classList.contains('btn-primary') ? '.btn-primary' : b2.classList.contains('btn-ghost') ? '.btn-ghost' : b2.classList.contains('btn-secondary') ? '.btn-secondary' : b2.classList.contains('cta') ? '.cta' : tag;
        const sel = cls.startsWith('.') ? cls : tag;
        push('CTAs', 'CTA · ' + txt.slice(0, 34), sel, idxOf(sel, b2), 'text', txt);
      });
      // ---- IMÁGENES de secciones (swap por otra del pool) ----
      doc.querySelectorAll('main img[src], section img[src], .section img[src]').forEach((im) => {
        const src = im.getAttribute('src') || ''; if (!src || src.startsWith('data:')) return;
        const sel = 'img[src="' + src + '"]';
        push('Imágenes', 'Imagen · ' + (src.split('/').pop() || '').slice(0, 30), sel, 0, 'src', src);
      });
      if (!abCands.length) throw new Error('No encontré elementos editables en esa página.');
      // render agrupado por sección — el índice global data-i se mantiene para abSave/abIdeas
      const groups = ['Hero', 'Secciones', 'CTAs', 'Imágenes'];
      let html = '';
      groups.forEach((g) => {
        const items = abCands.map((c, i) => ({ c, i })).filter((x) => x.c.group === g);
        if (!items.length) return;
        html += '<div class="ab-candgrp">' + esc(g) + '<span class="cnt">' + items.length + '</span></div>';
        html += items.map(({ c, i }) =>
          '<div class="ab-cand" data-i="' + i + '"><div class="k">' + esc(c.label) + '</div>' +
          '<div class="orig">' + esc(c.from.slice(0, 220)) + '</div>' +
          '<textarea data-i="' + i + '" placeholder="Versión B (vacío = sin cambio)"></textarea></div>').join('');
      });
      $('ab-cands').innerHTML = html;
      $('ab-cands').querySelectorAll('textarea').forEach((t2) => t2.addEventListener('input', () => { t2.closest('.ab-cand').classList.toggle('changed', !!t2.value.trim()); }));
      abEditing = { url_path: path };
      $('ab-editor').hidden = false;
      $('ab-ideas-box').hidden = true; $('ab-ideas-box').innerHTML = '';
      $('ab-wiz-note').textContent = '✓ ' + abCands.length + ' elementos encontrados. Editá los que quieras testear.';
      if (!$('ab-name').value || /^Test \//.test($('ab-name').value)) $('ab-name').value = 'Test ' + path;
    } catch (e) { $('ab-wiz-note').textContent = '⚠️ ' + (e.message || e); }
  }
