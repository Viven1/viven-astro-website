  /* ---- mapa de bloques: click = ir al panel · ⏻ = on/off · ⠿ drag = reordenar ---- */
  let ppActiveBlock = null;
  function renderPropBlocks(){
    const box = $('pp3-blocks'); if (!box || !ppCur) return;
    ppCur.block_order = ppNormOrder(ppCur.block_order);
    const off = new Set(ppCur.blocks_off || []);
    box.innerHTML = ppCur.block_order.map((k) => {
      const n = k === 'tiers' ? ' (' + (ppCur.tiers || []).length + ')' : k === 'addons' ? ' (' + (ppCur.addons || []).length + ')' : k === 'videos' ? ' (' + (ppCur.videos || []).length + ')' : '';
      return '<div class="pp3-b' + (off.has(k) ? ' off' : '') + (k === ppActiveBlock ? ' act' : '') + '" data-bk="' + k + '">' +
        '<span class="pp3-h" title="Arrastrá para reordenar">⠿</span><span class="pp3-bl">' + ppBlockLabel(k) + n + '</span>' +
        '<button class="pp3-tgl" type="button" title="' + (off.has(k) ? 'Encender bloque' : 'Apagar bloque (no sale en la propuesta)') + '">' + (off.has(k) ? '◯' : '⏻') + '</button></div>';
    }).join('');
    applyBlockDim();
    box.querySelectorAll('.pp3-b').forEach((el) => {
      const k = el.dataset.bk;
      el.addEventListener('click', (e) => {
        if (e.target.closest('.pp3-tgl') || e.target.closest('.pp3-h')) return;
        ppActiveBlock = k;
        box.querySelectorAll('.pp3-b').forEach((x) => x.classList.toggle('act', x === el));
        const panel = document.querySelector('.pp3-blk[data-pblock="' + k + '"]');
        if (panel) panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
      el.querySelector('.pp3-tgl').addEventListener('click', () => {
        const s = new Set(ppCur.blocks_off || []);
        s.has(k) ? s.delete(k) : s.add(k);
        ppCur.blocks_off = [...s];
        renderPropBlocks(); ppMarkDirty();
      });
      // drag para reordenar (pointer events, como el board de deals): agarra del ⠿
      el.querySelector('.pp3-h').addEventListener('pointerdown', (e) => {
        e.preventDefault();
        el.classList.add('drag');
        el.setPointerCapture && el.querySelector('.pp3-h').setPointerCapture(e.pointerId);
        const move = (ev) => {
          const under = document.elementFromPoint(ev.clientX, ev.clientY);
          const over = under && under.closest && under.closest('.pp3-b');
          if (!over || over === el || over.parentElement !== box) return;
          const r = over.getBoundingClientRect();
          const horizontal = getComputedStyle(box).flexDirection === 'row' || box.scrollWidth > box.clientWidth + 4;
          const before = horizontal ? ev.clientX < r.left + r.width / 2 : ev.clientY < r.top + r.height / 2;
          box.insertBefore(el, before ? over : over.nextSibling);
        };
        const up = () => {
          document.removeEventListener('pointermove', move);
          document.removeEventListener('pointerup', up);
          el.classList.remove('drag');
          const order = [...box.querySelectorAll('.pp3-b')].map((x) => x.dataset.bk);
          if (order.join() !== (ppCur.block_order || []).join()){
            ppCur.block_order = ppNormOrder(order);
            renderPropBlocks(); ppMarkDirty();
          }
        };
        document.addEventListener('pointermove', move);
        document.addEventListener('pointerup', up);
      });
    });
  }
