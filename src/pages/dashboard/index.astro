      (roas >= 1 ? 'Cada franco invertido volvió ×' + roas.toFixed(1) + ' ✓' : 'Cada franco invertido volvió ×' + roas.toFixed(1) + ' ✗ — todavía no se recupera') + '</div>';
  }

  // pageviews de 60 días (solo created_at): UNA vez por ciclo, TTL 10 min — alimenta sparkline y KPI visitas
  async function hmFetchWeeks(){
    if (hmViews60Busy || (hmViews60 && Date.now() - hmViews60At < 6e5)) return;
    hmViews60Busy = true;
    try {
      const { data, error } = await fetchAllRows('pageviews', 'created_at', new Date(Date.now() - 60 * 864e5).toISOString(), new Date().toISOString());
      if (!error && data){ hmViews60 = data; hmViews60At = Date.now(); if (!$('tab-hoy').hidden) renderHome(); }
    } catch (e) { /* best-effort */ }
    finally { hmViews60Busy = false; }
  }

  // gasto de Ads: gads-stats UNA vez por día por navegador (cache en localStorage) + fallback manual
  async function hmFetchAds(){
    const today = new Date().toISOString().slice(0, 10);
    if (hmAds && hmAds.date === today) return;
    try {
      const c = JSON.parse(localStorage.getItem(HM_ADS_LS) || 'null');
      if (c && c.date === today){ hmAds = c; if (!$('tab-hoy').hidden) renderHome(); return; }
    } catch (e) { /* cache corrupto → refetch */ }
    if (hmAdsBusy) return;
    hmAdsBusy = true;
    let spend = 0, official = false;
    try { const { data: gs } = await supabase.functions.invoke('gads-stats', { body: { days: 30 } }); if (gs && gs.ok){ spend = Math.round(gs.total.cost); official = true; } } catch (e) { /* función no deployada / token pendiente */ }
    // mismos fallbacks que el tab de Ads: inversión manual (ads_settings → localStorage)
    if (!spend){ try { const { data: st } = await supabase.from('ads_settings').select('spend').eq('id', 1).maybeSingle(); spend = +((st || {}).spend || 0); } catch (e) { /* tabla pendiente (SQL 0037) */ } }
    if (!spend) spend = +(localStorage.getItem('vv_ads_spend') || 0);
    hmAds = { date: today, spend, official };
    try { localStorage.setItem(HM_ADS_LS, JSON.stringify(hmAds)); } catch (e) { /* sin espacio */ }
    hmAdsBusy = false;
    if (!$('tab-hoy').hidden) renderHome();
  }

  // resumen IA del día: 1 invoke por día por navegador (cache vv_home_ai) — ↻ regenera
  function hmAiRender(i){
    $('hm-ai').innerHTML = '<div class="ai-insight"><span class="ico">' + esc(i.icon || '🪄') + '</span>' +
      '<div class="txt"><h4>' + esc(i.title || '') + '</h4><p>' + esc(i.detail || '') + '</p></div></div>';
  }
  function hmAiSummary(){
    const k = hmDealKpis();
    const ads = hmAdsStats();
    const spend = hmAds ? (+hmAds.spend || 0) : 0;
    return {
      contexto: 'Arranque del día en Viven (productora de video, Zúrich). Con estos pendientes, señales de compra y KPIs, devolvé UNA sola prioridad del día, concreta y accionable, en 2 líneas máximo, en español.',
      fecha: new Date().toISOString().slice(0, 10),
      para_hoy: hmTodayItems().slice(0, 8).map((i) => i.t + ' — ' + i.ctx),
      senales_calientes: hmSignalItems().slice(0, 6).map((s) => s.plain),
