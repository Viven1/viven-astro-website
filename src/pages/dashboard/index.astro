  function bindOffers(){
    $('of-new').addEventListener('click', newOffer);
    $('of-back').addEventListener('click', () => showEditor(false));
    $('of-add-blank').addEventListener('click', () => { ofCur.items.push({ name: '', phase: 'Production', qty: 1, unit: 'Tag', price: 0, cost: 0 }); renderRows(); });
    $('of-add-preset').addEventListener('click', () => {
      const [ph, idx] = $('of-preset').value.split('::'); const p = CATALOG()[ph][+idx];
      ofCur.items.push({ name: p.name, phase: ph, qty: 1, unit: p.unit, price: p.price, cost: p.cost }); renderRows();
    });
    $('of-vat').addEventListener('input', () => { ofCur.vat_rate = parseFloat($('of-vat').value) || 0; recalc(); });
    $('of-disc').addEventListener('input', () => { ofCur.discount_pct = parseFloat($('of-disc').value) || 0; recalc(); });
    $('of-status').addEventListener('change', () => {
      ofCur.status = $('of-status').value;
      // al marcar Perdida a mano, registrar el motivo (queda grabado al guardar)
      if (ofCur.status === 'lost') {
        const rz = prompt('¿Por qué se perdió esta oferta? (opcional)', ofCur.lost_reason || '');
        if (rz !== null) ofCur.lost_reason = rz || null;
      }
      showLostNote('of-lostr', ofCur.lost_reason || leadLostReason(ofCur.lead_id), ofCur.status === 'lost');
      refreshInvoiceBtn();   // marcar Ganada acá mismo tiene que mostrar el botón de factura sin tener que cerrar y reabrir
    });
    $('of-lead').addEventListener('change', () => { ofCur.lead_id = $('of-lead').value || null; prefillInquiry(true); prefillClientBlock(); });
    $('of-ai-gen').addEventListener('click', generateOfferAI);
