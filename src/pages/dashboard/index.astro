  /* ── Combobox buscable para "ligar a lead/cliente" (hoy son pocos, mañana un montón) ──
     Envuelve el <select> existente SIN tocar la lógica: el select queda oculto pero sigue
     siendo la fuente de verdad (.value, innerHTML = leadOptions(...), eventos change).
     Un MutationObserver sincroniza el picker cuando el código re-llena el select. */
  function leadPicker(sel, opts){
    if (!sel || sel.dataset.lp) return; sel.dataset.lp = '1';
    const poolFn = (opts && opts.pool) || (() => allLeads || []);
    sel.style.display = 'none';
    const box = document.createElement('div'); box.className = 'lp-box';
    box.innerHTML = '<div class="lp-chip" hidden><span class="lp-chip-t"></span><button type="button" class="lp-x" title="Desligar">✕</button></div>' +
      '<input class="lp-in" type="text" placeholder="Buscar persona… (nombre, empresa o email)" autocomplete="off" />' +
      '<div class="lp-dd" hidden></div>';
    sel.after(box);
    const chip = box.querySelector('.lp-chip'), chipT = box.querySelector('.lp-chip-t'), inp = box.querySelector('.lp-in'), dd = box.querySelector('.lp-dd');
    const norm = (s) => String(s || '').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
    const rowOf = (l) => ({ id: String(l.id), name: l.name || l.email || '(sin nombre)', company: l.company || '', email: l.email || '', status: l.status || '' });
    let results = [], hi = -1, serverT = null;
    const setVal = (id) => {
      if (id && ![...sel.options].some((o) => String(o.value) === String(id))){
        const l = (allLeads || []).find((x) => String(x.id) === String(id)) || results.find((r) => r.id === String(id));
        const o = document.createElement('option'); o.value = id; o.textContent = l ? (l.name || l.email || id) : id; sel.appendChild(o);
      }
      sel.value = id || '';
      sel.dispatchEvent(new Event('change', { bubbles: true }));
      sync();
    };
    const sync = () => {
      const id = sel.value;
      const l = (allLeads || []).find((x) => String(x.id) === String(id));
      chip.hidden = !id; inp.hidden = !!id;
      if (id) chipT.textContent = l ? ((l.name || l.email || id) + (l.company ? ' — ' + l.company : '')) : ((sel.selectedOptions[0] || {}).textContent || id);
      else inp.value = '';
      dd.hidden = true;
    };
    const paint = () => {
      hi = Math.min(hi, results.length - 1);
      dd.innerHTML = results.length
        ? results.map((r, i) => '<button type="button" class="lp-r' + (i === hi ? ' hi' : '') + '" data-id="' + esc(r.id) + '"><b>' + esc(r.name) + '</b>' + (r.company ? ' <span class="lp-co">— ' + esc(r.company) + '</span>' : '') + '<span class="lp-sub">' + esc(r.email) + (r.status ? ' · <i>' + esc(r.status) + '</i>' : '') + '</span></button>').join('')
        : '<div class="lp-none">Sin resultados</div>';
      dd.hidden = false;
      dd.querySelectorAll('.lp-r').forEach((b) => b.addEventListener('click', () => setVal(b.dataset.id)));
    };
    const search = (q) => {
      const nq = norm(q);
      const pool = (poolFn() || []).filter((l) => !l.is_template);
      if (pool.length){
        results = pool.filter((l) => norm((l.name || '') + ' ' + (l.company || '') + ' ' + (l.email || '')).includes(nq)).slice(0, 8).map(rowOf);
        hi = results.length ? 0 : -1; paint();
      } else {
        // sin leads en memoria todavía: búsqueda server-side (ilike sobre nombre/email/empresa)
        clearTimeout(serverT);
        serverT = setTimeout(async () => {
          try {
            const safe = q.replace(/[%,()]/g, '');
            const { data } = await supabase.from('leads').select('id,name,company,email,status')
              .or('name.ilike.%' + safe + '%,email.ilike.%' + safe + '%,company.ilike.%' + safe + '%').limit(8);
            results = (data || []).map(rowOf); hi = results.length ? 0 : -1; paint();
          } catch (e) { results = []; paint(); }
        }, 250);
      }
    };
    inp.addEventListener('input', () => { const q = inp.value.trim(); if (!q){ dd.hidden = true; return; } search(q); });
    inp.addEventListener('focus', () => { if (inp.value.trim()) search(inp.value.trim()); });
    inp.addEventListener('keydown', (e) => {
      if (dd.hidden) return;
      if (e.key === 'ArrowDown'){ e.preventDefault(); hi = Math.min(hi + 1, results.length - 1); paint(); }
      else if (e.key === 'ArrowUp'){ e.preventDefault(); hi = Math.max(hi - 1, 0); paint(); }
      else if (e.key === 'Enter'){ e.preventDefault(); if (hi >= 0 && results[hi]) setVal(results[hi].id); }
      else if (e.key === 'Escape'){ dd.hidden = true; }
    });
    box.querySelector('.lp-x').addEventListener('click', () => setVal(''));
    document.addEventListener('click', (e) => { if (!box.contains(e.target)) dd.hidden = true; });
    new MutationObserver(sync).observe(sel, { childList: true, attributes: true, subtree: true });
    sync();
  }
  function fillEditor(){
