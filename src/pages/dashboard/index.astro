  async function abSave(status){
    if (!abEditing){ toast('Analizá una página primero'); return; }
    const changes = [];
    $('ab-cands').querySelectorAll('textarea').forEach((t3) => {
      const v = t3.value.trim(); if (!v) return;
      const c = abCands[+t3.dataset.i];
      if (v === c.from) return;
      changes.push({ sel: c.sel, idx: c.idx, type: c.type, name: c.name || undefined, from: c.from, to: v });
    });
    if (!changes.length){ toast('No cambiaste ningún elemento — la variante B sería idéntica'); return; }
    const row = {
      name: $('ab-name').value.trim() || null, url_path: abEditing.url_path, status,
      split_pct: Math.min(95, Math.max(5, parseFloat($('ab-split').value) || 50)), changes,
      start_at: $('ab-start').value ? new Date($('ab-start').value).toISOString() : null,
      end_at: $('ab-end').value ? new Date($('ab-end').value + 'T23:59:59').toISOString() : null,
    };
    const { error } = await supabase.from('ab_tests').insert(row);
    if (error){ toast('No se pudo guardar (¿SQL 0030?): ' + error.message); return; }
    $('ab-wiz').hidden = true;
    toast(status === 'running' ? '🧪 Test corriendo — el sitio ya reparte el tráfico' : '💾 Test guardado como borrador');
    abLoad();
  }

  /* ================= SERVICIOS: catálogo de precios editable =================
     Tabla services (SQL 0025). Si no existe o está vacía → RATECARD hardcodeado.
     El catálogo de las ofertas sale SIEMPRE de acá (CATALOG). */
  let servicesList = [], servicesBuilt = false;
  const CATALOG = () => {
    const act = (servicesList || []).filter((x) => x.active !== false);
    if (!act.length) return RATECARD;
    const m = {};
    PHASES.forEach((p) => { m[p] = []; });
    act.forEach((x) => {
      const ph = PHASES.includes(x.phase) ? x.phase : 'Production';
      m[ph].push({ name: x.name || '', unit: x.unit || 'Fix', price: Number(x.price) || 0, cost: Number(x.cost) || 0 });
    });
    Object.keys(m).forEach((k) => { if (!m[k].length) delete m[k]; });
    return m;
  };
  async function servicesLoad(){
    const { data, error } = await supabase.from('services').select('*').order('phase').order('sort').order('id');
    if (error){ servicesList = []; return { error }; }
    servicesList = data || [];
    return {};
  }
