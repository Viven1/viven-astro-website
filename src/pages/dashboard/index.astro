  /* ── slice verde: capa de lectura de performance por workflow (fila resumen + A/B mide + franja de pasos) ──
     Prefijo wfp- para no colisionar. Reusa vars/grammar del dashboard (no los colores dark del mockup). */
  .wfp{padding:0 18px 13px;display:flex;flex-direction:column;gap:10px}
  .wfp-sum{display:flex;flex-wrap:wrap;gap:7px}
  .wfp-chip{display:inline-flex;align-items:center;gap:5px;font-size:11.5px;color:var(--muted);background:var(--navy-900);border:1px solid var(--line);border-radius:20px;padding:3px 10px;white-space:nowrap}
  .wfp-chip b{color:var(--text);font-weight:700}
  .wfp-chip.win{border-color:rgba(126,217,87,.45);color:#7ed957}
  .wfp-chip.win b{color:#7ed957}
  .wfp-empty{font-size:11.5px;color:var(--muted-2)}
  .wfp-note{font-size:10.5px;color:var(--muted-2);font-style:italic;line-height:1.4}
  .wfp-steps{display:flex;gap:6px;overflow-x:auto;padding-bottom:3px}
  .wfp-step{flex:0 0 auto;min-width:112px;border:1px solid var(--line);border-radius:10px;background:var(--navy-900);padding:7px 10px}
  .wfp-step .t{font-size:11px;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:150px}
  .wfp-step .n{font-size:10px;color:var(--muted-2);margin-top:3px}
  .wfp-step .n b{color:var(--text);font-family:'Space Grotesk';font-size:12px}
  .wfp-arrow{align-self:center;color:var(--muted-2);flex:none;font-size:11px}
  .wfp-ab{border:1px solid var(--line);border-radius:11px;padding:10px 12px;background:var(--navy-900)}
  .wfp-ab-grid{display:flex;gap:10px;flex-wrap:wrap}
  .wfp-var{flex:1;min-width:160px;border:1px solid var(--line);border-radius:9px;padding:8px 10px}
  .wfp-var.win{border-color:rgba(126,217,87,.5);background:rgba(126,217,87,.06)}
  .wfp-var .k{font-size:10.5px;font-weight:800;letter-spacing:.4px;color:var(--muted-2)}
  .wfp-var .nums{display:flex;gap:11px;margin-top:5px;font-size:10px;color:var(--muted-2);flex-wrap:wrap}
  .wfp-var .nums b{display:block;color:var(--text);font-family:'Space Grotesk';font-size:13px}
  .wfp-verdict{margin-top:9px;font-size:11.5px;color:var(--muted);display:flex;align-items:center;gap:8px}
  .wfp-verdict .conf{font-family:'Space Grotesk';font-weight:700;flex:none}
