  // refresh silencioso desde loadAll: nunca pisa una edición inline ni texto a medio escribir
  function co3SafeRefresh(){
    if (!co3Modal.classList.contains('open') || !co3Cur) return;
    if (co3Modal.querySelector('#co3-l input, #co3-l select')) return;
    const typed = [...co3Modal.querySelectorAll('#co3-r textarea, #co3-r input[type="text"], #co3-tl textarea')].some((t) => (t.value || '').trim());
    if (typed) return;
    co3Open(co3Cur, true);
  }

  function co3Open(domain, isRefresh){
