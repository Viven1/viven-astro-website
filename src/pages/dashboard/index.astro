    const delBtn = $('co3-del-btn'); if (delBtn) delBtn.onclick = async () => { await deleteCompany(); if (!coCur) co3Close(); };
    $('co3-back').addEventListener('click', () => { co3Close(); gotoTab('companies'); });
    $('co3-nav-prev') && $('co3-nav-prev').addEventListener('click', () => oi > 0 && co3Open(order[oi - 1]));
    $('co3-nav-next') && $('co3-nav-next').addEventListener('click', () => oi < order.length - 1 && co3Open(order[oi + 1]));
    // popover compartido (➕ Crear / ⋯) — mismo patrón que lm2Menu
    const menu = $('co3-menu');
    function co3Menu(html, wire){
