    else if (st.type === 'ai_email') fields = '<label>Sale de</label>' + F(st.from) + '<div class="au-field-wrap"><label>Instrucción para la IA (usa el contexto real del contacto y escribe en su idioma) <button type="button" class="au-fs-toggle" data-act="fs">⤢ Expandir</button></label><textarea class="f-prompt">' + esc(st.prompt || '') + '</textarea></div><p class="muted-note" style="margin-top:6px">No se envía solo: cae en 📤 Bandeja para tu aprobación.</p>';
    else if (st.type === 'wait') fields = '<label>Días</label><input class="f-days" type="number" min="0" value="' + (+st.days || 1) + '" />';
    else if (st.type === 'task' || st.type === 'push') fields = '<label>Texto</label><input class="f-title" value="' + esc(st.title || '') + '" />';
    else fields = '<label>Nueva etapa</label><select class="f-status"><option value="contactado"' + (st.value === 'contactado' ? ' selected' : '') + '>Contactado</option><option value="propuesta"' + (st.value === 'propuesta' ? ' selected' : '') + '>Propuesta</option><option value="perdido"' + (st.value === 'perdido' ? ' selected' : '') + '>Perdido</option></select>';
    return '<div class="au-node" draggable="true" data-v="' + v + '" data-i="' + i + '" data-type="' + st.type + '">' +
      '<div class="au-node-h"><span class="au-drag" title="Arrastrar para reordenar">⠿</span><span class="au-node-ic">' + m.ic + '</span>' +
      '<div class="au-node-tt"><span class="au-tag">' + m.tag + '</span><span class="au-node-sum">' + auStepSummary(st) + '</span></div>' +
      '<button class="au-node-btn" data-act="edit" title="Editar">✏️</button><button class="au-node-btn" data-act="dup" title="Duplicar">📋</button><button class="au-node-btn" data-act="del" title="Borrar">🗑</button></div>' +
