  // resuelve el texto de "Empresa" a {domain,name,existing}: conecta con una existente o crea una nueva
  // (usado por la edición inline de la V2 — lm2RenderLeft — y por Empresa/co3)
  function resolveCompany(text, email){
    const name = (text || '').trim();
    const known = [...companiesData().map((c) => ({ domain: c.domain, name: c.name })), ...Object.values(coMeta).map((c) => ({ domain: c.domain, name: c.name }))];
    const match = known.find((c) => (c.name || '').toLowerCase() === name.toLowerCase());
    if (match) return { domain: match.domain, name: match.name, existing: true };
    const domain = domainOf(email) || slugKey(name);
    return { domain, name, existing: false };
  }
  // update de lead que sobrevive si falta una columna nueva (reintenta sin ella y avisa cuáles faltan)
  async function updateLeadResilient(id, patch){
    const p = { ...patch }; const stripped = [];
    for (let i = 0; i < 5; i++){
      const { error } = await supabase.from('leads').update(p).eq('id', id);
      if (!error) return { error: null, stripped };
      const m = /Could not find the '([^']+)' column|column "?([a-z_]+)"? .* does not exist/i.exec(error.message || '');
      const col = m && (m[1] || m[2]);
      if (col && col in p) { delete p[col]; stripped.push(col); continue; }
      return { error, stripped };
    }
    return { error: null, stripped };
  }
