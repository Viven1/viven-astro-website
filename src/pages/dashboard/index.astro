        // acciones que antes obligaban a saltar a la clásica — nativas en V2 para no romper el flujo
        '<button data-act="enrich">✨ Enriquecer con IA</button>' +
        (stageOf(r.status) === 'ganado' ? '<button data-act="review">⭐ Pedir reseña</button>' : '') +   // misma regla que la clásica: solo ganados
        '<button data-act="replied">✉️ Respondió</button>' +
        (r.gclid ? '<button data-act="ads">' + (r.ads_exclude ? '🚫 Ads: excluido — incluir' : '🎯 Ads: se envía — excluir') + '</button>' : '') +
        '<hr /><button data-act="del" class="danger">🗑 Borrar contacto</button>',
        (m) => m.querySelectorAll('button').forEach((b) => b.addEventListener('click', async (ev) => {
          ev.stopPropagation(); m.hidden = true;
          const act = b.dataset.act;
          if (act === 'wa') window.open('https://wa.me/' + (r.phone || '').replace(/[^\d+]/g, '').replace(/^\+/, ''), '_blank');
          if (act === 'enrich') lm2RunEnrich(r);
          if (act === 'review') {
            // confirmar → edge function review-request
            if (!confirm('¿Mandar AHORA el pedido de reseña de Google a ' + (r.name || r.email) + '?\n\nSolo si el proyecto ya está entregado.')) return;
            try {
              const { data, error } = await supabase.functions.invoke('review-request', { body: { lead_id: r.id } });
              if (error || data?.error) throw new Error(data?.error || error?.message || 'sin respuesta');
              toast('⭐ Pedido de reseña enviado a ' + data.sent_to);
              lm2LoadTimeline(r);   // la nota del envío aparece sola en la timeline
            } catch (e) { toast('No se pudo: ' + (e.message || e)); }
          }
          if (act === 'replied') {
            // marcar respuesta y frenar las secuencias automáticas activas
            try {
              const { error } = await supabase.from('leads').update({ last_reply_at: new Date().toISOString() }).eq('id', r.id);
              if (error){ toast(/column/.test(error.message || '') ? '⚠️ Falta correr el SQL 0042' : '⚠️ ' + error.message); return; }
              const { error: e2 } = await supabase.from('automation_runs').update({ status: 'stopped' }).eq('lead_id', r.id).eq('status', 'active');
              toast(e2 ? '✉️ Marcado (⚠️ no se pudieron frenar los workflows: falta SQL 0043)' : '✉️ Marcado como respondió — fuera de todas las secuencias automáticas');
            } catch (e) { toast('⚠️ ' + (e && e.message || e)); }
          }
          if (act === 'ads') {
            // incluir/excluir de las conversiones que van a Google Ads
            const nv = !r.ads_exclude;
            const { error } = await supabase.from('leads').update({ ads_exclude: nv }).eq('id', r.id);
            if (error){ toast(/column/.test(error.message || '') ? 'Falta correr el SQL 0036 (columna ads_exclude)' : 'No se pudo: ' + error.message); return; }
            r.ads_exclude = nv;
            const i = allLeads.findIndex((l) => String(l.id) === String(r.id)); if (i > -1) allLeads[i].ads_exclude = nv;
            toast(nv ? 'Este lead NO se reporta a Google Ads (spam/test)' : 'Este lead vuelve a reportarse a Google Ads');
          }
          if (act === 'del') {
            if (!confirm('¿Borrar definitivamente el contacto "' + (r.name || r.email) + '"? Esta acción no se puede deshacer.')) return;
            const { error } = await supabase.from('leads').delete().eq('id', r.id);
            if (error) { alert('No se pudo borrar: ' + error.message); return; }
            allLeads = allLeads.filter((l) => l.id !== r.id);
            closeLead2(); renderLeads();
          }
        })));
    });
    $('lm2-crear').addEventListener('click', (e) => {
      e.stopPropagation();
      if (!menu.hidden) { menu.hidden = true; return; }
      lm2Menu('<button data-c="offer">🧾 Oferta</button><button data-c="prop">🌐 Propuesta</button><button data-c="deal">🤝 Proyecto</button><button data-c="task">✅ Task</button>',
        (m) => m.querySelectorAll('button').forEach((cb) => cb.addEventListener('click', async (ev) => {
          ev.stopPropagation(); m.hidden = true;
          const c = cb.dataset.c;
          if (c === 'offer') { closeLead2(); makeOfferForLead(r); }
          if (c === 'prop') { closeLead2(); makePropForLead(r); }
          if (c === 'deal') { const t = prompt('Nombre del nuevo proyecto:', 'Nuevo proyecto — ' + (r.name || r.email || '')); if (t === null) return; const d = await newDealForLead(r.id, t.trim() || 'Nuevo proyecto', 'nuevo'); if (d) { toast('🤝 Proyecto creado'); openLeadV2(r.id); } }
          if (c === 'task') { lm2Tab = 'task'; lm2CompCollapsed = false; lm2RenderComposer(); const inp = $('lm2-task-t'); if (inp) inp.focus(); }
        })));
    });

    lm2RenderLeft(r);

    lm2CompCollapsed = lm2Mobile(); // en móvil arranca plegado; en desktop siempre abierto
    lm2RenderComposer();
    lm2RenderRight(r);   // pinta al toque con lo que hay en memoria; el brief/followups llegan async
    lm2LoadTimeline(r);

    modal2.classList.add('open');
    modal2.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  /* --- izquierda: campos SIEMPRE visibles (— si están vacíos) y editables inline,
     como HubSpot — clic en el valor → input → Enter guarda, Esc cancela. Sin esto,
     a un contacto nuevo no se le podía cargar empresa/teléfono/idioma desde la V2 --- */
  function lm2RenderLeft(r){
    const box = $('lm2-l'); if (!box || !lm2Lead || String(lm2Lead.id) !== String(r.id)) return;
    const ldom = leadDomain(r);
    const fmtD2 = (d) => d ? new Date(d).toLocaleDateString('es-CH', { day: '2-digit', month: 'short', year: '2-digit' }) : '';
    const FIELDS = [
      ['name', 'Nombre'], ['email', 'Email'], ['phone', 'Teléfono'],
      ['company', 'Empresa'], ['job_title', 'Cargo'], ['lang', 'Idioma'],
    ];
    const disp = (f) => {
      if (f === 'company') return esc(r.company || (ldom && companyName(ldom)) || '');
      if (f === 'lang') return esc((r.lang || '').toUpperCase());
      return esc(r[f] || '');
    };
    const kvA = (k, v) => '<div><div class="k">' + k + '</div><div class="v">' + (v || '<span style="color:var(--muted-2)">—</span>') + '</div></div>';
    // móvil: todo el rail dentro de un acordeón para que la ficha termine compacta; en desktop
    // el summary se oculta por CSS y el details se renderiza con open → siempre visible
    box.innerHTML =
      '<details class="lm2-l-fold"' + (lm2Mobile() ? '' : ' open') + '><summary>👤 Datos del contacto ▾</summary>' +
      '<div class="lm2-sech">Sobre este contacto</div>' +
      '<div class="lm2-kv">' +
        FIELDS.map(([f, label]) =>
          '<div><div class="k">' + label + (f === 'company' && ldom ? ' <a href="#" id="lm2-colink" title="Abrir la empresa" style="color:var(--acid);text-decoration:none">↗</a>' : '') + '</div>' +
          '<div class="v lm2-edit" data-f="' + f + '" title="Clic para editar">' + (disp(f) || '<span style="color:var(--muted-2)">— agregar</span>') + '</div></div>').join('') +
        kvA('Canal', esc(r.channel || 'direct')) +
      '</div>' +
      '<details class="lm2-morefields"><summary>Ver todos los campos ▾</summary><div class="lm2-kv">' +
        kvA('Fuente (UTM)', esc(r.utm_source || '')) + kvA('Campaña (UTM)', esc(r.utm_campaign || '')) +
        kvA('Google Ads', r.gclid ? 'sí (gclid)' : '') + kvA('Página de entrada', esc(r.landing_path || '')) +
        kvA('Convirtió en', esc(r.form_path || '')) +
        kvA('Sesión web', r.session_id ? 'sí — actividad en la timeline (chip 🌐 Web)' : 'sin sesión conocida') +
        kvA('Creado', fmtD2(r.created_at)) + kvA('Contactado', fmtD2(r.contacted_at)) +
        kvA('Video call', fmtD2(r.videocall_at)) + kvA('Propuesta', fmtD2(r.proposal_at)) +
        kvA('Ganado', fmtD2(r.won_at)) + kvA('Perdido', fmtD2(r.lost_at)) +
        kvA('ID', esc(String(r.id))) +
      '</div></details></details>';
    const cl = $('lm2-colink'); if (cl) cl.addEventListener('click', (e) => { e.preventDefault(); e.stopPropagation(); closeLead2(); gotoTab('companies'); openCompany(ldom); });
    box.querySelectorAll('.lm2-edit').forEach((el) => el.addEventListener('click', () => {
      if (el.querySelector('input,select')) return;   // ya está en edición
      const f = el.dataset.f;
      const cur = f === 'company' ? (r.company || (ldom && companyName(ldom)) || '') : f === 'lang' ? (r.lang || 'en') : (r[f] || '');
      let inp;
      if (f === 'lang') {
        inp = document.createElement('select');
        ['en', 'de', 'es'].forEach((l) => { const o = document.createElement('option'); o.value = l; o.textContent = l.toUpperCase(); if (l === cur) o.selected = true; inp.appendChild(o); });
      } else {
        inp = document.createElement('input');
        inp.type = f === 'email' ? 'email' : f === 'phone' ? 'tel' : 'text';
        inp.value = cur;
      }
      inp.style.cssText = 'width:100%;background:var(--navy-900);border:1px solid var(--acid);border-radius:7px;color:var(--text);font:600 12.5px Inter,sans-serif;padding:5px 7px';
      el.innerHTML = ''; el.appendChild(inp); inp.focus();
      if (inp.select) try { inp.select(); } catch (e) {}
      let done = false;
      const save = async () => {
        if (done) return; done = true;
        const v = inp.value.trim();
        let patch;
        if (f === 'name') { const parts = v.split(/\s+/).filter(Boolean); patch = { name: v || null, first_name: parts[0] || null, last_name: parts.slice(1).join(' ') || null }; }
        else if (f === 'email') { if (v && !/\S+@\S+\.\S+/.test(v)) { toast('Email inválido'); lm2RenderLeft(r); return; } patch = { email: v || null }; }
        else { patch = {}; patch[f] = v || null; }
        const { error } = await updateLeadResilient(r.id, patch);
        if (error) { toast('No se pudo guardar: ' + error.message); lm2RenderLeft(r); return; }
        Object.assign(r, patch);
        const i = allLeads.findIndex((l) => String(l.id) === String(r.id)); if (i > -1) Object.assign(allLeads[i], patch);
        toast('💾 Guardado');
        renderLeads();
        // nombre/email también viven en el header → redibujar la ficha entera
        if (f === 'name' || f === 'email') openLeadV2(r.id); else lm2RenderLeft(r);
      };
      inp.addEventListener('keydown', (ev) => {
        if (ev.key === 'Enter') { ev.preventDefault(); inp.blur(); }
        if (ev.key === 'Escape') { done = true; lm2RenderLeft(r); }
      });
      inp.addEventListener('blur', save);
      if (f === 'lang') inp.addEventListener('change', () => inp.blur());
    }));
  }

  /* --- composer: Nota / Task / Email en un solo lugar --- */
  function lm2RenderComposer(){
    const r = lm2Lead; if (!r) return;
    const box = $('lm2-composer');
    box.className = 'lm2-composer' + (lm2CompCollapsed ? ' collapsed' : '');
    // móvil: plegado = una barra finita; al tocarla se expande y se enfoca el campo del tab activo
    if (lm2CompCollapsed){
      box.innerHTML = '<button class="lm2-cbar" type="button">➕ Nota, task o email…</button>';
      box.querySelector('.lm2-cbar').addEventListener('click', () => {
        lm2CompCollapsed = false; lm2RenderComposer();
        const inp = $(lm2Tab === 'nota' ? 'lm2-note-b' : lm2Tab === 'task' ? 'lm2-task-t' : 'lm2-mail-b'); if (inp) inp.focus();
      });
      return;
    }
    const tab = (k, l) => '<button data-t="' + k + '" class="' + (lm2Tab === k ? 'on' : '') + '">' + l + '</button>';
    let body = '';
    if (lm2Tab === 'nota') body =
      '<textarea id="lm2-note-b" placeholder="Agregar una nota… (contexto, objeción, próximo paso)"></textarea>' +
      '<div class="lm2-crow"><select id="lm2-note-m">' + teamOptions('', 'Avisar a…') + '</select><span class="sp"></span><button class="btn btn-primary small" id="lm2-note-save" type="button">Guardar nota</button></div>';
    else if (lm2Tab === 'task') body =
      '<input id="lm2-task-t" placeholder="Nueva task…" style="width:100%" />' +
      '<div class="lm2-crow"><input id="lm2-task-d" type="date" /><input id="lm2-task-h" type="time" /><select id="lm2-task-a">' + teamOptions('', 'Responsable') + '</select><span class="sp"></span><button class="btn btn-primary small" id="lm2-task-save" type="button">+ Task</button></div>';
    else body =
      '<textarea id="lm2-mail-b" style="min-height:110px">' + esc(buildDraft(r)) + '</textarea>' +
      '<div class="lm2-crow"><label style="font-size:12px;color:var(--muted)">De: <select id="lm2-mail-de"><option value="sofia"' + (sender === 'sofia' ? ' selected' : '') + '>Sofia</option><option value="sebastian"' + (sender === 'sebastian' ? ' selected' : '') + '>Sebastian</option></select></label><button class="btn btn-ghost small" id="lm2-mail-ai" type="button" title="Sugerencia personalizada con IA">✨ IA</button><span class="sp"></span><button class="btn btn-primary small" id="lm2-mail-send" type="button">📨 Enviar al lead</button></div>';
    box.innerHTML = '<div class="lm2-ctabs">' + tab('nota', '📝 Nota') + tab('task', '✅ Task') + tab('email', '✉️ Email') + '</div><div class="lm2-cbody">' + body + '</div>';
    box.querySelectorAll('.lm2-ctabs button').forEach((b) => b.addEventListener('click', () => { lm2Tab = b.dataset.t; lm2RenderComposer(); }));
    const nb = $('lm2-note-save'); if (nb) nb.addEventListener('click', async () => {
      const bodyTxt = $('lm2-note-b').value.trim(); if (!bodyTxt) { toast('Escribí la nota'); return; }
      const mention = $('lm2-note-m').value || null;
      const author = teamName(myEmail());
      const { error } = await supabase.from('lead_notes').insert({ lead_id: String(r.id), body: bodyTxt, mention, author });
      if (error) { toast('No se pudo: ' + error.message); return; }
      if (mention) notifyUser(mention, '📝 Nota en el lead ' + (r.name || r.email), author + ' te mencionó:\n\n"' + bodyTxt + '"', r.id);
      if (lm2Mobile()) lm2CompCollapsed = true; // móvil: guardó → el composer vuelve a plegarse
      toast('Nota guardada'); lm2RenderComposer(); lm2LoadTimeline(r);
    });
    const tb = $('lm2-task-save'); if (tb) tb.addEventListener('click', async () => {
      const title = $('lm2-task-t').value.trim(); if (!title) { toast('Escribí la task'); return; }
      const due = $('lm2-task-d').value || null, time = $('lm2-task-h').value || null, assignee = $('lm2-task-a').value || null;
      const row = { lead_id: String(r.id), title, due_date: due, due_time: time, assignee };
      let { error } = await supabase.from('lead_tasks').insert(row);
      if (error && /due_time/.test(error.message || '')) { delete row.due_time; ({ error } = await supabase.from('lead_tasks').insert(row)); }
      if (error) { toast('No se pudo: ' + error.message); return; }
      if (assignee) notifyUser(assignee, '✅ Task nueva — ' + (r.name || r.email), 'Te asignaron: "' + title + '"', r.id);
      if (lm2Mobile()) lm2CompCollapsed = true; // móvil: guardó → el composer vuelve a plegarse
      toast('Task creada'); loadBell(); lm2RenderComposer(); lm2LoadTimeline(r); lm2RenderRight(r);
    });
    /* ✨ IA en el email V2: misma edge function ai-suggest —
       la IA devuelve SOLO la frase personalizada (proof) y buildDraft arma el resto,
       así las CTAs y el brief nunca se pierden. Acá el error va por toast (no hay lm-status-note). */
    const ab = $('lm2-mail-ai'); if (ab) ab.addEventListener('click', async () => {
      const prev = ab.textContent;
      ab.disabled = true; ab.textContent = '✨ Pensando…';
      try {
        const { data, error } = await supabase.functions.invoke('ai-suggest', {
          body: { lead: r, lang: r.lang || 'es' }
        });
        if (error) throw new Error(data?.error || error?.message || 'sin respuesta');
        let aiProof = (data && data.proof || '').trim();
        // Si vino un email entero (versión vieja de ai-suggest, con saludo/firma/CTA) NO lo insertamos como frase.
        const looksLikeFullEmail = /\n|hola|guten tag|hi\b|saludos|grüsse|best,|\[tu nombre\]|agendá|book|brief/i.test(aiProof);
        if (data && data.suggestion && !data.proof) {
          throw new Error('La función ai-suggest está desactualizada. Redeployala: supabase functions deploy ai-suggest --no-verify-jwt');
        }
        if (!aiProof) throw new Error(data?.error || 'sin respuesta');
        if (looksLikeFullEmail || aiProof.length > 240) {
          throw new Error('La IA devolvió un texto raro (no una frase corta). Probá de nuevo o redeployá ai-suggest.');
        }
        // limpiar comillas/punto final por las dudas
        aiProof = aiProof.replace(/^["'«»]+|["'«».]+$/g, '').trim();
        const ta = $('lm2-mail-b'); if (ta) ta.value = buildDraft(r, aiProof);
        toast('✨ Frase personalizada con IA — revisalo antes de enviar');
      } catch (e) {
        toast('No se pudo generar con IA (¿deployaste la función ai-suggest?): ' + (e.message || e));
      } finally {
        ab.disabled = false; ab.textContent = prev;
      }
    });
    const mb = $('lm2-mail-send'); if (mb) mb.addEventListener('click', async () => {
      const lang = ['en', 'de', 'es'].includes(r.lang) ? r.lang : 'en';
      const bodyTxt = $('lm2-mail-b').value.trim(); if (!bodyTxt) return;
      const de = $('lm2-mail-de').value;
      if (!confirm('¿Enviar este email a ' + r.email + '? Sale desde info@viven.ch.')) return;
      mb.disabled = true; mb.textContent = '📨 Enviando…';
      try {
        const { data, error } = await supabase.functions.invoke('send-outreach', {
          body: { to: r.email, subject: SUBJECTS[lang], body: bodyTxt, lead_id: r.id, mark_contacted: true, fromName: (SENDERS[de] || SENDERS.sofia).name }
        });
        if (error || !data || !data.ok) throw new Error(data?.error || error?.message || 'sin respuesta');
        r.status = 'contactado'; renderLeads();
        toast('✓ Enviado — el lead pasó a Contactado');
        lm2Tab = 'nota'; lm2RenderComposer(); lm2LoadTimeline(r); openLeadV2(r.id);
      } catch (e) { toast('No se pudo enviar: ' + e.message); }
      finally { mb.disabled = false; mb.textContent = '📨 Enviar al lead'; }
    });
  }

  /* --- timeline unificada --- */
  async function lm2LoadTimeline(r){
    const box = $('lm2-tl'); if (!box || !lm2Lead || String(lm2Lead.id) !== String(r.id)) return;
    const q = (t) => t.then((x) => (x && !x.error && x.data) || []).catch(() => []);
    const [emails, notes, tasks, briefs1, briefs2, pv, vp] = await Promise.all([
      q(supabase.from('email_log').select('*').eq('lead_id', String(r.id)).order('created_at', { ascending: false }).limit(100)),
      q(supabase.from('lead_notes').select('*').eq('lead_id', String(r.id)).order('created_at', { ascending: false }).limit(100)),
      q(supabase.from('lead_tasks').select('*').eq('lead_id', String(r.id)).order('created_at', { ascending: false }).limit(100)),
      q(supabase.from('briefs').select('*').eq('lead_id', String(r.id)).order('created_at', { ascending: false }).limit(10)),
      r.email ? q(supabase.from('briefs').select('*').ilike('email', r.email).order('created_at', { ascending: false }).limit(10)) : Promise.resolve([]),
      r.session_id ? q(supabase.from('pageviews').select('path,created_at,duration').eq('session_id', r.session_id).order('created_at').limit(200)) : Promise.resolve([]),
      r.session_id ? q(supabase.from('video_plays').select('video_id,label,created_at').eq('session_id', r.session_id).order('created_at').limit(100)) : Promise.resolve([]),
    ]);
    if (!lm2Lead || String(lm2Lead.id) !== String(r.id)) return;   // cambió de contacto mientras cargaba
    const briefSeen = new Set(); const briefs = [...briefs1, ...briefs2].filter((b) => !briefSeen.has(b.id) && briefSeen.add(b.id));
    const ev = [];
    if (r.message) ev.push({ t: r.created_at, ty: 'nota', chip: ['nota', '💬 Consulta'], title: '<b>Mensaje original del lead</b>', body: r.message });
    emails.forEach((e2) => ev.push({ t: e2.created_at, ty: 'email', chip: ['email', e2.direction === 'in' ? '📥 Recibido' : '✉️ Enviado'], title: '<b>' + esc(e2.subject || '(sin asunto)') + '</b>', meta: esc(e2.sender_label || ''), body: String(e2.body || '').replace(/<[^>]+>/g, ' ') }));
    // notas agrupadas en HILOS estilo chat (0057: parent_id apunta a la nota RAÍZ, hilo plano de 1 nivel).
    // Un solo evento por hilo, fechado por el ÚLTIMO mensaje — las conversaciones activas flotan arriba.
    // Las respuestas viejas con cita en el body (empiezan con '↩') no tienen parent_id → quedan como raíces sueltas, sin parsear.
    const thrMap = new Map();
    notes.filter((n) => !n.parent_id).forEach((n) => thrMap.set(n.id, { root: n, replies: [] }));
    notes.filter((n) => n.parent_id).forEach((n) => { const t2 = thrMap.get(n.parent_id); if (t2) t2.replies.push(n); else thrMap.set(n.id, { root: n, replies: [] }); }); // raíz fuera del límite de fetch → mostrar la respuesta suelta
    thrMap.forEach((t2) => {
      t2.replies.sort((a, b) => new Date(a.created_at) - new Date(b.created_at));
      const last = t2.replies.length ? t2.replies[t2.replies.length - 1] : t2.root;
      // nid/nauthor/nbody habilitan el «↩︎ Responder»; title solo alimenta el resumen para la IA (el render usa e.thread)
      ev.push({ t: last.created_at, ty: 'nota', chip: ['nota', t2.replies.length ? '💬 Hilo (' + (t2.replies.length + 1) + ')' : '📝 Nota'], title: esc((last.body || '').slice(0, 90)), thread: t2, nid: t2.root.id, nauthor: t2.root.author || '', nbody: t2.root.body || '' });
    });
    tasks.forEach((t) => ev.push({ t: t.created_at, ty: 'task', chip: ['task', t.done ? '✅ Task hecha' : '⏳ Task'], title: '<label style="display:flex;gap:8px;align-items:center;cursor:pointer"><input type="checkbox" class="lm2-tk" data-id="' + esc(String(t.id)) + '"' + (t.done ? ' checked' : '') + ' /> <span' + (t.done ? ' style="text-decoration:line-through;color:var(--muted)"' : '') + '>' + esc(t.title) + '</span></label>', meta: [t.due_date ? 'vence ' + t.due_date + (t.due_time ? ' ' + t.due_time : '') : '', t.assignee ? teamName(t.assignee) : ''].filter(Boolean).join(' · ') }));
    briefs.forEach((b) => { const a = b.answers || {}; const quote = /QUIERE COTIZACIÓN/.test(b.extra || '');
      // el brief completo, legible, en el desplegable — sin esto el evento no sirve de mucho
      const li = (k, v) => { if (!v) return ''; const s = Array.isArray(v) ? v.join(', ') : String(v); return s.trim() ? k + ': ' + s + '\n' : ''; };
      const full =
        li('Objetivo', b.goal) + li('Audiencia', a.audience) + li('Dónde va a correr', b.distribution || a.distribution) +
        li('Cantidad de videos', a.quantity) + li('Formatos', a.formats) + li('Idiomas y subtítulos', a.languages) +
        li('En cámara', a.oncamera) + li('Locaciones', a.locations) + li('Timing', b.timeline) + li('Presupuesto', b.budget) +
        li('Qué deben HACER después de verlo', a.action) + li('Qué deben sentir', a.feeling) + li('Adónde deben llegar', a.destination) +
        li('Referencias', a.references) + (b.extra ? '\n' + b.extra : '');
      ev.push({ t: b.created_at, ty: 'brief', chip: ['brief', '📋 Brief'], title: '<b>' + (quote ? '🔔 Pidió cotización — ' : 'Brief recibido — ') + esc(b.goal || '') + '</b>', meta: [b.budget, b.timeline, a.quantity].filter(Boolean).map(esc).join(' · '), body: full.trim() }); });
    [['contacted_at', 'Contactado'], ['videocall_at', 'Video call'], ['proposal_at', 'Propuesta enviada'], ['won_at', '🎉 Ganado'], ['lost_at', 'Perdido']].forEach(([f, l]) => { if (r[f]) ev.push({ t: r[f], ty: 'sys', chip: ['sys', '⚙️ Etapa'], title: l }); });
    // web: agrupar pageviews por día (200 sueltos ahogarían la timeline)
    const byDay = {};
    pv.forEach((p) => { const d = (p.created_at || '').slice(0, 10); (byDay[d] = byDay[d] || []).push(p); });
    Object.keys(byDay).forEach((d) => { const ps = byDay[d]; const top = ps.slice(0, 3).map((p) => esc(p.path || '/')).join(', ');
      ev.push({ t: ps[ps.length - 1].created_at, ty: 'web', chip: ['web', '🌐 Web'], title: 'Visitó ' + ps.length + ' página' + (ps.length === 1 ? '' : 's'), meta: top + (ps.length > 3 ? '…' : '') }); });
    vp.forEach((v) => ev.push({ t: v.created_at, ty: 'web', chip: ['web', '🎬 Video'], title: 'Vio: ' + esc(v.label || v.video_id) }));
    ev.sort((a, b) => new Date(b.t) - new Date(a.t));
    lm2Events = ev;
    lm2RenderChips();
    lm2RenderTl();
    lm2RenderNext(r, tasks);
  }
  function lm2RenderChips(){
    const CH = [['all', 'Todo'], ['email', '✉️ Emails'], ['nota', '📝 Notas'], ['task', '✅ Tasks'], ['web', '🌐 Web'], ['sys', '⚙️ Etapas']];
    $('lm2-chips').innerHTML = CH.map(([k, l]) => { const n = k === 'all' ? lm2Events.length : lm2Events.filter((e) => e.ty === k || (k === 'nota' && e.ty === 'brief')).length;
      return '<button data-f="' + k + '" class="' + (lm2Filter === k ? 'on' : '') + '">' + l + (n ? ' ' + n : '') + '</button>'; }).join('');
    $('lm2-chips').querySelectorAll('button').forEach((b) => b.addEventListener('click', () => { lm2Filter = b.dataset.f; lm2RenderChips(); lm2RenderTl(); }));
  }
  function lm2RenderTl(){
    const box = $('lm2-tl');
    const list = lm2Filter === 'all' ? lm2Events : lm2Events.filter((e) => e.ty === lm2Filter || (lm2Filter === 'nota' && e.ty === 'brief'));
    if (!list.length) { box.innerHTML = '<p class="muted-note">Sin actividad todavía — las notas, emails y tasks van a aparecer acá.</p>'; return; }
    const replyLink = (i) => '<div><a href="#" class="lm2-nreply" data-i="' + i + '" style="color:var(--acid);font-size:11px;text-decoration:none">↩︎ Responder</a><div class="lm2-nreply-box" hidden></div></div>';
    box.innerHTML = list.map((e, i) => {
      const head = '<div class="lm2-ev' + (i === 0 && lm2Filter === 'all' ? ' hot' : '') + '"><div class="when">' + lm2FmtDT(e.t) + ' · hace ' + timeAgo(e.t) + '</div><div class="card">';
      if (e.thread){
        // hilo de notas estilo chat: la raíz arriba, las respuestas colgando abajo con sangría, UN solo «Responder» al pie del hilo
        const msg = (n, isRep) => '<div class="lm2-msg' + (isRep ? ' rep' : '') + '"><div class="a">' + esc(n.author || '¿?') + ' <span class="w">hace ' + timeAgo(n.created_at) + '</span></div><div class="b">' + esc(n.body || '') + '</div></div>';
        return head + '<span class="lm2-chip nota">' + e.chip[1] + '</span>' + msg(e.thread.root, false) + e.thread.replies.map((n) => msg(n, true)).join('') + replyLink(i) + '</div></div>';
      }
      return head + '<span class="lm2-chip ' + e.chip[0] + '">' + e.chip[1] + '</span>' + e.title +
        (e.meta ? '<div class="meta">' + e.meta + '</div>' : '') +
        (e.body ? '<details><summary>ver completo</summary><div>' + esc(e.body) + '</div></details>' : '') +
        (e.nid ? replyLink(i) : '') +
        '</div></div>';
    }).join('');
    box.querySelectorAll('.lm2-tk').forEach((cb) => cb.addEventListener('change', async () => {
      await supabase.from('lead_tasks').update({ done: cb.checked, done_at: cb.checked ? new Date().toISOString() : null }).eq('id', cb.dataset.id);
      loadBell(); if (lm2Lead) { lm2LoadTimeline(lm2Lead); lm2RenderRight(lm2Lead); }
    }));
    /* ↩︎ Responder a una nota: mini-form inline debajo de la tarjeta. La respuesta es otra
       nota más (sin migración de DB) que cita a la original, y usa el mecanismo de mention
       existente para avisarle al autor original — así Sofia y Sebastián pueden charlar acá. */
    box.querySelectorAll('.lm2-nreply').forEach((a) => a.addEventListener('click', (e2) => {
      e2.preventDefault();
      const ev = list[Number(a.dataset.i)]; if (!ev || !ev.nid) return;
      // solo un form abierto a la vez
      box.querySelectorAll('.lm2-nreply-box').forEach((f) => { f.hidden = true; f.innerHTML = ''; });
      const holder = a.parentElement.querySelector('.lm2-nreply-box'); if (!holder) return;
      holder.hidden = false;
      holder.innerHTML =
        '<textarea class="lm2-nreply-t" placeholder="Respondele a ' + esc(ev.nauthor || 'la nota') + '…" style="width:100%;min-height:60px;margin-top:6px;background:var(--navy-900);border:1px solid var(--line);border-radius:7px;color:var(--text);font:500 12.5px Inter,sans-serif;padding:6px 8px"></textarea>' +
        '<div style="display:flex;gap:6px;justify-content:flex-end;margin-top:5px">' +
          '<button class="btn btn-ghost small lm2-nreply-x" type="button">Cancelar</button>' +
          '<button class="btn btn-primary small lm2-nreply-ok" type="button">↩︎ Responder</button></div>';
      const ta = holder.querySelector('.lm2-nreply-t'); ta.focus();
      holder.querySelector('.lm2-nreply-x').addEventListener('click', () => { holder.hidden = true; holder.innerHTML = ''; });
      holder.querySelector('.lm2-nreply-ok').addEventListener('click', async () => {
        const r = lm2Lead; if (!r) return;
        const replyTxt = ta.value.trim(); if (!replyTxt) { toast('Escribí la respuesta'); return; }
        const okBtn = holder.querySelector('.lm2-nreply-ok'); okBtn.disabled = true;
        const author = teamName(myEmail());
        // nombre → email: por el mapeo del TEAM, si no por heurística de nombre (notas viejas sin autor mapeado)
        const toEmail = (n) => teamEmailByName(String(n || '')) || (/sofia/i.test(n) ? 'sofia@viven.ch' : /sebastian/i.test(n) ? 'sebastian@viven.ch' : null);
        // avisar a TODOS los participantes del hilo (autor raíz + todos los que respondieron) menos al que
        // escribe — antes solo se avisaba al autor raíz y saltearse el propio hacía parecer que nunca llegaban
        const partNames = [ev.nauthor, ...((ev.thread && ev.thread.replies) || []).map((n) => n.author || '')];
        const recipients = [...new Set(partNames.map(toEmail).filter(Boolean))].filter((e3) => e3 !== myEmail());
        // mention (columna existente): el autor raíz si no soy yo; si no, el primer otro participante
        const rootEmail = toEmail(ev.nauthor);
        const mention = (rootEmail && rootEmail !== myEmail()) ? rootEmail : (recipients[0] || null);
        // hilo real (0057): body limpio + parent_id = nota RAÍZ (responder a una respuesta también cuelga de la raíz)
        let { error } = await supabase.from('lead_notes').insert({ lead_id: String(r.id), body: replyTxt, author, parent_id: Number(ev.nid), mention });
        if (error && /parent_id/.test(error.message || '')){
          // sin el SQL 0057 corrido: caer al formato viejo con cita para no perder la respuesta
          const quote = (ev.nbody || '').slice(0, 60) + ((ev.nbody || '').length > 60 ? '…' : '');
          ({ error } = await supabase.from('lead_notes').insert({ lead_id: String(r.id), body: '↩︎ En respuesta a ' + (ev.nauthor || 'una nota') + ' («' + quote + '»): ' + replyTxt, author, mention }));
        }
        if (error) { toast('No se pudo: ' + error.message); okBtn.disabled = false; return; }
        recipients.forEach((to) => notifyUser(to, '💬 ' + author + ' respondió en un hilo — ' + (r.name || r.email), author + ' escribió en el hilo de notas de ' + (r.name || r.email) + ':\n\n' + replyTxt, r.id));
        if (recipients.length) loadBell();
        toast('↩︎ Respuesta guardada' + (recipients.length ? ' · avisado a ' + recipients.map((e3) => teamName(e3)).join(', ') : ''));
        lm2LoadTimeline(r);
      });
    }));
  }
  function lm2RenderNext(r, tasks){
    const el = $('lm2-next'); if (!el) return;
    const open = (tasks || []).filter((t) => !t.done);
    const dated = open.filter((t) => t.due_date).sort((a, b) => (a.due_date + (a.due_time || '')) < (b.due_date + (b.due_time || '')) ? -1 : 1);
    const pick = dated[0] || open[0];
    let head = '';
    if (pick) head = '<div class="v">' + esc(pick.title) + '<small>' + [pick.due_date ? 'vence ' + pick.due_date + (pick.due_time ? ' ' + pick.due_time : '') : 'sin fecha', pick.assignee ? teamName(pick.assignee) : ''].filter(Boolean).join(' · ') + '</small></div>';
    else if (r.next_follow_up_at) head = '<div class="v">Follow-up automático<small>' + new Date(r.next_follow_up_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short' }) + '</small></div>';
    el.innerHTML = '<div class="t">Próximo paso <a href="#" id="lm2-next-ai" style="float:right;color:var(--acid);font-weight:700;text-decoration:none" title="La IA sugiere el próximo paso según la etapa, los mensajes y la actividad">✨ IA</a></div>' +
      head + '<div id="lm2-ai-sug"></div>';
    const aiBtn = $('lm2-next-ai');
    aiBtn.addEventListener('click', (e) => { e.preventDefault(); lm2AiNext(r, true); });
    // sin una TASK concreta → la IA sugiere sola (el follow-up automático no cuenta como
    // "próximo paso pensado": mostrarlo solo hacía que la tarjeta dijera siempre lo mismo).
    // Cacheado por contacto para no re-pagar tokens en cada apertura.
    if (!pick) lm2AiNext(r, false);
  }
  /* Sugerencias IA de próximo paso: usa ai-insights (ya deployada) con un resumen del
     contacto — etapa, días sin actividad, brief, ofertas y los últimos eventos de la
     timeline. Cada sugerencia se convierte en task con un click. */
  const lm2AiCache = {};
  async function lm2AiNext(r, force){
    const box = $('lm2-ai-sug'); if (!box) return;
    if (!force && lm2AiCache[r.id]) { lm2AiPaint(r, lm2AiCache[r.id]); return; }
    box.innerHTML = '<div style="font-size:11.5px;color:var(--muted);margin-top:6px">✨ La IA está pensando el próximo paso…</div>';
    const evs = (lm2Events || []).slice(0, 10).map((e) => '[' + e.chip[1] + '] ' + String(e.title || '').replace(/<[^>]+>/g, '').slice(0, 90) + (e.meta ? ' (' + String(e.meta).replace(/<[^>]+>/g, '').slice(0, 60) + ')' : ''));
    const lastAct = lm2Events && lm2Events.length ? Math.round((Date.now() - new Date(lm2Events[0].t)) / 864e5) : null;
    const ofs = offersForLead(r.id);
    const summary = {
      contexto: 'CRM de Viven (productora de video en Zúrich). Sugerí el PRÓXIMO PASO DE VENTA concreto para este contacto — una acción específica y accionable (llamar, mandar X, agendar Y), no consejos genéricos. Máximo 3 sugerencias, la mejor primero.',
      contacto: { nombre: r.name || r.email, empresa: r.company || companyName(leadDomain(r)) || null, idioma: r.lang, canal: r.channel },
      etapa: stageOf(r.status),
      dias_desde_ultima_actividad: lastAct,
      presupuesto_y_brief: null,   // se completa abajo si hay brief en la timeline
      ofertas: ofs.map((o) => ({ titulo: o.title, estado: o.status, neto: offerNet(o) })),
      ultimos_eventos: evs,
    };
    const br = (lm2Events || []).find((e) => e.ty === 'brief');
    if (br) summary.presupuesto_y_brief = String(br.title || '').replace(/<[^>]+>/g, '') + ' · ' + String(br.meta || '');
    try {
      const { data, error } = await supabase.functions.invoke('ai-insights', { body: { summary, lang: 'es' } });
      if (error || !data || !Array.isArray(data.insights) || !data.insights.length) throw new Error(data?.error || error?.message || 'sin respuesta');
      lm2AiCache[r.id] = data.insights.slice(0, 3);
      if (lm2Lead && String(lm2Lead.id) === String(r.id)) lm2AiPaint(r, lm2AiCache[r.id]);
    } catch (e) {
      box.innerHTML = '<div style="font-size:11.5px;color:var(--muted);margin-top:6px">No se pudo sugerir: ' + esc(e.message) + '</div>';
    }
  }
  function lm2AiPaint(r, sugs){
    const box = $('lm2-ai-sug'); if (!box) return;
    box.innerHTML = sugs.map((s, i) =>
      '<div style="display:flex;gap:7px;align-items:flex-start;margin-top:8px;font-size:12px">' +
        '<span style="flex:none">' + esc(s.icon || '💡') + '</span>' +
        '<div style="min-width:0"><b>' + esc(s.title || '') + '</b><div style="color:var(--muted);font-size:11px;margin-top:1px">' + esc(s.detail || '') + '</div>' +
        '<a href="#" class="lm2-sug-task" data-i="' + i + '" style="color:var(--acid);font-size:11px;text-decoration:none">➕ crear task</a></div></div>').join('');
    box.querySelectorAll('.lm2-sug-task').forEach((a) => a.addEventListener('click', async (e) => {
      e.preventDefault();
      const s = sugs[Number(a.dataset.i)]; if (!s) return;
      const { error } = await supabase.from('lead_tasks').insert({ lead_id: String(r.id), title: s.title, due_date: null, assignee: null });
      if (error) { toast('No se pudo: ' + error.message); return; }
      toast('✅ Task creada desde la sugerencia'); loadBell();
      lm2LoadTimeline(r); lm2RenderRight(r);
    }));
  }

  /* ✨ Enriquecer con IA: misma edge function ai-enrich que usa enrichHTML(),
     pero acá el resultado se pinta en la tarjeta «🔎 Enriquecido» de la columna derecha. */
  let lm2Enriching = false;
  async function lm2RunEnrich(r){
    if (!r || lm2Enriching) return;
    lm2Enriching = true; lm2RenderRight(r);   // muestra la tarjeta en estado «buscando…»
    try {
      const dom = leadDomain(r);
      const { data, error } = await supabase.functions.invoke('ai-enrich', { body: { lead: {
        name: r.name, email: r.email, job_title: r.job_title, lang: r.lang,
        company: r.company || (dom ? companyName(dom) : ''), domain: dom } } });
      if (error || (data && data.error)) { toast('No se pudo: ' + ((data && data.error) || error.message)); return; }
      r.enrichment = data.enrichment; r.enriched_at = new Date().toISOString();
      const i = allLeads.findIndex((l) => l.id === r.id);
      if (i > -1) { allLeads[i].enrichment = r.enrichment; allLeads[i].enriched_at = r.enriched_at; }
      const { stripped } = await updateLeadResilient(r.id, { enrichment: r.enrichment, enriched_at: r.enriched_at });
      if (stripped && stripped.length) toast('⚠️ Corré el SQL 0021 para que quede guardado');
      else toast('🔎 Contacto enriquecido y guardado');
    } catch (e) { toast('No se pudo: ' + (e && e.message || e)); }
    finally { lm2Enriching = false; if (lm2Lead && String(lm2Lead.id) === String(r.id)) lm2RenderRight(r); }
  }

  /* --- columna derecha: próximo paso + negocio --- */
  async function lm2RenderRight(r){
    if (!lm2Lead || String(lm2Lead.id) !== String(r.id)) return;
    const ldeals = dealsForLead(r.id).slice().sort((a, b) => new Date(b.created_at) - new Date(a.created_at));
    const ofs = offersForLead(r.id);
    const props = (typeof propsAll !== 'undefined' ? propsAll : []).filter((p) => p.lead_id && String(p.lead_id) === String(r.id) && !p.is_template);
    const stB = (key) => { const s = STAGES.find((x) => x.key === stageOf(key)) || STAGES[0]; return '<span class="stb" style="color:' + s.color + ';border-color:' + s.color + '">' + s.label + '</span>'; };
    const ofB = (st) => { const b = { draft: ['Borrador', '#8ab4ff'], sent: ['Enviada', '#f0c060'], won: ['Ganada', '#7ed957'], lost: ['Perdida', '#ff6b6b'], accepted: ['Aceptada', '#7ed957'], published: ['Publicada', '#f0c060'] }[st] || ['Borrador', '#8ab4ff']; return '<span class="stb" style="color:' + b[1] + ';border-color:' + b[1] + '">' + b[0] + '</span>'; };
    $('lm2-r').innerHTML =
      '<div class="lm2-next" id="lm2-next"><div class="t">Próximo paso</div><div class="v" style="color:var(--muted)">Cargando…</div></div>' +
      '<div class="lm2-as"><div class="top">🤝 Proyectos <span class="n">' + ldeals.length + '</span></div>' +
        ldeals.map((d) => { const v = stageOf(d.stage) === 'perdido' ? dealLostValue(d) : dealValue(d);
          return '<div class="row" style="cursor:default">' + esc(d.title || '(proyecto)') + ' ' + stB(d.stage) + '<span class="amt">' + (v ? fmtChf(v) : '—') + '</span></div>'; }).join('') +
        '<button class="add" id="lm2-add-deal" type="button">➕ Nuevo proyecto</button></div>' +
      '<div class="lm2-as"><div class="top">🧾 Ofertas y propuestas <span class="n">' + (ofs.length + props.length) + '</span></div>' +
        ofs.map((o) => '<button class="row lm2-of" data-oid="' + o.id + '" type="button">' + esc(o.title || '(sin título)') + ' ' + ofB(o.status) + '<span class="amt">' + fmtM(offerNet(o)) + '</span></button>').join('') +
        props.map((p) => '<button class="row lm2-pp" data-pid="' + p.id + '" type="button">🌐 ' + esc(p.title || '(propuesta)') + ' ' + ofB(p.status) + '</button>').join('') +
        '<button class="add" id="lm2-add-of" type="button">➕ Oferta · 🌐 Propuesta</button></div>' +
      // enriquecido con IA: misma data que la clásica (r.enrichment/r.enriched_at) pero como tarjeta plegable acá
      (lm2Enriching || r.enrichment
        ? '<div class="lm2-as" id="lm2-en-card">' +
            (lm2Enriching
              ? '<div class="top">🔎 Enriquecido</div><div class="row" style="color:var(--muted);cursor:default">🔎 Buscando en la web…</div>'
              : '<details><summary class="top" style="cursor:pointer;list-style:none">🔎 Enriquecido <span class="n">' + (r.enriched_at ? esc(fmtDMY(r.enriched_at)) : '') + '</span></summary><div style="font-size:12px;padding:4px 2px 2px">' + enrichHTML(r.enrichment || {}) + '</div></details>') +
          '</div>'
        : '') +
      '<div class="lm2-as" id="lm2-brief-card" hidden><div class="top">📋 Brief <span class="n" id="lm2-brief-when"></span></div><div class="row" id="lm2-brief-row" style="color:var(--muted)"></div></div>' +
      '<div class="lm2-as" id="lm2-fu-card" hidden><div class="top">📬 Automación <span class="n" id="lm2-fu-n"></span></div><div class="row" id="lm2-fu-row" style="color:var(--muted);cursor:default"></div></div>';
    $('lm2-add-deal').addEventListener('click', async () => { const t = prompt('Nombre del nuevo proyecto:', 'Nuevo proyecto — ' + (r.name || r.email || '')); if (t === null) return; const d = await newDealForLead(r.id, t.trim() || 'Nuevo proyecto', 'nuevo'); if (d) { toast('🤝 Proyecto creado'); openLeadV2(r.id); } });
    $('lm2-add-of').addEventListener('click', () => { closeLead2(); makeOfferForLead(r); });
    $('lm2-r').querySelectorAll('.lm2-of').forEach((b) => b.addEventListener('click', () => { closeLead2(); gotoTab('offers'); openOffer(b.dataset.oid); }));
    $('lm2-r').querySelectorAll('.lm2-pp').forEach((b) => b.addEventListener('click', () => { closeLead2(); gotoTab('props'); }));
    // brief y automación llegan async
    latestBriefFor(r).then((b) => { if (!b || !lm2Lead || String(lm2Lead.id) !== String(r.id)) return;
      $('lm2-brief-card').hidden = false;
      $('lm2-brief-when').textContent = new Date(b.created_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short' });
      $('lm2-brief-row').textContent = [b.goal, b.budget, b.timeline].filter(Boolean).join(' · ') || 'ver en la timeline';
    });
    supabase.from('lead_followups').select('status,send_at').eq('lead_id', String(r.id)).order('send_at').then(({ data }) => {
      if (!data || !data.length || !lm2Lead || String(lm2Lead.id) !== String(r.id)) return;
      const appr = data.filter((f) => f.status === 'approved'), draft = data.filter((f) => f.status === 'draft');
      if (!appr.length && !draft.length) return;
      $('lm2-fu-card').hidden = false;
      $('lm2-fu-n').textContent = appr.length ? 'activa' : 'borradores';
      $('lm2-fu-row').textContent = appr.length ? (appr.length + ' programado' + (appr.length === 1 ? '' : 's') + ' · próximo: ' + new Date(appr[0].send_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short' })) : (draft.length + ' borrador' + (draft.length === 1 ? '' : 'es') + ' sin aprobar');
    });
  }

  /* ---------- Export CSV ---------- */
  /* toggle Board / Lista */
  $('export-csv').addEventListener('click', () => {
    const cols = ['created_at','first_name','last_name','email','message','status','channel','gclid','utm_source','utm_campaign','landing_path','lang','session_id'];
    const csvCell = (v) => '"' + String(v ?? '').replace(/"/g, '""') + '"';
    const csv = [cols.join(',')].concat(
      filteredLeads().map((r) => cols.map((c) => csvCell(r[c])).join(','))
    ).join('\n');
    const a = document.createElement('a');
    a.href = URL.createObjectURL(new Blob(['﻿' + csv], { type: 'text/csv;charset=utf-8' }));
    a.download = 'viven-leads-' + new Date().toISOString().slice(0, 10) + '.csv';
    a.click();
    URL.revokeObjectURL(a.href);
  });

  /* ---------- ANALYTICS ---------- */
  function countBy(rows, key){
    const m = new Map();
    rows.forEach((r) => {
      const k = r[key] || '(sin dato)';
      m.set(k, (m.get(k) || 0) + 1);
    });
    return [...m.entries()].sort((a, b) => b[1] - a[1]);
  }
  function bars(el, entries, max, valFmt){
    const top = entries.slice(0, max || 10);
    const peak = top.length ? top[0][1] : 1;
    el.innerHTML = top.map(([k, v, extra]) =>
      '<div class="bar-row"><span class="lbl" title="' + esc(k) + '">' + esc(k) + '</span>' +
      '<span class="track"><span class="fill" style="width:' + Math.max(2, Math.round((v / peak) * 100)) + '%"></span></span>' +
      '<span class="val">' + (valFmt ? valFmt(v, extra) : v) + '</span></div>'
    ).join('') || '<p class="muted-note">Sin datos todavía.</p>';
  }

  /* tabla de rendimiento: canal/página → sesiones, leads y % de conversión */
  // clickable: 'channel' | 'landing' — qué filtro de Personas setea el click en el
  // número de leads (pedido explícito: "eso tiene que ser un shortcut a esos leads,
  // asi entiendo si son buenos o no de ese canal" — antes solo funcionaba en la
  // tabla de Canales, no en "¿Qué páginas convierten?")
  function perfTable(el, list, opts){
    const clickable = opts && opts.clickable;
    const withRate = list.map((r) => ({ ...r, rate: r.sessions ? (r.leads / r.sessions * 100) : 0 }))
      .sort((a, b) => (b.leads - a.leads) || (b.sessions - a.sessions));
    const maxRate = Math.max(1, ...withRate.map((r) => r.rate));
    el.innerHTML = withRate.slice(0, 8).map((r) =>
      '<tr>' +
        '<td>' + (r.badge ? '<span class="badge b-' + esc(r.key) + '">' + esc(r.label) + '</span>' : '<span title="' + esc(r.label) + '">' + esc(r.label) + '</span>') + '</td>' +
        '<td class="num">' + r.sessions + '</td>' +
        '<td class="num">' + (clickable && r.leads
          ? '<span class="lead-n perf-lead-click" data-val="' + esc(r.key) + '" title="Ver estos leads en Personas" style="cursor:pointer;text-decoration:underline dotted">' + r.leads + '</span>'
          : '<span class="lead-n' + (r.leads ? '' : ' zero') + '">' + r.leads + '</span>') + '</td>' +
        '<td class="num"><span class="rate-cell"><span class="rate-bar"><i style="width:' + Math.round((r.rate / maxRate) * 100) + '%"></i></span><span class="rate-num">' + (r.sessions ? r.rate.toFixed(1) + '%' : '—') + '</span></span></td>' +
      '</tr>'
    ).join('') || '<tr><td colspan="4" class="muted-note" style="padding:14px">Sin datos todavía.</td></tr>';
    if (clickable) el.querySelectorAll('.perf-lead-click').forEach((sp) => sp.addEventListener('click', (ev) => {
      ev.stopPropagation();
      if (clickable === 'landing') landingFilter = sp.dataset.val; else channelFilter = sp.dataset.val;
      psStage = 'all';
      gotoTab('leads'); renderLeads();
    }));
  }

  /* ---------- Funnel de ventas: conversión + tiempo entre etapas ---------- */
  function renderFunnel(leads, targetId){
    const set = (leads || []).filter((l) => !/^claude-/.test(l.session_id || ''));
    const steps = [
      { key: 'lead',       label: 'Leads',      ts: (l) => l.created_at },
      { key: 'contactado', label: 'Contactado', ts: (l) => l.contacted_at },
      { key: 'videocall',  label: 'Video Call', ts: (l) => l.videocall_at },
      { key: 'propuesta',  label: 'Propuesta enviada', ts: (l) => l.proposal_at },
      { key: 'ganado',     label: 'Ganado',     ts: (l) => l.won_at },
    ];
    const rows = steps.map((s) => ({ ...s, n: set.filter((l) => s.ts(l)).length, list: set.filter((l) => s.ts(l)) }));
    const top = Math.max(1, rows[0].n);
    const fmtDur = (d) => d >= 14 ? (d / 7).toFixed(1) + ' sem' : d.toFixed(1) + ' d';
    let html = '';
    rows.forEach((s, i) => {
      const prev = i ? rows[i - 1].n : s.n;
      const conv = i ? (prev ? Math.round(s.n / prev * 100) : 0) : 100;
      let avg = '—';
      if (i) {
        const prevTs = rows[i - 1].ts;
        const diffs = s.list.map((l) => { const a = Date.parse(s.ts(l)), b = Date.parse(prevTs(l)); return (a && b && a >= b) ? (a - b) / 864e5 : null; }).filter((x) => x != null);
        if (diffs.length) avg = fmtDur(diffs.reduce((a, b) => a + b, 0) / diffs.length);
      }
      const color = (STAGES.find((x) => x.key === s.key) || {}).color || '#8ab4ff';
      html += '<div class="fn-row"><div class="fn-label">' + s.label + '</div>' +
        '<div class="fn-bar-wrap"><div class="fn-bar" style="width:' + Math.max(5, Math.round(s.n / top * 100)) + '%;background:' + color + '"><span class="fn-n">' + s.n + '</span></div></div>' +
        '<div class="fn-meta">' + (i ? '<b>' + conv + '%</b><span>' + avg + '</span>' : '<b>100%</b><span>base</span>') + '</div></div>';
    });
    const won = rows[4].n, lost = set.filter((l) => l.lost_at).length, dec = won + lost;
    html += '<div class="fn-foot">Perdidos <b>' + lost + '</b> · Cierre (ganado / decididos) <b>' + (dec ? Math.round(won / dec * 100) + '%' : '—') + '</b>' +
      ' · <span class="fn-hint">los tiempos se miden arrastrando los leads por las etapas en orden</span></div>';
    $(targetId || 'funnel').innerHTML = html;
  }

  /* ▲▼% vs período anterior: verde sube / rojo baja / gris sin cambio */
  function setDelta(id, cur, prev){
    const el = $(id); if (!el) return;
    if (!prev && !cur){ el.textContent = '='; el.className = 'kdelta flat'; return; }
    if (!prev){ el.textContent = '▲ nuevo'; el.className = 'kdelta up'; return; }
    const pct = (cur - prev) / prev * 100;
    if (Math.abs(pct) < 0.05){ el.textContent = '='; el.className = 'kdelta flat'; return; }
    el.textContent = (pct > 0 ? '▲ +' : '▼ ') + pct.toFixed(Math.abs(pct) >= 10 ? 0 : 1) + '%';
    el.className = 'kdelta ' + (pct > 0 ? 'up' : 'down');
  }

  function renderAnalytics(rows, leads){
    /* fuera las sesiones/leads de prueba */
    const real = rows.filter((r) => !/^claude-/.test(r.session_id || ''));
    const entries = real.filter((r) => r.is_entry);
    const sessions = new Set(real.map((r) => r.session_id));
    const periodLeads = (leads || []).filter((l) =>
      inRange(l.created_at) && !/^claude-/.test(l.session_id || ''));

    /* KPIs — la conversión = lead real enviado (fiable, no depende del pageview) */
    $('ka-views').textContent = real.length;
    $('ka-sessions').textContent = sessions.size;
    const durs = real.filter((r) => r.duration > 0);
    const avg = durs.length ? durs.reduce((a, r) => a + r.duration, 0) / durs.length : 0;
    $('ka-time').textContent = fmtTime(avg);
    $('ka-conv').textContent = periodLeads.length;
    $('ka-rate').textContent = sessions.size ? (periodLeads.length / sessions.size * 100).toFixed(1) + '%' : '—';

    /* ▲▼ vs el período anterior de igual longitud (pageviews de prevViews, leads por created_at) */
    const pReal = (prevViews || []).filter((r) => !/^claude-/.test(r.session_id || ''));
    const pSessions = new Set(pReal.map((r) => r.session_id));
    const pLeads = (leads || []).filter((l) => {
      if (/^claude-/.test(l.session_id || '')) return false;
      const t = new Date(l.created_at).getTime();
      return t >= prevWin.start && t <= prevWin.end;
    });
    const pDurs = pReal.filter((r) => r.duration > 0);
    const pAvg = pDurs.length ? pDurs.reduce((a, r) => a + r.duration, 0) / pDurs.length : 0;
    setDelta('ka-sessions-d', sessions.size, pSessions.size);
    setDelta('ka-views-d', real.length, pReal.length);
    setDelta('ka-time-d', avg, pAvg);
    setDelta('ka-conv-d', periodLeads.length, pLeads.length);
    setDelta('ka-rate-d', sessions.size ? periodLeads.length / sessions.size : 0, pSessions.size ? pLeads.length / pSessions.size : 0);

    /* tráfico + leads por día (anclado al fin de la ventana) */
    const span = rangeSpanDays();
    const anchor = rangeEnd();
    const dl = $('daily-label'); if (dl) dl.textContent = '(' + rangeLabel().toLowerCase() + ' vs anterior)';
    const spanMs = span * 864e5; // corrimiento para alinear día a día con la ventana previa
    const days = [];
    for (let i = span - 1; i >= 0; i--) {
      const d = new Date(anchor - i * 864e5);
      days.push({ key: d.toISOString().slice(0, 10), pkey: new Date(d.getTime() - spanMs).toISOString().slice(0, 10), label: d.toLocaleDateString('es-CH', { day: '2-digit', month: 'short' }), set: new Set(), pset: new Set(), leads: 0 });
    }
    const dayMap = new Map(days.map((d) => [d.key, d]));
    const prevDayMap = new Map(days.map((d) => [d.pkey, d]));
    real.forEach((r) => { const d = dayMap.get(r.created_at.slice(0, 10)); if (d) d.set.add(r.session_id); });
    pReal.forEach((r) => { const d = prevDayMap.get(r.created_at.slice(0, 10)); if (d) d.pset.add(r.session_id); });
    periodLeads.forEach((l) => { const d = dayMap.get(l.created_at.slice(0, 10)); if (d) d.leads++; });
    /* gráfico SVG real: área + línea de sesiones, puntos de leads, línea punteada del período anterior */
    const n = days.length, W = 1000, H = 260, padL = 42, padR = 14, padT = 16, padB = 28;
    const pw = W - padL - padR, ph = H - padT - padB, baseY = padT + ph;
    const maxS = Math.max(1, ...days.map((d) => d.set.size), ...days.map((d) => d.pset.size));
    const X = (i) => padL + (n <= 1 ? pw / 2 : (i / (n - 1)) * pw);
    const Y = (v) => padT + (1 - v / maxS) * ph;
    const pts = days.map((d, i) => [X(i), Y(d.set.size)]);
    const linePath = pts.map((p, i) => (i ? 'L' : 'M') + p[0].toFixed(1) + ' ' + p[1].toFixed(1)).join(' ');
    const areaPath = 'M' + X(0).toFixed(1) + ' ' + baseY + ' ' + pts.map((p) => 'L' + p[0].toFixed(1) + ' ' + p[1].toFixed(1)).join(' ') + ' L' + X(n - 1).toFixed(1) + ' ' + baseY + ' Z';
    const prevPath = days.map((d, i) => (i ? 'L' : 'M') + X(i).toFixed(1) + ' ' + Y(d.pset.size).toFixed(1)).join(' ');
    const grid = [0, 0.5, 1].map((t) => {
      const v = Math.round(maxS * t), y = Y(v);
      return '<line x1="' + padL + '" y1="' + y.toFixed(1) + '" x2="' + (W - padR) + '" y2="' + y.toFixed(1) + '" class="g-grid"/>' +
        '<text x="' + (padL - 8) + '" y="' + (y + 4).toFixed(1) + '" class="g-yl">' + v + '</text>';
    }).join('');
    const leadDots = days.map((d, i) => d.leads ? '<circle cx="' + X(i).toFixed(1) + '" cy="' + Y(d.set.size).toFixed(1) + '" r="' + (3 + Math.min(4, d.leads)) + '" class="g-lead"><title>' + d.label + ': ' + d.leads + ' leads</title></circle>' : '').join('');
    const hover = days.map((d, i) => '<circle cx="' + X(i).toFixed(1) + '" cy="' + Y(d.set.size).toFixed(1) + '" r="11" fill="transparent"><title>' + d.label + ' — ' + d.set.size + ' sesiones · ' + d.leads + ' leads · período anterior: ' + d.pset.size + '</title></circle>').join('');
    const step = Math.max(1, Math.ceil(n / 7));
    const xls = days.map((d, i) => ((i % step === 0) || i === n - 1) ? '<text x="' + X(i).toFixed(1) + '" y="' + (H - 8) + '" class="g-xl" text-anchor="middle">' + d.label + '</text>' : '').join('');
    $('daily-chart').innerHTML = '<svg viewBox="0 0 ' + W + ' ' + H + '" class="gsvg">' +
      '<defs><linearGradient id="gfill" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#ddf98f" stop-opacity=".28"/><stop offset="1" stop-color="#ddf98f" stop-opacity="0"/></linearGradient></defs>' +
      grid + '<path d="' + prevPath + '" class="g-prev"/><path d="' + areaPath + '" fill="url(#gfill)"/><path d="' + linePath + '" class="g-line"/>' + leadDots + hover + xls + '</svg>';

    /* funnel del período: del tráfico al cierre */
    renderAnaFunnel(sessions.size, periodLeads);

    /* rendimiento por CANAL: sesiones vs leads */
    const chSessions = new Map();
    entries.forEach((e) => { const k = e.channel || 'direct'; chSessions.set(k, (chSessions.get(k) || 0) + 1); });
    const chLeads = new Map();
    periodLeads.forEach((l) => { const k = l.channel || 'direct'; chLeads.set(k, (chLeads.get(k) || 0) + 1); });
    const chKeys = new Set([...chSessions.keys(), ...chLeads.keys()]);
    const channelPerf = [...chKeys].map((k) => ({ key: k, label: k, badge: true, sessions: chSessions.get(k) || 0, leads: chLeads.get(k) || 0 }));
    perfTable($('perf-channel'), channelPerf, { clickable: 'channel' });

    /* rendimiento por PÁGINA DE ENTRADA */
    const lpSessions = new Map();
    entries.forEach((e) => { const k = e.path || '/'; lpSessions.set(k, (lpSessions.get(k) || 0) + 1); });
    const lpLeads = new Map();
    periodLeads.forEach((l) => { const k = l.landing_path || '(sin dato)'; lpLeads.set(k, (lpLeads.get(k) || 0) + 1); });
    const lpKeys = new Set([...lpSessions.keys(), ...lpLeads.keys()]);
    const landingPerf = [...lpKeys].map((k) => ({ key: k, label: k, sessions: lpSessions.get(k) || 0, leads: lpLeads.get(k) || 0 }));
    perfTable($('perf-landing'), landingPerf, { clickable: 'landing' });

    /* REFERRERS externos: hostname del referrer de la ENTRADA de cada sesión.
       La atribución de leads es por session_id (igual espíritu que la tabla de canales). */
    const refBySess = new Map();
    entries.forEach((e) => {
      if (!e.referrer || !e.session_id || refBySess.has(e.session_id)) return;
      let h = '';
      try { h = new URL(e.referrer).hostname.replace(/^www\./, ''); } catch (err) { return; }
      if (!h || h === 'viven.ch' || h.endsWith('.viven.ch')) return; // navegación interna no cuenta
      refBySess.set(e.session_id, h);
    });
    const refSessN = new Map();
    refBySess.forEach((h) => refSessN.set(h, (refSessN.get(h) || 0) + 1));
    const refLeadsN = new Map();
    periodLeads.forEach((l) => { const h = l.session_id && refBySess.get(l.session_id); if (h) refLeadsN.set(h, (refLeadsN.get(h) || 0) + 1); });
    const refPerf = [...refSessN.keys()]
      .map((h) => ({ key: h, label: h, sessions: refSessN.get(h) || 0, leads: refLeadsN.get(h) || 0 }))
      .sort((a, b) => (b.leads - a.leads) || (b.sessions - a.sessions)).slice(0, 10);
    perfTable($('perf-ref'), refPerf);

    /* resumen compacto para los insights con IA */
    insightsData = {
      periodo: rangeLabel(),
      sesiones: sessions.size,
      paginas_vistas: real.length,
      tiempo_medio_seg: Math.round(avg),
      leads: periodLeads.length,
      tasa_conversion_pct: sessions.size ? +(periodLeads.length / sessions.size * 100).toFixed(2) : 0,
      canales: channelPerf.map((c) => ({ canal: c.label, sesiones: c.sessions, leads: c.leads })).slice(0, 8),
      paginas_entrada: landingPerf.map((p) => ({ path: p.label, sesiones: p.sessions, leads: p.leads })).slice(0, 8),
      referrers: refPerf.map((r) => ({ sitio: r.label, sesiones: r.sessions, leads: r.leads })).slice(0, 8),
    };

    /* insights automáticos (cache diario por navegador; el ↻ los fuerza) */
    autoInsights(false);

    /* dispositivos / idiomas */
    bars($('bars-device'), countBy(real, 'device'), 3);
    bars($('bars-lang'), countBy(entries, 'lang'), 8);

    /* top páginas por engagement (visitas + tiempo) */
    const byPath = new Map();
    real.forEach((r) => {
      const p = byPath.get(r.path) || { views: 0, dur: 0, durN: 0 };
      p.views++;
      if (r.duration > 0) { p.dur += r.duration; p.durN++; }
      byPath.set(r.path, p);
    });
    const pages = [...byPath.entries()]
      .map(([k, p]) => [k, p.views, p.durN ? p.dur / p.durN : 0])
      .sort((a, b) => b[1] - a[1]);
    bars($('bars-pages'), pages, 15, (v, t) => v + ' <small>· ' + fmtTime(t) + '</small>');
  }

  /* Funnel del período (sub-tab Web): arranca en SESIONES (tráfico) y baja hasta ganado.
     Adaptado de renderFunnel (Home/Personas) SIN tocarlo — acá la base es el tráfico y
     los pasos se cuentan sobre los leads CREADOS en el período (sus timestamps de etapa). */
  function renderAnaFunnel(sessionCount, periodLeads){
    const el = $('ana-funnel'); if (!el) return;
    const stColor = (k) => (STAGES.find((x) => x.key === k) || {}).color || '#8ab4ff';
    const steps = [
      { label: 'Sesiones',   n: sessionCount, color: '#8ab4ff' },
      { label: 'Leads',      n: periodLeads.length, color: stColor('lead') },
      { label: 'Video Call', n: periodLeads.filter((l) => l.videocall_at).length, color: stColor('videocall') },
      { label: 'Propuesta',  n: periodLeads.filter((l) => l.proposal_at).length, color: stColor('propuesta') },
      { label: 'Ganado',     n: periodLeads.filter((l) => l.won_at).length, color: stColor('ganado') },
    ];
    const top = Math.max(1, steps[0].n);
    el.innerHTML = steps.map((s, i) => {
      const prev = i ? steps[i - 1].n : s.n;
      const conv = i ? (prev ? Math.round(s.n / prev * 100) : 0) : 100;
      return '<div class="fn-row"><div class="fn-label">' + s.label + '</div>' +
        '<div class="fn-bar-wrap"><div class="fn-bar" style="width:' + Math.max(5, Math.round(s.n / top * 100)) + '%;background:' + s.color + '"><span class="fn-n">' + s.n + '</span></div></div>' +
        '<div class="fn-meta">' + (i ? '<b>' + conv + '%</b><span>del paso previo</span>' : '<b>100%</b><span>base</span>') + '</div></div>';
    }).join('') + '<div class="fn-foot">Cada % es sobre el paso anterior · leads creados en ' + esc(rangeLabel().toLowerCase()) + '</div>';
  }

  /* =================== OFFER TOOL (Kostenkalkulation) =================== */
  /* Rate card con tarifas reales de Viven (Moco). price = precio al cliente, cost = costo externo (freelancer/rental). */
  const RATECARD = {
    'Development': [
      { name: 'Concept / Treatment', unit: 'Fix', price: 800, cost: 0 },
      { name: 'Scriptwriting', unit: 'Fix', price: 600, cost: 0 },
      { name: 'Storyboard', unit: 'Fix', price: 500, cost: 0 },
      { name: 'Casting', unit: 'Std', price: 120, cost: 0 },
    ],
    'Pre-Production': [
      { name: 'Producer', unit: 'Std', price: 120, cost: 0 },
      { name: '1st AC', unit: 'Std', price: 60, cost: 0 },
      { name: 'Project Admin', unit: 'Fix', price: 300, cost: 0 },
      { name: 'Scouting (Producer)', unit: 'Std', price: 120, cost: 0 },
    ],
    'Production': [
      { name: 'Producer', unit: 'Tag', price: 950, cost: 0 },
      { name: 'Director of Photography', unit: 'Tag', price: 1000, cost: 800 },
      { name: 'Gaffer', unit: 'Tag', price: 700, cost: 670 },
      { name: 'Sound / Audio', unit: 'Tag', price: 800, cost: 750 },
      { name: 'Sony FX6 (Kit)', unit: 'Tag', price: 250, cost: 0 },
      { name: 'Lenses Set', unit: 'Tag', price: 100, cost: 0 },
      { name: '3-Point LED Kit', unit: 'Tag', price: 250, cost: 0 },
      { name: 'Ronin RS3 Pro', unit: 'Tag', price: 60, cost: 0 },
      { name: 'Van inkl. km', unit: 'Tag', price: 120, cost: 0 },
      { name: 'Per Diems', unit: 'Person', price: 32, cost: 32 },
    ],
    'Post-Production': [
      { name: 'Editor inkl. Suite + Color', unit: 'Tag', price: 950, cost: 550 },
      { name: 'Motion / VFX Animation', unit: 'Tag', price: 900, cost: 750 },
      { name: 'Music license', unit: 'Stk', price: 60, cost: 60 },
      { name: 'Additional Correction Round', unit: 'Tag', price: 950, cost: 550 },
    ],
    'Delivery': [
      { name: 'Master exports / Formate', unit: 'Fix', price: 200, cost: 0 },
      { name: 'Untertitel / Subtitles', unit: 'Sprache', price: 120, cost: 0 },
      { name: 'Social cutdowns (15s/9:16)', unit: 'Stk', price: 250, cost: 0 },
    ],
  };
  const PHASES = Object.keys(RATECARD);   // Development · Pre-Production · Production · Post-Production · Delivery
  const fmtM = (n) => 'CHF ' + (Number(n) || 0).toLocaleString('de-CH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  // Facturación y Portal del cliente: pausadas a pedido de Sebastián (2026-07-12)
  // — demasiadas features nuevas juntas, las retomamos más adelante mejor
  // pulidas. El código y las tablas quedan intactos, solo se ocultan los
  // botones/paneles — reactivar es cambiar estos dos a true.
  const FEATURE_INVOICING = false;
  const FEATURE_PORTAL = false;
  let offersList = [], ofCur = null, offersBuilt = false, inquiryFromLead = '', curInvoice = null, ofDragI = null;
  /* ---- editor V3: pasos, chips de estado, autosave, toggle de costos internos ---- */
  let of3Step = 1, ofLastSaved = 0, ofSaving = false, ofAutoT = null;
  let ofShowCosts = localStorage.getItem('vv_of_costs') !== '0';
  const OF3_STEPS = [[1, '① Cliente'], [2, '② Posiciones'], [3, '③ Condiciones'], [4, '④ Enviar']];
  function of3Go(n){
    of3Step = n;
    for (let i = 1; i <= 4; i++){ const s = $('of3-sec-' + i); if (s) s.hidden = i !== n; }
    renderOf3Steps();
    if (n === 4) renderOf3Send();
  }
  function renderOf3Steps(){
    const box = $('of3-steps'); if (!box) return;
    box.innerHTML = OF3_STEPS.map(([n, l]) => '<button type="button" class="of3-chip' + (n === of3Step ? ' on' : '') + '" data-n="' + n + '">' + l + '</button>').join('');
    box.querySelectorAll('button').forEach((b) => b.addEventListener('click', () => of3Go(+b.dataset.n)));
  }
  function renderOf3Status(){
    const box = $('of3-status'); if (!box || !ofCur) return;
    const st = ofCur.status || 'draft';
    box.innerHTML = [['draft', 'Borrador'], ['sent', 'Enviada'], ['won', 'Ganada'], ['lost', 'Perdida']]
      .map(([k, l]) => '<button type="button" class="of3-chip st' + (st === k ? ' on' : '') + '" data-k="' + k + '">' + l + '</button>').join('');
    // 'tier' y template ya no son estados en la UI: etiquetas al costado (el valor guardado NO se toca)
    $('of3-flags').innerHTML =
      (st === 'tier' ? '<span class="of-badge" style="color:#c58af9;border-color:#c58af9">Paquete de propuesta</span>' : '') +
      (ofCur.is_template ? '<span class="of-badge">📋 Template</span>' : '');
    box.querySelectorAll('button').forEach((b) => b.addEventListener('click', () => {
      $('of-status').value = b.dataset.k;
      $('of-status').dispatchEvent(new Event('change'));   // corre el handler de siempre (prompt de motivo si es Perdida, etc.)
      renderOf3Status();
      ofMarkDirty();
    }));
  }
  function applyCostVis(){
    $('of-editor').classList.toggle('of3-nocost', !ofShowCosts);
    const b = $('of3-costs'); if (b) b.textContent = ofShowCosts ? '👁 Costos internos: ON' : '👁 Costos internos: OFF';
  }
  function ofMarkDirty(){
    if (!ofCur || $('of-editor').hidden) return;
    clearTimeout(ofAutoT);
    ofAutoT = setTimeout(() => {
      // autosave solo con algo que guardar (no crear filas vacías mientras tipeás la primera letra)
      if (ofCur && !$('of-editor').hidden && !ofSaving && ($('of-title').value.trim() || (ofCur.items || []).length)) saveOffer(true);
    }, 2000);
  }
  function offersInit(){ buildPresetSelect(); if (!offersBuilt){ offersBuilt = true; bindOffers(); } showEditor(false); offersLoad(); }

  /* ================= A/B TESTS: variantes servidas por site.js =================
     El wizard analiza la página (fetch same-origin + DOMParser), extrae H1/lead/
     CTAs/imágenes editables, guarda los cambios en ab_tests y el sitio hace el
     resto: split por visitante, exposiciones en ab_hits y leads taggeados (.ab). */
  let abBuilt = false, abTests = [], abCands = [], abEditing = null;
  let abExpandedId = null, abExp = {}, abLeadsCache = [];
  function abInit(){
    if (!abBuilt){
      abBuilt = true;
      $('ab-new').addEventListener('click', () => { abEditing = null; $('ab-wiz').hidden = false; $('ab-editor').hidden = true; $('ab-url').value = ''; $('ab-wiz-note').textContent = ''; });
      $('ab-cancel').addEventListener('click', () => { $('ab-wiz').hidden = true; });
      $('ab-analyze').addEventListener('click', abAnalyze);

      // Google Ads — conversiones offline (CSV con el formato exacto del import oficial)
      const adsIsWon = (r) => /ganado|won|cerrado/i.test(r.status || '');
      const adsOk = (r) => !r.ads_exclude && !ADS_LEAD_TEST_RE.test(r.email || '') && !/spam|descartado|perdido-spam/i.test(r.status || '');
      const adsFetch = async () => {
        let q = await supabase.from('leads').select('id,gclid,name,email,deal_value,status,created_at,won_at,last_stage_at,utm_campaign,ads_exclude').not('gclid', 'is', null);
        if (q.error && /column/.test(q.error.message || '')) q = await supabase.from('leads').select('id,gclid,name,email,deal_value,status,created_at,won_at,last_stage_at,utm_campaign').not('gclid', 'is', null);
        return q;
      };
      const chf = (n) => 'CHF ' + (+n || 0).toLocaleString('de-CH');

      /* ======= tabla ÚNICA de campañas: merge Google (gasto/clicks) + CRM (leads/ganados/ROAS) =======
         Junta por nombre normalizado (Google `campaign.name` vs `leads.utm_campaign`) — coincidencia
         exacta o contención (evita duplicar filas cuando el nombre no es carácter-por-carácter igual). */
      const normCamp = (s) => (s || '').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, ' ').trim();
      function mergeCampaigns(googleCamps, byCamp){
        const used = new Set(), rows = [];
        (googleCamps || []).forEach((g) => {
          const gn = normCamp(g.name);
          let matchKey = null;
          Object.keys(byCamp).forEach((k) => {
            if (matchKey || used.has(k) || k === '(sin campaña)') return;
            const kn = normCamp(k);
            if (kn && (kn === gn || (kn.length > 3 && gn.includes(kn)) || (gn.length > 3 && kn.includes(gn)))) matchKey = k;
          });
          const crm = matchKey ? byCamp[matchKey] : null;
          if (matchKey) used.add(matchKey);
          rows.push({ name: g.name, id: g.id, status: g.status, spend: g.cost, clicks: g.clicks, cpc: g.clicks ? g.cost / g.clicks : 0,
            leads: crm ? crm.leads : 0, won: crm ? crm.won : 0, wonVal: crm ? crm.wonVal : 0, openVal: crm ? crm.openVal : 0, hasGoogle: true, campKey: matchKey || g.name });
        });
        Object.keys(byCamp).forEach((k) => {
          if (used.has(k)) return;
          const crm = byCamp[k];
          rows.push({ name: k, id: null, status: '', spend: 0, clicks: 0, cpc: 0, leads: crm.leads, won: crm.won, wonVal: crm.wonVal, openVal: crm.openVal, hasGoogle: false, campKey: k });
        });
        return rows;
      }
      let gadsMergedRows = [], gadsCampSort = { k: 'spend', dir: -1 };
      function gadsRenderCamps(){
        const cont = $('gads-camps'); if (!cont) return;
        const rows = gadsMergedRows.slice(), k = gadsCampSort.k, dir = gadsCampSort.dir;
        const val = (r) => k === 'name' ? r.name.toLowerCase() : k === 'cpl' ? (r.leads ? r.spend / r.leads : Infinity) : k === 'roas' ? (r.spend ? r.wonVal / r.spend : (r.wonVal ? Infinity : -1)) : (r[k] || 0);
        rows.sort((a, b) => { const av = val(a), bv = val(b); return av < bv ? -dir : av > bv ? dir : 0; });
        if (!rows.length){ cont.innerHTML = '<p class="muted-note">Sin datos todavía — aparecen solas cuando lleguen clicks o leads con gclid.</p>'; return; }
        const sortTh = (label, key, num) => '<th class="lt-sort' + (num ? ' lt-num' : '') + (gadsCampSort.k === key ? ' on' : '') + '" data-k="' + key + '">' + label + (gadsCampSort.k === key ? (dir > 0 ? ' ▲' : ' ▼') : '') + '</th>';
        let html = '<table class="lead-table"><thead><tr>' +
          sortTh('Campaña', 'name') + sortTh('Gasto', 'spend', 1) + sortTh('Clicks', 'clicks', 1) + sortTh('CPC', 'cpc', 1) +
          sortTh('Leads', 'leads', 1) + sortTh('CPL', 'cpl', 1) + sortTh('Ganado', 'wonVal', 1) + sortTh('ROAS', 'roas', 1) + '<th></th></tr></thead><tbody>';
        rows.forEach((r) => {
          const roas = r.spend ? r.wonVal / r.spend : null;
          const sem = !r.leads ? 'bad' : ((roas != null && roas >= 1) || (!r.spend && r.wonVal)) ? 'ok' : 'mid';
          const roasTxt = r.spend ? (roas >= 1 ? '<span class="gads-roas-ok">' + roas.toFixed(1) + '×</span>' : '<span class="gads-roas-bad">' + roas.toFixed(1) + '×</span>') :
            (r.openVal ? '<span class="muted-note">pipeline ' + chf(r.openVal) + '</span>' : '—');
          html += '<tr><td><span class="gads-sem ' + sem + '"></span>' + esc(r.name) + (r.hasGoogle ? '' : ' <span class="muted-note">(solo CRM)</span>') + '</td>' +
            '<td class="lt-num">' + (r.spend ? chf(Math.round(r.spend)) : '—') + '</td>' +
            '<td class="lt-num">' + (r.hasGoogle ? r.clicks : '—') + '</td>' +
            '<td class="lt-num">' + (r.clicks ? chf(r.cpc.toFixed(2)) : '—') + '</td>' +
            '<td class="lt-num">' + r.leads + '</td>' +
            '<td class="lt-num">' + (r.leads ? chf(Math.round(r.spend / r.leads)) : '—') + '</td>' +
            '<td class="lt-num">' + (r.wonVal ? chf(r.wonVal) : '—') + '</td>' +
            '<td class="lt-num">' + roasTxt + '</td>' +
            '<td><div class="gads-camp-acts">' +
              '<button type="button" data-camp-leads="' + esc(r.campKey) + '" title="Ver leads de esta campaña">👁</button>' +
              (r.id ? '<button type="button" data-camp-st="' + esc(r.id) + '" title="Ver search terms de esta campaña">🔎</button>' : '') +
            '</div></td></tr>';
        });
        cont.innerHTML = html + '</tbody></table>';
        cont.querySelectorAll('th.lt-sort').forEach((th) => th.addEventListener('click', () => {
          const k2 = th.dataset.k;
          gadsCampSort = gadsCampSort.k === k2 ? { k: k2, dir: -gadsCampSort.dir } : { k: k2, dir: k2 === 'name' ? 1 : -1 };
          gadsRenderCamps();
        }));
        cont.querySelectorAll('[data-camp-leads]').forEach((b) => b.addEventListener('click', () => {
          gadsContactsFilter = b.dataset.campLeads; gadsRenderList();
          const det = document.querySelector('#ana-sub-gads details.bg-group'); if (det) det.open = true;
          $('gads-list').scrollIntoView({ behavior: 'smooth', block: 'center' });
        }));
        cont.querySelectorAll('[data-camp-st]').forEach((b) => b.addEventListener('click', () => {
          gadsStCampFilter = b.dataset.campSt; gadsRenderSearchTerms();
          $('gads-searchterms').scrollIntoView({ behavior: 'smooth', block: 'center' });
        }));
      }

      // sparkline de gasto diario (ads_daily) + puntos de leads — reusa .g-line/.g-lead del chart grande
      function gadsRenderSpark(dailyRows, curLeads){
        const box = $('gads-spark'), note = $('gads-spark-note');
        if (!dailyRows || !dailyRows.length){
          if (box) box.innerHTML = '';
          if (note) note.textContent = 'Todavía no hay historia diaria guardada — arranca sola con el próximo sync de las 06:50 (SQL 0066). El gasto de arriba es en vivo desde Google mientras tanto.';
          return;
        }
        const byDate = {};
        dailyRows.forEach((r) => { byDate[r.date] = (byDate[r.date] || 0) + (+r.spend || 0); });
        const leadsByDate = {};
        (curLeads || []).forEach((l) => { const d = (l.created_at || '').slice(0, 10); leadsByDate[d] = (leadsByDate[d] || 0) + 1; });
        const dates = Object.keys(byDate).sort();
        const n = dates.length, W = 700, H = 64, pad = 4;
        const maxV = Math.max(1, ...dates.map((d) => byDate[d]));
        const X = (i) => n <= 1 ? W / 2 : pad + (i / (n - 1)) * (W - 2 * pad);
        const Y = (v) => H - 6 - (v / maxV) * (H - 14);
        const pts = dates.map((d, i) => [X(i), Y(byDate[d])]);
        const line = pts.map((p, i) => (i ? 'L' : 'M') + p[0].toFixed(1) + ' ' + p[1].toFixed(1)).join(' ');
        const dots = dates.map((d, i) => leadsByDate[d] ? '<circle cx="' + X(i).toFixed(1) + '" cy="' + Y(byDate[d]).toFixed(1) + '" r="' + (2.5 + Math.min(3, leadsByDate[d])) + '" class="g-lead"><title>' + d + ': ' + chf(Math.round(byDate[d])) + ' · ' + leadsByDate[d] + ' leads</title></circle>' : '').join('');
        if (box) box.innerHTML = '<svg viewBox="0 0 ' + W + ' ' + H + '" class="gads-spark-svg" preserveAspectRatio="none"><path d="' + line + '" class="g-line" fill="none"/>' + dots + '</svg>';
        if (note) note.textContent = 'Gasto diario (línea) + leads (puntos) · últimos ' + n + ' días guardados en ads_daily';
      }

      // pacing de presupuesto: gasto mes-a-la-fecha (GAQL en vivo) vs presupuesto mensual (manual u oficial)
      function gadsRenderPacing(official, settings){
        const fill = $('gads-pace-fill'), txt = $('gads-pace-txt'), warn = $('gads-pace-warn'), mo = $('gads-pace-month');
        const now = new Date();
        if (mo) mo.textContent = ' — ' + now.toLocaleDateString('es-CH', { month: 'long' });
        const officialMonthly = (official && official.budget && official.month) ? official.budget.daily_total * official.month.daysInMonth : 0;
        const monthly = +((settings || {}).monthly_budget) || officialMonthly;
        if (!official || !official.month || !monthly){
          if (fill){ fill.style.width = '0%'; fill.className = ''; }
          if (txt) txt.textContent = (official && official.month) ? 'Completá el presupuesto mensual en ⚙️ Configurar para ver el pacing.' : 'Necesita el gasto oficial de Google (developer token aprobado) o un presupuesto manual en ⚙️ Configurar.';
          if (warn) warn.textContent = '';
          return;
        }
        const spendSoFar = official.month.cost, de = official.month.daysElapsed, dm = official.month.daysInMonth;
        const pct = Math.min(100, Math.round((spendSoFar / monthly) * 100));
        const projected = de ? (spendSoFar / de) * dm : spendSoFar;
        const over = projected > monthly;
        if (fill){ fill.style.width = pct + '%'; fill.className = over ? 'over' : ''; }
        if (txt) txt.textContent = chf(Math.round(spendSoFar)) + ' de ' + chf(monthly) + ' (' + pct + '%) · día ' + de + ' de ' + dm + ' (' + Math.round(de / dm * 100) + '%)';
        if (warn) warn.innerHTML = over
          ? '<span style="color:#ff8b8b">⚠ A este ritmo terminás el mes en ' + chf(Math.round(projected)) + ' — ' + chf(Math.round(projected - monthly)) + ' sobre presupuesto</span>'
          : '<span style="color:#7ed957">✓ A este ritmo terminás el mes en ' + chf(Math.round(projected)) + ', dentro del presupuesto</span>';
      }

      // search terms reales — negativa sugerida: clicks≥2 + término de bajo intento (job/gratis/tutorial/…);
      // no hay forma de unir un search term puntual a un lead/sesión con el esquema actual, así que va por heurística
      const GADS_NEG_RE = /gratis|kostenlos|\bfree\b|\blehre\b|ausbildung|gehalt|praktikum|\bjobs?\b|stelle(n)?|vorlage|\btemplate\b|\bdownload\b|tutorial|anleitung|\bkurs\b|schule|\bapp\b|selber machen|\bdiy\b/i;
      let gadsStRows = [], gadsStSort = { k: 'clicks', dir: -1 }, gadsStCampFilter = null;
      function gadsRenderSearchTerms(){
        const cont = $('gads-searchterms'), copyBtn = $('gads-st-copy'); if (!cont) return;
        let rows = gadsStRows.slice();
        if (gadsStCampFilter) rows = rows.filter((r) => r.campaign_id === gadsStCampFilter);
        if (!rows.length){
          cont.innerHTML = '<p class="muted-note">' + (gadsStCampFilter ? 'Sin search terms para esta campaña en el período. ' : 'Sin datos todavía en este período — llegan cuando Google apruebe el developer token. ') +
            (gadsStCampFilter ? '<a href="#" id="gads-st-clear" style="color:var(--acid)">ver todas</a>' : '') + '</p>';
          if (copyBtn) copyBtn.hidden = true;
          const clr = $('gads-st-clear'); if (clr) clr.addEventListener('click', (ev) => { ev.preventDefault(); gadsStCampFilter = null; gadsRenderSearchTerms(); });
          return;
        }
        const k = gadsStSort.k, dir = gadsStSort.dir;
        rows.sort((a, b) => { const av = a[k], bv = b[k]; return av < bv ? -dir : av > bv ? dir : 0; });
        const sortTh = (label, key) => '<th class="lt-sort lt-num' + (gadsStSort.k === key ? ' on' : '') + '" data-k="' + key + '">' + label + (gadsStSort.k === key ? (dir > 0 ? ' ▲' : ' ▼') : '') + '</th>';
        let html = (gadsStCampFilter ? '<p class="muted-note" style="margin-bottom:8px">Filtrado por campaña · <a href="#" id="gads-st-clear" style="color:var(--acid)">ver todas</a></p>' : '') +
          '<table class="lead-table"><thead><tr><th>Search term</th>' + sortTh('Clicks', 'clicks') + sortTh('CHF', 'cost') + '<th></th></tr></thead><tbody>';
        const negatives = [];
        rows.forEach((r) => {
          const neg = r.clicks >= 2 && GADS_NEG_RE.test(r.term);
          if (neg) negatives.push(r.term);
          html += '<tr><td>' + esc(r.term) + (r.campaign ? ' <span class="muted-note">· ' + esc(r.campaign) + '</span>' : '') + '</td>' +
            '<td class="lt-num">' + r.clicks + '</td><td class="lt-num">' + Math.round(r.cost) + '</td>' +
            '<td>' + (neg ? '<span class="gads-negflag">🗑 negativa sugerida</span>' : '<span class="gads-okflag">✓ trae clicks limpios</span>') + '</td></tr>';
        });
        cont.innerHTML = html + '</tbody></table>';
        cont.querySelectorAll('th.lt-sort').forEach((th) => th.addEventListener('click', () => {
          const k2 = th.dataset.k;
          gadsStSort = gadsStSort.k === k2 ? { k: k2, dir: -gadsStSort.dir } : { k: k2, dir: -1 };
          gadsRenderSearchTerms();
        }));
        const clr = $('gads-st-clear'); if (clr) clr.addEventListener('click', (ev) => { ev.preventDefault(); gadsStCampFilter = null; gadsRenderSearchTerms(); });
        if (copyBtn){
          copyBtn.hidden = !negatives.length;
          copyBtn.onclick = () => { navigator.clipboard.writeText(negatives.join('\n')).then(() => toast('📋 ' + negatives.length + ' negativas copiadas — pegalas en Google Ads')).catch(() => toast('No se pudo copiar')); };
        }
      }

      // contactos: misma lista de siempre + toggle 🎯/🚫 inline (antes solo se podía desde la ficha)
      let gadsContactsFilter = null;
      function gadsRenderList(){
        const cont = $('gads-list'); if (!cont) return;
        let all = (allLeads || []).filter((r) => r.gclid);
        if (gadsContactsFilter) all = all.filter((r) => (r.utm_campaign || '(sin campaña)') === gadsContactsFilter);
        $('gads-nlist').textContent = all.length;
        cont.innerHTML = (gadsContactsFilter ? '<p class="muted-note" style="margin-bottom:8px">Filtrado por campaña: <b>' + esc(gadsContactsFilter) + '</b> · <a href="#" id="gads-clear-filter" style="color:var(--acid)">quitar filtro</a></p>' : '') +
          (all.map((r) => {
            const out = !adsOk(r);
            return '<div class="of-card"><div class="of-card-open" data-glead="' + r.id + '">' +
              '<div class="of-card-main"><div class="of-card-title">' + (out ? '🚫 ' : '🎯 ') + esc(r.name || r.email || '(sin nombre)') + (adsIsWon(r) ? ' <span class="of-badge" style="color:#7ed957;border-color:#7ed957">Ganado</span>' : '') + '</div>' +
              '<div class="of-card-sub">' + esc(r.email || '') + ' · ' + esc(r.utm_campaign || 'sin campaña') + ' · ' + new Date(r.created_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short' }) + (out ? ' · <b>no se reporta</b>' : '') + '</div></div>' +
              '<span class="of-badge">' + chf(r.deal_value) + '</span>' +
              '<button type="button" class="gads-lead-x" data-toggle-x="' + r.id + '">' + (out ? '🎯 incluir' : '🚫 excluir') + '</button>' +
              '</div></div>';
          }).join('') || '<p class="muted-note">Todavía no llegó ningún lead desde Ads.</p>');
        cont.querySelectorAll('[data-glead]').forEach((c) => c.addEventListener('click', () => { gotoTab('leads'); openLead(c.dataset.glead); }));
        cont.querySelectorAll('[data-toggle-x]').forEach((b) => b.addEventListener('click', async (ev) => {
          ev.stopPropagation();
          const id = b.dataset.toggleX, l = (allLeads || []).find((x) => String(x.id) === String(id)); if (!l) return;
          const nv = !l.ads_exclude;
          const { error } = await supabase.from('leads').update({ ads_exclude: nv }).eq('id', id);
          if (error){ toast(/column/.test(error.message || '') ? 'Falta correr el SQL 0036 (columna ads_exclude)' : 'No se pudo: ' + error.message); return; }
          l.ads_exclude = nv;
          if (typeof currentLead !== 'undefined' && currentLead && String(currentLead.id) === String(id)) currentLead.ads_exclude = nv;
          toast(nv ? '🚫 Excluido del ROAS de Ads' : '🎯 Incluido de nuevo');
          window.gadsLoad();
        }));
        const clearBtn = $('gads-clear-filter');
        if (clearBtn) clearBtn.addEventListener('click', (ev) => { ev.preventDefault(); gadsContactsFilter = null; gadsRenderList(); });
      }

      window.gadsLoad = async () => {
        adsInfoLoad();
        // el período global manda también acá (adsRoasFor clampa por su lado en gads-stats)
        const gadsDays = Math.max(7, Math.min(365, rangeSpanDays()));

        // 1) CRM canónico — MISMA función que usa Home (adsRoasFor): período actual y anterior
        const cur = adsRoasFor(gadsDays, 0), prev = adsRoasFor(gadsDays, gadsDays);

        // 2) datos oficiales de Google (gasto/clicks + mes-a-la-fecha + presupuesto + search terms)
        let official = null, pendingReason = null;
        try {
          const { data: gs } = await supabase.functions.invoke('gads-stats', { body: { days: gadsDays, month: true, budget: true, search_terms: true } });
          if (gs && gs.ok) official = gs; else if (gs && gs.pending) pendingReason = gs.reason || 'Basic access pendiente';
        } catch (e) { /* función aún no deployada */ }
        const pendEl = $('gads-pending');
        if (pendEl){
          pendEl.hidden = !pendingReason;
          // "faltan secrets" = nadie conectó Google Ads todavía (config faltante);
          // cualquier otro reason = credenciales SÍ están, Google está revisando el
          // developer token. Son estados bien distintos, no el mismo mensaje.
          if (/faltan secrets/i.test(pendingReason || '')){
            pendEl.innerHTML = '⚙️ Google Ads todavía no está conectado (' + esc(pendingReason) + ') — el tab funciona con tus datos propios (sesiones gclid, leads, ganados) + el gasto manual hasta que se configuren las credenciales GOOGLE_ADS_*.';
          } else if (pendingReason){
            pendEl.innerHTML = '⏳ El developer token de Google Ads sigue pendiente de aprobación de Google (' + esc(pendingReason) + ') — hasta entonces el gasto/clicks/search terms "oficiales" no llegan. Mientras tanto el tab funciona completo con tus datos propios (sesiones gclid, leads, ganados) + el gasto manual. Cuando Google apruebe, se enciende todo solo, sin tocar nada.';
          }
        }

        // 3) inversión: gasto oficial manda; si no hay, cae a la inversión manual guardada
        let settings = {};
        try { const { data: st } = await supabase.from('ads_settings').select('spend,monthly_budget,last_sync_at,last_sync_leads,last_sync_won,last_sync_error').eq('id', 1).maybeSingle(); settings = st || {}; } catch (e) { /* tabla pendiente (SQL 0037/0067) */ }
        let spend = official ? Math.round(official.total.cost) : 0;
        if (!spend) spend = +settings.spend || +(localStorage.getItem('vv_ads_spend') || 0) || 0;
