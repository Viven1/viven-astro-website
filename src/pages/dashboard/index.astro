  $('ps-csv').addEventListener('change', async (e) => {
    const f = e.target.files[0]; e.target.value = ''; if (!f) return;
    const rows = parseCSV(await f.text());
    if (rows.length < 2){ toast('CSV vacío (necesita encabezado + filas)'); return; }
    const H = rows[0];
    const ix = {
      first: csvIx(H, ['firstname', 'first', 'nombre', 'vorname']),
      last: csvIx(H, ['lastname', 'last', 'apellido', 'apellidos', 'nachname', 'surname']),
      name: csvIx(H, ['name', 'fullname', 'nombrecompleto']),
      email: csvIx(H, ['email', 'emailaddress', 'correo', 'mail', 'emailadresse']),
      phone: csvIx(H, ['phone', 'phonenumber', 'telefono', 'telefon', 'tel']),
      company: csvIx(H, ['company', 'companyname', 'empresa', 'firma', 'unternehmen']),
      job: csvIx(H, ['jobtitle', 'job', 'cargo', 'rol', 'position', 'puesto', 'funktion']),
      lang: csvIx(H, ['lang', 'language', 'idioma', 'sprache']),
      msg: csvIx(H, ['message', 'mensaje', 'nota', 'notas', 'notes', 'comentario'])
    };
    if (ix.email < 0){ toast('El CSV necesita una columna "email"'); return; }
    const existing = new Set((allLeads || []).map((l) => String(l.email || '').toLowerCase()).filter(Boolean));
    const seen = new Set(); const list = []; let skipped = 0;
    rows.slice(1).forEach((r) => {
      const email = cell(r, ix.email).toLowerCase();
      if (!email || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email) || existing.has(email) || seen.has(email)){ skipped++; return; }
      seen.add(email);
      let first = cell(r, ix.first), last = cell(r, ix.last);
      if (!first && ix.name > -1){ const parts = cell(r, ix.name).split(/\s+/); first = parts[0] || ''; last = parts.slice(1).join(' '); }
      const company = cell(r, ix.company);
      const dom = domainOf(email) || (company ? slugKey(company) : '');
      const lg = cell(r, ix.lang).toLowerCase().slice(0, 2);
      list.push({ name: (first + ' ' + last).trim() || email, first_name: first || null, last_name: last || null, email,
        phone: cell(r, ix.phone) || null, company: company || null, company_domain: dom || null, job_title: cell(r, ix.job) || null,
        lang: ['en', 'de', 'es'].includes(lg) ? lg : 'en', status: 'new', channel: 'import', message: cell(r, ix.msg) || null });
    });
    if (!list.length){ toast('Nada para importar (' + skipped + ' filas saltadas: sin email válido o ya existen)'); return; }
    if (!confirm('¿Importar ' + list.length + ' personas' + (skipped ? ' (' + skipped + ' saltadas por duplicado/email inválido)' : '') + '?')) return;
    try {
      const res = await sbWriteRowsResilient('leads', list, null);
      res.rows.forEach((r) => { if (!allLeads.some((l) => l.id === r.id)) allLeads.unshift(r); });
      // crear las empresas nuevas que vinieron en el CSV
      const cos = {};
      list.forEach((p) => { if (p.company && p.company_domain && !coMeta[p.company_domain]) cos[p.company_domain] = { domain: p.company_domain, name: p.company }; });
      const coRows = Object.values(cos);
      if (coRows.length){ const { data } = await supabase.from('companies').upsert(coRows, { onConflict: 'domain' }).select(); (data || []).forEach((c) => { if (c.domain) coMeta[c.domain] = c; }); }
      renderLeads();
      toast('✅ ' + res.rows.length + ' personas importadas' + (skipped ? ' · ' + skipped + ' saltadas' : '') + (res.stripped.length ? ' · columnas sin guardar: ' + res.stripped.join(', ') : ''));
    } catch (err){ toast('Error importando: ' + err.message); }
  });

  /* ---- Companies: alta manual ---- */
  $('co-new-btn').addEventListener('click', () => { $('co-form').hidden = !$('co-form').hidden; if (!$('co-form').hidden) $('cof-name').focus(); });
  $('cof-cancel').addEventListener('click', () => { $('co-form').hidden = true; });
  $('cof-save').addEventListener('click', async () => {
    const name = $('cof-name').value.trim();
    if (!name){ toast('Poné el nombre de la empresa'); return; }
    const domain = cleanDomain($('cof-domain').value) || slugKey(name);
    const row = { domain, name, industry: $('cof-industry').value.trim() || null, website: $('cof-domain').value.trim() ? 'https://' + domain : null,
      city: $('cof-city').value.trim() || null, employees: $('cof-emp').value.trim() || null, phone: $('cof-phone').value.trim() || null,
      linkedin: $('cof-linkedin').value.trim() || null, owner: $('cof-owner').value.trim() || null, notes: $('cof-notes').value.trim() || null };
    try {
      const res = await sbWriteRowsResilient('companies', [row], 'domain');
      const created = res.rows[0]; if (created && created.domain) coMeta[created.domain] = created;
      ['cof-name', 'cof-domain', 'cof-industry', 'cof-city', 'cof-emp', 'cof-phone', 'cof-linkedin', 'cof-owner', 'cof-notes'].forEach((id) => { $(id).value = ''; });
      $('co-form').hidden = true;
      renderCompaniesList();
      toast('✅ Empresa creada' + (res.stripped.length ? ' (columnas sin guardar: ' + res.stripped.join(', ') + ' — corré el SQL 0011)' : ''));
      if (created && created.domain) openCompany(created.domain);
    } catch (err){ toast('No se pudo crear: ' + err.message); }
  });

  /* ---- Companies: importar CSV ---- */
  $('co-import').addEventListener('click', () => $('co-csv').click());
  $('co-csv').addEventListener('change', async (e) => {
    const f = e.target.files[0]; e.target.value = ''; if (!f) return;
    const rows = parseCSV(await f.text());
    if (rows.length < 2){ toast('CSV vacío (necesita encabezado + filas)'); return; }
    const H = rows[0];
    const ix = {
      name: csvIx(H, ['name', 'companyname', 'nombre', 'empresa', 'firma', 'company', 'unternehmen']),
      domain: csvIx(H, ['domain', 'dominio']),
      web: csvIx(H, ['website', 'web', 'url', 'sitioweb']),
      industry: csvIx(H, ['industry', 'industria', 'branche', 'sector']),
      phone: csvIx(H, ['phone', 'telefono', 'telefon', 'tel']),
      city: csvIx(H, ['city', 'ciudad', 'ort', 'stadt']),
      emp: csvIx(H, ['employees', 'empleados', 'mitarbeiter', 'size', 'numberofemployees']),
      linkedin: csvIx(H, ['linkedin', 'linkedincompanypage', 'linkedinurl']),
      notes: csvIx(H, ['notes', 'notas', 'descripcion', 'description', 'beschreibung'])
    };
    if (ix.name < 0){ toast('El CSV necesita una columna "nombre" o "name"'); return; }
    const seen = new Set(); const list = []; let skipped = 0;
    rows.slice(1).forEach((r) => {
      const name = cell(r, ix.name); if (!name){ skipped++; return; }
      const domain = cleanDomain(cell(r, ix.domain)) || cleanDomain(cell(r, ix.web)) || slugKey(name);
      if (!domain || seen.has(domain)){ skipped++; return; }
      seen.add(domain);
      const web = cell(r, ix.web);
      list.push({ domain, name, industry: cell(r, ix.industry) || null, website: web ? (web.startsWith('http') ? web : 'https://' + cleanDomain(web)) : null,
        phone: cell(r, ix.phone) || null, city: cell(r, ix.city) || null, employees: cell(r, ix.emp) || null,
        linkedin: cell(r, ix.linkedin) || null, notes: cell(r, ix.notes) || null });
    });
    if (!list.length){ toast('Nada para importar'); return; }
    if (!confirm('¿Importar ' + list.length + ' empresas' + (skipped ? ' (' + skipped + ' saltadas)' : '') + '? Las que ya existan por dominio se actualizan.')) return;
    try {
      const res = await sbWriteRowsResilient('companies', list, 'domain');
      res.rows.forEach((c) => { if (c.domain) coMeta[c.domain] = c; });
      renderCompaniesList();
      toast('✅ ' + res.rows.length + ' empresas importadas' + (res.stripped.length ? ' · columnas sin guardar: ' + res.stripped.join(', ') : ''));
    } catch (err){ toast('Error importando: ' + err.message); }
  });

  // abInit() ata los botones de Google Ads / Newsletter / Workflows (quedaron
  // adentro de su guard "una sola vez" por error de copy-paste) — si el guard
  // solo se disparaba al entrar al tab A/B Tests, esos botones quedaban SIN
  // ningún listener (clic = no pasa nada, sin error) hasta que alguien pasara
  // por A/B Tests primero. abInit() ya es idempotente (if(!abBuilt)), así que
  // llamarla acá una vez al cargar el dashboard garantiza que esos tres tabs
  // funcionen sin depender del orden en que se navega.
  abInit();

  /* ---------- Sesión persistente ---------- */
  // si venimos de una notificación push (/dashboard/?lead=12), abrir ese lead directo
  // — o del link "🧾 oferta ↗" de una propuesta (/dashboard/?offer=34), que abre en
  // pestaña nueva para no perder lo que estabas editando en Propuestas
  function openFromQuery(){
    try {
      const qs = new URLSearchParams(location.search);
      const lid = qs.get('lead');
      const oid = qs.get('offer');
      if (!lid && !oid) return;
      history.replaceState({}, '', location.pathname);
      if (lid) { gotoTab('leads'); openLead(lid); }
      else if (oid) { gotoTab('offers'); openOffer(oid); }
    } catch (e) {}
  }
  // restaura el tab (+ sub-tab) de la URL al entrar/refrescar — contraparte de
  // syncTabUrl(). Si además hay ?lead=/?offer= (link viejo o compartido), esos
  // ganan: openFromQuery() corre después y pisa el tab con el suyo.
  async function openTabFromQuery(){
    try {
      const qs = new URLSearchParams(location.search);
      const tab = qs.get('tab');
      if (!tab || !TABS.includes(tab)) return;
      const sub = qs.get('sub');
      if (tab === 'analytics' && ['web', 'gads', 'videos'].includes(sub)) anaSetSub(sub);
      else if (tab === 'contenido' && ['blog', 'news', 'seo', 'magnets'].includes(sub)) contenidoSetSub(sub);
      else if (tab === 'sistema' && ['services', 'licenses', 'booking', 'ab', 'auto', 'tmpl', 'cashflow', 'profile'].includes(sub)) sistemaSetSub(sub);
      await gotoTab(tab);
    } catch (e) {}
  }

  /* ============================================================================
     SHELL REDESIGN — slice seguro/aditivo: ⌘K palette + riel colapsable + Crear global
     No toca tabs, gotoTab ni data-tab: solo agrega cromo alrededor de lo existente.
     Reutiliza los flujos ya montados (openLead/openCompany/openOffer/openProp,
     newOffer/newProp y los botones "nuevo" de cada tab). Sin fetch nuevo: lee los
     arrays ya cargados en memoria (allLeads, companiesData(), offersList, propsAll).
     ============================================================================ */

  /* ---------- Riel colapsable (memoria: vv_sidebar_collapsed) ---------- */
  (function initRail(){
    const btn = $('side-rail-btn'), body = document.querySelector('.dash-body');
    if (!btn || !body) return;
    const KEY = 'vv_sidebar_collapsed';
    function apply(on){
      body.classList.toggle('dash-collapsed', on);
      const ic = btn.querySelector('.srb-ic'); if (ic) ic.textContent = on ? '⟩⟩' : '⟨⟨';
      btn.title = on ? 'Expandir menú' : 'Colapsar menú';
      btn.setAttribute('aria-label', btn.title);
    }
    let on = false; try { on = localStorage.getItem(KEY) === '1'; } catch (e) {}
    apply(on);
    btn.addEventListener('click', () => { on = !on; apply(on); try { localStorage.setItem(KEY, on ? '1' : '0'); } catch (e) {} });
    // tooltip en riel: title = SOLO el texto del item (sin el emoji del .si-ic ni el .pill)
    document.querySelectorAll('.dash-side .side-item[data-tab]').forEach((it) => {
      if (it.title) return;
      const label = Array.from(it.childNodes).filter((n) => n.nodeType === 3).map((n) => n.textContent).join('').replace(/\s+/g, ' ').trim();
      if (label) it.title = label;
    });
  })();

  /* ---------- ➕ Crear ▾ global: rutea a los flujos "nuevo" ya existentes ---------- */
  (function initCreate(){
    const wrap = $('vv-create'), btn = $('vv-create-btn'), menu = $('vv-create-menu');
    if (!wrap || !btn || !menu) return;
    const close = () => { menu.hidden = true; btn.setAttribute('aria-expanded', 'false'); };
    btn.addEventListener('click', (e) => { e.stopPropagation(); const open = menu.hidden; menu.hidden = !open; btn.setAttribute('aria-expanded', open ? 'true' : 'false'); });
    document.addEventListener('click', (e) => { if (!wrap.contains(e.target)) close(); });
    menu.querySelectorAll('[data-create]').forEach((b) => b.addEventListener('click', async () => {
      close();
      const k = b.dataset.create;
      // fix (auditoría 2026-07-14): estos 3 botones son TOGGLE, no "abrir siempre" — si el
      // usuario había dejado el form abierto con un borrador sin guardar en otro momento,
      // gotoTab NO lo cierra (no toca hidden de estos forms), así que el .click() de acá
      // caía en la rama "cerrar" y Crear global terminaba DESCARTANDO el borrador en vez de
      // abrir uno nuevo. Forzamos hidden=true justo antes para que el toggle siempre abra.
      if (k === 'persona')   { await gotoTab('leads');     const f = $('ps-form'); if (f) f.hidden = true; const n = $('ps-new-btn'); if (n) n.click(); }
      else if (k === 'empresa')   { await gotoTab('companies'); const f = $('co-form'); if (f) f.hidden = true; const n = $('co-new-btn'); if (n) n.click(); }
      else if (k === 'deal')      { await gotoTab('deals');     const f = $('dl-form'); if (f) f.hidden = true; const n = $('dl-new-btn'); if (n) n.click(); }
      else if (k === 'oferta')    { await gotoTab('offers');    const n = $('of-new');     if (n) n.click(); }
      else if (k === 'propuesta') { await gotoTab('offers');    const n = $('pp-new');     if (n) n.click(); }
    }));
  })();

  /* ---------- ⌘K Command palette ---------- */
  // destinos de navegación (mismos labels/íconos del sidebar; Cash Flow solo si es visible)
  // los tabs viejos (blog/news/seo/magnets/services/licenses/booking/ab/auto/tmpl/
  // cashflow/profile) siguen funcionando acá tal cual — gotoTab() ya sabe redirigirlos
  // al destino agrupado correcto (contenido/sistema) + su sub-tab (ver aliases arriba).
  const CMDK_NAV = [
    { tab: 'hoy', ic: '🏠', label: 'Hoy' },
    { tab: 'deals', ic: '🤝', label: 'Pipeline' },
    { tab: 'leads', ic: '👤', label: 'Personas' },
    { tab: 'companies', ic: '🏢', label: 'Empresas' },
    { tab: 'agenda', ic: '📅', label: 'Agenda' },
    { tab: 'offers', ic: '🧾', label: 'Ofertas y propuestas' },
    { tab: 'analytics', ic: '📊', label: 'Analytics' },
    { tab: 'blog', ic: '📝', label: 'Contenido → Blog' },
    { tab: 'news', ic: '📰', label: 'Contenido → Newsletter' },
    { tab: 'seo', ic: '🔍', label: 'Contenido → Search Console' },
    { tab: 'magnets', ic: '🧲', label: 'Contenido → Lead Magnets' },
    { tab: 'services', ic: '🛠', label: 'Sistema → Servicios' },
    { tab: 'licenses', ic: '📄', label: 'Sistema → Licencias' },
    { tab: 'booking', ic: '📅', label: 'Sistema → Booking' },
    { tab: 'ab', ic: '🧪', label: 'Sistema → A/B Tests' },
    { tab: 'auto', ic: '⚙️', label: 'Sistema → Workflows' },
    { tab: 'tmpl', ic: '📚', label: 'Sistema → Plantillas' },
    { tab: 'profile', ic: '👤', label: 'Sistema → Mi perfil' },
    { tab: 'cashflow', ic: '💰', label: 'Sistema → Cash Flow', hidden: () => !isSuperadmin }
  ];
  let cmdkFlat = [], cmdkSel = 0;
  // abrir una propuesta desde cualquier lado: usa ppList si ya cargó, si no propsAll (misma tabla)
  function cmdkOpenProp(id){
    const src = (typeof ppList !== 'undefined' ? ppList : []).find((p) => String(p.id) === String(id))
             || (propsAll || []).find((p) => String(p.id) === String(id));
    if (!src) return;
    try { ppCur = fromRow(src); fillPropEditor(); showPropEditor(true); } catch (e) {}
  }
  function cmdkRender(q){
    q = (q || '').trim(); const ql = q.toLowerCase();
    const has = (s) => !!s && String(s).toLowerCase().includes(ql);
    cmdkFlat = []; let html = '';
    function group(title, items){
      if (!items.length) return;
      html += '<div class="vv-cmdk-grp">' + esc(title) + '</div>';
      items.forEach((it) => { const i = cmdkFlat.length; cmdkFlat.push(it);
        html += '<button class="vv-cmdk-item" type="button" data-i="' + i + '">' +
          '<span class="ci-ic">' + it.ic + '</span><span class="ci-main"><span class="ci-t">' + esc(it.title) + '</span>' +
          (it.sub ? '<span class="ci-sub">' + esc(it.sub) + '</span>' : '') + '</span></button>';
      });
    }
    // registros solo con query (no volcamos miles de leads sobre un input vacío)
    if (ql){
      const ppl = (allLeads || []).filter((l) => !/^claude-/.test(l.session_id || '')).filter((l) => {
        const dom = leadDomain(l), co = dom ? companyName(dom) : '';
        return has(l.name) || has(l.email) || has(co) || has(l.company);
      }).slice(0, 6).map((l) => { const dom = leadDomain(l), co = (dom && companyName(dom)) || l.company || '';
        return { ic: '👤', title: l.name || l.email || '(sin nombre)', sub: [co, l.email].filter(Boolean).join(' · '), run: () => { cmdkClose(); openLead(l.id); } }; });
      group('Personas', ppl);

      const emp = (companiesData() || []).filter((c) => has(c.name) || has(c.domain)).slice(0, 4).map((c) =>
        ({ ic: '🏢', title: c.name || c.domain, sub: c.domain + ' · ' + c.contacts.length + ' contacto' + (c.contacts.length === 1 ? '' : 's'), run: () => { cmdkClose(); openCompany(c.domain); } }));
      group('Empresas', emp);

      const ofs = (offersList || []).filter((o) => o.status !== 'tier').filter((o) => has(o.title) || has(o.number)).slice(0, 4).map((o) =>
        ({ ic: '🧾', title: o.title || ('Oferta ' + (o.number || '#' + o.id)), sub: [o.number ? ('N.º ' + o.number) : '', o.client || leadName(o.lead_id)].filter(Boolean).join(' · '), run: () => { cmdkClose(); (async () => { await gotoTab('offers'); openOffer(o.id); })(); } }));
      group('Ofertas', ofs);

      const prs = (propsAll || []).filter((p) => !p.is_template && !p.archived).filter((p) => has(p.title)).slice(0, 4).map((p) =>
        ({ ic: '🌐', title: p.title || '(propuesta)', sub: leadName(p.lead_id), run: () => { cmdkClose(); (async () => { await gotoTab('offers'); cmdkOpenProp(p.id); })(); } }));
      group('Propuestas', prs);
    }
    // navegación: vacío → todas las secciones; con query → las que matcheen (máx 5)
    const nav = CMDK_NAV.filter((n) => !n.hidden || !n.hidden())
      .filter((n) => !ql || n.label.toLowerCase().includes(ql) || n.tab.includes(ql))
      .slice(0, ql ? 5 : 99)
      .map((n) => ({ ic: n.ic, title: n.label, sub: 'Ir a la sección', run: () => { cmdkClose(); gotoTab(n.tab); } }));
    group(ql ? 'Ir a…' : 'Secciones', nav);

    const res = $('vv-cmdk-results');
    res.innerHTML = html || '<div class="vv-cmdk-empty">Sin resultados para «' + esc(q) + '»</div>';
    cmdkSel = 0; cmdkHi();
    res.querySelectorAll('.vv-cmdk-item').forEach((b) => {
      b.addEventListener('click', () => { const it = cmdkFlat[+b.dataset.i]; if (it && it.run) it.run(); });
      b.addEventListener('mousemove', () => { if (cmdkSel !== +b.dataset.i){ cmdkSel = +b.dataset.i; cmdkHi(); } });
    });
  }
  function cmdkHi(){
    const items = $('vv-cmdk-results').querySelectorAll('.vv-cmdk-item');
    items.forEach((b, i) => b.classList.toggle('sel', i === cmdkSel));
    const cur = items[cmdkSel]; if (cur) cur.scrollIntoView({ block: 'nearest' });
  }
  function cmdkMove(d){ if (!cmdkFlat.length) return; cmdkSel = (cmdkSel + d + cmdkFlat.length) % cmdkFlat.length; cmdkHi(); }
  function cmdkOpen(){
    const ov = $('vv-cmdk'); if (!ov) return;
    ov.classList.add('open');
    const inp = $('vv-cmdk-input'); inp.value = ''; cmdkRender('');
    requestAnimationFrame(() => inp.focus());
  }
  function cmdkClose(){ const ov = $('vv-cmdk'); if (ov) ov.classList.remove('open'); }
  (function initCmdk(){
    const ov = $('vv-cmdk'); if (!ov) return;
    $('vv-search-btn') && $('vv-search-btn').addEventListener('click', cmdkOpen);
    $('vv-cmdk-bd') && $('vv-cmdk-bd').addEventListener('click', cmdkClose);
    $('vv-cmdk-input').addEventListener('input', (e) => cmdkRender(e.target.value));
    document.addEventListener('keydown', (e) => {
      // ⌘K / Ctrl+K: abre/cierra (solo con el dashboard visible, no sobre el login)
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k'){
        const dv = $('dash-view'); if (!dv || dv.hidden) return;
        const isOpen = ov.classList.contains('open');
        // fix (auditoría 2026-07-14): Ctrl+K en Mac es el atajo nativo "borrar hasta fin de
        // línea" dentro de cualquier campo de texto — antes esto lo interceptaba SIEMPRE,
        // robando el foco de notas/textos a medio escribir. Si la paleta ya está abierta sí
        // se puede cerrar igual (toggle); si está cerrada y estás escribiendo, dejamos pasar
        // el atajo nativo sin abrir nada encima.
        if (!isOpen){
          const tag = (e.target && e.target.tagName) || '';
          if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT' || (e.target && e.target.isContentEditable)) return;
        }
        e.preventDefault(); isOpen ? cmdkClose() : cmdkOpen(); return;
      }
      if (!ov.classList.contains('open')) return;
      if (e.key === 'Escape'){ e.preventDefault(); cmdkClose(); }
      else if (e.key === 'ArrowDown'){ e.preventDefault(); cmdkMove(1); }
      else if (e.key === 'ArrowUp'){ e.preventDefault(); cmdkMove(-1); }
      else if (e.key === 'Enter'){ e.preventDefault(); const it = cmdkFlat[cmdkSel]; if (it && it.run) it.run(); }
    });
  })();

  supabase.auth.getSession().then(async ({ data }) => {
    __perfMark('session_done');
    if (data.session) {
      meEmail = (data.session.user?.email || '').toLowerCase();
      await checkRole();
      __perfMark('role_done');
      show('dash'); loadAll().then(async () => { await openTabFromQuery(); openFromQuery(); });
      __perfMark('shell_shown');
    }
    else show('login');
  });
</script>

</body>
</html>
