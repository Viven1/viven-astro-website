  function auEnrStepTxt(a, run){
    const steps = run.variant === 'b' ? (a.steps_b || []) : (a.steps_a || []);
    if (run.status === 'done' || run.step_idx >= steps.length) return 'Terminó la secuencia';
    const st = steps[run.step_idx];
    if (!st) return '—';
    return 'Paso ' + (run.step_idx + 1) + '/' + steps.length + ': ' + (AU_TYPE_META[st.type] || {}).ic + ' ' + auStepSummary(st);
  }
  function auEnrNextTxt(run){
    if (run.status === 'stopped') return 'Frenado';
    if (run.status === 'done') return '—';
    if (!run.next_at) return 'pendiente';
    const t = new Date(run.next_at).getTime(), now = Date.now();
    if (t <= now) return 'se procesa en el próximo pase del motor (~20 min)';
    const days = Math.round((t - now) / 864e5);
    return days >= 1 ? 'envía en ' + days + ' día' + (days === 1 ? '' : 's') : 'envía hoy ' + new Date(run.next_at).toLocaleTimeString('es-CH', { hour: '2-digit', minute: '2-digit' });
  }
