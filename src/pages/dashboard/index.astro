  // Desde el contacto: crear una propuesta ya ligada a este lead
  function makePropForLead(r){
    const client = clientNameFor(r);
    closeLead(); gotoTab('props');
    ppCur = blankProp();
    ppCur.lead_id = r.id;
    ppCur.client_name = client;
    ppCur.client_email = r.email || '';
    ppCur.title = 'Propuesta — ' + (client || r.name || '');
    ppCur.lang = ['en', 'de', 'es'].includes(r.lang) ? r.lang : 'en';
    fillPropEditor(); showPropEditor(true);
    toast('Nueva propuesta para ' + (client || r.name || 'el cliente'));
  }
  // Convertir una oferta existente en una propuesta: la oferta queda como una de las opciones (tiers)
  function offerToProp(offerId, r){
    const o = (offersList || []).find((x) => String(x.id) === String(offerId));
    if (!o) { toast('No encontré la oferta'); return; }
    const client = clientNameFor(r) || o.client || '';
    closeLead(); gotoTab('props');
    ppCur = blankProp();
    ppCur.lead_id = r.id;
    ppCur.client_name = client;
    ppCur.client_email = r.email || '';
    ppCur.title = 'Propuesta — ' + (client || r.name || '');
    ppCur.lang = ['en', 'de', 'es'].includes(r.lang) ? r.lang : 'en';
    const items = Array.isArray(o.items) ? o.items : [];
    const price = items.reduce((a, it) => a + (Number(it.qty) || 0) * (Number(it.price) || 0), 0);
    ppCur.tiers = [{ name: o.title || 'Opción', subtitle: '', price: Math.round(price), discount_pct: 0, recommended: true, includes: items.map((it) => it.name).filter(Boolean), items: items }];
    fillPropEditor(); showPropEditor(true);
    toast('Propuesta creada con la oferta como opción — agregá 2 más o usá la IA');
  }
  modal.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', closeLead));
