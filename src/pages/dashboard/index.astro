  /* ---- bl2: pageviews del blog (30d) para KPIs + columna Visitas ---- */
  let bl2Views = null, bl2ViewsAt = 0, bl2ViewsBusy = false;
  async function bl2LoadViews(force){
    if (bl2ViewsBusy) return;
    if (!force && bl2Views && Date.now() - bl2ViewsAt < 5 * 60e3) return;
    bl2ViewsBusy = true;
    try {
      const since = new Date(Date.now() - 30 * 864e5).toISOString();
      const PAGE = 1000; let all = [], from = 0;
      for (;;) {
        const { data, error } = await supabase.from('pageviews').select('created_at,path')
          .gte('created_at', since).like('path', '%/blog/%')
          .order('created_at', { ascending: true }).range(from, from + PAGE - 1);
        if (error) throw error;
        all = all.concat(data || []);
        if (!data || data.length < PAGE) break;
        from += PAGE;
        if (from > 50000) break;   // salvavidas
      }
      bl2Views = all; bl2ViewsAt = Date.now();
      renderBlogList();
    } catch (e) { /* sin pageviews el tab sigue funcionando (columna queda en —) */ }
    bl2ViewsBusy = false;
  }
  // índice: slug → { total, last7, prev7 } + total del canal /blog/
  function bl2Index(){
    const bySlug = new Map(); let total = 0;
    const wk = Date.now() - 7 * 864e5, wk2 = Date.now() - 14 * 864e5;
    (bl2Views || []).forEach((v) => {
      total++;
      const m = /\/blog\/([^\/?#]+)/.exec(v.path || ''); if (!m || !m[1]) return;
      const e = bySlug.get(m[1]) || { total: 0, last7: 0, prev7: 0 };
      e.total++;
      const t = +new Date(v.created_at);
      if (t >= wk) e.last7++; else if (t >= wk2) e.prev7++;
      bySlug.set(m[1], e);
    });
    return { bySlug, total };
  }
  // grupos: el cron escribe 3 variantes (EN/DE/ES) con el mismo group_id
  function bl2Groups(){
    const map = new Map();
    blogsList.forEach((b) => {
      const k = b.group_id || ('solo-' + b.id);
      if (!map.has(k)) map.set(k, []);
      map.get(k).push(b);
    });
    const ord = { en: 0, de: 1, es: 2 };
    return [...map.entries()].map(([k, rows]) => {
      rows.sort((a, b) => (ord[a.lang] ?? 9) - (ord[b.lang] ?? 9));
      const pub = rows.filter((r) => r.status === 'published');
      const main = rows.find((r) => r.lang === 'en') || rows[0];
      return { key: k, rows, pub, main, pending: pub.length === 0,
        date: Math.max(...rows.map((r) => +new Date(r.published_at || r.updated_at || r.created_at || 0))) };
    });
  }
