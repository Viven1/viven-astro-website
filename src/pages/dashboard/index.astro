        : '<button class="of-act" data-act="edit" type="button">✏️ Editar</button>' +
          '<button class="of-act danger" data-act="del" type="button">🗑 Borrar</button>';
      return '<div class="of-card" data-lid="' + l.id + '"><div class="of-card-open"><div class="of-card-main">' +
        '<div class="of-card-title">' + esc(l.title) + '</div>' +
        '<div class="of-card-sub">' + sub + '</div></div>' +
        (l.status === 'active' ? licDaysBadge(l.renewal_date) : '<span class="lic-days past">' + statusLbl + '</span>') +
        '</div>' +
        '<div class="lic-renew" hidden><input type="date" class="lic-renew-date" value="' + esc(l.renewal_date || '') + '" /><button class="of-act lic-pri" data-act="renew-confirm" type="button">✅ Renovar</button><button class="of-act" data-act="renew-cancel" type="button">Cancelar</button></div>' +
        '<div class="of-actions">' + actions + '</div></div>';
    }).join('');
    box.querySelectorAll('[data-act]').forEach((btn) => btn.addEventListener('click', async () => {
      const card = btn.closest('[data-lid]'); const id = card.dataset.lid; const l = licList.find((x) => String(x.id) === id); if (!l) return;
      const act = btn.dataset.act;
      if (act === 'edit'){ licEditing = l; licOpenForm(l); }
      else if (act === 'genoffer'){
        // precarga una oferta nueva con el mismo cliente y monto (1 click en vez de armarla de cero)
        const lead = l.lead_id ? leadById(l.lead_id) : null;
        await gotoTab('offers');   // cambia de tab (offersInit deja la lista visible, no toca el editor luego)
        newOffer();                // abre un editor en blanco
        ofCur.title = 'Renovación — ' + (l.title || 'licencia');
        ofCur.lead_id = l.lead_id || null;
        ofCur.client = lead ? (lead.name || lead.email || '') : '';
        ofCur.items = [{ phase: 'Production', name: l.title || 'Renovación de licencia', qty: 1, unit: 'Fix', price: Number(l.amount) || 0, cost: 0 }];
        fillEditor(); showEditor(true);
        toast('🧾 Oferta de renovación precargada — revisá y guardá');
      }
      else if (act === 'renew'){ const r = card.querySelector('.lic-renew'); if (r){ r.hidden = false; const inp = r.querySelector('input'); if (inp) inp.focus(); } }
      else if (act === 'renew-cancel'){ const r = card.querySelector('.lic-renew'); if (r) r.hidden = true; }
      else if (act === 'renew-confirm'){
        const inp = card.querySelector('.lic-renew-date'); const next = inp && inp.value;
        if (!next){ toast('Elegí una fecha'); return; }
        const { error } = await supabase.from('licenses').update({ renewal_date: next, status: 'renewed', updated_at: new Date().toISOString() }).eq('id', l.id);
        if (error){ toast('⚠️ ' + error.message); return; }
        toast('✅ Renovada — próxima: ' + next); licLoad();
      }
      else if (act === 'cancel'){
        if (!confirm('¿Marcar como cancelada?')) return;
        await supabase.from('licenses').update({ status: 'cancelled', updated_at: new Date().toISOString() }).eq('id', l.id);
        licLoad();
      } else if (act === 'del'){
        if (!confirm('¿Borrar esta licencia del todo?')) return;
        await supabase.from('licenses').delete().eq('id', l.id);
        licLoad();
      }
    }));
  }
  function servicesInit(){
    if (!servicesBuilt){
      servicesBuilt = true;
      $('sv-add').addEventListener('click', async () => {
        const { data, error } = await supabase.from('services').insert({ name: 'Nuevo servicio', phase: 'Production', unit: 'Tag', price: 0, cost: 0 }).select().single();
        if (error){ toast('No se pudo agregar (¿corriste el SQL 0025?): ' + error.message); return; }
        servicesList.push(data); renderServices();
        const inp = document.querySelector('.sv-row[data-id="' + data.id + '"] input[data-f="name"]');
        if (inp){ inp.focus(); inp.select(); }
      });
    }
    servicesLoad().then(({ error }) => {
      const note = $('sv-note');
      if (error){ note.hidden = false; note.innerHTML = '⚠️ La tabla <b>services</b> no existe todavía — corré el SQL <b>0025</b> en Supabase. Mientras tanto las ofertas usan el catálogo fijo.'; $('sv-list').innerHTML = ''; return; }
      note.hidden = true; renderServices();
    });
  }
  const svPhaseOf = (x) => (PHASES.includes(x.phase) ? x.phase : 'Production');
  const svVisible = (x) => svFilter === 'all' || (svFilter === 'paused' ? x.active === false : x.active !== false);
  // "Usado en N ofertas" — READ-ONLY: cuenta cuántas ofertas/propuestas RECIENTES referencian el servicio por NOMBRE.
  // NUNCA reescribe ofertas viejas (offers.items / proposals.tiers son snapshots denormalizados, sin FK a services.id).
  function svUsageMap(){
    const m = new Map();
    const bumpSet = (names) => names.forEach((k) => m.set(k, (m.get(k) || 0) + 1));
    (typeof offersList !== 'undefined' ? offersList : []).forEach((o) => {
      const seen = new Set();
      (Array.isArray(o.items) ? o.items : []).forEach((it) => { const k = it && it.name ? String(it.name).trim().toLowerCase() : ''; if (k) seen.add(k); });
      bumpSet(seen);
    });
    (typeof propsAll !== 'undefined' ? propsAll : []).forEach((p) => {
      const seen = new Set();
      (Array.isArray(p.tiers) ? p.tiers : []).forEach((t) => (t && Array.isArray(t.items) ? t.items : []).forEach((it) => { const k = it && it.name ? String(it.name).trim().toLowerCase() : ''; if (k) seen.add(k); }));
      bumpSet(seen);
    });
    return m;
  }
  function svDecorateUsage(box){
    try {
      const m = svUsageMap();
      box.querySelectorAll('.sv-row').forEach((row) => {
        const it = servicesList.find((x) => String(x.id) === String(row.dataset.id));
        const span = row.querySelector('[data-usage]'); if (!it || !span) return;
        const n = m.get(String(it.name || '').trim().toLowerCase()) || 0;
        if (n > 0){ span.className = 'usage'; span.textContent = 'usado en ' + n + (n === 1 ? ' oferta' : ' ofertas'); }
        else { span.className = 'usage none'; span.textContent = 'sin uso reciente'; }
      });
    } catch (e) { /* usage es best-effort: nunca rompe la tab */ }
  }
  function svRenderSeg(){
    const seg = $('sv-seg'); if (!seg) return;
    const act = servicesList.filter((x) => x.active !== false).length;
    const off = servicesList.filter((x) => x.active === false).length;
    const defs = [['active', 'Activos', act], ['paused', 'Pausados', off], ['all', 'Todos', servicesList.length]];
    seg.innerHTML = defs.map(([k, lbl, n]) => '<button data-f="' + k + '" class="' + (svFilter === k ? 'on' : '') + '" type="button">' + lbl + ' ' + n + '</button>').join('');
    seg.querySelectorAll('button').forEach((b) => b.addEventListener('click', () => { svFilter = b.dataset.f; renderServices(); }));
  }
  // reordenar dentro de la MISMA fase: reasigna `sort` 0..n y persiste
  async function svReorder(fromId, toId){
    if (!fromId || !toId || String(fromId) === String(toId)) return;
    const from = servicesList.find((x) => String(x.id) === String(fromId));
    const to = servicesList.find((x) => String(x.id) === String(toId));
    if (!from || !to) return;
    const ph = svPhaseOf(from);
    if (svPhaseOf(to) !== ph){ toast('Solo se reordena dentro de la misma fase'); return; }
    const group = servicesList.filter((x) => svPhaseOf(x) === ph);
    const fi = group.findIndex((x) => String(x.id) === String(fromId));
    const ti = group.findIndex((x) => String(x.id) === String(toId));
    const [moved] = group.splice(fi, 1); group.splice(ti, 0, moved);
    group.forEach((x, i) => { x.sort = i; });
    const pIdx = (x) => { const k = PHASES.indexOf(svPhaseOf(x)); return k < 0 ? PHASES.length : k; };
    servicesList.sort((a, b) => pIdx(a) - pIdx(b) || (Number(a.sort) || 0) - (Number(b.sort) || 0) || (Number(a.id) || 0) - (Number(b.id) || 0));
    renderServices();
    for (const x of group){ const { error } = await supabase.from('services').update({ sort: x.sort }).eq('id', x.id); if (error){ toast('No se pudo guardar el orden: ' + error.message); break; } }
    svTouch();
  }
  function renderServices(){
    const box = $('sv-list'); if (!box) return;
    svRenderSeg();
    if (!servicesList.length){ box.innerHTML = '<p class="muted-note">Sin servicios. Agregá el primero con ➕ — o corré el SQL 0025 que precarga el catálogo actual.</p>'; return; }
    let html = '', shown = 0;
    PHASES.forEach((ph) => {
      const rows = servicesList.filter((x) => svPhaseOf(x) === ph && svVisible(x));
      if (!rows.length) return;
      shown += rows.length;
      html += '<div class="sv-phase">' + esc(ph) + '</div>';
      rows.forEach((x) => {
        html += '<div class="sv-row' + (x.active === false ? ' sv-off' : '') + '" data-id="' + x.id + '">' +
          '<span class="sv-drag" draggable="true" title="Arrastrar para reordenar">⠿</span>' +
          '<input data-f="name" value="' + esc(x.name || '') + '" placeholder="Nombre del servicio" />' +
          '<select data-f="phase">' + PHASES.map((p) => '<option' + (p === x.phase ? ' selected' : '') + '>' + p + '</option>').join('') + '</select>' +
          '<input data-f="unit" value="' + esc(x.unit || '') + '" placeholder="Tag/Std/Fix" title="Unidad: Tag, Std, Fix, Stk, Person, Sprache…" />' +
          '<label class="sv-num">CHF<input data-f="price" type="number" step="10" value="' + (Number(x.price) || 0) + '" title="Precio al cliente" /></label>' +
          '<label class="sv-num sv-cost">costo<input data-f="cost" type="number" step="10" value="' + (Number(x.cost) || 0) + '" title="Costo interno (freelancer/alquiler) — para calcular tu margen" /></label>' +
          '<span class="usage none" data-usage title="Ofertas/propuestas recientes que usan este servicio (solo lectura)"></span>' +
          '<button class="sv-tgl" data-act="tgl" type="button" title="' + (x.active === false ? 'Reactivar (hoy no aparece en el catálogo)' : 'Pausar (sale del catálogo sin borrarlo)') + '">' + (x.active === false ? '▶' : '⏸') + '</button>' +
          '<button class="sv-del" data-act="del" type="button" title="Borrar definitivamente">✕</button>' +
        '</div>';
      });
    });
    if (!shown){ box.innerHTML = '<p class="muted-note">Sin servicios en este filtro.</p>'; return; }
    box.innerHTML = html;
    box.querySelectorAll('.sv-row input,.sv-row select').forEach((inp) => inp.addEventListener('change', async () => {
      const row = inp.closest('.sv-row'), id = row.dataset.id, f = inp.dataset.f;
      let v = inp.value;
      if (f === 'price' || f === 'cost') v = parseFloat(v) || 0;
      const it = servicesList.find((x) => String(x.id) === String(id)); if (it) it[f] = v;
      const { error } = await supabase.from('services').update({ [f]: v, updated_at: new Date().toISOString() }).eq('id', id);
      if (error) toast('No se pudo guardar: ' + error.message); else svTouch();
    }));
    box.querySelectorAll('[data-act="tgl"]').forEach((b) => b.addEventListener('click', async () => {
      const id = b.closest('.sv-row').dataset.id, it = servicesList.find((x) => String(x.id) === String(id));
      const nv = it.active === false;
      const { error } = await supabase.from('services').update({ active: nv }).eq('id', id);
      if (error){ toast(error.message); return; }
      it.active = nv; renderServices(); svTouch();
    }));
    box.querySelectorAll('[data-act="del"]').forEach((b) => b.addEventListener('click', async () => {
      const id = b.closest('.sv-row').dataset.id, it = servicesList.find((x) => String(x.id) === String(id));
      if (!confirm('¿Borrar «' + (it.name || 'servicio') + '» del catálogo?')) return;
      const { error } = await supabase.from('services').delete().eq('id', id);
      if (error){ toast(error.message); return; }
      servicesList = servicesList.filter((x) => String(x.id) !== String(id)); renderServices(); svTouch();
    }));
    // drag-to-reorder por el handle ⠿ (persiste la columna `sort`)
    box.querySelectorAll('.sv-drag').forEach((h) => {
      h.addEventListener('dragstart', (e) => {
        svDragId = h.closest('.sv-row').dataset.id;
        e.dataTransfer.effectAllowed = 'move';
        try { e.dataTransfer.setData('text/plain', svDragId); } catch (_) { /* algunos navegadores */ }
        h.closest('.sv-row').classList.add('sv-dragging');
      });
      h.addEventListener('dragend', () => { box.querySelectorAll('.sv-row').forEach((r) => r.classList.remove('sv-dragging', 'sv-dragover')); svDragId = null; });
    });
    box.querySelectorAll('.sv-row').forEach((row) => {
      row.addEventListener('dragover', (e) => { if (svDragId == null) return; e.preventDefault(); e.dataTransfer.dropEffect = 'move'; row.classList.add('sv-dragover'); });
      row.addEventListener('dragleave', () => row.classList.remove('sv-dragover'));
      row.addEventListener('drop', (e) => { e.preventDefault(); row.classList.remove('sv-dragover'); svReorder(svDragId, row.dataset.id); });
    });
    // decorar con "usado en N ofertas" DESPUÉS de pintar filas (best-effort, nunca bloquea)
    svDecorateUsage(box);
  }
  // el catálogo de ofertas se rearma la próxima vez que entres a Ofertas
  function svTouch(){ const sel = $('of-preset'); if (sel) delete sel.dataset.built; }

  function buildPresetSelect(){
    const sel = $('of-preset');
    if (sel.dataset.built) return;
    sel.dataset.built = '1';
