<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Viven — Dashboard</title>
<!-- Página privada: fuera de buscadores y del sitemap -->
<meta name="robots" content="noindex,nofollow" />
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%20viewBox%3D%220%200%2064%2064%22%3E%3Crect%20width%3D%2264%22%20height%3D%2264%22%20rx%3D%2214%22%20fill%3D%22%23142033%22/%3E%3Ctext%20x%3D%2232%22%20y%3D%2247%22%20font-family%3D%22Arial%2CHelvetica%2Csans-serif%22%20font-size%3D%2244%22%20font-weight%3D%22700%22%20fill%3D%22%23ddf98f%22%20text-anchor%3D%22middle%22%3Ev%3C/text%3E%3C/svg%3E" />
<meta name="theme-color" content="#0f1826" />
<link rel="stylesheet" href="/assets/site.css" />
<style is:global>
  .dash-wrap{max-width:1220px;margin:0 auto;padding:32px 24px 80px}
  .dash-head{display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;margin-bottom:24px}
  .dash-head h1{font-size:clamp(24px,3.4vw,32px)}
  .dash-head h1 span{color:var(--acid)}
  .dash-sub{color:var(--muted-2);font-size:13px;margin-top:4px}
  .login-card{max-width:420px;margin:12vh auto 0;border:1px solid var(--line-strong);border-radius:20px;background:var(--navy-800);padding:40px}
  .login-card h1{font-size:26px;margin-bottom:6px}
  .login-card p{color:var(--muted);font-size:14px;margin-bottom:24px}

  /* tabs */
  .tabs{display:flex;gap:8px;margin-bottom:28px;border-bottom:1px solid var(--line);padding-bottom:0}
  .tab{background:none;border:0;border-bottom:2px solid transparent;color:var(--muted);font-family:'Space Grotesk';font-size:16px;font-weight:600;padding:12px 18px;cursor:pointer;transition:.25s;display:inline-flex;align-items:center;gap:8px}
  .tab:hover{color:var(--text)}
  .tab.active{color:var(--acid);border-bottom-color:var(--acid)}
  .tab .pill{background:rgba(221,249,143,.14);color:var(--acid);border-radius:100px;font-size:11.5px;padding:2px 9px;font-family:'Inter'}

  .kpis{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:28px}
  .kpis.four{grid-template-columns:repeat(4,1fr)}
  .kpi{border:1px solid var(--line);border-radius:var(--radius);background:linear-gradient(180deg,var(--navy-700),var(--navy-800));padding:20px}
  .kpi .n{font-family:'Space Grotesk';font-weight:700;font-size:30px;color:var(--acid);line-height:1.1;white-space:nowrap}
  .kpi .n small{font-size:16px;color:var(--muted)}
  .kpi .l{color:var(--muted);font-size:12.5px;margin-top:6px}

  .panel{border:1px solid var(--line);border-radius:var(--radius);background:var(--navy-800);padding:24px;margin-bottom:22px;overflow-x:auto}
  .panel h2{font-size:17px;margin-bottom:16px;display:flex;align-items:center;gap:10px}
  .panel h2 .count{font-size:12px;color:var(--muted-2);font-weight:500}
  .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:22px}

  /* daily chart */
  .chart{display:flex;align-items:flex-end;gap:3px;height:120px;padding-top:8px}
  .chart .col{flex:1;display:flex;flex-direction:column;justify-content:flex-end;height:100%;position:relative;border-radius:4px 4px 0 0;background:rgba(255,255,255,.03)}
  .chart .col .fill{background:var(--acid);opacity:.85;border-radius:4px 4px 0 0;min-height:2px;transition:.3s}
  .chart .col:hover .fill{opacity:1}
  .chart .col .tip{display:none;position:absolute;bottom:calc(100% + 6px);left:50%;transform:translateX(-50%);background:var(--navy-900);border:1px solid var(--line-strong);border-radius:8px;padding:5px 9px;font-size:11px;color:var(--text);white-space:nowrap;z-index:5}
  .chart .col:hover .tip{display:block}
  .chart-labels{display:flex;justify-content:space-between;color:var(--muted-2);font-size:11px;margin-top:8px}

  /* bar rows */
  .bars{display:grid;gap:9px}
  .bar-row{display:grid;grid-template-columns:minmax(90px,160px) 1fr 88px;align-items:center;gap:12px;font-size:13px}
  .bar-row .lbl{color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .bar-row .track{height:9px;border-radius:100px;background:rgba(255,255,255,.05);overflow:hidden}
  .bar-row .fill{height:100%;border-radius:100px;background:var(--acid);min-width:2px}
  .bar-row .val{text-align:right;color:var(--text);font-weight:600;font-size:12.5px;white-space:nowrap}
  .bar-row .val small{color:var(--muted-2);font-weight:400}

  /* chart with conversion dots */
  .chart .col .dot{position:absolute;left:50%;transform:translateX(-50%);width:7px;height:7px;border-radius:50%;background:#ff9ec9;box-shadow:0 0 0 2px var(--navy-800);z-index:3}
  .chart-legend{display:flex;gap:18px;margin-top:10px;font-size:11.5px;color:var(--muted-2)}
  .chart-legend i{display:inline-block;width:10px;height:10px;border-radius:3px;margin-right:6px;vertical-align:-1px}
  .chart-legend .s{background:var(--acid)}
  .chart-legend .c{border-radius:50%;background:#ff9ec9}

  /* insight banner */
  .insights{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:22px}
  .insight{border:1px solid var(--line);border-radius:var(--radius);background:linear-gradient(180deg,var(--navy-700),var(--navy-800));padding:18px 20px}
  .insight .t{font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted-2);margin-bottom:8px;display:flex;align-items:center;gap:7px}
  .insight .v{font-family:'Space Grotesk';font-weight:700;font-size:19px;color:var(--text);line-height:1.25}
  .insight .v em{color:var(--acid);font-style:normal}
  .insight .d{color:var(--muted);font-size:12.5px;margin-top:6px}
  @media(max-width:980px){.insights{grid-template-columns:1fr}}

  /* performance table (canales / páginas que traen leads) */
  .perf{width:100%;border-collapse:collapse;font-size:13px;min-width:520px}
  .perf th{text-align:left;color:var(--muted-2);font-size:10.5px;letter-spacing:.09em;text-transform:uppercase;padding:7px 10px;border-bottom:1px solid var(--line-strong)}
  .perf th.num,.perf td.num{text-align:right}
  .perf td{padding:10px;border-bottom:1px solid var(--line);vertical-align:middle}
  .perf tr:last-child td{border-bottom:0}
  .perf .rate-cell{display:flex;align-items:center;gap:9px;justify-content:flex-end}
  .perf .rate-bar{width:56px;height:7px;border-radius:100px;background:rgba(255,255,255,.06);overflow:hidden;flex-shrink:0}
  .perf .rate-bar i{display:block;height:100%;background:var(--acid);border-radius:100px}
  .perf .rate-num{font-weight:700;color:var(--text);min-width:42px;text-align:right}
  .perf .lead-n{font-weight:700;color:var(--acid)}
  .perf .lead-n.zero{color:var(--muted-2);font-weight:400}

  /* tables */
  table.dt{width:100%;border-collapse:collapse;font-size:13.5px;min-width:820px}
  .dt th{text-align:left;color:var(--muted-2);font-size:11px;letter-spacing:.1em;text-transform:uppercase;padding:8px 12px;border-bottom:1px solid var(--line-strong)}
  .dt td{padding:11px 12px;border-bottom:1px solid var(--line);color:var(--text);vertical-align:top}
  .dt tr:hover td{background:rgba(255,255,255,.02)}
  .dt td .sub{color:var(--muted-2);font-size:12px;display:block;margin-top:2px}
  .dt .msg{max-width:260px;color:var(--muted);font-size:13px}
  .badge{display:inline-block;padding:3px 10px;border-radius:100px;font-size:11.5px;font-weight:600;background:rgba(255,255,255,.08);color:var(--muted)}
  .b-paid_search{background:rgba(66,133,244,.18);color:#8ab4f8}
  .b-paid_social{background:rgba(24,119,242,.18);color:#7ba9e8}
  .b-organic{background:rgba(52,168,83,.18);color:#81c995}
  .b-ai{background:rgba(221,249,143,.16);color:var(--acid)}
  .b-social{background:rgba(255,110,180,.16);color:#ff9ec9}
  .b-referral{background:rgba(255,190,90,.16);color:#ffd28a}
  .b-email{background:rgba(160,110,255,.18);color:#c4a7ff}
  .gclid-dot{color:var(--acid);font-weight:700;font-size:12.5px}
  select.status{background:var(--navy-900);border:1px solid var(--line-strong);border-radius:8px;color:var(--text);font-family:inherit;font-size:12.5px;padding:6px 9px;cursor:pointer}

  /* toolbar */
  .toolbar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:18px;align-items:center}
  .toolbar input[type="search"]{flex:1;min-width:180px;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:100px;padding:9px 18px;color:var(--text);font-family:inherit;font-size:13.5px}
  .toolbar input[type="search"]:focus{outline:none;border-color:var(--acid)}
  .toolbar .fpill{background:transparent;border:1px solid var(--line-strong);color:var(--muted);font-family:inherit;font-size:12.5px;font-weight:600;padding:8px 15px;border-radius:100px;cursor:pointer;transition:.25s}
  .toolbar .fpill:hover{border-color:var(--acid);color:var(--acid)}
  .toolbar .fpill.active{background:var(--acid);border-color:var(--acid);color:#142033}

  .muted-note{color:var(--muted-2);font-size:13px}
  .btn.small{padding:9px 18px;font-size:13px}
  .dt tbody tr{cursor:pointer}

  /* ---------- Lead detail modal ---------- */
  .lead-modal{position:fixed;inset:0;z-index:300;display:none;align-items:flex-start;justify-content:center;padding:5vh 20px;overflow-y:auto}
  .lead-modal.open{display:flex}
  .lead-modal .backdrop{position:fixed;inset:0;background:rgba(9,15,26,.86);backdrop-filter:blur(8px)}
  .lead-card{position:relative;z-index:2;width:min(760px,100%);background:var(--navy-800);border:1px solid var(--line-strong);border-radius:20px;padding:32px;animation:pop .35s var(--ease)}
  @keyframes pop{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
  .lead-card .close{position:absolute;top:18px;right:18px;width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,.08);border:1px solid var(--line-strong);color:#fff;font-size:18px;cursor:pointer;display:grid;place-items:center;transition:.25s}
  .lead-card .close:hover{background:var(--acid);color:#142033}
  .lead-card h3{font-size:24px;margin-bottom:2px}
  .lead-card .email-line{color:var(--muted);font-size:14px;margin-bottom:22px}
  .lead-card .email-line a{color:var(--acid)}
  .detail-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px}
  .detail{background:var(--navy-900);border:1px solid var(--line);border-radius:12px;padding:12px 14px}
  .detail .k{font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted-2);margin-bottom:4px}
  .detail .v{font-size:13.5px;color:var(--text);word-break:break-all}
  .lead-msg{background:var(--navy-900);border:1px solid var(--line);border-radius:12px;padding:16px;color:var(--muted);font-size:14px;line-height:1.6;margin-bottom:24px;white-space:pre-wrap}
  .draft-head{display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:10px}
  .draft-head h4{font-size:15px;display:flex;align-items:center;gap:8px}
  .draft-head h4 span{color:var(--acid)}
  .draft-box{width:100%;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:12px;padding:16px;color:var(--text);font-family:inherit;font-size:13.5px;line-height:1.6;min-height:230px;resize:vertical}
  .draft-box:focus{outline:none;border-color:var(--acid)}
  .lead-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:16px;justify-content:space-between}
  .lead-actions .left{display:flex;gap:10px;flex-wrap:wrap}
  .btn-danger{background:transparent;border:1px solid rgba(255,120,120,.4);color:#ff9a9a}
  .btn-danger:hover{background:rgba(255,90,90,.12);border-color:#ff9a9a;transform:translateY(-2px)}
  @media(max-width:680px){.detail-grid{grid-template-columns:1fr 1fr}}
  [hidden]{display:none!important}
  @media(max-width:980px){.kpis,.kpis.four{grid-template-columns:repeat(2,1fr)}.grid-2{grid-template-columns:1fr}}
  /* ---------- Pipeline kanban ---------- */
  .pipe-bar{display:flex;align-items:center;gap:12px;margin-bottom:16px;flex-wrap:wrap}
  .pipe-bar input[type=search]{flex:1;min-width:220px;background:var(--navy-800);border:1px solid var(--line-strong);border-radius:10px;color:var(--text);font-family:inherit;font-size:14px;padding:10px 14px}
  .pipe-hint{color:var(--muted-2);font-size:12.5px}
  .pipeline{display:flex;gap:14px;overflow-x:auto;padding-bottom:10px;align-items:flex-start}
  .pipe-col{flex:0 0 268px;min-width:268px;background:var(--navy-900);border:1px solid var(--line);border-radius:16px;padding:12px;display:flex;flex-direction:column;max-height:72vh}
  .pipe-col.drop{border-color:var(--acid);box-shadow:0 0 0 2px rgba(221,249,143,.25)}
  .pipe-col-head{display:flex;align-items:center;gap:8px;padding:4px 6px 12px;font-family:'Space Grotesk';font-weight:600;font-size:14px}
  .pipe-col-head .dot{width:9px;height:9px;border-radius:50%;flex:none}
  .pipe-col-head .cnt{margin-left:auto;background:rgba(255,255,255,.06);color:var(--muted);border-radius:100px;font-size:12px;font-weight:600;padding:1px 9px;font-family:'Inter'}
  .pipe-list{display:flex;flex-direction:column;gap:9px;overflow-y:auto;min-height:60px;padding:2px}
  .pipe-card{background:linear-gradient(180deg,var(--navy-700),var(--navy-800));border:1px solid var(--line);border-left:3px solid var(--stage,#8ab4ff);border-radius:11px;padding:12px 13px;cursor:grab;transition:transform .12s,border-color .2s,box-shadow .2s}
  .pipe-card:hover{border-color:var(--line-strong);box-shadow:0 6px 20px -10px rgba(0,0,0,.6);transform:translateY(-1px)}
  .pipe-card.dragging{opacity:.4;cursor:grabbing}
  .pipe-card .pc-name{font-family:'Space Grotesk';font-weight:600;font-size:14.5px;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .pipe-card .pc-mail{font-size:12px;color:var(--muted-2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:1px}
  .pipe-card .pc-msg{font-size:12.5px;color:var(--muted);margin-top:7px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
  .pipe-card .pc-meta{display:flex;align-items:center;gap:7px;margin-top:9px;flex-wrap:wrap}
  .pc-badge{font-size:10.5px;letter-spacing:.04em;text-transform:uppercase;font-weight:600;color:var(--acid);background:rgba(221,249,143,.12);border-radius:100px;padding:2px 8px}
  .pc-ads{font-size:10.5px;font-weight:700;color:#142033;background:#8ab4ff;border-radius:100px;padding:2px 8px}
  .pc-time{font-size:11.5px;color:var(--muted-2);margin-left:auto}
  .pc-follow{font-size:11px;color:#f0c060}
  .pipe-empty{color:var(--muted-2);font-size:12px;text-align:center;padding:18px 6px;border:1px dashed var(--line);border-radius:10px}

  /* ---------- Insights con IA ---------- */
  .ai-panel{background:linear-gradient(135deg,rgba(221,249,143,.06),var(--navy-800))}
  .ai-head{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:14px;flex-wrap:wrap}
  .ai-head h2{margin:0}
  .ai-insight{display:flex;gap:12px;padding:14px 0;border-top:1px solid var(--line)}
  .ai-insight:first-child{border-top:0}
  .ai-insight .ico{font-size:20px;flex:none;line-height:1.3}
  .ai-insight .txt h4{font-size:15px;margin:0 0 3px;color:var(--text);font-family:'Space Grotesk'}
  .ai-insight .txt p{font-size:13.5px;color:var(--muted);margin:0;line-height:1.5}
  .ai-loading{color:var(--muted);font-size:14px;padding:10px 0}

  /* ---------- Gráfico SVG (real) ---------- */
  #daily-chart{height:auto!important;display:block;padding-top:4px}
  .gsvg{width:100%;height:auto;display:block;overflow:visible}
  .g-grid{stroke:rgba(255,255,255,.07);stroke-width:1}
  .g-yl{fill:var(--muted-2);font-size:11px;text-anchor:end;font-family:'Inter'}
  .g-xl{fill:var(--muted-2);font-size:11px;font-family:'Inter'}
  .g-line{fill:none;stroke:var(--acid);stroke-width:2.5;stroke-linejoin:round;stroke-linecap:round}
  .g-lead{fill:#ff9ec9;stroke:var(--navy-800);stroke-width:2;transition:.2s}
  .gsvg circle:hover{opacity:.8}
  .chart-labels{display:none}
</style>
</head>
<body>

<!-- ============ LOGIN ============ -->
<div id="login-view" class="dash-wrap" hidden>
  <div class="login-card">
    <h1>Viven <span style="color:var(--acid)">Dashboard</span></h1>
    <p>Acceso privado. Inicia sesión con tu usuario.</p>
    <form id="login-form" class="lead-form">
      <div class="field"><label>Email</label><input type="email" name="email" required autocomplete="username" /></div>
      <div class="field"><label>Contraseña</label><input type="password" name="password" required autocomplete="current-password" /></div>
      <button type="submit">Entrar</button>
      <p class="form-error">Login incorrecto — revisa email y contraseña.</p>
    </form>
  </div>
</div>

<!-- ============ DASHBOARD ============ -->
<div id="dash-view" class="dash-wrap" hidden>
  <div class="dash-head">
    <div>
      <h1>Viven <span>Dashboard</span></h1>
      <p class="dash-sub" id="updated-at">Últimos 30 días</p>
    </div>
    <div style="display:flex;gap:10px">
      <button class="btn btn-ghost small" id="refresh-btn" type="button">↻ Actualizar</button>
      <button class="btn btn-ghost small" id="logout-btn" type="button">Salir</button>
    </div>
  </div>

  <div class="tabs">
    <button class="tab active" data-tab="leads" type="button">📥 Leads <span class="pill" id="tab-leads-count">0</span></button>
    <button class="tab" data-tab="analytics" type="button">📊 Analytics</button>
  </div>

  <!-- ============ TAB: LEADS ============ -->
  <div id="tab-leads">
    <div class="kpis four">
      <div class="kpi"><div class="n" id="kl-total">–</div><div class="l">Leads totales</div></div>
      <div class="kpi"><div class="n" id="kl-week">–</div><div class="l">Últimos 7 días</div></div>
      <div class="kpi"><div class="n" id="kl-new">–</div><div class="l">Sin contactar</div></div>
      <div class="kpi"><div class="n" id="kl-ads">–</div><div class="l">Desde Google Ads (GCLID)</div></div>
    </div>
    <div class="kpis">
      <div class="kpi"><div class="n" id="kl-contacted">–</div><div class="l">Contactados</div></div>
      <div class="kpi"><div class="n" id="kl-won">–</div><div class="l">Ganados</div></div>
      <div class="kpi"><div class="n" id="kl-lost">–</div><div class="l">Perdidos</div></div>
      <div class="kpi"><div class="n" id="kl-convrate">–</div><div class="l">Tasa de conversión</div></div>
      <div class="kpi"><div class="n" id="kl-followup">–</div><div class="l">Follow-ups esta semana</div></div>
    </div>
    <div class="pipe-bar">
      <input type="search" id="lead-search" placeholder="Buscar por nombre, email o mensaje…" />
      <span class="pipe-hint">Arrastrá las tarjetas entre columnas para cambiar el estado →</span>
      <button class="btn btn-ghost small" id="export-csv" type="button">⬇ CSV</button>
    </div>
    <div class="pipeline" id="pipeline"></div>
    <p class="muted-note" id="leads-empty" hidden>No hay leads que coincidan. Envía el formulario del sitio para testear.</p>
  </div>

  <!-- ============ TAB: ANALYTICS ============ -->
  <div id="tab-analytics" hidden>
    <div class="kpis">
      <div class="kpi"><div class="n" id="ka-sessions">–</div><div class="l">Sesiones (visitantes)</div></div>
      <div class="kpi"><div class="n" id="ka-views">–</div><div class="l">Páginas vistas</div></div>
      <div class="kpi"><div class="n" id="ka-time">–</div><div class="l">Tiempo medio en página</div></div>
      <div class="kpi"><div class="n" id="ka-conv">–</div><div class="l">Leads (conversiones)</div></div>
      <div class="kpi"><div class="n" id="ka-rate">–</div><div class="l">Tasa de conversión</div></div>
    </div>

    <!-- Insights con IA: recomendaciones de mejora -->
    <div class="panel ai-panel">
      <div class="ai-head">
        <h2>🧠 Insights con IA <span class="count">recomendaciones para vender más</span></h2>
        <button class="btn btn-primary small" id="ai-insights-btn" type="button">✨ Generar</button>
      </div>
      <div class="ai-body" id="ai-insights-body">
        <p class="muted-note">Apretá <strong>✨ Generar</strong> para que la IA analice tu tráfico, canales y conversión, y te dé 3–5 mejoras concretas y accionables.</p>
      </div>
    </div>

    <!-- Titulares automáticos: qué está funcionando -->
    <div class="insights" id="insights"></div>

    <div class="panel">
      <h2>Tráfico y leads por día <span class="count">(últimos 30 días)</span></h2>
      <div class="chart" id="daily-chart"></div>
      <div class="chart-labels"><span id="chart-from"></span><span id="chart-to"></span></div>
      <div class="chart-legend"><span><i class="s"></i>Sesiones</span><span><i class="c"></i>Leads</span></div>
    </div>

    <div class="grid-2">
      <div class="panel">
        <h2>¿Qué canales traen leads? <span class="count">(sesiones → leads)</span></h2>
        <div style="overflow-x:auto"><table class="perf"><thead><tr><th>Canal</th><th class="num">Sesiones</th><th class="num">Leads</th><th class="num">Conversión</th></tr></thead><tbody id="perf-channel"></tbody></table></div>
      </div>
      <div class="panel">
        <h2>¿Qué páginas convierten? <span class="count">(entrada → leads)</span></h2>
        <div style="overflow-x:auto"><table class="perf"><thead><tr><th>Página de entrada</th><th class="num">Sesiones</th><th class="num">Leads</th><th class="num">Conversión</th></tr></thead><tbody id="perf-landing"></tbody></table></div>
      </div>
    </div>

    <div class="panel">
      <h2>Páginas más vistas <span class="count">(visitas · cuánto se quedan)</span></h2>
      <div class="bars" id="bars-pages"></div>
    </div>

    <div class="grid-2">
      <div class="panel">
        <h2>Dispositivos <span class="count">(páginas vistas)</span></h2>
        <div class="bars" id="bars-device"></div>
      </div>
      <div class="panel">
        <h2>Idiomas del navegador <span class="count">(sesiones)</span></h2>
        <div class="bars" id="bars-lang"></div>
      </div>
    </div>

    <p class="muted-note">Video stats: <span id="ka-videos">–</span> registros. (El tracking de qué % de cada video se mira se conecta en una próxima etapa.)</p>
  </div>
</div>

<!-- ============ LEAD DETAIL MODAL ============ -->
<div class="lead-modal" id="lead-modal" aria-hidden="true" role="dialog" aria-modal="true">
  <div class="backdrop" data-close></div>
  <div class="lead-card">
    <button class="close" type="button" data-close aria-label="Cerrar">&times;</button>
    <h3 id="lm-name"></h3>
    <p class="email-line"><a id="lm-email" href="#"></a> · <span id="lm-date"></span></p>
    <div class="detail-grid" id="lm-details"></div>
    <div class="lead-msg" id="lm-message"></div>
    <div class="draft-head">
      <h4>✍️ <span>Borrador de respuesta</span> (editable — generado según lo que pide)</h4>
      <div style="display:flex;gap:8px">
        <button class="btn btn-ghost small" id="lm-ai" type="button" title="Sugerencia personalizada con IA">✨ IA</button>
        <button class="btn btn-ghost small" id="lm-copy" type="button">📋 Copiar</button>
        <a class="btn btn-primary small" id="lm-mailto" href="#">✉️ Abrir en tu correo</a>
      </div>
    </div>
    <textarea class="draft-box" id="lm-draft"></textarea>
    <div class="lead-actions">
      <div class="left">
        <span class="muted-note" id="lm-status-note"></span>
      </div>
      <button class="btn btn-danger small" id="lm-delete" type="button">🗑 Borrar lead</button>
    </div>
  </div>
</div>

<script>
  import { createClient } from '@supabase/supabase-js';

  /* misma URL + publishable key que usa el sitio (públicas por diseño);
     los datos solo se pueden LEER tras login gracias a las policies RLS */
  const supabase = createClient(
    'https://lumoevaotokgqnpybkyf.supabase.co',
    'sb_publishable_ORGL5_FNZTXcGKwvjs-ymw_Y8DV_4ca'
  );

  const $ = (id) => document.getElementById(id);
  const esc = (s) => String(s ?? '').replace(/[&<>"']/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  const fmtTime = (secs) => {
    if (!secs || secs <= 0) return '—';
    const m = Math.floor(secs / 60), s = Math.round(secs % 60);
    return m ? m + 'm ' + (s < 10 ? '0' : '') + s + 's' : s + 's';
  };
  const STATUSES = ['new', 'nuevo', 'contacted', 'contactado', 'qualified', 'won', 'cerrado', 'lost', 'perdido'];
  const THANKS = /^\/(thank-you|danke|gracias)\/?$/;
  let allLeads = [], statusFilter = 'all', searchTerm = '', insightsData = null;

  function show(view){
    $('login-view').hidden = view !== 'login';
    $('dash-view').hidden = view !== 'dash';
  }

  /* ---------- Tabs ---------- */
  document.querySelectorAll('.tab').forEach((t) => {
    t.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach((x) => x.classList.toggle('active', x === t));
      $('tab-leads').hidden = t.dataset.tab !== 'leads';
      $('tab-analytics').hidden = t.dataset.tab !== 'analytics';
    });
  });

  /* ---------- Login ---------- */
  $('login-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const f = e.target;
    f.classList.remove('has-error');
    const { error } = await supabase.auth.signInWithPassword({
      email: f.email.value.trim(),
      password: f.password.value
    });
    if (error) { f.classList.add('has-error'); return; }
    show('dash');
    loadAll();
  });
  $('logout-btn').addEventListener('click', async () => {
    await supabase.auth.signOut();
    show('login');
  });
  $('refresh-btn').addEventListener('click', loadAll);

  /* ---------- Insights con IA (Edge Function ai-insights → Claude) ---------- */
  $('ai-insights-btn').addEventListener('click', async () => {
    const btn = $('ai-insights-btn'), body = $('ai-insights-body');
    if (!insightsData) { body.innerHTML = '<p class="muted-note">Todavía no hay datos de analytics. Abrí la pestaña Analytics primero.</p>'; return; }
    const prev = btn.textContent; btn.disabled = true; btn.textContent = '✨ Analizando…';
    body.innerHTML = '<p class="ai-loading">La IA está analizando tu tráfico, canales y conversión…</p>';
    try {
      const pipeline = {};
      STAGES.forEach((s) => pipeline[s.key] = allLeads.filter((l) => stageOf(l.status) === s.key).length);
      const { data, error } = await supabase.functions.invoke('ai-insights', {
        body: { summary: { ...insightsData, pipeline, leads_totales: allLeads.length }, lang: 'es' }
      });
      if (error || !data || !Array.isArray(data.insights)) throw new Error(data?.error || error?.message || 'sin respuesta');
      body.innerHTML = data.insights.map((i) =>
        '<div class="ai-insight"><span class="ico">' + esc(i.icon || '💡') + '</span>' +
        '<div class="txt"><h4>' + esc(i.title || '') + '</h4><p>' + esc(i.detail || '') + '</p></div></div>'
      ).join('') || '<p class="muted-note">La IA no devolvió sugerencias.</p>';
    } catch (e) {
      body.innerHTML = '<p class="muted-note">No se pudo generar (¿deployaste ai-insights y hay crédito en Anthropic?): ' + esc(e.message) + '</p>';
    } finally { btn.disabled = false; btn.textContent = prev; }
  });

  /* ---------- Data ---------- */
  const DAYS = 30;
  const since = () => new Date(Date.now() - DAYS * 864e5).toISOString();

  async function loadAll(){
    const [leadsQ, viewsQ, videosQ] = await Promise.all([
      supabase.from('leads').select('*').order('created_at', { ascending: false }).limit(1000),
      supabase.from('pageviews')
        .select('created_at,path,device,session_id,channel,referrer,lang,is_entry,duration')
        .gte('created_at', since()).limit(20000),
      supabase.from('video_stats').select('id', { count: 'exact', head: true })
    ]);
    if (leadsQ.error || viewsQ.error) {
      alert('Error cargando datos: ' + (leadsQ.error || viewsQ.error).message);
      return;
    }
    allLeads = leadsQ.data || [];
    renderLeads();
    renderAnalytics(viewsQ.data || [], allLeads);
    $('ka-videos').textContent = videosQ.count ?? 0;
    $('updated-at').textContent = 'Últimos 30 días · actualizado ' + new Date().toLocaleTimeString('es-CH', { hour: '2-digit', minute: '2-digit' });
    subscribeRealtime();
  }

  /* ---------- Realtime: leads nuevos aparecen solos (gratis, sin polling) ---------- */
  let rtSubscribed = false;
  function subscribeRealtime(){
    if (rtSubscribed) return;
    rtSubscribed = true;
    supabase.channel('leads-live')
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'leads' }, (payload) => {
        const r = payload.new;
        if (allLeads.some((l) => l.id === r.id)) return;
        allLeads.unshift(r);
        renderLeads();
        toast('🎬 Nuevo lead: ' + (r.name || r.email));
      })
      .on('postgres_changes', { event: 'UPDATE', schema: 'public', table: 'leads' }, (payload) => {
        const i = allLeads.findIndex((l) => l.id === payload.new.id);
        if (i > -1) { allLeads[i] = payload.new; renderLeads(); }
      })
      .subscribe();
  }
  function toast(msg){
    let t = document.getElementById('dash-toast');
    if (!t) {
      t = document.createElement('div'); t.id = 'dash-toast';
      t.style.cssText = 'position:fixed;bottom:24px;right:24px;z-index:9999;background:var(--acid);color:#142033;font-weight:700;font-family:Space Grotesk;padding:14px 20px;border-radius:12px;box-shadow:0 12px 40px -10px rgba(0,0,0,.6);transition:.3s;opacity:0;transform:translateY(10px)';
      document.body.appendChild(t);
    }
    t.textContent = msg;
    requestAnimationFrame(() => { t.style.opacity = '1'; t.style.transform = 'none'; });
    clearTimeout(t._h);
    t._h = setTimeout(() => { t.style.opacity = '0'; t.style.transform = 'translateY(10px)'; }, 6000);
  }

  /* ---------- LEADS ---------- */
  const isNew = (s) => s === 'new' || s === 'nuevo';
  $('lead-search').addEventListener('input', (e) => { searchTerm = e.target.value.toLowerCase(); renderLeads(); });
  document.querySelectorAll('.toolbar .fpill').forEach((p) => {
    p.addEventListener('click', () => {
      document.querySelectorAll('.toolbar .fpill').forEach((x) => x.classList.toggle('active', x === p));
      statusFilter = p.dataset.status;
      renderLeads();
    });
  });

  function filteredLeads(){
    return allLeads.filter((r) => {
      if (statusFilter === 'new' && !isNew(r.status)) return false;
      if (statusFilter === 'contacted' && !(r.status === 'contacted' || r.status === 'contactado')) return false;
      if (statusFilter === 'won' && !(r.status === 'won' || r.status === 'cerrado')) return false;
      if (searchTerm) {
        const hay = ((r.name || '') + ' ' + (r.email || '') + ' ' + (r.message || '')).toLowerCase();
        if (hay.indexOf(searchTerm) === -1) return false;
      }
      return true;
    });
  }

  function renderLeads(){
    const week = Date.now() - 7 * 864e5;
    $('kl-total').textContent = allLeads.length;
    $('tab-leads-count').textContent = allLeads.filter((r) => isNew(r.status)).length;
    $('kl-week').textContent = allLeads.filter((r) => new Date(r.created_at) > week).length;
    $('kl-new').textContent = allLeads.filter((r) => isNew(r.status)).length;
    $('kl-ads').textContent = allLeads.filter((r) => r.gclid).length;

    /* estado del pipeline + follow-ups */
    const isS = (r, ...v) => v.includes(r.status);
    const contacted = allLeads.filter((r) => isS(r, 'contacted', 'contactado')).length;
    const won = allLeads.filter((r) => isS(r, 'won', 'cerrado')).length;
    const lost = allLeads.filter((r) => isS(r, 'lost', 'perdido')).length;
    const total = allLeads.length;
    const in7 = Date.now() + 7 * 864e5;
    const followWeek = allLeads.filter((r) => r.next_follow_up_at && new Date(r.next_follow_up_at).getTime() <= in7).length;
    $('kl-contacted').textContent = contacted;
    $('kl-won').textContent = won;
    $('kl-lost').textContent = lost;
    $('kl-convrate').innerHTML = total ? (won / total * 100).toFixed(1) + '<small>%</small>' : '–';
    $('kl-followup').textContent = followWeek;

    renderPipeline();
  }

  /* ---------- Pipeline kanban (drag & drop entre etapas) ---------- */
  const STAGES = [
    { key: 'nuevo',      label: 'Nuevo',      color: '#8ab4ff', match: ['new', 'nuevo', '', 'pending'] },
    { key: 'contactado', label: 'Contactado', color: '#f0c060', match: ['contacted', 'contactado'] },
    { key: 'propuesta',  label: 'Propuesta',  color: '#f0904e', match: ['proposal', 'propuesta', 'qualified'] },
    { key: 'ganado',     label: 'Ganado',     color: '#7ed957', match: ['won', 'cerrado', 'ganado'] },
    { key: 'perdido',    label: 'Perdido',    color: '#ff6b6b', match: ['lost', 'perdido'] },
  ];
  function stageOf(status){
    const s = (status || '').toLowerCase();
    for (const st of STAGES) if (st.match.includes(s)) return st.key;
    return 'nuevo';
  }
  function timeAgo(iso){
    const s = (Date.now() - new Date(iso).getTime()) / 1000;
    if (s < 3600) return Math.max(1, Math.round(s / 60)) + 'm';
    if (s < 86400) return Math.round(s / 3600) + 'h';
    return Math.round(s / 86400) + 'd';
  }
  function cardHTML(r, st){
    const msg = r.message ? '<div class="pc-msg">' + esc(r.message) + '</div>' : '';
    const ch = r.channel ? '<span class="pc-badge">' + esc(r.channel) + '</span>' : '';
    const ads = r.gclid ? '<span class="pc-ads">Ads</span>' : '';
    const follow = (st.key === 'contactado' && r.next_follow_up_at)
      ? '<span class="pc-follow">⏰ ' + new Date(r.next_follow_up_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short' }) + '</span>' : '';
    return '<div class="pipe-card" draggable="true" data-id="' + r.id + '" style="--stage:' + st.color + '">' +
      '<div class="pc-name">' + esc(r.name || r.first_name || '(sin nombre)') + '</div>' +
      '<div class="pc-mail">' + esc(r.email || '') + '</div>' + msg +
      '<div class="pc-meta">' + ch + ads + follow + '<span class="pc-time">' + timeAgo(r.created_at) + '</span></div>' +
    '</div>';
  }
  function renderPipeline(){
    const rows = filteredLeads();
    $('leads-empty').hidden = rows.length > 0;
    const byStage = {}; STAGES.forEach((s) => byStage[s.key] = []);
    rows.forEach((r) => byStage[stageOf(r.status)].push(r));
    Object.values(byStage).forEach((a) => a.sort((x, y) => new Date(y.created_at) - new Date(x.created_at)));
    $('pipeline').innerHTML = STAGES.map((s) => {
      const cards = byStage[s.key].map((r) => cardHTML(r, s)).join('') || '<div class="pipe-empty">Sin leads</div>';
      return '<div class="pipe-col" data-stage="' + s.key + '">' +
        '<div class="pipe-col-head"><span class="dot" style="background:' + s.color + '"></span>' + s.label +
        '<span class="cnt">' + byStage[s.key].length + '</span></div>' +
        '<div class="pipe-list">' + cards + '</div></div>';
    }).join('');
    bindPipeline();
  }
  let dragId = null;
  function bindPipeline(){
    document.querySelectorAll('.pipe-card').forEach((card) => {
      card.addEventListener('dragstart', (e) => { dragId = card.dataset.id; card.classList.add('dragging'); e.dataTransfer.effectAllowed = 'move'; });
      card.addEventListener('dragend', () => { card.classList.remove('dragging'); dragId = null; });
      card.addEventListener('click', () => openLead(card.dataset.id));
    });
    document.querySelectorAll('.pipe-col').forEach((col) => {
      col.addEventListener('dragover', (e) => { e.preventDefault(); col.classList.add('drop'); });
      col.addEventListener('dragleave', () => col.classList.remove('drop'));
      col.addEventListener('drop', async (e) => {
        e.preventDefault(); col.classList.remove('drop');
        const id = dragId; if (!id) return;
        const stage = col.dataset.stage;
        const lead = allLeads.find((l) => String(l.id) === String(id));
        if (!lead || stageOf(lead.status) === stage) return;
        const prev = lead.status;
        lead.status = stage;               // optimista
        renderLeads();
        const { error } = await supabase.from('leads').update({ status: stage }).eq('id', id);
        if (error) { lead.status = prev; renderLeads(); toast('No se pudo mover: ' + error.message); }
      });
    });
  }

  /* ---------- Lead detail + draft de respuesta ---------- */
  const modal = $('lead-modal');
  let currentLead = null;

  const TOPICS = [
    { key: 'employer', re: /employer|recruit|talent|hiring|arbeitgeber|mitarbeiter|karriere|reclut|empleo|kultur|culture/i },
    { key: 'product',  re: /product|produkt|producto|launch|lancierung|lanzamiento|e-?com/i },
    { key: 'social',   re: /social|instagram|tiktok|linkedin|reels|shorts|redes/i },
    { key: 'event',    re: /event|keynote|kongress|congress|messe|evento|aftermovie|confer/i },
    { key: 'howto',    re: /tutorial|how.?to|explainer|erklär|explicativ|onboarding|schulung/i },
    { key: 'brand',    re: /brand|marke|marca|campaign|kampagne|campaña|image|corporate/i }
  ];
  const detectTopic = (msg) => (TOPICS.find((t) => t.re.test(msg || '')) || {}).key || 'general';

  const PROOF = {
    en: {
      employer: 'employer-branding films we made for UBS, Siemens and KPMG attract exactly the candidates our clients want',
      product:  'product films we made for V-ZUG, ON and Franke turn features into desire — and clicks into buyers',
      social:   'the social series we produce for brands like Philips are built to stop the scroll',
      event:    'we cover keynotes and events for brands like UBS and PMI — with first highlights ready the next day',
      howto:    'our explainer and tutorial films make complex products easy to say yes to',
      brand:    'a brand film we made for Siemens tripled their website visits',
      general:  'we’ve produced films for 187 brands across 32 industries — including UBS, Siemens, Porsche and ON'
    },
    de: {
      employer: 'unsere Employer-Branding-Filme für UBS, Siemens und KPMG ziehen genau die richtigen Kandidaten an',
      product:  'unsere Produktfilme für V-ZUG, ON und Franke verwandeln Features in Begehren — und Klicks in Käufer',
      social:   'unsere Social-Serien für Marken wie Philips sind gebaut, um den Scroll zu stoppen',
      event:    'wir begleiten Keynotes und Events für Marken wie UBS und PMI — erste Highlights schon am nächsten Tag',
      howto:    'unsere Erklär- und Tutorial-Filme machen komplexe Produkte leicht verständlich',
      brand:    'ein Markenfilm von uns hat Siemens 3× mehr Website-Besuche gebracht',
      general:  'wir haben Filme für 187 Marken in 32 Branchen produziert — darunter UBS, Siemens, Porsche und ON'
    },
    es: {
      employer: 'nuestros films de employer branding para UBS, Siemens y KPMG atraen exactamente a los candidatos correctos',
      product:  'nuestros videos de producto para V-ZUG, ON y Franke convierten características en deseo — y clics en compradores',
      social:   'las series de social que producimos para marcas como Philips están hechas para frenar el scroll',
      event:    'cubrimos keynotes y eventos para marcas como UBS y PMI — con los primeros highlights al día siguiente',
      howto:    'nuestros videos explicativos hacen fácil decir que sí a productos complejos',
      brand:    'un film de marca nuestro le dio a Siemens 3× más visitas web',
      general:  'hemos producido films para 187 marcas en 32 industrias — incluyendo UBS, Siemens, Porsche y ON'
    }
  };

  function buildDraft(r){
    const lang = ['en', 'de', 'es'].includes(r.lang) ? r.lang : 'en';
    const first = esc0(r.first_name || (r.name || '').trim().split(/\s+/)[0] || '');
    const proof = PROOF[lang][detectTopic(r.message)];
    if (lang === 'de') return 'Guten Tag ' + first + '\n\n' +
      'Vielen Dank für Ihre Anfrage — gerne helfen wir weiter.\n\n' +
      'Damit wir Ihnen einen konkreten Vorschlag machen können, drei kurze Fragen:\n' +
      '• Was soll das Video bewirken (Launch, Leads, Recruiting …)?\n' +
      '• Wo wird es laufen (Website, Social, Paid, Event)?\n' +
      '• Ihr idealer Zeitrahmen?\n\n' +
      'Zur Einordnung: ' + proof + '. Nach Ihrem Briefing erhalten Sie ein fixes Angebot mit Timing — der erste Entwurf ist in der Regel ca. zwei Wochen nach Start fertig.\n\n' +
      'Hätten Sie diese Woche 15 Minuten für einen kurzen Call?\n\n' +
      'Freundliche Grüsse\nSebastian Cepeda\nViven — viven.ch · +41 43 508 33 81';
    if (lang === 'es') return 'Hola ' + first + ':\n\n' +
      'Gracias por escribirnos — nos encantaría ayudarte.\n\n' +
      'Para hacerte una propuesta concreta, tres preguntas rápidas:\n' +
      '• ¿Qué debe lograr el video (lanzamiento, leads, contratación…)?\n' +
      '• ¿Dónde va a correr (web, social, paid, evento)?\n' +
      '• ¿Tu timeline ideal?\n\n' +
      'Para que nos ubiques: ' + proof + '. Con tu brief te mandamos una propuesta con presupuesto fijo y tiempos — el primer borrador suele estar listo unas dos semanas después de arrancar.\n\n' +
      '¿Tienes 15 minutos esta semana para una llamada corta?\n\n' +
      'Saludos,\nSebastian Cepeda\nViven — viven.ch · +41 43 508 33 81';
    return 'Hi ' + first + ',\n\n' +
      'Thanks for reaching out — we’d love to help.\n\n' +
      'To send you a concrete proposal, three quick questions:\n' +
      '• What should the video achieve (launch, leads, hiring…)?\n' +
      '• Where will it run (website, social, paid, event)?\n' +
      '• Your ideal timeline?\n\n' +
      'For context: ' + proof + '. Once we have your brief, you’ll get a fixed quote with timing — the first draft is typically ready about two weeks after we start.\n\n' +
      'Would you have 15 minutes this week for a quick call?\n\n' +
      'Best,\nSebastian Cepeda\nViven — viven.ch · +41 43 508 33 81';
  }
  /* nombre sin HTML para el draft (texto plano) */
  const esc0 = (s) => String(s ?? '').replace(/[<>]/g, '');

  const SUBJECTS = {
    en: 'Your video project — Viven',
    de: 'Ihr Videoprojekt — Viven',
    es: 'Tu proyecto de video — Viven'
  };

  function openLead(id){
    const r = allLeads.find((l) => String(l.id) === String(id));
    if (!r) return;
    currentLead = r;
    $('lm-name').textContent = r.name || '(sin nombre)';
    $('lm-email').textContent = r.email;
    $('lm-email').href = 'mailto:' + r.email;
    $('lm-date').textContent = new Date(r.created_at).toLocaleString('es-CH', { day: '2-digit', month: 'long', hour: '2-digit', minute: '2-digit' });
    const fields = [
      ['Canal', r.channel || '—'],
      ['Idioma', (r.lang || '—').toUpperCase()],
      ['Estado', r.status || '—'],
      ['Página de entrada', r.landing_path || '—'],
      ['Campaña (UTM)', r.utm_campaign || '—'],
      ['Fuente (UTM)', r.utm_source || '—'],
      ['GCLID (Google Ads)', r.gclid || '—'],
      ['Próximo follow-up', r.next_follow_up_at
        ? new Date(r.next_follow_up_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short' }) + (r.follow_up_count ? ' · #' + (r.follow_up_count + 1) : '')
        : (r.status === 'contacted' || r.status === 'contactado' ? 'programando…' : '—')],
      ['Sesión', r.session_id ? r.session_id.slice(0, 13) + '…' : '—']
    ];
    $('lm-details').innerHTML = fields.map(([k, v]) =>
      '<div class="detail"><div class="k">' + k + '</div><div class="v">' + esc(v) + '</div></div>'
    ).join('');
    $('lm-message').textContent = r.message || '(sin mensaje)';
    const draft = buildDraft(r);
    $('lm-draft').value = draft;
    updateMailto();
    $('lm-status-note').textContent = 'El borrador usa el idioma del lead (' + (r.lang || 'en').toUpperCase() + ') y se adapta a su mensaje.';
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function updateMailto(){
    if (!currentLead) return;
    const lang = ['en', 'de', 'es'].includes(currentLead.lang) ? currentLead.lang : 'en';
    $('lm-mailto').href = 'mailto:' + currentLead.email +
      '?subject=' + encodeURIComponent(SUBJECTS[lang]) +
      '&body=' + encodeURIComponent($('lm-draft').value);
  }
  $('lm-draft').addEventListener('input', updateMailto);
  function closeLead(){
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    currentLead = null;
  }
  modal.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', closeLead));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modal.classList.contains('open')) closeLead(); });

  $('lm-copy').addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText($('lm-draft').value);
      $('lm-copy').textContent = '✓ Copiado';
    } catch (e) {
      $('lm-draft').select();
      document.execCommand('copy');
      $('lm-copy').textContent = '✓ Copiado';
    }
    setTimeout(() => { $('lm-copy').textContent = '📋 Copiar'; }, 1600);
  });

  /* ✨ Sugerencia con IA (Edge Function ai-suggest → Claude). Reemplaza el borrador. */
  $('lm-ai').addEventListener('click', async () => {
    if (!currentLead) return;
    const btn = $('lm-ai'), prev = btn.textContent;
    btn.disabled = true; btn.textContent = '✨ Pensando…';
    try {
      const { data, error } = await supabase.functions.invoke('ai-suggest', {
        body: { lead: currentLead, lang: currentLead.lang || 'es' }
      });
      if (error || !data || !data.suggestion) throw new Error(data?.error || error?.message || 'sin respuesta');
      $('lm-draft').value = data.suggestion;
      updateMailto();
      $('lm-status-note').textContent = '✨ Borrador generado con IA — revisalo antes de enviar.';
    } catch (e) {
      $('lm-status-note').textContent = 'No se pudo generar con IA (¿deployaste la función ai-suggest?): ' + e.message;
    } finally {
      btn.disabled = false; btn.textContent = prev;
    }
  });

  $('lm-delete').addEventListener('click', async () => {
    if (!currentLead) return;
    if (!confirm('¿Borrar definitivamente el lead de "' + (currentLead.name || currentLead.email) + '"? Esta acción no se puede deshacer.')) return;
    const { error } = await supabase.from('leads').delete().eq('id', currentLead.id);
    if (error) { alert('No se pudo borrar: ' + error.message); return; }
    allLeads = allLeads.filter((l) => l.id !== currentLead.id);
    closeLead();
    renderLeads();
  });

  /* ---------- Export CSV ---------- */
  $('export-csv').addEventListener('click', () => {
    const cols = ['created_at','first_name','last_name','email','message','status','channel','gclid','utm_source','utm_campaign','landing_path','lang','session_id'];
    const csvCell = (v) => '"' + String(v ?? '').replace(/"/g, '""') + '"';
    const csv = [cols.join(',')].concat(
      filteredLeads().map((r) => cols.map((c) => csvCell(r[c])).join(','))
    ).join('\n');
    const a = document.createElement('a');
    a.href = URL.createObjectURL(new Blob(['﻿' + csv], { type: 'text/csv;charset=utf-8' }));
    a.download = 'viven-leads-' + new Date().toISOString().slice(0, 10) + '.csv';
    a.click();
    URL.revokeObjectURL(a.href);
  });

  /* ---------- ANALYTICS ---------- */
  function countBy(rows, key){
    const m = new Map();
    rows.forEach((r) => {
      const k = r[key] || '(sin dato)';
      m.set(k, (m.get(k) || 0) + 1);
    });
    return [...m.entries()].sort((a, b) => b[1] - a[1]);
  }
  function bars(el, entries, max, valFmt){
    const top = entries.slice(0, max || 10);
    const peak = top.length ? top[0][1] : 1;
    el.innerHTML = top.map(([k, v, extra]) =>
      '<div class="bar-row"><span class="lbl" title="' + esc(k) + '">' + esc(k) + '</span>' +
      '<span class="track"><span class="fill" style="width:' + Math.max(2, Math.round((v / peak) * 100)) + '%"></span></span>' +
      '<span class="val">' + (valFmt ? valFmt(v, extra) : v) + '</span></div>'
    ).join('') || '<p class="muted-note">Sin datos todavía.</p>';
  }

  /* tabla de rendimiento: canal/página → sesiones, leads y % de conversión */
  function perfTable(el, list){
    const withRate = list.map((r) => ({ ...r, rate: r.sessions ? (r.leads / r.sessions * 100) : 0 }))
      .sort((a, b) => (b.leads - a.leads) || (b.sessions - a.sessions));
    const maxRate = Math.max(1, ...withRate.map((r) => r.rate));
    el.innerHTML = withRate.slice(0, 8).map((r) =>
      '<tr>' +
        '<td>' + (r.badge ? '<span class="badge b-' + esc(r.key) + '">' + esc(r.label) + '</span>' : '<span title="' + esc(r.label) + '">' + esc(r.label) + '</span>') + '</td>' +
        '<td class="num">' + r.sessions + '</td>' +
        '<td class="num"><span class="lead-n' + (r.leads ? '' : ' zero') + '">' + r.leads + '</span></td>' +
        '<td class="num"><span class="rate-cell"><span class="rate-bar"><i style="width:' + Math.round((r.rate / maxRate) * 100) + '%"></i></span><span class="rate-num">' + (r.sessions ? r.rate.toFixed(1) + '%' : '—') + '</span></span></td>' +
      '</tr>'
    ).join('') || '<tr><td colspan="4" class="muted-note" style="padding:14px">Sin datos todavía.</td></tr>';
  }

  function renderAnalytics(rows, leads){
    /* fuera las sesiones/leads de prueba */
    const real = rows.filter((r) => !/^claude-/.test(r.session_id || ''));
    const entries = real.filter((r) => r.is_entry);
    const sessions = new Set(real.map((r) => r.session_id));
    const periodStart = Date.now() - DAYS * 864e5;
    const periodLeads = (leads || []).filter((l) =>
      new Date(l.created_at).getTime() >= periodStart && !/^claude-/.test(l.session_id || ''));

    /* KPIs — la conversión = lead real enviado (fiable, no depende del pageview) */
    $('ka-views').textContent = real.length;
    $('ka-sessions').textContent = sessions.size;
    const durs = real.filter((r) => r.duration > 0);
    const avg = durs.length ? durs.reduce((a, r) => a + r.duration, 0) / durs.length : 0;
    $('ka-time').textContent = fmtTime(avg);
    $('ka-conv').textContent = periodLeads.length;
    $('ka-rate').textContent = sessions.size ? (periodLeads.length / sessions.size * 100).toFixed(1) + '%' : '—';

    /* tráfico + leads por día */
    const days = [];
    for (let i = DAYS - 1; i >= 0; i--) {
      const d = new Date(Date.now() - i * 864e5);
      days.push({ key: d.toISOString().slice(0, 10), label: d.toLocaleDateString('es-CH', { day: '2-digit', month: 'short' }), set: new Set(), leads: 0 });
    }
    const dayMap = new Map(days.map((d) => [d.key, d]));
    real.forEach((r) => { const d = dayMap.get(r.created_at.slice(0, 10)); if (d) d.set.add(r.session_id); });
    periodLeads.forEach((l) => { const d = dayMap.get(l.created_at.slice(0, 10)); if (d) d.leads++; });
    /* gráfico SVG real: área + línea de sesiones, puntos de leads */
    const n = days.length, W = 1000, H = 260, padL = 42, padR = 14, padT = 16, padB = 28;
    const pw = W - padL - padR, ph = H - padT - padB, baseY = padT + ph;
    const maxS = Math.max(1, ...days.map((d) => d.set.size));
    const X = (i) => padL + (n <= 1 ? pw / 2 : (i / (n - 1)) * pw);
    const Y = (v) => padT + (1 - v / maxS) * ph;
    const pts = days.map((d, i) => [X(i), Y(d.set.size)]);
    const linePath = pts.map((p, i) => (i ? 'L' : 'M') + p[0].toFixed(1) + ' ' + p[1].toFixed(1)).join(' ');
    const areaPath = 'M' + X(0).toFixed(1) + ' ' + baseY + ' ' + pts.map((p) => 'L' + p[0].toFixed(1) + ' ' + p[1].toFixed(1)).join(' ') + ' L' + X(n - 1).toFixed(1) + ' ' + baseY + ' Z';
    const grid = [0, 0.5, 1].map((t) => {
      const v = Math.round(maxS * t), y = Y(v);
      return '<line x1="' + padL + '" y1="' + y.toFixed(1) + '" x2="' + (W - padR) + '" y2="' + y.toFixed(1) + '" class="g-grid"/>' +
        '<text x="' + (padL - 8) + '" y="' + (y + 4).toFixed(1) + '" class="g-yl">' + v + '</text>';
    }).join('');
    const leadDots = days.map((d, i) => d.leads ? '<circle cx="' + X(i).toFixed(1) + '" cy="' + Y(d.set.size).toFixed(1) + '" r="' + (3 + Math.min(4, d.leads)) + '" class="g-lead"><title>' + d.label + ': ' + d.leads + ' leads</title></circle>' : '').join('');
    const hover = days.map((d, i) => '<circle cx="' + X(i).toFixed(1) + '" cy="' + Y(d.set.size).toFixed(1) + '" r="11" fill="transparent"><title>' + d.label + ' — ' + d.set.size + ' sesiones · ' + d.leads + ' leads</title></circle>').join('');
    const step = Math.max(1, Math.ceil(n / 7));
    const xls = days.map((d, i) => ((i % step === 0) || i === n - 1) ? '<text x="' + X(i).toFixed(1) + '" y="' + (H - 8) + '" class="g-xl" text-anchor="middle">' + d.label + '</text>' : '').join('');
    $('daily-chart').innerHTML = '<svg viewBox="0 0 ' + W + ' ' + H + '" class="gsvg">' +
      '<defs><linearGradient id="gfill" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#ddf98f" stop-opacity=".28"/><stop offset="1" stop-color="#ddf98f" stop-opacity="0"/></linearGradient></defs>' +
      grid + '<path d="' + areaPath + '" fill="url(#gfill)"/><path d="' + linePath + '" class="g-line"/>' + leadDots + hover + xls + '</svg>';

    /* rendimiento por CANAL: sesiones vs leads */
    const chSessions = new Map();
    entries.forEach((e) => { const k = e.channel || 'direct'; chSessions.set(k, (chSessions.get(k) || 0) + 1); });
    const chLeads = new Map();
    periodLeads.forEach((l) => { const k = l.channel || 'direct'; chLeads.set(k, (chLeads.get(k) || 0) + 1); });
    const chKeys = new Set([...chSessions.keys(), ...chLeads.keys()]);
    const channelPerf = [...chKeys].map((k) => ({ key: k, label: k, badge: true, sessions: chSessions.get(k) || 0, leads: chLeads.get(k) || 0 }));
    perfTable($('perf-channel'), channelPerf);

    /* rendimiento por PÁGINA DE ENTRADA */
    const lpSessions = new Map();
    entries.forEach((e) => { const k = e.path || '/'; lpSessions.set(k, (lpSessions.get(k) || 0) + 1); });
    const lpLeads = new Map();
    periodLeads.forEach((l) => { const k = l.landing_path || '(sin dato)'; lpLeads.set(k, (lpLeads.get(k) || 0) + 1); });
    const lpKeys = new Set([...lpSessions.keys(), ...lpLeads.keys()]);
    const landingPerf = [...lpKeys].map((k) => ({ key: k, label: k, sessions: lpSessions.get(k) || 0, leads: lpLeads.get(k) || 0 }));
    perfTable($('perf-landing'), landingPerf);

    /* resumen compacto para los insights con IA */
    insightsData = {
      dias: DAYS,
      sesiones: sessions.size,
      paginas_vistas: real.length,
      tiempo_medio_seg: Math.round(avg),
      leads: periodLeads.length,
      tasa_conversion_pct: sessions.size ? +(periodLeads.length / sessions.size * 100).toFixed(2) : 0,
      canales: channelPerf.map((c) => ({ canal: c.label, sesiones: c.sessions, leads: c.leads })).slice(0, 8),
      paginas_entrada: landingPerf.map((p) => ({ path: p.label, sesiones: p.sessions, leads: p.leads })).slice(0, 8),
    };

    /* titulares automáticos */
    renderInsights(channelPerf, landingPerf, entries, periodLeads, sessions.size);

    /* dispositivos / idiomas */
    bars($('bars-device'), countBy(real, 'device'), 3);
    bars($('bars-lang'), countBy(entries, 'lang'), 8);

    /* top páginas por engagement (visitas + tiempo) */
    const byPath = new Map();
    real.forEach((r) => {
      const p = byPath.get(r.path) || { views: 0, dur: 0, durN: 0 };
      p.views++;
      if (r.duration > 0) { p.dur += r.duration; p.durN++; }
      byPath.set(r.path, p);
    });
    const pages = [...byPath.entries()]
      .map(([k, p]) => [k, p.views, p.durN ? p.dur / p.durN : 0])
      .sort((a, b) => b[1] - a[1]);
    bars($('bars-pages'), pages, 15, (v, t) => v + ' <small>· ' + fmtTime(t) + '</small>');
  }

  function renderInsights(channelPerf, landingPerf, entries, periodLeads, sessionCount){
    const cards = [];
    /* 1 — mejor canal para leads */
    const chLeaders = channelPerf.filter((c) => c.leads > 0).sort((a, b) => b.leads - a.leads);
    if (chLeaders.length) {
      const c = chLeaders[0];
      cards.push({ t: '🏆 Canal que más convierte', v: '<em>' + esc(c.label) + '</em>',
        d: c.leads + ' lead' + (c.leads > 1 ? 's' : '') + ' · ' + (c.sessions ? (c.leads / c.sessions * 100).toFixed(1) + '% de sus sesiones' : '') });
    } else {
      const top = [...channelPerf].sort((a, b) => b.sessions - a.sessions)[0];
      cards.push({ t: '📡 Mayor fuente de tráfico', v: top ? '<em>' + esc(top.label) + '</em>' : '—',
        d: top ? top.sessions + ' sesiones · aún sin leads atribuidos' : 'Sin tráfico todavía' });
    }
    /* 2 — página que más convierte */
    const lpLeaders = landingPerf.filter((p) => p.leads > 0).sort((a, b) => b.leads - a.leads);
    if (lpLeaders.length) {
      const p = lpLeaders[0];
      cards.push({ t: '🎯 Página que más convierte', v: '<em>' + esc(p.label) + '</em>',
        d: p.leads + ' lead' + (p.leads > 1 ? 's' : '') + ' desde esta entrada' });
    } else {
      cards.push({ t: '🎯 Página que más convierte', v: '<em>—</em>', d: 'Aún sin leads. Comparte el sitio o lanza una campaña.' });
    }
    /* 3 — oportunidad: página con mucho tráfico y 0 leads */
    const opp = [...landingPerf].filter((p) => p.leads === 0 && p.sessions >= 3).sort((a, b) => b.sessions - a.sessions)[0];
    if (opp) {
      cards.push({ t: '⚠️ Oportunidad a revisar', v: '<em>' + esc(opp.label) + '</em>',
        d: opp.sessions + ' sesiones y 0 leads — ¿mejorar el CTA o el mensaje?' });
    } else {
      cards.push({ t: '📈 Conversión global', v: '<em>' + (sessionCount ? (periodLeads.length / sessionCount * 100).toFixed(1) + '%' : '—') + '</em>',
        d: periodLeads.length + ' leads de ' + sessionCount + ' sesiones (30 días)' });
    }
    $('insights').innerHTML = cards.map((c) =>
      '<div class="insight"><div class="t">' + c.t + '</div><div class="v">' + c.v + '</div><div class="d">' + esc0html(c.d) + '</div></div>'
    ).join('');
  }
  const esc0html = (s) => String(s ?? '');

  /* ---------- Sesión persistente ---------- */
  supabase.auth.getSession().then(({ data }) => {
    if (data.session) { show('dash'); loadAll(); }
    else show('login');
  });
</script>

</body>
</html>
