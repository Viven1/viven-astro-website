  // barra + badge estilo Licencias (.lic-days): verde si falta mucho, ámbar si se acerca el fin
  function cfLoanBadge(l){
    const now = new Date(), start = new Date(l.start_date + 'T00:00:00'), end = new Date(l.end_date + 'T00:00:00');
    const totalMonths = Math.max(1, Math.round((end - start) / (30.44 * 864e5)));
    const elapsed = Math.min(totalMonths, Math.max(0, Math.round((now - start) / (30.44 * 864e5))));
    const remaining = Math.max(0, totalMonths - elapsed);
    const pct = Math.min(100, Math.max(0, Math.round((elapsed / totalMonths) * 100)));
    let cls;
    if (remaining <= 0) cls = 'past'; else if (remaining <= 3) cls = 'due'; else if (remaining <= 6) cls = 'soon'; else cls = 'ok';
    const txt = remaining > 0 ? remaining + ' cuota' + (remaining === 1 ? '' : 's') + ' restantes' : 'finalizado';
    return { html: '<span class="lic-days ' + cls + '">' + txt + '</span>', pct };
  }
