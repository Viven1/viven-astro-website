  // el orden default replica EXACTO el layout que la página pública tenía hasta hoy
  const PP_BLOCK_DEFAULT = ['intro', 'photo1', 'overview', 'scope', 'tiers', 'addons', 'terms', 'call', 'testimonial', 'videos'];
  const ppBlockLabel = (k) => (PP_BLOCKS.find(([key]) => key === k) || [k, k])[1];
  // sanea un block_order guardado: solo claves conocidas, sin duplicados, y las que falten al final
  function ppNormOrder(order){
    const known = PP_BLOCKS.map(([k]) => k);
    const seen = new Set();
    const out = (Array.isArray(order) ? order : []).filter((k) => known.includes(k) && !seen.has(k) && seen.add(k));
    known.forEach((k) => { if (!seen.has(k)) out.push(k); });
    return out.length ? out : PP_BLOCK_DEFAULT.slice();
  }
