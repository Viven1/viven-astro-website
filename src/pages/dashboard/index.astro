      const la = abLeads.filter((l) => String(l.ab || '').includes(t.id + ':a')).length;
      const lb = abLeads.filter((l) => String(l.ab || '').includes(t.id + ':b')).length;
      const st = abStats(ea, la, eb, lb);
      return { t, ea, eb, la, lb, eff: abEffStatus(t), ...st };
