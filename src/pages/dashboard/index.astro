    if (!title || !renewal){ toast('Falta título o fecha de renovación'); return; }
    const row = {
      title, lead_id: $('lic-lead').value || null,
      amount: $('lic-amount').value ? +$('lic-amount').value : null,
      start_date: $('lic-start').value || null,
      renewal_date: renewal,
      notes: $('lic-notes').value.trim() || null,
      updated_at: new Date().toISOString(),
    };
    let error;
    if (licEditing){ ({ error } = await supabase.from('licenses').update(row).eq('id', licEditing.id)); }
    else { ({ error } = await supabase.from('licenses').insert(row)); }
    if (error){ toast(/does not exist|relation/i.test(error.message) ? 'Falta correr el SQL 0048' : '⚠️ ' + error.message); return; }
    toast('💾 Guardada'); $('lic-form').hidden = true; licLoad();
  }
  function licDaysBadge(renewalDate){
    const days = Math.round((new Date(renewalDate + 'T00:00:00').getTime() - new Date(new Date().toDateString()).getTime()) / 864e5);
    let cls, txt;
    if (days < 0){ cls = 'past'; txt = 'venció hace ' + Math.abs(days) + 'd'; }
    else if (days === 0){ cls = 'due'; txt = 'HOY'; }
    else if (days <= 30){ cls = 'due'; txt = 'en ' + days + 'd'; }
    else if (days <= 90){ cls = 'soon'; txt = 'en ' + days + 'd'; }
    else { cls = 'ok'; txt = 'en ' + days + 'd'; }
    return '<span class="lic-days ' + cls + '">' + txt + '</span>';
  }
  async function licLoad(){
    const { data, error } = await supabase.from('licenses').select('*').order('renewal_date', { ascending: true });
    if (error){ $('lic-list').innerHTML = '<p class="muted-note">Corré el SQL 0048 para activar Licencias.</p>'; return; }
    licList = data || [];
    licRender();
  }
  const licCHF = (n) => 'CHF ' + Math.round(Number(n) || 0).toLocaleString('de-CH');
  // KPIs de ingreso recurrente — todo client-side sobre licList (montos = mensuales)
  function licKpis(){
    const active = licList.filter((l) => l.status === 'active');
    const monthly = active.reduce((a, l) => a + (Number(l.amount) || 0), 0);
    const renewed30 = licList.filter((l) => l.status === 'renewed' && l.updated_at && (Date.now() - Date.parse(l.updated_at) < 30 * 864e5))
      .reduce((a, l) => a + (Number(l.amount) || 0), 0);
    const due90 = active.filter((l) => l.renewal_date && licDaysTo(l.renewal_date) >= 0 && licDaysTo(l.renewal_date) <= 90)
      .reduce((a, l) => a + (Number(l.amount) || 0), 0);
    const risk = active.filter((l) => l.renewal_date && licDaysTo(l.renewal_date) <= 30).length;
    $('lic-k-active').innerHTML = licCHF(monthly) + '<small>/mes</small>';
    $('lic-k-renewed').textContent = licCHF(renewed30);
    $('lic-k-due90').textContent = licCHF(due90);
    const rk = $('lic-k-risk'); rk.textContent = String(risk); rk.style.color = risk > 0 ? '#ff8b8b' : '';
  }
  function licMatch(l){
    if (licFilter === 'active') return l.status === 'active';
    if (licFilter === 'due') return l.status === 'active' && l.renewal_date && licDaysTo(l.renewal_date) <= 30;
    if (licFilter === 'renewed') return l.status === 'renewed';
    if (licFilter === 'expired') return l.status === 'expired';
    if (licFilter === 'cancelled') return l.status === 'cancelled';
    return true;
  }
  function licSeg(){
    const seg = $('lic-seg'); if (!seg) return;
    const cnt = (f) => licList.filter((l) => { const bak = licFilter; licFilter = f; const r = licMatch(l); licFilter = bak; return r; }).length;
    const defs = [['active', 'Activas'], ['due', 'Por vencer <30d'], ['renewed', 'Renovadas'], ['expired', 'Vencidas'], ['cancelled', 'Canceladas']];
    seg.innerHTML = defs.map(([k, lbl]) => '<button data-f="' + k + '" class="' + (licFilter === k ? 'on' : '') + '" type="button">' + lbl + ' ' + cnt(k) + '</button>').join('');
    seg.querySelectorAll('button').forEach((b) => b.addEventListener('click', () => { licFilter = b.dataset.f; licRender(); }));
  }
  function licRender(){
    licSeg(); licKpis();
