    const pubT = (p) => Date.parse(p.published_at || p.updated_at) || 0;
    const updT = (p) => Date.parse(p.updated_at) || 0;
    if (ppSort === 'value') pool.sort((a, b) => propVal(b) - propVal(a));
    else if (ppSort === 'recent') pool.sort((a, b) => updT(b) - updT(a));
    else pool.sort((a, b) => {
      const g = (p) => p.status === 'sent' ? 0 : p.status === 'draft' ? 1 : 2;
      if (g(a) !== g(b)) return g(a) - g(b);
      return g(a) === 0 ? pubT(a) - pubT(b) : updT(b) - updT(a);
    });
    const BDG = { draft: ['Borrador', '#8ab4ff'], sent: ['Publicada', '#f0c060'], accepted: ['Aceptada', '#7ed957'], lost: ['Perdida', '#ff6b6b'] };
