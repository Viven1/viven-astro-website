  let sender = localStorage.getItem('viven_sender') || 'sofia';
  const briefUrl = (r) => 'https://www.viven.ch/brief/?lead=' + encodeURIComponent(r.id) + '&lang=' + (['en', 'de', 'es'].includes(r.lang) ? r.lang : 'en') + '&topic=' + detectTopic(r.message);

  // customProof: frase personalizada de la IA (opcional). Si no viene, usa la estática.
  // La estructura (saludo, 2 CTAs, brief, firma) SIEMPRE la controla el código — la IA solo cambia el hook.
  function buildDraft(r, customProof){
    const lang = ['en', 'de', 'es'].includes(r.lang) ? r.lang : 'en';
    const first = esc0(r.first_name || (r.name || '').trim().split(/\s+/)[0] || '');
    const proof = customProof || PROOF[lang][detectTopic(r.message)];
    const S = SENDERS[sender] || SENDERS.sofia;
    const BOOK_URL = S.book;
    const SIGN = S.name + '\nViven — viven.ch · +41 43 508 33 81';
    if (lang === 'de') return 'Guten Tag ' + first + '\n\n' +
      'Vielen Dank für Ihre Anfrage — gerne helfen wir weiter.\n\n' +
      'Zur Einordnung: ' + proof + '.\n\n' +
      'Damit es schnell geht, wählen Sie einfach, was für Sie leichter ist:\n\n' +
      '① 15-Min-Call buchen: ' + BOOK_URL + '\n' +
      '② Oder Ihr Briefing in 2 Minuten ausfüllen: ' + briefUrl(r) + '\n\n' +
      'So oder so bekommen Sie ein fixes Angebot mit Timing — der erste Entwurf ist in der Regel ca. zwei Wochen nach Start fertig.\n\n' +
      'Freundliche Grüsse\n' + SIGN;
    if (lang === 'es') return 'Hola ' + first + ':\n\n' +
      'Gracias por escribirnos — nos encantaría ayudarte.\n\n' +
      'Para que nos ubiques: ' + proof + '.\n\n' +
      'Para avanzar rápido, elegí lo que te resulte más fácil:\n\n' +
      '① Agendá una llamada de 15 min: ' + BOOK_URL + '\n' +
      '② O completá tu brief en 2 minutos: ' + briefUrl(r) + '\n\n' +
      'En cualquier caso te mandamos una propuesta con presupuesto fijo y tiempos — el primer borrador suele estar listo unas dos semanas después de arrancar.\n\n' +
      'Saludos,\n' + SIGN;
    return 'Hi ' + first + ',\n\n' +
      'Thanks for reaching out — we’d love to help.\n\n' +
      'For context: ' + proof + '.\n\n' +
      'To move fast, pick whichever is easier for you:\n\n' +
      '① Book a 15-min call: ' + BOOK_URL + '\n' +
      '② Or send us your brief in 2 minutes: ' + briefUrl(r) + '\n\n' +
      'Either way you’ll get a fixed quote with timing — the first draft is typically ready about two weeks after we start.\n\n' +
      'Best,\n' + SIGN;
  }
  /* nombre sin HTML para el draft (texto plano) */
  const esc0 = (s) => String(s ?? '').replace(/[<>]/g, '');

  const SUBJECTS = {
    en: 'Your video project — Viven',
