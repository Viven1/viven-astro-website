          '<div class="cell"><div class="l">Leads B</div><div class="v">' + lb + (eb ? ' <span style="font-size:12px;color:var(--muted-2)">' + cb.toFixed(1) + '%</span>' : '') + '</div></div>' +
          '<div class="cell"><div class="l">Uplift B</div><div class="v" style="color:' + (up >= 0 ? '#7ed957' : '#ff8b8b') + '">' + (up >= 0 ? '+' : '') + up.toFixed(0) + '%</div></div>' +
