      ? supabase.from('offers').update(p).eq('id', ofCur.id).select().single()
      : supabase.from('offers').insert(p).select().single();
    let res = await doSave(payload);
    // columnas nuevas sin migrar (SQL 0014/0018/0061): sacarlas y reintentar
    for (let a = 0; a < 8 && res.error; a++) {
      const m = /Could not find the '([^']+)' column/.exec(res.error.message || '');
