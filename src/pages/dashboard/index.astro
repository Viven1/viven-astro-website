  async function publishBlog(){
    const b = buildBlogAstro(); if (!b) return;
    if (!/^[a-z0-9-]+$/.test(b.slug)) { toast('El slug solo puede tener letras, números y guiones'); return; }
    if (!confirm('¿Publicar "' + $('bg-title').value + '" en la web?\n\nSe commitea a GitHub y Netlify lo publica en ~1-2 min en viven.ch/blog/' + b.slug + '/')) return;
    const btn = $('bg-publish'), prev = btn.textContent; btn.disabled = true; btn.textContent = '🚀 Publicando…';
    $('bg-pub-note').textContent = 'Commiteando a GitHub…';
    try {
