  const AU_TYPE_OPTS = '<option value="email">📧 Email</option><option value="ai_email">🤖 Email IA (a bandeja)</option><option value="wait">⏱ Esperar días</option><option value="task">✅ Tarea para el team</option><option value="push">🔔 Push al team</option><option value="status">🔀 Cambiar etapa</option>';
