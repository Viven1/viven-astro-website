  // Cambia la etapa de un lead (desde el board o desde el contacto): pregunta motivo
  // si es Perdido, sella el hito de la etapa y persiste. Devuelve true si movió.
  async function setLeadStage(id, stage){
    const lead = allLeads.find((l) => String(l.id) === String(id));
    if (!lead || stageOf(lead.status) === stage) return false;
    const prev = lead.status;
    let lostReason;
    if (stage === 'perdido') {
      lostReason = prompt('¿Por qué se perdió este lead? (opcional)', lead.lost_reason || '');
      if (lostReason === null) return false;   // canceló → no mover
    }
    lead.status = stage;               // optimista
    const nowIso = new Date().toISOString();
    // last_stage_at se sella SIEMPRE (última actividad); los hitos del funnel solo la primera vez
    const patch = { status: stage, last_stage_at: nowIso };
    lead.last_stage_at = nowIso;
    const tsCol = STAGE_TS[stage];
    if (tsCol && !lead[tsCol]) { patch[tsCol] = nowIso; lead[tsCol] = nowIso; }
    if (stage === 'perdido') { patch.lost_reason = lostReason || null; lead.lost_reason = lostReason || null; }
    renderLeads();
    let { error } = await supabase.from('leads').update(patch).eq('id', id);
    // si falta la columna last_stage_at (SQL 0015 sin correr), guardar sin ella
    if (error && /last_stage_at/.test(error.message || '')) { delete patch.last_stage_at; ({ error } = await supabase.from('leads').update(patch).eq('id', id)); }
    if (error) { lead.status = prev; if (tsCol) lead[tsCol] = null; renderLeads(); toast('No se pudo mover: ' + error.message); return false; }
    // Perdido: el motivo queda grabado en TODO — nota en el contacto + ofertas y propuestas ligadas
    if (stage === 'perdido') cascadeLost(lead, lostReason || null);
    // Ganado: las ofertas abiertas del lead pasan a ganadas (sync total deals ↔ ofertas)
    if (stage === 'ganado') cascadeWon(lead);
    // el deal avanzó o cerró → cancelar follow-ups pendientes (además del guard del cron)
    if (['videocall', 'propuesta', 'ganado', 'perdido'].includes(stage))
      supabase.from('lead_followups').update({ status: 'canceled' }).eq('lead_id', String(id)).in('status', ['draft', 'approved']).then(() => { if (currentLead && String(currentLead.id) === String(id)) loadFollowups(currentLead); });
    return true;
  }
  // Deal ganado → sus ofertas abiertas (borrador/enviada) también, así Home y Ofertas dicen la verdad
  async function cascadeWon(lead){
    const open = (offersList || []).filter((o) => o.lead_id && String(o.lead_id) === String(lead.id) && !o.archived && !o.is_template && ['draft', 'sent'].includes(o.status));
    if (!open.length) return;
    const { error } = await supabase.from('offers').update({ status: 'won' }).eq('lead_id', String(lead.id)).in('status', ['draft', 'sent']);
    if (error) return;
    open.forEach((o) => { o.status = 'won'; });
    try { renderOffersList(); renderHome(); } catch (e) {}
    toast('🏆 ' + open.length + ' oferta' + (open.length > 1 ? 's' : '') + ' marcada' + (open.length > 1 ? 's' : '') + ' como ganada' + (open.length > 1 ? 's' : ''));
  }
  // Registra la pérdida donde haga falta (best-effort: nada de esto bloquea el cambio de etapa)
  async function cascadeLost(lead, reason){
    const rTxt = reason || 'sin especificar';
    // 1) nota automática en el contacto → historial permanente aunque la etapa cambie después
    supabase.from('lead_notes').insert({ lead_id: String(lead.id), author: teamName(myEmail()), body: '❌ Deal perdido — motivo: ' + rTxt })
      .then(() => { if (currentLead && String(currentLead.id) === String(lead.id)) loadTasksNotes(lead); });
    // 2) ofertas ligadas (no ganadas) → lost + motivo
    const ofs = (offersList || []).filter((o) => o.lead_id && String(o.lead_id) === String(lead.id) && o.status !== 'won');
    for (const o of ofs) {
      let { error } = await supabase.from('offers').update({ status: 'lost', lost_reason: reason }).eq('id', o.id);
      if (error && /lost_reason/.test(error.message || '')) ({ error } = await supabase.from('offers').update({ status: 'lost' }).eq('id', o.id));
      if (!error) { o.status = 'lost'; o.lost_reason = reason; }
    }
    if (ofs.length && typeof renderOffersList === 'function') try { renderOffersList(); } catch (e) {}
    // 3) propuestas ligadas → guardar el motivo (sin tocar su status público)
    supabase.from('proposals').update({ lost_reason: reason }).eq('lead_id', String(lead.id)).then(() => {});
  }

  /* ---------- Lead detail + draft de respuesta ---------- */
  const modal = $('lead-modal');
  let currentLead = null;

  const TOPICS = [
    { key: 'employer', re: /employer|recruit|talent|hiring|arbeitgeber|mitarbeiter|karriere|reclut|empleo|kultur|culture/i },
    { key: 'product',  re: /product|produkt|producto|launch|lancierung|lanzamiento|e-?com/i },
    { key: 'social',   re: /social|instagram|tiktok|linkedin|reels|shorts|redes/i },
