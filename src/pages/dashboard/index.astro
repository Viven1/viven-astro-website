      const ref = oSent.sent_at || oSent.updated_at;
      return '<div class="pc-doc">🧾 enviada' + (ref ? ' hace ' + timeAgo(ref) : '') + '</div>';
    }
    const oDraft = newest(ofs.filter((o) => o.status === 'draft'));
    const pDraft = newest(props.filter((p) => p.status === 'draft'));
    if (oDraft || pDraft) return '<div class="pc-doc">' + (oDraft ? '🧾' : '🌐') + ' borrador listo para enviar</div>';
    // en etapas tempranas todavía no hace falta la alarma
    if (stKey === 'videocall' || stKey === 'propuesta') return '<div class="pc-doc warn">⚠ sin documento</div>';
    return '';
  }
  function cardHTML(d, st){
    const r = leadById(d.lead_id) || {};
    const PRIO = { won: 0, sent: 1, draft: 2, lost: 3 };
    const ofs = offersForDeal(d).slice().sort((a, b) => (PRIO[a.status] ?? 9) - (PRIO[b.status] ?? 9));
    let total = st.key === 'perdido' ? dealLostValue(d) : dealValue(d);
    let est = '';
    if (!ofs.some((o) => o.status !== 'lost') && Number(d.deal_value)) est = ' <span style="font-weight:400;font-size:10px;color:var(--muted-2)">est.</span>';
    // nombre del deal: su título, o el de la oferta más relevante, o el de la persona
    const dealName = d.title || ((ofs[0] && ofs[0].title) ? ofs[0].title : (r.name || r.first_name || '(sin nombre)'));
    // empresa · persona en una sola línea (el detalle vive en la ficha)
    const dom = leadDomain(r);
