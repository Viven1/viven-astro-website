  // Embudo real por video (rediseño): arranque→25→50→75→100 con Leads Y Ganados.
  // "Arrancó" en 0 con la bandera "no contabilizado" señala el hueco que existía
  // antes del fix de site.js (embeds sueltos sin openVideo() no sumaban play) —
  // filas viejas (previas al fix) también pueden mostrar esto si no tuvieron pct=0.
  function renderVideoAna(plays, leadsArr){
    const box = $('ka-video-table'); if (!box) return;
    const kpisEl = $('va-kpis');
    if (!plays.length){ box.innerHTML = '<p class="muted-note">Sin reproducciones en el período.</p>'; if (kpisEl) kpisEl.innerHTML = ''; return; }
    const leadSess = new Set((leadsArr || []).map((l) => l.session_id).filter(Boolean));
    const wonLeadIds = new Set((dealsList || []).filter((d) => stageOf(d.stage) === 'ganado').map((d) => String(d.lead_id)));
    const wonSess = new Set((leadsArr || []).filter((l) => l.session_id && wonLeadIds.has(String(l.id))).map((l) => l.session_id));
    const by = {};
    plays.forEach((p) => {
      const k = p.label || p.video_id;
      const b = by[k] = by[k] || { videoId: p.video_id, plays: 0, m: { 25: 0, 50: 0, 75: 0, 100: 0 }, sess: new Set(), maxBy: {} };
      const pct = +p.pct || 0;
      if (!pct){ b.plays++; if (p.session_id) b.sess.add(p.session_id); }
      else if (b.m[pct] !== undefined) b.m[pct]++;
      if (p.session_id) b.maxBy[p.session_id] = Math.max(b.maxBy[p.session_id] || 0, pct);
    });
    const rows = Object.entries(by).sort((a2, b2) => b2[1].plays - a2[1].plays);

    // KPIs globales del período
    const totalPlays = rows.reduce((a2, [, b]) => a2 + b.plays, 0);
    const allMax = []; rows.forEach(([, b]) => Object.values(b.maxBy).forEach((v) => allMax.push(v)));
    const avgAll = allMax.length ? Math.round(allMax.reduce((a2, v) => a2 + v, 0) / allMax.length) : 0;
    const leadSessAll = new Set(), wonSessAll = new Set();
    rows.forEach(([, b]) => b.sess.forEach((s) => { if (leadSess.has(s)) leadSessAll.add(s); if (wonSess.has(s)) wonSessAll.add(s); }));
    const pctOf = (n) => totalPlays ? (n / totalPlays * 100).toFixed(1) + '% de las reproducciones' : '';
    if (kpisEl) kpisEl.innerHTML =
      '<div class="kpi"><div class="n">' + totalPlays.toLocaleString('de-CH') + '</div><div class="l">Reproducciones</div></div>' +
      '<div class="kpi"><div class="n">' + avgAll + '%</div><div class="l">Visto en promedio</div></div>' +
      '<div class="kpi"><div class="n">' + leadSessAll.size + '</div><div class="l">→ Lead <span class="muted-note">' + pctOf(leadSessAll.size) + '</span></div></div>' +
      '<div class="kpi"><div class="n" style="color:var(--acid)">' + wonSessAll.size + '</div><div class="l">→ Ganado <span class="muted-note">' + pctOf(wonSessAll.size) + '</span></div></div>';

    box.innerHTML = rows.map(([k, b]) => {
      const sess = Object.keys(b.maxBy);
      const avg = sess.length ? Math.round(sess.reduce((a2, s2) => a2 + b.maxBy[s2], 0) / sess.length) : 0;
      const leads = [...b.sess].filter((s2) => leadSess.has(s2)).length;
      const won = [...b.sess].filter((s2) => wonSess.has(s2)).length;
      const noStart = !b.plays; // hueco real (pre-fix): hitos sin ningún pct=0 asociado
      const steps = [['Arrancó', noStart ? null : b.plays], ['25%', b.m[25]], ['50%', b.m[50]], ['75%', b.m[75]], ['100%', b.m[100]]];
      const base = Math.max(b.plays, b.m[25], b.m[50], b.m[75], b.m[100], 1);
      let worstDrop = null, worstPct = 0;
      for (let i = 1; i < steps.length; i++){
        const prev = steps[i - 1][1] || 0, cur = steps[i][1] || 0;
        if (prev > 0){ const drop = (prev - cur) / prev; if (drop > worstPct){ worstPct = drop; worstDrop = steps[i - 1][0] + '→' + steps[i][0]; } }
      }
      const bars = steps.map(([label, v], i) => {
        const h = v ? Math.max(6, Math.round((v / base) * 100)) : 6;
        const isStartGap = i === 0 && noStart;
        return '<div class="bar' + (i === steps.length - 1 && !isStartGap ? ' finish' : '') + '" style="height:' + h + '%' + (isStartGap ? ';background:var(--line)' : '') + '"><span>' + label + '</span><b style="color:' + (isStartGap ? 'var(--muted)' : '#0f1826') + '">' + (v == null ? '?' : v) + '</b></div>';
      }).join('');
      return '<div class="va-card">' +
        '<div class="hd"><b>🎬 ' + esc(String(k).slice(0, 60)) + '</b><span>' + (noStart ? '0 reproducciones' : b.plays + ' reproducciones') + ' · Ø visto ' + avg + '%' +
          (noStart ? ' <span class="of-badge" style="color:#f0c060;border-color:#f0c060">no contabilizado</span>' : '') + '</span></div>' +
        '<div class="va-funnel">' + bars + '</div>' +
        '<div class="va-fstats"><span>👤 Leads: <b>' + (leads || '<span class="muted-note">— (sin datos)</span>') + '</b></span>' +
        '<span>🏆 Ganados: <b class="acid">' + (won || '<span class="muted-note">— (sin datos)</span>') + '</b></span>' +
        (worstDrop ? '<span>Caída más fuerte: <b>' + worstDrop + '</b> (−' + Math.round(worstPct * 100) + '%)</span>' : '') + '</div>' +
        '<div class="va-vimeo" data-vimeo-badge="' + esc(b.videoId || '') + '"></div>' +
      '</div>';
    }).join('');

    loadVimeoOfficial(rows); // best-effort — nunca bloquea lo de arriba
  }
  // dato EXTRA de Vimeo oficial (play count del propio Vimeo) si hay token configurado
  // (VIMEO_ACCESS_TOKEN) — sin token, vimeo-stats responde {pending:true} y no mostramos
  // nada acá: el tracking propio de arriba ya es la fuente principal y confiable.
  async function loadVimeoOfficial(rows){
    try {
      const ids = [...new Set(rows.map(([, b]) => b.videoId).filter(Boolean))];
      if (!ids.length) return;
      const { data, error } = await supabase.functions.invoke('vimeo-stats', { body: { video_ids: ids } });
      if (error || !data || data.pending || data.error) return;
      const stats = data.stats || {};
      document.querySelectorAll('#ka-video-table [data-vimeo-badge]').forEach((el) => {
        const vid = el.dataset.vimeoBadge, s = stats[vid];
        if (s && s.plays != null) el.textContent = '📊 Vimeo oficial: ' + Number(s.plays).toLocaleString('de-CH') + ' plays';
      });
    } catch (e) { /* best-effort */ }
  }
  function renderBlogList(){
