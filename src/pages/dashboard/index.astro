        '<div class="nums"><div><b>' + e2 + '</b><span>sesiones</span></div><div><b>' + l2 + '</b><span>leads</span></div><div><b>' + (e2 ? (conv * 100).toFixed(1) : '0') + '%</b><span>conv.</span></div></div></div>';
    // sub-línea: path · split · día · auto-stop
    const sub = esc(t.url_path) + ' · split ' + (t.split_pct || 50) + '/' + (100 - (t.split_pct || 50)) +
      (day ? ' · día ' + day : '') + (endTxt ? ' · termina ' + endTxt + ' (auto-stop)' : '') + ' · ' + changes.length + ' cambio(s)';
    // acciones
