      if (error || !data || !data.body_html) throw new Error(data?.error || error?.message || 'sin respuesta');
      const row = { lang, topic, slug: data.slug, title: data.title, description: data.description, eyebrow: data.eyebrow, lead: data.lead, body_html: data.body_html, faq: data.faq || [], status: 'draft' };
      if (opts.groupId) row.group_id = opts.groupId;
