  /* ---------- ANALYTICS ---------- */
  function countBy(rows, key){
    const m = new Map();
    rows.forEach((r) => {
      const k = r[key] || '(sin dato)';
      m.set(k, (m.get(k) || 0) + 1);
    });
    return [...m.entries()].sort((a, b) => b[1] - a[1]);
  }
  function bars(el, entries, max, valFmt){
    const top = entries.slice(0, max || 10);
    const peak = top.length ? top[0][1] : 1;
    el.innerHTML = top.map(([k, v, extra]) =>
      '<div class="bar-row"><span class="lbl" title="' + esc(k) + '">' + esc(k) + '</span>' +
      '<span class="track"><span class="fill" style="width:' + Math.max(2, Math.round((v / peak) * 100)) + '%"></span></span>' +
      '<span class="val">' + (valFmt ? valFmt(v, extra) : v) + '</span></div>'
    ).join('') || '<p class="muted-note">Sin datos todavía.</p>';
  }

  /* tabla de rendimiento: canal/página → sesiones, leads y % de conversión */
  function perfTable(el, list){
    const withRate = list.map((r) => ({ ...r, rate: r.sessions ? (r.leads / r.sessions * 100) : 0 }))
      .sort((a, b) => (b.leads - a.leads) || (b.sessions - a.sessions));
    const maxRate = Math.max(1, ...withRate.map((r) => r.rate));
    el.innerHTML = withRate.slice(0, 8).map((r) =>
      '<tr>' +
        '<td>' + (r.badge ? '<span class="badge b-' + esc(r.key) + '">' + esc(r.label) + '</span>' : '<span title="' + esc(r.label) + '">' + esc(r.label) + '</span>') + '</td>' +
        '<td class="num">' + r.sessions + '</td>' +
        '<td class="num"><span class="lead-n' + (r.leads ? '' : ' zero') + '">' + r.leads + '</span></td>' +
        '<td class="num"><span class="rate-cell"><span class="rate-bar"><i style="width:' + Math.round((r.rate / maxRate) * 100) + '%"></i></span><span class="rate-num">' + (r.sessions ? r.rate.toFixed(1) + '%' : '—') + '</span></span></td>' +
      '</tr>'
    ).join('') || '<tr><td colspan="4" class="muted-note" style="padding:14px">Sin datos todavía.</td></tr>';
  }

  function renderAnalytics(rows, leads){
    /* fuera las sesiones/leads de prueba */
    const real = rows.filter((r) => !/^claude-/.test(r.session_id || ''));
    const entries = real.filter((r) => r.is_entry);
    const sessions = new Set(real.map((r) => r.session_id));
    const periodLeads = (leads || []).filter((l) =>
      inRange(l.created_at) && !/^claude-/.test(l.session_id || ''));

    /* KPIs — la conversión = lead real enviado (fiable, no depende del pageview) */
    $('ka-views').textContent = real.length;
    $('ka-sessions').textContent = sessions.size;
    const durs = real.filter((r) => r.duration > 0);
    const avg = durs.length ? durs.reduce((a, r) => a + r.duration, 0) / durs.length : 0;
    $('ka-time').textContent = fmtTime(avg);
    $('ka-conv').textContent = periodLeads.length;
    $('ka-rate').textContent = sessions.size ? (periodLeads.length / sessions.size * 100).toFixed(1) + '%' : '—';

    /* tráfico + leads por día (anclado al fin de la ventana) */
    const span = rangeSpanDays();
    const anchor = rangeEnd();
    const days = [];
    for (let i = span - 1; i >= 0; i--) {
      const d = new Date(anchor - i * 864e5);
      days.push({ key: d.toISOString().slice(0, 10), label: d.toLocaleDateString('es-CH', { day: '2-digit', month: 'short' }), set: new Set(), leads: 0 });
    }
    const dayMap = new Map(days.map((d) => [d.key, d]));
    real.forEach((r) => { const d = dayMap.get(r.created_at.slice(0, 10)); if (d) d.set.add(r.session_id); });
    periodLeads.forEach((l) => { const d = dayMap.get(l.created_at.slice(0, 10)); if (d) d.leads++; });
    /* gráfico SVG real: área + línea de sesiones, puntos de leads */
    const n = days.length, W = 1000, H = 260, padL = 42, padR = 14, padT = 16, padB = 28;
    const pw = W - padL - padR, ph = H - padT - padB, baseY = padT + ph;
    const maxS = Math.max(1, ...days.map((d) => d.set.size));
    const X = (i) => padL + (n <= 1 ? pw / 2 : (i / (n - 1)) * pw);
    const Y = (v) => padT + (1 - v / maxS) * ph;
    const pts = days.map((d, i) => [X(i), Y(d.set.size)]);
    const linePath = pts.map((p, i) => (i ? 'L' : 'M') + p[0].toFixed(1) + ' ' + p[1].toFixed(1)).join(' ');
    const areaPath = 'M' + X(0).toFixed(1) + ' ' + baseY + ' ' + pts.map((p) => 'L' + p[0].toFixed(1) + ' ' + p[1].toFixed(1)).join(' ') + ' L' + X(n - 1).toFixed(1) + ' ' + baseY + ' Z';
    const grid = [0, 0.5, 1].map((t) => {
      const v = Math.round(maxS * t), y = Y(v);
      return '<line x1="' + padL + '" y1="' + y.toFixed(1) + '" x2="' + (W - padR) + '" y2="' + y.toFixed(1) + '" class="g-grid"/>' +
        '<text x="' + (padL - 8) + '" y="' + (y + 4).toFixed(1) + '" class="g-yl">' + v + '</text>';
    }).join('');
    const leadDots = days.map((d, i) => d.leads ? '<circle cx="' + X(i).toFixed(1) + '" cy="' + Y(d.set.size).toFixed(1) + '" r="' + (3 + Math.min(4, d.leads)) + '" class="g-lead"><title>' + d.label + ': ' + d.leads + ' leads</title></circle>' : '').join('');
    const hover = days.map((d, i) => '<circle cx="' + X(i).toFixed(1) + '" cy="' + Y(d.set.size).toFixed(1) + '" r="11" fill="transparent"><title>' + d.label + ' — ' + d.set.size + ' sesiones · ' + d.leads + ' leads</title></circle>').join('');
    const step = Math.max(1, Math.ceil(n / 7));
    const xls = days.map((d, i) => ((i % step === 0) || i === n - 1) ? '<text x="' + X(i).toFixed(1) + '" y="' + (H - 8) + '" class="g-xl" text-anchor="middle">' + d.label + '</text>' : '').join('');
    $('daily-chart').innerHTML = '<svg viewBox="0 0 ' + W + ' ' + H + '" class="gsvg">' +
      '<defs><linearGradient id="gfill" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#ddf98f" stop-opacity=".28"/><stop offset="1" stop-color="#ddf98f" stop-opacity="0"/></linearGradient></defs>' +
      grid + '<path d="' + areaPath + '" fill="url(#gfill)"/><path d="' + linePath + '" class="g-line"/>' + leadDots + hover + xls + '</svg>';

    /* rendimiento por CANAL: sesiones vs leads */
    const chSessions = new Map();
    entries.forEach((e) => { const k = e.channel || 'direct'; chSessions.set(k, (chSessions.get(k) || 0) + 1); });
    const chLeads = new Map();
    periodLeads.forEach((l) => { const k = l.channel || 'direct'; chLeads.set(k, (chLeads.get(k) || 0) + 1); });
    const chKeys = new Set([...chSessions.keys(), ...chLeads.keys()]);
    const channelPerf = [...chKeys].map((k) => ({ key: k, label: k, badge: true, sessions: chSessions.get(k) || 0, leads: chLeads.get(k) || 0 }));
    perfTable($('perf-channel'), channelPerf);

    /* rendimiento por PÁGINA DE ENTRADA */
    const lpSessions = new Map();
    entries.forEach((e) => { const k = e.path || '/'; lpSessions.set(k, (lpSessions.get(k) || 0) + 1); });
    const lpLeads = new Map();
    periodLeads.forEach((l) => { const k = l.landing_path || '(sin dato)'; lpLeads.set(k, (lpLeads.get(k) || 0) + 1); });
    const lpKeys = new Set([...lpSessions.keys(), ...lpLeads.keys()]);
    const landingPerf = [...lpKeys].map((k) => ({ key: k, label: k, sessions: lpSessions.get(k) || 0, leads: lpLeads.get(k) || 0 }));
    perfTable($('perf-landing'), landingPerf);

    /* resumen compacto para los insights con IA */
    insightsData = {
      periodo: rangeLabel(),
      sesiones: sessions.size,
      paginas_vistas: real.length,
      tiempo_medio_seg: Math.round(avg),
      leads: periodLeads.length,
      tasa_conversion_pct: sessions.size ? +(periodLeads.length / sessions.size * 100).toFixed(2) : 0,
      canales: channelPerf.map((c) => ({ canal: c.label, sesiones: c.sessions, leads: c.leads })).slice(0, 8),
      paginas_entrada: landingPerf.map((p) => ({ path: p.label, sesiones: p.sessions, leads: p.leads })).slice(0, 8),
    };

    /* titulares automáticos */
    renderInsights(channelPerf, landingPerf, entries, periodLeads, sessions.size);

    /* dispositivos / idiomas */
    bars($('bars-device'), countBy(real, 'device'), 3);
    bars($('bars-lang'), countBy(entries, 'lang'), 8);

    /* top páginas por engagement (visitas + tiempo) */
    const byPath = new Map();
    real.forEach((r) => {
      const p = byPath.get(r.path) || { views: 0, dur: 0, durN: 0 };
      p.views++;
      if (r.duration > 0) { p.dur += r.duration; p.durN++; }
      byPath.set(r.path, p);
    });
    const pages = [...byPath.entries()]
      .map(([k, p]) => [k, p.views, p.durN ? p.dur / p.durN : 0])
      .sort((a, b) => b[1] - a[1]);
    bars($('bars-pages'), pages, 15, (v, t) => v + ' <small>· ' + fmtTime(t) + '</small>');
  }

  function renderInsights(channelPerf, landingPerf, entries, periodLeads, sessionCount){
    const cards = [];
    /* 1 — mejor canal para leads */
    const chLeaders = channelPerf.filter((c) => c.leads > 0).sort((a, b) => b.leads - a.leads);
    if (chLeaders.length) {
      const c = chLeaders[0];
      cards.push({ t: '🏆 Canal que más convierte', v: '<em>' + esc(c.label) + '</em>',
        d: c.leads + ' lead' + (c.leads > 1 ? 's' : '') + ' · ' + (c.sessions ? (c.leads / c.sessions * 100).toFixed(1) + '% de sus sesiones' : '') });
    } else {
      const top = [...channelPerf].sort((a, b) => b.sessions - a.sessions)[0];
      cards.push({ t: '📡 Mayor fuente de tráfico', v: top ? '<em>' + esc(top.label) + '</em>' : '—',
        d: top ? top.sessions + ' sesiones · aún sin leads atribuidos' : 'Sin tráfico todavía' });
    }
    /* 2 — página que más convierte */
    const lpLeaders = landingPerf.filter((p) => p.leads > 0).sort((a, b) => b.leads - a.leads);
    if (lpLeaders.length) {
      const p = lpLeaders[0];
      cards.push({ t: '🎯 Página que más convierte', v: '<em>' + esc(p.label) + '</em>',
        d: p.leads + ' lead' + (p.leads > 1 ? 's' : '') + ' desde esta entrada' });
    } else {
      cards.push({ t: '🎯 Página que más convierte', v: '<em>—</em>', d: 'Aún sin leads. Comparte el sitio o lanza una campaña.' });
    }
    /* 3 — oportunidad: página con mucho tráfico y 0 leads */
    const opp = [...landingPerf].filter((p) => p.leads === 0 && p.sessions >= 3).sort((a, b) => b.sessions - a.sessions)[0];
    if (opp) {
      cards.push({ t: '⚠️ Oportunidad a revisar', v: '<em>' + esc(opp.label) + '</em>',
        d: opp.sessions + ' sesiones y 0 leads — ¿mejorar el CTA o el mensaje?' });
    } else {
      cards.push({ t: '📈 Conversión global', v: '<em>' + (sessionCount ? (periodLeads.length / sessionCount * 100).toFixed(1) + '%' : '—') + '</em>',
        d: periodLeads.length + ' leads de ' + sessionCount + ' sesiones (30 días)' });
    }
    $('insights').innerHTML = cards.map((c) =>
      '<div class="insight"><div class="t">' + c.t + '</div><div class="v">' + c.v + '</div><div class="d">' + esc0html(c.d) + '</div></div>'
    ).join('');
  }
  const esc0html = (s) => String(s ?? '');

  /* =================== OFFER TOOL (Kostenkalkulation) =================== */
  /* Rate card con tarifas reales de Viven (Moco). price = precio al cliente, cost = costo externo (freelancer/rental). */
  const RATECARD = {
    'Development': [
      { name: 'Concept / Treatment', unit: 'Fix', price: 800, cost: 0 },
      { name: 'Scriptwriting', unit: 'Fix', price: 600, cost: 0 },
      { name: 'Storyboard', unit: 'Fix', price: 500, cost: 0 },
      { name: 'Casting', unit: 'Std', price: 120, cost: 0 },
    ],
    'Pre-Production': [
      { name: 'Producer', unit: 'Std', price: 120, cost: 0 },
      { name: '1st AC', unit: 'Std', price: 60, cost: 0 },
      { name: 'Project Admin', unit: 'Fix', price: 300, cost: 0 },
      { name: 'Scouting (Producer)', unit: 'Std', price: 120, cost: 0 },
    ],
    'Production': [
      { name: 'Producer', unit: 'Tag', price: 950, cost: 0 },
      { name: 'Director of Photography', unit: 'Tag', price: 1000, cost: 800 },
      { name: 'Gaffer', unit: 'Tag', price: 700, cost: 670 },
      { name: 'Sound / Audio', unit: 'Tag', price: 800, cost: 750 },
      { name: 'Sony FX6 (Kit)', unit: 'Tag', price: 250, cost: 0 },
      { name: 'Lenses Set', unit: 'Tag', price: 100, cost: 0 },
      { name: '3-Point LED Kit', unit: 'Tag', price: 250, cost: 0 },
      { name: 'Ronin RS3 Pro', unit: 'Tag', price: 60, cost: 0 },
      { name: 'Van inkl. km', unit: 'Tag', price: 120, cost: 0 },
      { name: 'Per Diems', unit: 'Person', price: 32, cost: 32 },
    ],
    'Post-Production': [
      { name: 'Editor inkl. Suite + Color', unit: 'Tag', price: 950, cost: 550 },
      { name: 'Motion / VFX Animation', unit: 'Tag', price: 900, cost: 750 },
      { name: 'Music license', unit: 'Stk', price: 60, cost: 60 },
      { name: 'Additional Correction Round', unit: 'Tag', price: 950, cost: 550 },
    ],
    'Delivery': [
      { name: 'Master exports / Formate', unit: 'Fix', price: 200, cost: 0 },
      { name: 'Untertitel / Subtitles', unit: 'Sprache', price: 120, cost: 0 },
      { name: 'Social cutdowns (15s/9:16)', unit: 'Stk', price: 250, cost: 0 },
    ],
  };
  const PHASES = Object.keys(RATECARD);   // Development · Pre-Production · Production · Post-Production · Delivery
  const fmtM = (n) => 'CHF ' + (Number(n) || 0).toLocaleString('de-CH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  let offersList = [], ofCur = null, offersBuilt = false;

  function offersInit(){ buildPresetSelect(); if (!offersBuilt){ offersBuilt = true; bindOffers(); } offersLoad(); }

  function buildPresetSelect(){
    const sel = $('of-preset');
    if (sel.dataset.built) return;
    sel.dataset.built = '1';
    sel.innerHTML = PHASES.map((ph) =>
      '<optgroup label="' + ph + '">' +
      RATECARD[ph].map((it, i) => '<option value="' + ph + '::' + i + '">' + esc(it.name) + ' — ' + fmtM(it.price) + '/' + it.unit + '</option>').join('') +
      '</optgroup>').join('');
  }

  const offerNet = (o) => (o.items || []).reduce((a, it) => a + (Number(it.qty) || 0) * (Number(it.price) || 0), 0);
  const offerCost = (o) => (o.items || []).reduce((a, it) => a + (Number(it.qty) || 0) * (Number(it.cost) || 0), 0);
  const offerMarginPct = (o) => { const n = offerNet(o); return n ? (n - offerCost(o)) / n * 100 : NaN; };

  async function offersLoad(){
    const { data, error } = await supabase.from('offers').select('*').order('updated_at', { ascending: false });
    if (error){ $('of-empty').hidden = false; $('of-empty').textContent = 'No se pudo cargar (¿corriste el SQL 0003_offers?): ' + error.message; return; }
    offersList = data || [];
    renderOffersList();
  }

  function renderOffersList(){
    const box = $('of-list');
    $('of-empty').hidden = offersList.length > 0;
    const open = offersList.filter((o) => o.status === 'sent');
    const margins = offersList.map(offerMarginPct).filter((m) => isFinite(m));
    $('of-k-count').textContent = offersList.length;
    $('of-k-open').textContent = open.length;
    $('of-k-value').textContent = fmtM(open.reduce((a, o) => a + offerNet(o), 0));
    $('of-k-margin').textContent = margins.length ? Math.round(margins.reduce((a, b) => a + b, 0) / margins.length) + '%' : '–';
    const badge = { draft: ['Borrador', '#8ab4ff'], sent: ['Enviada', '#f0c060'], won: ['Ganada', '#7ed957'], lost: ['Perdida', '#ff6b6b'] };
    box.innerHTML = offersList.map((o) => {
      const net = offerNet(o), mp = offerMarginPct(o), b = badge[o.status] || badge.draft;
      return '<button class="of-card" data-id="' + o.id + '" type="button">' +
        '<div class="of-card-main"><div class="of-card-title">' + esc(o.title || '(sin título)') + '</div>' +
        '<div class="of-card-sub">' + esc(o.client || '—') + ' · ' + (o.items ? o.items.length : 0) + ' posiciones · ' + new Date(o.updated_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short' }) + '</div></div>' +
        '<div class="of-card-nums"><div class="of-card-net">' + fmtM(net) + '</div>' +
        '<div class="of-card-margin" style="color:' + (mp >= 50 ? '#7ed957' : mp >= 30 ? '#f0c060' : '#ff8b8b') + '">' + (isFinite(mp) ? Math.round(mp) + '% margen' : '') + '</div></div>' +
        '<span class="of-badge" style="color:' + b[1] + ';border-color:' + b[1] + '">' + b[0] + '</span></button>';
    }).join('');
    box.querySelectorAll('.of-card').forEach((c) => c.addEventListener('click', () => openOffer(c.dataset.id)));
  }

  function showEditor(on){ $('of-editor').hidden = !on; $('of-list-view').hidden = on; }

  function newOffer(){ ofCur = { title: '', client: '', lead_id: null, vat_rate: 8.1, status: 'draft', items: [] }; fillEditor(); showEditor(true); }
  function openOffer(id){
    const src = offersList.find((o) => String(o.id) === String(id));
    if (!src) return;
    ofCur = JSON.parse(JSON.stringify(src));
    if (!Array.isArray(ofCur.items)) ofCur.items = [];
    fillEditor(); showEditor(true);
  }

  function leadOptions(sel){
    return ['<option value="">— ninguno —</option>'].concat(
      (allLeads || []).map((l) => '<option value="' + esc(l.id) + '"' + (String(sel) === String(l.id) ? ' selected' : '') + '>' + esc(l.name || l.email || l.id) + '</option>')
    ).join('');
  }
  function fillEditor(){
    $('of-title').value = ofCur.title || '';
    $('of-client').value = ofCur.client || '';
    $('of-status').value = ofCur.status || 'draft';
    $('of-vat').value = ofCur.vat_rate ?? 8.1;
    $('of-lead').innerHTML = leadOptions(ofCur.lead_id);
    $('of-inquiry').value = ''; $('of-ai-note').textContent = '';
    prefillInquiry();
    renderRows();
  }
  // llena la consulta desde el lead ligado (si hay) para que la IA arme la oferta
  function prefillInquiry(){
    const lead = (allLeads || []).find((l) => String(l.id) === String(ofCur.lead_id));
    if (lead && !$('of-inquiry').value.trim()){
      $('of-inquiry').value = lead.message || '';
    }
    $('of-ai-src').textContent = lead ? '· del lead ' + (lead.name || lead.email || lead.id) : '';
  }
  // catálogo plano para pasarle a la IA (precios reales)
  const catalogFlat = () => PHASES.flatMap((ph) => RATECARD[ph].map((it) => ({ phase: ph, name: it.name, unit: it.unit, price: it.price, cost: it.cost })));
  // si la IA usó un ítem del catálogo, forzamos SUS precio/costo exactos (que no drifteen)
  function snapToCatalog(items){
    const cat = catalogFlat();
    return items.map((it) => {
      const hit = cat.find((c) => c.name.toLowerCase() === String(it.name || '').toLowerCase() && c.phase === it.phase)
        || cat.find((c) => c.name.toLowerCase() === String(it.name || '').toLowerCase());
      return hit
        ? { phase: hit.phase, name: hit.name, qty: Number(it.qty) || 1, unit: hit.unit, price: hit.price, cost: hit.cost }
        : { phase: it.phase || 'Production', name: it.name, qty: Number(it.qty) || 1, unit: it.unit || 'Tag', price: Number(it.price) || 0, cost: Number(it.cost) || 0 };
    });
  }
  async function generateOfferAI(){
    const inquiry = $('of-inquiry').value.trim();
    if (!inquiry){ $('of-ai-note').textContent = 'Pegá la consulta del cliente primero (o ligá un lead).'; return; }
    const btn = $('of-ai-gen'), prev = btn.textContent; btn.disabled = true; btn.textContent = '✨ Pensando…';
    $('of-ai-note').textContent = '';
    try {
      // si hay lead ligado, traemos su brief para dar más contexto
      let brief = null;
      if (ofCur.lead_id){
        const { data } = await supabase.from('briefs').select('*').eq('lead_id', String(ofCur.lead_id)).order('created_at', { ascending: false }).limit(1);
        brief = (data && data[0]) || null;
      }
      const lead = (allLeads || []).find((l) => String(l.id) === String(ofCur.lead_id));
      const lang = (brief && brief.lang) || (lead && lead.lang) || 'es';
      const { data, error } = await supabase.functions.invoke('ai-offer', {
        body: { inquiry, brief, catalog: catalogFlat(), lang }
      });
      if (error) throw new Error(data?.error || error?.message || 'sin respuesta');
      if (data?.error) throw new Error(data.error);
      if (!data || !Array.isArray(data.items) || !data.items.length) throw new Error('la IA no devolvió posiciones');
      ofCur.items = snapToCatalog(data.items);
      if (data.title && !$('of-title').value.trim()) { $('of-title').value = data.title; ofCur.title = data.title; }
      if (lead && !$('of-client').value.trim()) { $('of-client').value = lead.name || ''; }
      renderRows();
      $('of-ai-note').textContent = '✨ Oferta propuesta (' + ofCur.items.length + ' posiciones) — revisá y ajustá antes de guardar.' + (data.summary ? ' ' + data.summary : '');
    } catch (e) {
      $('of-ai-note').textContent = 'No se pudo generar (¿deployaste ai-offer? ¿hay crédito Anthropic?): ' + e.message;
    } finally {
      btn.disabled = false; btn.textContent = prev;
    }
  }

  const phaseOf = (it) => it.phase || 'Production';
  function phaseSubtotal(ph){
    let net = 0, cost = 0;
    ofCur.items.forEach((it) => { if (phaseOf(it) === ph){ const q = Number(it.qty) || 0; net += q * (Number(it.price) || 0); cost += q * (Number(it.cost) || 0); } });
    return { net, cost };
  }
  function rowHTML(it, i){
    const total = (Number(it.qty) || 0) * (Number(it.price) || 0);
    const margin = total - (Number(it.qty) || 0) * (Number(it.cost) || 0);
    return '<tr data-i="' + i + '">' +
      '<td><input class="ofi" data-f="name" value="' + esc(it.name || '') + '"/></td>' +
      '<td><select class="ofi" data-f="phase">' + PHASES.map((p) => '<option' + (p === phaseOf(it) ? ' selected' : '') + '>' + p + '</option>').join('') + '</select></td>' +
      '<td class="num"><input class="ofi w" data-f="qty" type="number" step="0.25" value="' + (it.qty ?? 1) + '"/></td>' +
      '<td><input class="ofi w" data-f="unit" value="' + esc(it.unit || '') + '"/></td>' +
      '<td class="num"><input class="ofi w" data-f="price" type="number" step="10" value="' + (it.price ?? 0) + '"/></td>' +
      '<td class="num"><input class="ofi w" data-f="cost" type="number" step="10" value="' + (it.cost ?? 0) + '"/></td>' +
      '<td class="num">' + fmtM(total) + '</td>' +
      '<td class="num" style="color:' + (margin >= 0 ? '#7ed957' : '#ff8b8b') + '">' + fmtM(margin) + '</td>' +
      '<td><button class="of-del" type="button" data-i="' + i + '">✕</button></td></tr>';
  }
  function renderRows(){
    const tb = $('of-rows');
    let html = '';
    // agrupado por fase, en el orden del catálogo, con subtotal por fase
    PHASES.filter((ph) => ofCur.items.some((it) => phaseOf(it) === ph)).forEach((ph) => {
      html += '<tr class="of-phase"><td colspan="9">' + esc(ph) + '</td></tr>';
      ofCur.items.forEach((it, i) => { if (phaseOf(it) === ph) html += rowHTML(it, i); });
      const s = phaseSubtotal(ph);
      html += '<tr class="of-sub" data-phase="' + esc(ph) + '"><td colspan="6">Subtotal ' + esc(ph) + '</td><td class="num">' + fmtM(s.net) + '</td><td class="num">' + fmtM(s.net - s.cost) + '</td><td></td></tr>';
    });
    tb.innerHTML = html;
    tb.querySelectorAll('.ofi').forEach((inp) => inp.addEventListener('input', onRowInput));
    tb.querySelectorAll('.ofi[data-f="phase"]').forEach((s) => s.addEventListener('change', renderRows));
    tb.querySelectorAll('.of-del').forEach((b) => b.addEventListener('click', () => { ofCur.items.splice(+b.dataset.i, 1); renderRows(); }));
    recalc();
  }
  function onRowInput(e){
    const tr = e.target.closest('tr'), i = +tr.dataset.i, f = e.target.dataset.f;
    let v = e.target.value;
    if (['qty', 'price', 'cost'].includes(f)) v = parseFloat(v) || 0;
    ofCur.items[i][f] = v;
    if (['qty', 'price', 'cost'].includes(f)){
      const it = ofCur.items[i], total = (Number(it.qty) || 0) * (Number(it.price) || 0), margin = total - (Number(it.qty) || 0) * (Number(it.cost) || 0);
      tr.children[6].textContent = fmtM(total);
      tr.children[7].textContent = fmtM(margin);
      tr.children[7].style.color = margin >= 0 ? '#7ed957' : '#ff8b8b';
      // actualizar el subtotal de la fase en vivo (sin re-render, para no perder el foco)
      const s = phaseSubtotal(phaseOf(it));
      const sub = $('of-rows').querySelector('.of-sub[data-phase="' + phaseOf(it) + '"]');
      if (sub){ sub.children[1].textContent = fmtM(s.net); sub.children[2].textContent = fmtM(s.net - s.cost); }
      recalc();
    }
  }
  function recalc(){
    const net = offerNet(ofCur), cost = offerCost(ofCur);
    const vat = net * (parseFloat($('of-vat').value) || 0) / 100;
    const profit = net - cost, mp = net ? profit / net * 100 : 0;
    $('of-net').textContent = fmtM(net);
    $('of-vatamt').textContent = fmtM(vat);
    $('of-gross').textContent = fmtM(net + vat);
    $('of-cost').textContent = fmtM(cost);
    $('of-profit').textContent = fmtM(profit);
    $('of-profit').className = profit >= 0 ? 'pos' : 'neg';
    $('of-marginpct').textContent = Math.round(mp) + '%';
    $('of-marginpct').className = mp >= 50 ? 'pos' : mp >= 30 ? '' : 'neg';
    $('of-bep').textContent = cost > 0
      ? 'Breakeven en ' + fmtM(cost) + ' de costo externo. Podés descontar hasta ' + fmtM(profit) + ' (' + Math.round(mp) + '%) antes de perder plata.'
      : 'Sin costo externo cargado — todo el neto es margen.';
  }

  async function saveOffer(){
    ofCur.title = $('of-title').value.trim();
    ofCur.client = $('of-client').value.trim();
    ofCur.lead_id = $('of-lead').value || null;
    ofCur.vat_rate = parseFloat($('of-vat').value) || 0;
    ofCur.status = $('of-status').value;
    const payload = { title: ofCur.title, client: ofCur.client, lead_id: ofCur.lead_id, vat_rate: ofCur.vat_rate, status: ofCur.status, items: ofCur.items };
    const btn = $('of-save'), prev = btn.textContent; btn.disabled = true; btn.textContent = 'Guardando…';
    const res = ofCur.id
      ? await supabase.from('offers').update(payload).eq('id', ofCur.id).select().single()
      : await supabase.from('offers').insert(payload).select().single();
    btn.disabled = false; btn.textContent = prev;
    if (res.error){ alert('No se pudo guardar: ' + res.error.message); return; }
    await offersLoad(); showEditor(false);
  }
  async function deleteOffer(){
    if (!ofCur.id){ showEditor(false); return; }
    if (!confirm('¿Borrar esta oferta definitivamente?')) return;
    const { error } = await supabase.from('offers').delete().eq('id', ofCur.id);
    if (error){ alert('No se pudo borrar: ' + error.message); return; }
    await offersLoad(); showEditor(false);
  }
  function printOffer(){
    const net = offerNet(ofCur), vat = net * (parseFloat($('of-vat').value) || 0) / 100;
    // agrupado por fase, con subtotal por fase (versión cliente: sin costo interno)
    let rows = '';
    PHASES.filter((ph) => ofCur.items.some((it) => phaseOf(it) === ph)).forEach((ph) => {
      rows += '<tr class="ph"><td colspan="4">' + esc(ph) + '</td></tr>';
      ofCur.items.forEach((it) => {
        if (phaseOf(it) !== ph) return;
        const t = (Number(it.qty) || 0) * (Number(it.price) || 0);
        rows += '<tr><td>' + esc(it.name || '') + '</td><td style="text-align:center">' + (it.qty ?? '') + ' ' + esc(it.unit || '') + '</td><td style="text-align:right">' + fmtM(it.price) + '</td><td style="text-align:right">' + fmtM(t) + '</td></tr>';
      });
      const s = phaseSubtotal(ph);
      rows += '<tr class="sub"><td colspan="3">Zwischensumme ' + esc(ph) + '</td><td style="text-align:right">' + fmtM(s.net) + '</td></tr>';
    });
    const w = window.open('', '_blank');
    if (!w){ alert('Permití las ventanas emergentes para imprimir/guardar como PDF.'); return; }
    w.document.write('<html><head><title>' + esc(ofCur.title || 'Offerte') + '</title><style>body{font-family:-apple-system,Arial,sans-serif;padding:44px;color:#111;max-width:760px;margin:auto}h1{font-size:22px;margin:0 0 4px}.sub{color:#666;margin:0 0 24px}table{width:100%;border-collapse:collapse}td,th{padding:9px 8px;border-bottom:1px solid #e2e2e2;font-size:14px}th{text-align:left;font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:#888}tr.ph td{background:#f4f6f2;font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#3a5a1e;padding-top:14px}tr.sub td{font-weight:600;color:#555;border-bottom:2px solid #ccc}.tot{margin-top:22px;text-align:right;font-size:14px;line-height:1.9}.tot b{font-size:19px}</style></head><body><h1>' + esc(ofCur.title || 'Offerte') + '</h1><p class="sub">' + esc(ofCur.client || '') + '</p><table><thead><tr><th>Position</th><th style="text-align:center">Menge</th><th style="text-align:right">Preis</th><th style="text-align:right">Total</th></tr></thead><tbody>' + rows + '</tbody></table><div class="tot">Total netto: ' + fmtM(net) + '<br>MwSt ' + (parseFloat($('of-vat').value) || 0) + '%: ' + fmtM(vat) + '<br><b>Total brutto: ' + fmtM(net + vat) + '</b></div></body></html>');
    w.document.close(); w.focus(); setTimeout(() => w.print(), 350);
  }

  function bindOffers(){
    $('of-new').addEventListener('click', newOffer);
    $('of-back').addEventListener('click', () => showEditor(false));
    $('of-add-blank').addEventListener('click', () => { ofCur.items.push({ name: '', phase: 'Production', qty: 1, unit: 'Tag', price: 0, cost: 0 }); renderRows(); });
    $('of-add-preset').addEventListener('click', () => {
      const [ph, idx] = $('of-preset').value.split('::'); const p = RATECARD[ph][+idx];
      ofCur.items.push({ name: p.name, phase: ph, qty: 1, unit: p.unit, price: p.price, cost: p.cost }); renderRows();
    });
    $('of-vat').addEventListener('input', () => { ofCur.vat_rate = parseFloat($('of-vat').value) || 0; recalc(); });
    $('of-status').addEventListener('change', () => { ofCur.status = $('of-status').value; });
    $('of-lead').addEventListener('change', () => { ofCur.lead_id = $('of-lead').value || null; prefillInquiry(); });
    $('of-ai-gen').addEventListener('click', generateOfferAI);
    $('of-save').addEventListener('click', saveOffer);
    $('of-delete').addEventListener('click', deleteOffer);
    $('of-print').addEventListener('click', printOffer);
  }

  /* ---------- Sesión persistente ---------- */
  supabase.auth.getSession().then(({ data }) => {
    if (data.session) { show('dash'); loadAll(); }
    else show('login');
  });
</script>

</body>
</html>
