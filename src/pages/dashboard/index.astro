       CONTENIDO (980px con el board) y toda la página quedaba ancha → iOS no scrolleaba */
    .dash-body{flex-direction:column;align-items:stretch}
    .dash-main{width:100%;max-width:100%;min-width:0}
    .dash-side{display:none}                          /* fuera la lista gigante de arriba */
    .dash-wrap{padding:calc(14px + env(safe-area-inset-top)) 14px calc(84px + env(safe-area-inset-bottom));overflow-x:hidden}
    body{overflow-x:clip}
    /* cards de ofertas/propuestas: nada cortado a la derecha — el monto baja a su propia línea */
    .of-card-open{flex-wrap:wrap;gap:6px 12px;padding:13px 14px}
    .of-card-main{flex:1 1 100%}
    .of-card-nums{text-align:left;display:flex;align-items:baseline;gap:10px;flex-wrap:wrap}
    .of-card-net{font-size:16px}
    .of-actions{padding:0 10px 10px;gap:6px}
    .of-act{font-size:12px;padding:7px 10px}
    /* modal de contacto: header respeta el notch */
    .lead-card-wide{padding-top:calc(10px + env(safe-area-inset-top))}
    .dash-head{margin-bottom:12px;flex-wrap:nowrap;gap:8px}
    .dash-head h1{font-size:20px;white-space:nowrap}
    .dash-sub{display:none}
    .dash-head .btn.small{padding:8px 11px;font-size:12.5px;white-space:nowrap}
    #refresh-btn{font-size:0;width:38px;height:38px;padding:0;display:grid;place-items:center;border-radius:10px}
    #refresh-btn::before{content:'↻';font-size:17px}
    .dash-actions{gap:7px;flex-wrap:nowrap!important}
    #logout-btn{font-size:0;width:38px;height:38px;padding:0;display:grid;place-items:center;border-radius:10px}
    #logout-btn::before{content:'⏻';font-size:16px}
    /* inputs a 16px: iOS no hace zoom al enfocar */
    input,select,textarea{font-size:16px!important}
    .tabs{overflow-x:auto;scrollbar-width:none;margin-bottom:18px;flex-wrap:nowrap}
    .tabs::-webkit-scrollbar{display:none}
    .tab{padding:10px 12px;font-size:14.5px;white-space:nowrap;flex:none}
    .panel{padding:16px 14px}
    .kpis,.kpis.four{grid-template-columns:repeat(2,1fr);gap:10px}
    .kpi{padding:14px 15px}
    .kpi .n{font-size:clamp(19px,6.5vw,26px)}
    .home-kpis{grid-template-columns:repeat(2,1fr);gap:10px}
    .hk{padding:13px 14px}
    .hk-n{font-size:22px}
    /* pipeline: una columna por pantalla, con snap como un carrusel */
    .pipe-pager{display:flex!important}
    /* iOS: sin snap (se pelea con el scroll vertical anidado de las columnas) — scroll libre y robusto */
    .pipeline{touch-action:pan-x pan-y;overscroll-behavior-x:contain}
    .pipe-col{flex:0 0 85vw;min-width:85vw;max-height:68dvh;touch-action:pan-x pan-y}
    .pipe-list{touch-action:pan-x pan-y}
    .pipe-card{cursor:default;touch-action:pan-x pan-y}
    /* tabla de Personas/Empresas → cards apiladas (nada de scroll horizontal).
       OJO: el mapeo es POSICIONAL y la 1ª celda ahora es el CHECKBOX de selección (batch delete)
       — antes era el nombre y el card quedaba sin título. El nombre vive en la 2ª celda;
       el checkbox va absoluto arriba a la derecha (el "seleccionar todos" del thead se pierde
       en móvil, aceptado). */
    .lead-table-hs table{min-width:0;width:100%}
    .lead-table-hs thead{display:none}
    .lead-table-hs tbody tr{position:relative;display:flex;flex-wrap:wrap;align-items:center;gap:3px 10px;padding:12px 44px 12px 14px;border-bottom:1px solid var(--line)}
    .lead-table-hs tbody td{display:none;padding:0;border:0;white-space:normal}
    .lead-table-hs tbody td.lt-chk{display:block;position:absolute;top:12px;right:12px;width:auto;padding:0}
    .lead-table-hs tbody td:nth-child(2){display:block;flex:1 1 100%}   /* nombre (persona/empresa): título del card */
    .lead-table-hs tbody td:nth-child(2) .lt-name{font-size:14.5px}
    .lead-table-hs tbody td:nth-child(5){display:block;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;color:var(--muted);font-size:12px}
    .lead-table-hs tbody td:nth-child(6){display:block}
    .lead-table-hs tbody td.lt-val{display:block;font-weight:700;font-family:'Space Grotesk';font-size:13px;color:var(--text)}
    /* contacto apilado en orden útil: conversación → proyectos/ofertas → ficha */
    .lm-center{order:1}
    .lm-right{order:2}
    .lm-left{order:3}
    /* acciones rápidas: TODAS visibles (envuelven en filas), nada escondido en scroll */
    .lm-quick{flex-wrap:wrap;overflow:visible;margin-right:0}
    .lm-quick .lm-qbtn{flex:0 1 auto}
    /* header del contacto compacto y sin pisar el notch */
    .lead-card-wide .close{top:calc(8px + env(safe-area-inset-top));right:14px}
    .lead-card h3{font-size:19px}
    .lm-top{padding-right:52px}
    /* botonera final: los útiles se estiran, BORRAR queda chico y al final — no un banner rojo */
    .lead-actions .btn{flex:1 1 auto}
    .lead-actions .btn-danger{flex:0 0 auto;margin-left:auto;font-size:12.5px;padding:9px 14px}
    /* barras de título (Deals/Ofertas/etc): que el texto envuelva y el botón baje */
    .of-bar{flex-wrap:wrap}
    .of-bar > div{min-width:0;flex:1 1 100%}
    .of-bar .muted-note{white-space:normal}
    /* editor de OFERTA: la tabla de posiciones se vuelve cards (adiós scroll lateral) */
    .of-table{min-width:0}
    .of-table thead{display:none}
    .of-table tr[data-i]{display:grid;grid-template-columns:repeat(4,1fr);gap:7px 8px;padding:11px 12px;border-bottom:1px solid var(--line)}
    .of-table tr[data-i] td{display:block;padding:0;border:0;min-width:0}
    .of-table tr[data-i] td:nth-child(1){grid-area:1/1/2/4}
    .of-table tr[data-i] td:nth-child(9){grid-area:1/4/2/5;justify-self:end}
    .of-table tr[data-i] td:nth-child(2){grid-area:2/1/3/3}
    .of-table tr[data-i] td:nth-child(3){grid-area:2/3/3/4}
    .of-table tr[data-i] td:nth-child(4){grid-area:2/4/3/5}
    .of-table tr[data-i] td:nth-child(5){grid-area:3/1/4/2}
    .of-table tr[data-i] td:nth-child(6){grid-area:3/2/4/3}
    .of-table tr[data-i] td:nth-child(7){grid-area:3/3/4/4;align-self:end;text-align:right;font-weight:700;font-family:'Space Grotesk'}
    .of-table tr[data-i] td:nth-child(8){grid-area:3/4/4/5;align-self:end;text-align:right;font-size:12px}
    .of-table tr[data-i] td:nth-child(n+3)::before{display:block;font-size:9.5px;text-transform:uppercase;letter-spacing:.06em;color:var(--muted-2);margin-bottom:3px}
    .of-table tr[data-i] td:nth-child(3)::before{content:'Cant.'}
    .of-table tr[data-i] td:nth-child(4)::before{content:'Unidad'}
    .of-table tr[data-i] td:nth-child(5)::before{content:'Precio'}
    .of-table tr[data-i] td:nth-child(6)::before{content:'Costo int.'}
    .of-table tr[data-i] td:nth-child(7)::before{content:'Total';font-weight:400;font-family:'Inter'}
    .of-table tr[data-i] td:nth-child(8)::before{content:'Margen'}
    .of-table tr.of-phase,.of-table tr.of-sub{display:flex;justify-content:space-between;gap:10px;padding:9px 12px;border-bottom:1px solid var(--line)}
    .of-table tr.of-phase td,.of-table tr.of-sub td{display:block;padding:0;border:0}
    #bg-result .pp-grid{grid-template-columns:1fr!important}
    .of-add{flex-direction:column;align-items:stretch}
    .of-add select{min-width:0;width:100%}
    .of-add .btn{width:100%}
    .mob-nav{display:flex;position:fixed;left:0;right:0;bottom:0;z-index:250;background:color-mix(in srgb,var(--navy-800) 88%,transparent);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-top:1px solid var(--line-strong);padding:6px 4px calc(6px + env(safe-area-inset-bottom))}
    .mob-nav button{flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;background:none;border:0;color:var(--muted-2);font-family:inherit;cursor:pointer;padding:4px 2px;border-radius:10px}
    .mob-nav button .mi{font-size:19px;line-height:1}
    .mob-nav button .ml{font-size:10px;font-weight:600;letter-spacing:.01em}
    .mob-nav button.active{color:var(--acid)}
    .mob-sheet{position:fixed;left:12px;right:12px;bottom:calc(66px + env(safe-area-inset-bottom));z-index:249;background:var(--navy-800);border:1px solid var(--line-strong);border-radius:16px;box-shadow:0 18px 50px rgba(0,0,0,.5);padding:8px;display:flex;flex-direction:column}
    .mob-sheet[hidden]{display:none}
    .mob-sheet button{background:none;border:0;color:var(--text);font-family:inherit;font-size:14.5px;font-weight:600;text-align:left;padding:13px 14px;border-radius:10px;cursor:pointer}
    .mob-sheet button.active,.mob-sheet button:hover{background:color-mix(in srgb,var(--acid) 10%,transparent);color:var(--acid)}
    /* modal de contacto a pantalla completa */
    .lead-modal{padding:0}
    .lead-modal .lead-card{width:100%;min-height:100dvh;border-radius:0;margin:0}
  }
  /* tablas genéricas (no la de Personas) en pantallas chicas: ocultar columnas 5 y 6 */
  @media(max-width:560px){
    .lead-table-wrap:not(.lead-table-hs) .lead-table th:nth-child(5),.lead-table-wrap:not(.lead-table-hs) .lead-table td:nth-child(5),
    .lead-table-wrap:not(.lead-table-hs) .lead-table th:nth-child(6),.lead-table-wrap:not(.lead-table-hs) .lead-table td:nth-child(6){display:none}
  }
  /* ---- home ---- */
  .home-h{font-size:22px;margin:0 0 18px}
  .home-h .home-sub{font-size:13px;font-weight:400;color:var(--muted-2);margin-left:6px}
  .home-kpis{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
  .hk{background:var(--navy-800);border:1px solid var(--line);border-radius:14px;padding:15px 17px}
  .hk-l{color:var(--muted);font-size:12.5px}
  .hk-n{font-family:'Space Grotesk';font-weight:700;font-size:26px;color:var(--text);line-height:1.15;margin-top:5px}
  .hk-t{font-size:12.5px;margin-top:4px;font-weight:600}
  .hk-t.up{color:#7ed957}
  .hk-t.down{color:#ff8b8b}
  .hk-t.muted{color:var(--muted-2);font-weight:400}
  .home-panels{display:grid;grid-template-columns:1.2fr 1fr;gap:16px;margin-top:16px}
  .home-att{display:flex;flex-direction:column;gap:2px}
  .home-att .att{display:flex;align-items:center;gap:11px;padding:10px 6px;border-radius:10px;cursor:pointer;font-size:14px;color:var(--text)}
  .home-att .att:hover{background:var(--navy-900)}
  .home-att .att .ai{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;flex:none}
  .home-att .att b{margin-left:auto;font-family:'Space Grotesk';font-weight:700}
  @media(max-width:920px){.home-kpis{grid-template-columns:repeat(2,1fr)}.home-panels{grid-template-columns:1fr}}
</style>
</head>
<body>

<!-- ============ LOGIN ============ -->
<div id="login-view" class="dash-wrap" hidden>
  <div class="login-card">
    <h1>Viven <span style="color:var(--acid)">Dashboard</span></h1>
    <p>Acceso privado. Inicia sesión con tu usuario.</p>
    <form id="login-form" class="lead-form">
      <div class="field"><label>Email</label><input type="email" name="email" required autocomplete="username" /></div>
      <div class="field"><label>Contraseña</label><input type="password" name="password" required autocomplete="current-password" /></div>
      <button type="submit">Entrar</button>
      <p class="form-error">Login incorrecto — revisa email y contraseña.</p>
    </form>
  </div>
</div>

<!-- ============ DASHBOARD ============ -->
<div id="dash-view" class="dash-wrap" hidden>
  <div class="dash-head">
    <div>
      <h1>Viven <span>Dashboard</span></h1>
      <p class="dash-sub" id="updated-at">Últimos 30 días</p>
    </div>
    <div class="dash-actions" style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
      <button class="bell-btn" id="theme-btn" type="button" title="Cambiar tema (oscuro/claro)" aria-label="Cambiar tema">◐</button>
      <div class="bell-wrap">
        <button class="bell-btn" id="bell-btn" type="button" title="Tareas y avisos" aria-label="Tareas y avisos">🔔<span class="bell-badge" id="bell-badge" hidden>0</span></button>
        <div class="bell-panel" id="bell-panel" hidden>
          <div class="bell-h"><span>🔔 Tareas y avisos</span><span style="display:flex;gap:8px;align-items:center"><button class="bell-pushbtn" id="bell-push" type="button" title="Recibir notificaciones en este dispositivo aunque la app esté cerrada">📲 Activar push</button><button class="bell-x" id="bell-x" type="button" aria-label="Cerrar">✕</button></span></div>
          <div id="bell-list"><p class="muted-note" style="padding:14px">Cargando…</p></div>
        </div>
      </div>
      <button class="btn btn-primary small" id="app-update-btn" type="button" hidden title="Hay una versión nueva de la app instalada — tocá para cargarla">🔄 Nueva versión</button>
      <button class="btn btn-ghost small" id="refresh-btn" type="button">↻ Actualizar</button>
      <button class="btn btn-ghost small" id="logout-btn" type="button">Salir</button>
    </div>
  </div>

  <div class="dash-body">
    <aside class="dash-side">
      <button class="side-item active" data-tab="home" type="button"><span class="si-ic">🏠</span>Home</button>
      <div class="side-group" data-group="crm">
        <button class="side-sec" type="button">CRM<svg class="side-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></button>
        <div class="side-group-items">
          <button class="side-item" data-tab="leads" type="button"><span class="si-ic">👤</span>Personas <span class="pill" id="tab-leads-count">0</span></button>
          <button class="side-item" data-tab="companies" type="button"><span class="si-ic">🏢</span>Companies</button>
        </div>
      </div>
      <div class="side-group" data-group="ventas">
        <button class="side-sec" type="button">Ventas<svg class="side-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></button>
        <div class="side-group-items">
          <button class="side-item" data-tab="deals" type="button"><span class="si-ic">🤝</span>Deals</button>
          <button class="side-item" data-tab="offers" type="button"><span class="si-ic">🧾</span>Ofertas</button>
          <button class="side-item" data-tab="props" type="button"><span class="si-ic">🌐</span>Propuestas</button>
          <button class="side-item" data-tab="booking" type="button"><span class="si-ic">📅</span>Booking</button>
          <button class="side-item" data-tab="services" type="button"><span class="si-ic">🛠</span>Servicios</button>
          <button class="side-item" data-tab="licenses" type="button"><span class="si-ic">📄</span>Licencias</button>
        </div>
      </div>
      <div class="side-group" data-group="analytics">
        <button class="side-sec" type="button">Analytics<svg class="side-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></button>
        <div class="side-group-items">
          <button class="side-item" data-tab="analytics" type="button"><span class="si-ic">📊</span>Analytics</button>
          <button class="side-item" data-tab="ab" type="button"><span class="si-ic">🧪</span>A/B Tests</button>
          <button class="side-item" data-tab="gads" type="button"><span class="si-ic">🎯</span>Google Ads</button>
        </div>
      </div>
      <div class="side-group" data-group="content">
        <button class="side-sec" type="button">Content<svg class="side-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></button>
        <div class="side-group-items">
          <button class="side-item" data-tab="blog" type="button"><span class="si-ic">📝</span>Blog</button>
          <button class="side-item" data-tab="news" type="button"><span class="si-ic">📰</span>Newsletter</button>
          <button class="side-item" data-tab="seo" type="button"><span class="si-ic">🔎</span>Search Console</button>
          <button class="side-item disabled" type="button" title="Fase 2"><span class="si-ic">🧲</span>Lead Magnets</button>
        </div>
      </div>
      <div class="side-group" data-group="automations">
        <button class="side-sec" type="button">Automations<svg class="side-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></button>
        <div class="side-group-items">
          <button class="side-item" data-tab="auto" type="button"><span class="si-ic">⚙️</span>Workflows</button>
        </div>
      </div>
    </aside>
    <div class="dash-main">

  <!-- ============ TAB: HOME ============ -->
  <div id="tab-home">
    <h2 class="home-h">Hola 👋 <span class="home-sub">últimos 7 días · vs semana anterior</span></h2>
    <div class="home-kpis">
      <div class="hk"><div class="hk-l">Nuevos leads</div><div class="hk-n" id="h-leads">–</div><div class="hk-t" id="h-leads-t"></div></div>
      <div class="hk"><div class="hk-l">Ganados</div><div class="hk-n" id="h-won">–</div><div class="hk-t" id="h-won-t"></div></div>
      <div class="hk"><div class="hk-l">Ingresos ganados</div><div class="hk-n" id="h-rev">–</div><div class="hk-t" id="h-rev-t"></div></div>
      <div class="hk"><div class="hk-l">Sesiones web</div><div class="hk-n" id="h-sess">–</div><div class="hk-t" id="h-sess-t"></div></div>
      <div class="hk"><div class="hk-l">Valor pipeline (abierto)</div><div class="hk-n" id="h-pipe">–</div><div class="hk-t muted">ofertas enviadas</div></div>
      <div class="hk"><div class="hk-l">Tasa de conversión</div><div class="hk-n" id="h-conv">–</div><div class="hk-t muted">ganado / decidido</div></div>
    </div>
    <div class="home-panels">
      <div class="panel"><h2>Funnel de ventas <span class="count">(últimos 30 días)</span></h2><div class="funnel" id="home-funnel"></div></div>
      <div class="panel"><h2>Necesita atención</h2><div class="home-att" id="home-att"></div></div>
    </div>
  </div>

  <!-- ============ TAB: LEADS ============ -->
  <!-- ============ TAB: PERSONAS (contactos) ============ -->
  <div id="tab-leads" hidden>
    <div class="of-bar" style="margin-bottom:14px">
      <div>
        <h2 style="margin:0">Personas</h2>
        <p class="muted-note" style="margin:2px 0 0">Contactos: la gente que escribió o con la que hablás. Cada persona está conectada a su empresa y a sus deals.</p>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <button class="btn btn-ghost small" id="ps-import" type="button" title="CSV con columnas: nombre, apellido, email, teléfono, empresa, cargo, idioma">⬆ Importar CSV</button>
        <button class="btn btn-primary small" id="ps-new-btn" type="button">➕ Nueva persona</button>
      </div>
    </div>
    <input type="file" id="ps-csv" accept=".csv,text/csv" hidden />
    <div class="panel crm-form" id="ps-form" hidden>
      <h2 style="margin-top:0">➕ Nueva persona</h2>
      <div class="crm-grid">
        <label>Nombre *<input class="ed-inp" id="psf-first" /></label>
        <label>Apellido<input class="ed-inp" id="psf-last" /></label>
        <label>Email *<input class="ed-inp" id="psf-email" type="email" /></label>
        <label>Teléfono<input class="ed-inp" id="psf-phone" /></label>
        <label>Empresa<input class="ed-inp" id="psf-company" list="psf-co-list" placeholder="Conectar o crear…" autocomplete="off" /><datalist id="psf-co-list"></datalist></label>
        <label>Cargo / rol<input class="ed-inp" id="psf-job" /></label>
        <label>Idioma<select class="ed-inp" id="psf-lang"><option value="en">EN</option><option value="de">DE</option><option value="es">ES</option></select></label>
        <label class="wide">Nota / contexto<textarea class="ed-inp" id="psf-msg" style="min-height:58px"></textarea></label>
      </div>
      <div style="display:flex;gap:8px;margin-top:12px">
        <button class="btn btn-primary small" id="psf-save" type="button">Guardar persona</button>
        <button class="btn btn-ghost small" id="psf-cancel" type="button">Cancelar</button>
      </div>
    </div>
    <div class="ps-stats"><b id="kl-total">–</b> personas · <b id="kl-new">–</b> sin contactar · <b id="kl-week">–</b> <span id="kl-week-l" style="display:none">en el período</span>en el período · <b id="kl-ads">–</b> desde Ads</div>
    <div class="pipe-bar ps-toolbar">
      <input type="search" id="lead-search" placeholder="Buscar por nombre, email, empresa o mensaje…" />
      <select id="ps-stage" class="status" title="Filtrar por etapa">
        <option value="all">Todas las etapas</option>
        <option value="nuevo">Nuevo</option>
        <option value="contactado">Contactado</option>
        <option value="videocall">Video Call</option>
        <option value="propuesta">Propuesta</option>
        <option value="ganado">Ganado</option>
        <option value="perdido">Perdido</option>
      </select>
      <select id="ps-act" class="status" title="Filtrar por última actividad">
        <option value="all">Cualquier actividad</option>
        <option value="web">🌐 Visitó la web</option>
        <option value="email">✉️ Email enviado</option>
        <option value="call">📞 Video call</option>
        <option value="offer">🧾 Oferta</option>
        <option value="prop">📄 Propuesta</option>
        <option value="note">📝 Nota</option>
        <option value="task">✅ Task</option>
        <option value="stage">🔁 Cambio de etapa</option>
      </select>
      <button class="btn btn-ghost small" id="export-csv" type="button">⬇ CSV</button>
      <button class="btn btn-danger small" id="ps-del-sel" type="button" hidden>🗑 Borrar seleccionados</button>
    </div>
    <div id="leads-list"></div>
  </div>

  <!-- ============ TAB: DEALS (pipeline / oportunidades) ============ -->
  <div id="tab-deals" hidden>
    <div class="of-bar" style="margin-bottom:12px">
      <div>
        <h2 style="margin:0">Deals</h2>
        <p class="muted-note" style="margin:2px 0 0">Arrastrá una tarjeta para moverla de etapa. El valor viene de las ofertas ligadas. Una persona puede tener varios deals (proyectos).</p>
      </div>
      <button class="btn btn-primary small" id="dl-new-btn" type="button">➕ Nuevo deal</button>
    </div>
    <!-- toolbar propia de Deals: el board deja de depender de los filtros de Personas -->
    <div class="pipe-bar dl-toolbar">
      <input type="search" id="dl-search" placeholder="Buscar por deal, persona o empresa…" />
      <button class="dl-chip" id="dl-stuck" type="button" title="Solo deals con más de 14 días en la misma etapa">🔥 Estancados +14d (<span id="dl-stuck-n">0</span>)</button>
      <div class="dl-views">
        <button id="dl-view-board" type="button">Board</button>
        <button id="dl-view-list" type="button">Lista</button>
      </div>
    </div>
    <div class="panel crm-form" id="dl-form" hidden>
      <h2 style="margin-top:0">➕ Nuevo deal (proyecto)</h2>
      <div class="crm-grid">
        <label>Persona *<select class="ed-inp" id="dlf-lead"></select></label>
        <label>Nombre del proyecto *<input class="ed-inp" id="dlf-title" placeholder="p. ej. Employer branding 2026" /></label>
        <label>Etapa<select class="ed-inp" id="dlf-stage"><option value="nuevo">Nuevo</option><option value="contactado">Contactado</option><option value="videocall">Video Call</option><option value="propuesta">Propuesta enviada</option></select></label>
        <label>Valor estimado (CHF)<input class="ed-inp" id="dlf-value" type="number" min="0" step="100" placeholder="opcional" /></label>
      </div>
      <div style="display:flex;gap:8px;margin-top:12px">
        <button class="btn btn-primary small" id="dlf-save" type="button">Crear deal</button>
        <button class="btn btn-ghost small" id="dlf-cancel" type="button">Cancelar</button>
      </div>
    </div>
    <!-- resumen compacto + board arriba de todo (como HubSpot) -->
    <div class="deals-sum" id="deals-sum"></div>
    <div class="pipe-pager" id="pipe-pager" hidden>
      <button id="pgr-prev" type="button" aria-label="Etapa anterior">‹</button>
      <span id="pgr-label">—</span>
      <button id="pgr-next" type="button" aria-label="Etapa siguiente">›</button>
    </div>
    <div class="pipeline" id="pipeline"></div>
    <!-- Ganado/Perdido salen del board como columnas: son destino de drop + resumen 30d -->
    <div class="pipe-drops" id="pipe-drops"></div>
    <!-- vista Lista (toggle Board/Lista) -->
    <div id="deals-list" hidden></div>
    <!-- popover ⋯ de las tarjetas (mismo patrón que pp-menu: fixed para que el overflow no lo recorte) -->
    <div class="lm2-menu" id="dl-menu" hidden style="position:fixed;top:0;left:0;right:auto"></div>
    <p class="muted-note" id="leads-empty" hidden>No hay deals que coincidan. Envía el formulario del sitio para testear.</p>

    <!-- análisis del pipeline (secundario, debajo del board) -->
    <details class="deals-analytics">
      <summary>📊 Análisis del pipeline <span>(funnel · KPIs · insights IA)</span></summary>
      <div class="kpis" style="margin-top:14px">
        <div class="kpi"><div class="n" id="kl-contacted">–</div><div class="l">Contactados</div></div>
        <div class="kpi"><div class="n" id="kl-won">–</div><div class="l">Ganados</div></div>
        <div class="kpi"><div class="n" id="kl-lost">–</div><div class="l">Perdidos</div></div>
        <div class="kpi"><div class="n" id="kl-convrate">–</div><div class="l">Tasa de conversión</div></div>
