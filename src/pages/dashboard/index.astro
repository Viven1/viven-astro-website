  .deals-analytics[open]>summary::before{transform:rotate(90deg)}
  .deals-analytics>summary span{color:var(--muted-2);font-weight:400;font-size:12.5px}
  .pipe-empty{color:var(--muted-2);font-size:12px;text-align:center;padding:16px 6px;border:1px dashed var(--line);border-radius:10px;margin-top:10px}
  /* ---- Deals V2: toolbar propia, semáforo de días, chip de documento, drop-zones y vista Lista ---- */
  .dl-chip{background:transparent;border:1px solid var(--line-strong);color:var(--muted);font-family:inherit;font-size:12.5px;font-weight:600;padding:9px 15px;border-radius:100px;cursor:pointer;transition:.2s;white-space:nowrap}
  .dl-chip:hover{border-color:var(--acid);color:var(--acid)}
  .dl-chip.active{background:var(--acid);border-color:var(--acid);color:#142033}
  .dl-views{display:flex;border:1px solid var(--line-strong);border-radius:10px;overflow:hidden;flex:none}
  .dl-views button{background:transparent;border:0;color:var(--muted);font-family:inherit;font-size:12.5px;font-weight:600;padding:9px 14px;cursor:pointer}
  .dl-views button.on{background:var(--acid);color:#142033}
  .pc-head{display:flex;align-items:flex-start;justify-content:space-between;gap:6px}
  .pc-head .pc-name{margin-bottom:0;flex:1;min-width:0}
  .pc-dots{background:transparent;border:1px solid var(--line-strong);border-radius:7px;color:var(--muted);font-size:14px;line-height:1;padding:2px 7px;cursor:pointer;flex:none}
  .pc-dots:hover{color:var(--text);border-color:var(--acid)}
  .pc-sub{font-size:11.5px;color:var(--muted);margin-top:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .pc-row{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-top:8px}
  .pc-amt{font-weight:700;font-family:'Space Grotesk';font-size:13.5px}
  .pc-next{font-size:11.5px;color:var(--muted);margin-top:7px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .pc-next.warn{color:#f0c060}
  .pc-doc{display:inline-block;font-size:11px;font-weight:600;border:1px solid var(--line-strong);border-radius:999px;padding:3px 9px;margin-top:7px;color:var(--muted);max-width:100%;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .pc-doc.ok{color:#7ed957;border-color:rgba(126,217,87,.5)}
  .pc-doc.hot{color:var(--acid);border-color:rgba(221,249,143,.55)}
  .pc-doc.warn{color:#f0c060;border-color:rgba(240,192,96,.5)}
  /* borde de alerta según los días en etapa (ámbar 7-14d, rojo >14d) */
  .pipe-card.pc-mid{border-color:rgba(240,192,96,.5)}
  .pipe-card.pc-bad{border-color:rgba(255,107,107,.55)}
  .pipeline[hidden]{display:none!important}   /* la vista Lista lo esconde; sin esto el display:flex le gana al hidden */
  .pipe-drops{display:flex;gap:10px;margin-top:4px;flex-wrap:wrap}
  .pipe-drops[hidden]{display:none!important}
  .pipe-drop{flex:1;min-width:230px;border:2px dashed;border-radius:12px;padding:13px 16px;text-align:center;cursor:pointer;font-family:'Space Grotesk';font-weight:600;font-size:13.5px;transition:.2s;background:transparent}
  .pipe-drop .pd-sum{display:block;font-family:'Inter',sans-serif;font-weight:400;font-size:11.5px;color:var(--muted);margin-top:3px}
  .pipe-drop.win{border-color:rgba(126,217,87,.45);color:#7ed957}
  .pipe-drop.lose{border-color:rgba(255,107,107,.45);color:#ff8b8b}
  .pipe-drop.win.drop{background:rgba(126,217,87,.1);border-color:#7ed957}
  .pipe-drop.lose.drop{background:rgba(255,107,107,.1);border-color:#ff6b6b}
  .dl-lbar{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:12px}
  .dl-lbar select{margin-left:auto}

  /* ---------- Insights con IA ---------- */
  .ai-panel{background:linear-gradient(135deg,rgba(221,249,143,.06),var(--navy-800))}
  .ai-head{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:14px;flex-wrap:wrap}
  .ai-head h2{margin:0}
  .ai-insight{display:flex;gap:12px;padding:14px 0;border-top:1px solid var(--line)}
  .ai-insight:first-child{border-top:0}
  .ai-insight .ico{font-size:20px;flex:none;line-height:1.3}
  .ai-insight .txt h4{font-size:15px;margin:0 0 3px;color:var(--text);font-family:'Space Grotesk'}
  .ai-insight .txt p{font-size:13.5px;color:var(--muted);margin:0;line-height:1.5}
  .ai-loading{color:var(--muted);font-size:14px;padding:10px 0}

  /* ---------- Gráfico SVG (real) ---------- */
  #daily-chart{height:auto!important;display:block;padding-top:4px}
  .gsvg{width:100%;height:auto;display:block;overflow:visible}
  .g-grid{stroke:rgba(255,255,255,.07);stroke-width:1}
  .g-yl{fill:var(--muted-2);font-size:11px;text-anchor:end;font-family:'Inter'}
  .g-xl{fill:var(--muted-2);font-size:11px;font-family:'Inter'}
  .g-line{fill:none;stroke:var(--acid);stroke-width:2.5;stroke-linejoin:round;stroke-linecap:round}
  .g-lead{fill:#ff9ec9;stroke:var(--navy-800);stroke-width:2;transition:.2s}
  .gsvg circle:hover{opacity:.8}
  .chart-labels{display:none}

  /* ===== Funnel ===== */
  .funnel{display:grid;gap:10px;margin-top:6px}
  .fn-row{display:grid;grid-template-columns:110px 1fr 120px;align-items:center;gap:14px}
  .fn-label{font-size:13.5px;color:var(--text);font-weight:600}
  .fn-bar-wrap{background:var(--navy-900);border-radius:8px;overflow:hidden}
  .fn-bar{height:34px;border-radius:8px;display:flex;align-items:center;justify-content:flex-end;padding:0 12px;min-width:34px;transition:width .4s ease}
  .fn-n{font-weight:700;color:#10210a;font-size:14px}
  .fn-meta{text-align:right;font-size:12.5px;color:var(--muted)}
  .fn-meta b{display:block;color:var(--text);font-size:15px}
  .fn-meta span{font-size:11.5px;color:var(--muted-2)}
  .fn-foot{margin-top:14px;padding-top:12px;border-top:1px solid var(--line);font-size:13px;color:var(--muted)}
  .fn-foot b{color:var(--text)}
  .fn-hint{color:var(--muted-2);font-size:11.5px}
  @media(max-width:640px){.fn-row{grid-template-columns:80px 1fr 84px;gap:8px}}

  /* ===== Offer tool ===== */
  .of-bar{display:flex;justify-content:space-between;align-items:center;gap:14px;flex-wrap:wrap}
  .of-list{display:grid;gap:10px;margin-top:16px}
  .of-card{background:var(--navy-800);border:1px solid var(--line);border-radius:14px;color:var(--text);transition:border-color .15s;font-family:inherit;overflow:hidden}
  .of-card:hover{border-color:var(--muted)}
  .of-card.arch{opacity:.6}
  .of-card-open{display:flex;align-items:center;gap:16px;width:100%;text-align:left;padding:15px 18px;cursor:pointer}
  .of-actions{display:flex;gap:8px;padding:0 12px 12px;flex-wrap:wrap}
  .of-act{background:var(--navy-900);border:1px solid var(--line-strong);color:var(--muted);border-radius:9px;font-size:12.5px;padding:6px 11px;cursor:pointer;font-family:inherit;transition:border-color .15s,color .15s}
  .of-act:hover{border-color:var(--muted);color:var(--text)}
  .of-act.danger:hover{border-color:#ff6b6b;color:#ff8b8b}
  /* "Más métricas": summary plegable con look de link muted (reemplaza a las 6 tarjetas KPI secundarias) */
  .of-more-sum{color:var(--muted);font-size:13px;cursor:pointer;list-style:none;padding:6px 0;user-select:none;width:max-content}
  .of-more-sum:hover{color:var(--text)}
  .of-more-sum::-webkit-details-marker{display:none}
  .btn:disabled{opacity:.45;cursor:not-allowed}
  .of-arch-list{display:flex;flex-direction:column;gap:10px;margin-top:8px}
  /* ---- 📤 Bandeja de salida (outbox) ---- */
  #ob-list{display:flex;flex-direction:column;gap:14px}
  #ob-list .au-step{background:var(--navy-800);border:1px solid var(--line);border-radius:14px;padding:16px 18px}
  #ob-list .ob-hd{display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:12px}
  #ob-list .ob-who{display:flex;gap:10px;align-items:center}
  #ob-list .ob-kind{font-size:11px;font-weight:700;letter-spacing:.3px;color:var(--acid);background:color-mix(in srgb,var(--acid) 14%,transparent);border:1px solid color-mix(in srgb,var(--acid) 40%,transparent);border-radius:20px;padding:3px 11px;flex:none}
  #ob-list .ob-f{margin-bottom:10px}
  #ob-list .ob-f label{display:block;font-size:12px;font-weight:600;color:var(--muted);margin-bottom:5px}
  #ob-list .ob-f input,#ob-list .ob-f select,#ob-list .ob-f textarea{width:100%;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:11px;color:var(--text);font-family:inherit;font-size:14px;padding:10px 12px}
  #ob-list .ob-f select{cursor:pointer;max-width:220px}
  #ob-list .ob-body{min-height:130px;line-height:1.55;resize:vertical}
  #ob-list .ob-row{display:flex;gap:14px;flex-wrap:wrap}
  #ob-list .ob-row .ob-f{flex:1;min-width:180px}
  /* ---- editor de propuestas ---- */
  #pp-editor .bf,#contenido-sub-blog .bf,#sistema-sub-services .bf{margin-bottom:14px}
  #pp-editor .bf label,#contenido-sub-blog .bf label,#sistema-sub-services .bf label,#sistema-sub-licenses .bf label,#sistema-sub-cashflow .bf label{display:block;font-size:12.5px;font-weight:600;color:var(--muted);margin-bottom:6px}
  #pp-editor .bf input,#pp-editor .bf select,#pp-editor .bf textarea,#contenido-sub-blog .bf input,#contenido-sub-blog .bf select,#contenido-sub-blog .bf textarea,#sistema-sub-licenses .bf input,#sistema-sub-licenses .bf select,#sistema-sub-licenses .bf textarea,#sistema-sub-cashflow .bf input,#sistema-sub-cashflow .bf select,#sistema-sub-cashflow .bf textarea{width:100%;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:11px;color:var(--text);font-family:inherit;font-size:14.5px;padding:11px 13px}
  /* ---------- Cash Flow (SQL 0077/0078/0079) ---------- */
  .cf-tag{display:inline-block;padding:2px 9px;border-radius:100px;font-size:11px;font-weight:600;white-space:nowrap}
  .cf-tag.rec{color:var(--acid);background:rgba(221,249,143,.12)}
  .cf-tag.loan{color:#8fb8ff;background:rgba(143,184,255,.12)}
  .cf-tag.bexio{color:#7ed957;background:rgba(126,217,87,.12)}
  .cf-tag.manual{color:var(--muted);background:rgba(255,255,255,.06)}
  .cf-amt{font-weight:700;white-space:nowrap}
  .cf-amt.pos{color:#7ed957}
  .cf-amt.neg{color:#ff8b8b}
  .cf-loan-bar{background:var(--navy-900);border-radius:8px;height:6px;overflow:hidden;margin:8px 0 6px}
  .cf-loan-bar i{display:block;height:100%;background:var(--acid);border-radius:8px}
  #sistema-sub-cashflow .of-card-sub{margin-top:4px}
  .lic-days{font-size:11px;font-weight:700;letter-spacing:.3px;padding:3px 10px;border-radius:20px;flex:none}
  .lic-days.ok{color:#7ed957;border:1px solid #7ed957}
  .lic-days.soon{color:#f0c060;border:1px solid #f0c060}
  .lic-days.due{color:#ff8b8b;border:1px solid #ff8b8b}
  .lic-days.past{color:var(--muted-2);border:1px solid var(--line-strong)}
  .of-act.lic-pri{background:var(--acid);border-color:var(--acid);color:var(--navy-900);font-weight:700}
  .of-act.lic-pri:hover{border-color:var(--acid);color:var(--navy-900)}
  :root[data-theme="light"] .of-act.lic-pri{background:#dff28b;border-color:#dff28b;color:#1c2508}
  .lic-renew{display:flex;gap:8px;align-items:center;padding:0 12px 12px;flex-wrap:wrap}
  .lic-renew input[type=date]{background:var(--navy-900);border:1px solid var(--line-strong);border-radius:9px;color:var(--text);font-family:inherit;font-size:13px;padding:7px 10px}
  .pp-grid{display:grid;grid-template-columns:var(--cols,repeat(4,1fr));gap:14px;margin:18px 0 8px;align-items:end}
  .pp-grid .bf{margin-bottom:0}
  .pp-grid3{display:grid;grid-template-columns:2fr 1fr;gap:18px;margin-bottom:6px;align-items:start}
  .pp-grid3 > div .bf:last-child{margin-bottom:0}
  .pp-ta{width:100%;min-height:80px;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:11px;color:var(--text);font-family:inherit;font-size:14.5px;padding:11px 13px;resize:vertical}
  .pp-sec-h{display:flex;align-items:center;gap:12px;font-weight:700;font-size:14px;margin:22px 0 10px;color:var(--text)}
  .pp-sec-h .count{font-weight:400;color:var(--muted-2);font-size:12.5px}
  .btn.xs{font-size:12px;padding:4px 10px}
  .pp-status-badge{border:1px solid var(--line-strong);border-radius:999px;font-size:12px;font-weight:600;padding:4px 12px;color:var(--muted)}
  .pp-status-badge.sent{color:#f0c060;border-color:#f0c060}
  .pp-status-badge.accepted{color:#7ed957;border-color:#7ed957}
  /* Propuestas V2 (lista): semáforo de espera + señal de interés en la tabla */
  .pp2-sem{display:inline-flex;align-items:center;border:1px solid;border-radius:999px;font-size:11.5px;font-weight:600;padding:3px 10px;white-space:nowrap}
  .pp2-sem.ok{color:#7ed957;border-color:rgba(126,217,87,.5)}
  .pp2-sem.mid{color:#f0c060;border-color:rgba(240,192,96,.5)}
  .pp2-sem.bad{color:#ff8b8b;border-color:rgba(255,107,107,.55)}
  .pp2-eye{font-size:12px;color:var(--muted);white-space:nowrap}
  .pp2-eye.hot{color:var(--acid);font-weight:700}
  .pp2-eye.warn{color:#f0c060}
  .pp2-dots{background:transparent;border:1px solid var(--line-strong);border-radius:8px;color:var(--muted);font-size:15px;line-height:1;padding:4px 9px;cursor:pointer}
  .pp2-dots:hover{color:var(--text);border-color:var(--acid)}
  #pp-list table{min-width:920px} /* móvil = scroll horizontal dentro del wrap, sin colapsar columnas */
  .pp-linkbox{display:flex;align-items:center;gap:20px;flex-wrap:wrap;background:color-mix(in srgb,var(--acid) 8%,var(--navy-800));border:1px solid color-mix(in srgb,var(--acid) 40%,var(--line));border-radius:12px;padding:14px 18px;margin:8px 0 18px}
  .pp-linkbox .k{display:block;font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--muted-2);margin-bottom:3px}
  .pp-linkbox a{color:var(--acid);word-break:break-all;font-size:14px}
  .pp-linkbox code{color:var(--text);font-size:14px;background:var(--navy-900);padding:2px 8px;border-radius:6px}
  .pp-row{background:var(--navy-800);border:1px solid var(--line);border-radius:12px;padding:12px 14px;margin-bottom:10px}
  .pp-row .rowtop{display:flex;gap:10px;align-items:center;margin-bottom:8px}
  .pp-row input,.pp-row textarea,.pp-row select{background:var(--navy-900);border:1px solid var(--line-strong);border-radius:9px;color:var(--text);font-family:inherit;font-size:14px;padding:9px 11px}
  /* red de seguridad: ningún select/input suelto (sin .grow ni width:100%) puede forzar
     la fila -y de arrastre la página entera- más ancha que la pantalla en celular */
  #pp-editor select,#pp-editor input{max-width:100%}
  /* bündig: el texto ocupa TODO el ancho y crece con el contenido — nunca scroll interno */
  .pp-row textarea,#pp-editor textarea{width:100%;min-height:54px;resize:none;overflow:hidden;line-height:1.55;display:block;margin-top:8px}
  .pp-row .grow{flex:1;min-width:0}
  .pp-row .rm{background:none;border:0;color:var(--muted-2);cursor:pointer;font-size:16px;padding:2px 6px}
  .pp-row .rm:hover{color:#ff8b8b}
  .pp-tier-row .tnums{display:flex;gap:8px;flex-wrap:wrap}
  .pp-tier-row .tnums input{width:90px}
  /* fix: el <select> "usar oferta" no tenía ancho acotado — con títulos largos de oferta
     empujaba toda la fila (y la página entera) más ancha que la pantalla en celular */
  .pp-tier-row .tnums select.t-from{flex:1 1 160px;min-width:0;max-width:100%}
  .pp-tier-row .rec{display:flex;align-items:center;gap:6px;font-size:13px;color:var(--muted);white-space:nowrap}
  /* precio + % desc. con label visible (antes solo un placeholder que desaparecía
     al tipear — quedaba invisible el % OFF que ya existía, pedido explícito de
     Sebastián de hacer el descuento por paquete más claro) */
  .pp-tier-row .t-price-lbl{display:flex;flex-direction:column;gap:2px;font-size:10px;text-transform:uppercase;letter-spacing:.04em;color:var(--muted-2);font-weight:600}
  .pp-tier-row .t-price-lbl input{text-transform:none;letter-spacing:normal;font-size:13.5px;font-weight:400;color:var(--text);margin-top:2px}
  .t-disc-final{font-size:12px;color:var(--acid);font-weight:600;align-self:center;white-space:nowrap}
  .pp-tier-row textarea{width:100%;min-height:90px}
  .pp-oflink{background:none;border:1px solid var(--line-strong);border-radius:8px;color:var(--acid);font-family:inherit;font-size:11.5px;font-weight:700;padding:5px 9px;cursor:pointer;margin-left:8px}
  .pp-oflink:hover{border-color:var(--acid)}
  .pp-tier-margin{font-size:12px;color:var(--muted-2);margin-top:6px}
  /* ---- Propuestas V3 (pp3-): editor por bloques ---- */
  .pp3-split{display:grid;grid-template-columns:216px minmax(0,1fr);gap:18px;align-items:start;margin-top:6px}
  .pp3-blocks{position:sticky;top:12px;background:var(--navy-800);border:1px solid var(--line);border-radius:12px;padding:8px;font-size:12.5px}
  .pp3-b{display:flex;align-items:center;gap:7px;padding:8px 9px;border-radius:8px;color:var(--muted);cursor:pointer;border:1px solid transparent;user-select:none;-webkit-user-select:none}
  .pp3-b:hover{color:var(--text)}
  .pp3-b.act{background:var(--navy-900);color:var(--text);border-color:color-mix(in srgb,var(--acid) 55%,transparent)}
  .pp3-b.off{opacity:.45}
  .pp3-b.off .pp3-bl{text-decoration:line-through}
  .pp3-b.drag{opacity:.5;border:1px dashed var(--acid)}
  .pp3-h{cursor:grab;color:var(--muted-2);font-size:11px;touch-action:none;padding:2px 1px}
  .pp3-bl{flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .pp3-tgl{background:none;border:0;color:var(--muted-2);cursor:pointer;font-size:12.5px;padding:0 2px;line-height:1}
  .pp3-tgl:hover{color:var(--acid)}
  .pp3-blk{scroll-margin-top:80px}
  .pp3-blk.dim{opacity:.45}
  .pp3-auto{font-size:11.5px;color:#7ed957;white-space:nowrap}
  .pp-status-badge.lost{color:#ff8b8b;border-color:#ff8b8b}
  /* ítems de paquete inline (⇄ sync con la oferta ligada) */
  .pp3-items{margin-top:8px;border-top:1px dashed var(--line-strong);padding-top:8px}
  .pp3-it{display:flex;gap:6px;align-items:center;margin-bottom:6px}
  .pp3-it .iname{flex:1;min-width:0}
  .pp3-it .iqty{width:64px}
  .pp3-it .iprice{width:96px}
  .pp3-it .icost{font-size:11px;color:var(--muted-2);white-space:nowrap;min-width:70px;text-align:right}
  .pp3-it-bar{display:flex;gap:6px;align-items:center;margin-top:4px}
  .pp3-it-bar select{flex:1;min-width:0;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:8px;color:var(--muted);font-size:12px;padding:7px 8px;font-family:inherit}
  .pp3-sync{font-size:11px;color:#7ed957;margin-left:6px;white-space:nowrap}
  /* ---- Ofertas V3 (of3-): editor en 4 pasos ---- */
  .of3-steps{display:flex;gap:6px;flex-wrap:wrap;margin:12px 0 4px}
  .of3-chip{border:1px solid var(--line-strong);border-radius:999px;background:var(--navy-800);color:var(--muted);font-family:inherit;font-size:12.5px;padding:6px 13px;cursor:pointer}
  .of3-chip:hover{color:var(--text)}
  .of3-chip.on{background:var(--acid);color:#10210a;border-color:var(--acid);font-weight:700}
  .of3-status{display:inline-flex;gap:4px;flex-wrap:wrap}
  .of3-status .of3-chip{font-size:11.5px;padding:4px 10px}
  .of3-nocost .of-table th:nth-child(6),.of3-nocost .of-table tr[data-i] td:nth-child(6),
  .of3-nocost .of-table th:nth-child(8),.of3-nocost .of-table tr[data-i] td:nth-child(8){display:none}
  .of3-nocost .of-table tr.of-sub td:nth-child(3){display:none}
  .of3-nocost .of-sum-row.int,.of3-nocost .of-summary hr,.of3-nocost #of-bep{display:none}
  .of3-send{background:var(--navy-800);border:1px solid var(--line);border-radius:14px;padding:18px;max-width:640px}
  .of3-send .k{font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--muted-2);margin:10px 0 3px}
  .of3-send .k:first-child{margin-top:0}
  .of3-attach{display:inline-block;border:1px solid var(--line-strong);border-radius:10px;padding:8px 12px;background:var(--navy-900);font-size:13px;margin-top:4px}
  .of3-attach small{display:block;color:var(--muted-2);font-size:11px;margin-top:2px}
  /* ---- lead picker (lp-): combobox buscable para "ligar a lead/cliente" ---- */
  .lp-box{position:relative}
  .lp-in{width:100%;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:11px;color:var(--text);font-family:inherit;font-size:14px;padding:10px 13px}
  .lp-dd{position:absolute;top:calc(100% + 4px);left:0;right:0;z-index:80;background:var(--navy-800);border:1px solid var(--line-strong);border-radius:12px;box-shadow:0 14px 40px rgba(0,0,0,.45);max-height:290px;overflow:auto;padding:4px}
  .lp-r{display:block;width:100%;text-align:left;background:none;border:0;border-radius:8px;color:var(--text);font-family:inherit;font-size:13.5px;padding:8px 10px;cursor:pointer}
  .lp-r:hover,.lp-r.hi{background:color-mix(in srgb,var(--acid) 10%,transparent)}
  .lp-co{color:var(--muted)}
  .lp-sub{display:block;font-size:11.5px;color:var(--muted-2);margin-top:1px}
  .lp-sub i{font-style:normal;border:1px solid var(--line-strong);border-radius:20px;padding:0 7px;font-size:10.5px}
  .lp-none{color:var(--muted-2);font-size:13px;padding:8px 10px}
  .lp-chip{display:flex;align-items:center;gap:8px;background:var(--navy-900);border:1px solid color-mix(in srgb,var(--acid) 45%,var(--line-strong));border-radius:11px;padding:9px 13px;font-size:13.5px;color:var(--text)}
  .lp-chip-t{flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .lp-x{background:none;border:0;color:var(--muted-2);cursor:pointer;font-size:14px;padding:0 2px}
  .lp-x:hover{color:#ff8b8b}
  @media(max-width:820px){.pp-grid{grid-template-columns:1fr 1fr}.pp-grid3{grid-template-columns:1fr}
    .pp3-split{grid-template-columns:1fr}
    .pp3-blocks{position:sticky;top:0;z-index:5;display:flex;overflow-x:auto;gap:4px;padding:6px;scrollbar-width:none}
    .pp3-blocks::-webkit-scrollbar{display:none}
    .pp3-b{flex:0 0 auto;white-space:nowrap;padding:6px 8px}
  }
  /* fix: en celular real (≤560px) .pp-grid quedaba en 2 columnas (heredado de la regla de 820px)
     y se cortaba por el borde derecho — recién acá colapsa a 1 columna de verdad */
  @media(max-width:560px){.pp-grid{grid-template-columns:1fr}}
  /* ---- preview de blog ---- */
  .post-preview{background:var(--navy-800);border:1px solid var(--line);border-radius:14px;padding:26px 30px;max-width:760px;line-height:1.65}
  .post-preview .eyebrow{font-size:11.5px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--acid)}
  .post-preview h1{font-size:26px;margin:8px 0 12px;color:var(--text);line-height:1.2}
  .post-preview .lead{font-size:16px;color:var(--muted);margin-bottom:18px}
  /* ---- Blog rediseñado (bl2-): pipeline + performance + editor visual ---- */
  #bl2-kpis{gap:10px;margin-bottom:14px}
  #bl2-kpis .kpi{padding:12px 14px}
  #bl2-kpis .kpi .n{font-size:20px;white-space:normal}
  #bl2-kpis .kpi .l{margin-top:3px;font-size:11px}
  .bl2-cal{display:flex;gap:8px;margin:0 0 18px;overflow-x:auto;padding-bottom:4px;scrollbar-width:none}
  .bl2-cal::-webkit-scrollbar{display:none}
  .bl2-day{flex:1;min-width:132px;border:1px solid var(--line);border-radius:11px;background:var(--navy-800);padding:9px 11px;font-size:11px}
  .bl2-day .d{font-weight:700;color:var(--muted-2);text-transform:uppercase;font-size:9.5px;letter-spacing:.07em}
  .bl2-day .t{font-weight:600;margin-top:4px;font-size:11.5px;line-height:1.35;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
  .bl2-day.next{border-color:color-mix(in srgb,var(--acid) 45%,transparent)}
  .bl2-day.add{border-style:dashed;cursor:pointer;color:var(--muted-2)}
  .bl2-day.add:hover{border-color:var(--acid);color:var(--acid)}
  .bl2-st{font-size:9.5px;font-weight:700;border-radius:20px;padding:1px 7px;display:inline-block;margin-top:6px}
  .bl2-st.done{background:rgba(126,217,87,.15);color:#7ed957}
  .bl2-st.work{background:rgba(240,192,96,.15);color:#f0c060}
  .bl2-st.pend{background:rgba(138,180,255,.15);color:#8ab4ff}
  .bl2-lang{display:inline-grid;place-items:center;min-width:27px;height:19px;border-radius:5px;font-size:9px;font-weight:800;margin-right:3px;letter-spacing:.03em;border:1px solid transparent}
  .bl2-lang.pub{background:rgba(126,217,87,.16);color:#7ed957}
  .bl2-lang.dr{background:rgba(138,180,255,.15);color:#8ab4ff}
  .bl2-lang.no{background:transparent;border-color:var(--line-strong);color:var(--muted-2);cursor:pointer}
  .bl2-lang.no:hover{border-color:var(--acid);color:var(--acid)}
  .bl2-pend{border:1px solid color-mix(in srgb,#f0c060 35%,var(--line));border-radius:14px;background:var(--navy-800);padding:14px 16px;margin-bottom:10px;display:flex;gap:14px;align-items:center;flex-wrap:wrap}
  .bl2-pend-main{flex:1;min-width:240px}
  .bl2-pend-title{font-weight:700;font-size:14.5px}
  .bl2-pend-sub{font-size:12px;color:var(--muted-2);margin-top:3px}
  .bl2-pend-acts{display:flex;gap:8px;flex-wrap:wrap}
  .bl2-kw{width:100%;border:1px solid var(--line);border-radius:10px;background:var(--navy-900);padding:9px 13px;margin:2px 0}
  .bl2-kw-tag{display:inline-block;font-weight:800;font-size:10.5px;border:1px solid;border-radius:6px;padding:2px 7px;white-space:nowrap;margin-right:8px;vertical-align:middle}
  .bl2-kw-kw{font-weight:700;font-size:12.5px;color:var(--text)}
  .bl2-kw-why{font-size:12px;color:var(--muted-2);margin-top:4px;line-height:1.55}
  .bl2-kw.muted{background:transparent;border-style:dashed}
  .bl2-table .bl2-t{font-weight:700;font-size:13.5px}
  .bl2-table .bl2-sub{font-size:11px;color:var(--muted-2);margin-top:2px}
  .bl2-table td{vertical-align:middle}
  .bl2-num{font-family:'Space Grotesk';font-weight:700;text-align:right;white-space:nowrap}
  .bl2-num.good{color:#7ed957}
  .bl2-trend{font-size:11.5px;font-weight:700;white-space:nowrap;text-align:right}
  .bl2-trend.up{color:#7ed957}
  .bl2-trend.dn{color:var(--muted-2)}
  .bl2-dots{background:transparent;border:1px solid var(--line-strong);border-radius:8px;color:var(--muted);cursor:pointer;font-size:14px;line-height:1;padding:4px 8px;font-family:inherit}
  .bl2-dots:hover{border-color:var(--acid);color:var(--acid)}
  .bl2-ltabs{display:inline-flex;gap:6px;margin-left:6px}
  .bl2-ltab{background:transparent;border:1px solid var(--line-strong);border-radius:100px;color:var(--muted);font:700 11px Inter,sans-serif;padding:4px 11px;cursor:pointer}
  .bl2-ltab.on{border-color:var(--acid);color:var(--acid);background:rgba(221,249,143,.08)}
  .bl2-ltab.pub:not(.on){color:#7ed957}
  .bl2-ltab.miss{border-style:dashed;color:var(--muted-2)}
  .bl2-ltab.miss:hover{border-color:var(--acid);color:var(--acid)}
  .bl2-imgpick{display:grid;grid-template-columns:repeat(auto-fill,minmax(96px,1fr));gap:6px;margin-bottom:8px}
  .bl2-img{position:relative;aspect-ratio:16/10;border-radius:8px;overflow:hidden;border:2px solid var(--line);cursor:pointer;background:var(--navy-900);padding:0}
  .bl2-img img{width:100%;height:100%;object-fit:cover;display:block}
  .bl2-img:hover{border-color:var(--line-strong)}
  .bl2-img.sel{border-color:var(--acid);box-shadow:0 0 0 2px color-mix(in srgb,var(--acid) 30%,transparent)}
  .bl2-img.sel::after{content:'✓';position:absolute;top:4px;right:4px;background:var(--acid);color:#142033;border-radius:50%;width:17px;height:17px;display:grid;place-items:center;font-size:11px;font-weight:800}
  .bl2-img.none{display:grid;place-items:center;font-size:10px;color:var(--muted-2);font-weight:700}
  .bl2-vidpick{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px}
  .bl2-vid{background:transparent;border:1px solid var(--line-strong);border-radius:100px;color:var(--muted);font:600 11px Inter,sans-serif;padding:5px 11px;cursor:pointer}
  .bl2-vid:hover{border-color:var(--acid);color:var(--acid)}
  .bl2-vid.sel{border-color:var(--acid);color:var(--acid);background:rgba(221,249,143,.08)}
  @media(max-width:720px){
    .bl2-pend{padding:12px}
    .bl2-pend-acts{width:100%}
    .bl2-pend-acts .btn{flex:1;white-space:nowrap}
    .bl2-table th:nth-child(4),.bl2-table td:nth-child(4){display:none}
    .bl2-imgpick{grid-template-columns:repeat(3,1fr)}
  }
  .gads-kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:14px}
  .gads-kpi{border:1px solid var(--line);border-radius:12px;padding:12px 14px;display:flex;flex-direction:column;gap:4px}
  .gads-kpi b{font-size:19px;line-height:1.1}
  .gads-kpi span{font-size:11.5px;color:var(--muted)}
  .gads-roi{display:flex;gap:10px;flex-wrap:wrap;align-items:stretch}
  .gads-roi .gads-kpi{min-width:128px;justify-content:center}
  .gads-table{width:100%;border-collapse:collapse;font-size:13px;min-width:460px}
  .gads-table th,.gads-table td{padding:8px 10px;text-align:left;border-bottom:1px solid var(--line)}
  .gads-table th{color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.5px}

  /* ============ rediseño tab NEWSLETTER (scoped a #contenido-sub-news — nunca inputs pelados) ============ */
  #contenido-sub-news .nw-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:18px;align-items:start}
  @media(max-width:900px){#contenido-sub-news .nw-grid{grid-template-columns:1fr}}
  #contenido-sub-news .nw-sec-h{font-size:10px;letter-spacing:.11em;text-transform:uppercase;color:var(--muted-2);font-weight:700;margin:16px 0 8px;display:flex;align-items:center;gap:8px}
  #contenido-sub-news .nw-sec-h:first-child{margin-top:0}
  /* campos de formulario — dedicados, con clase reconocible */
  #contenido-sub-news .nw-inp{width:100%;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:10px;color:var(--text);font:14px/1.5 inherit;padding:10px 12px}
  #contenido-sub-news textarea.nw-inp{min-height:120px;resize:vertical}
  #contenido-sub-news select.nw-sel{background:var(--navy-900);border:1px solid var(--line-strong);border-radius:100px;color:var(--text);font:600 12.5px inherit;padding:8px 13px;cursor:pointer}
  #contenido-sub-news .nw-inp:focus,#contenido-sub-news .nw-sel:focus{outline:none;border-color:var(--acid)}
  #contenido-sub-news .nw-row{display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:10px}
  /* bloques de contenido — cards compactas en el editor */
  #contenido-sub-news .nw-block{border:1.5px solid rgba(221,249,143,.4);border-radius:12px;background:var(--navy-900);padding:10px 13px;margin:8px 0;position:relative}
  #contenido-sub-news .nw-block .nw-bh{display:flex;align-items:center;gap:8px;font-weight:700;font-size:12px;color:var(--acid);margin-bottom:8px}
  #contenido-sub-news .nw-block .nw-bctl{margin-left:auto;display:flex;gap:4px}
  #contenido-sub-news .nw-block .nw-bctl button{background:none;border:1px solid var(--line-strong);border-radius:7px;color:var(--muted);cursor:pointer;font-size:12px;line-height:1;padding:3px 7px}
  #contenido-sub-news .nw-block .nw-bctl button:hover{border-color:var(--acid);color:var(--acid)}
  #contenido-sub-news .nw-block .nw-bctl button:disabled{opacity:.3;cursor:default}
  #contenido-sub-news .nw-textblock{border:1px solid var(--line);border-radius:12px;background:var(--navy-900);margin:8px 0}
  #contenido-sub-news .nw-textblock textarea{width:100%;background:transparent;border:0;color:var(--text);font:13.5px/1.6 inherit;padding:11px 13px;resize:vertical;min-height:70px}
  #contenido-sub-news .nw-textblock textarea:focus{outline:none}
  #contenido-sub-news .nw-addrow{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px}
  #contenido-sub-news .nw-addbtn{border:1px dashed var(--line-strong);border-radius:100px;padding:6px 12px;font-size:11.5px;color:var(--muted);background:transparent;cursor:pointer}
  #contenido-sub-news .nw-addbtn:hover{border-color:var(--acid);color:var(--acid)}
  /* mini campo dentro de un bloque */
  #contenido-sub-news .nw-bfield{display:flex;flex-direction:column;gap:3px;margin-top:6px}
  #contenido-sub-news .nw-bfield label{font-size:10.5px;color:var(--muted-2);text-transform:uppercase;letter-spacing:.04em}
  #contenido-sub-news .nw-thumbrow{display:flex;gap:9px;align-items:center;margin-top:6px}
  #contenido-sub-news .nw-thumb{width:96px;aspect-ratio:16/9;border-radius:8px;background:#16233a center/cover no-repeat;display:grid;place-items:center;font-size:15px;color:#fff;flex:none}
  /* send box acid */
  #contenido-sub-news .nw-sendbox{border:1px solid rgba(221,249,143,.4);border-radius:13px;background:rgba(221,249,143,.06);padding:14px 16px;margin-top:12px}
  #contenido-sub-news .nw-sendbox .t{font-weight:700;font-size:13.5px}
  #contenido-sub-news .nw-sendbox .m{font-size:12px;color:var(--muted);margin-top:6px;line-height:1.6}
  #contenido-sub-news .nw-sendbox .m b{color:var(--text)}
  #contenido-sub-news .nw-sendbox .m .cap-over{color:var(--lost);font-weight:700}
  #contenido-sub-news .nw-bar{height:8px;border-radius:10px;background:rgba(255,255,255,.09);overflow:hidden;margin-top:10px}
  #contenido-sub-news .nw-bar i{display:block;height:100%;width:0;background:var(--acid);border-radius:10px;transition:width .3s}
  #contenido-sub-news .nw-bar-t{font-size:10.5px;color:var(--muted-2);margin-top:5px}
  /* KPI mini row */
  #contenido-sub-news .kmini{display:flex;gap:9px;margin-bottom:14px}
  #contenido-sub-news .kmini .k{flex:1;border:1px solid var(--line);border-radius:11px;background:var(--navy-900);padding:10px 12px}
  #contenido-sub-news .kmini .k .n{font-family:'Space Grotesk';font-weight:700;font-size:18px;color:var(--acid)}
  #contenido-sub-news .kmini .k .l{font-size:9px;color:var(--muted-2);text-transform:uppercase;letter-spacing:.05em;margin-top:2px}
  /* lista de campañas */
  #contenido-sub-news .nw-sr{display:flex;align-items:flex-start;gap:9px;padding:11px 0;border-bottom:1px solid var(--line);font-size:12.5px}
  #contenido-sub-news .nw-sr:last-child{border-bottom:0}
  #contenido-sub-news .nw-sr .tt{font-weight:600;color:var(--text)}
  #contenido-sub-news .nw-sr .sub{font-size:10.5px;color:var(--muted-2);margin-top:2px}
  #contenido-sub-news .nw-sr .st2{margin-left:auto;font-size:10.5px;text-align:right;white-space:nowrap}
  #contenido-sub-news .nw-pill{font-size:9.5px;font-weight:700;border-radius:20px;padding:2px 8px;display:inline-block}
  #contenido-sub-news .nw-pill.ok{background:rgba(126,217,87,.15);color:var(--won)}
  #contenido-sub-news .nw-pill.warn{background:rgba(240,192,96,.15);color:var(--warn)}
  #contenido-sub-news .nw-sr.clickable{cursor:pointer}
  #contenido-sub-news .nw-sr.clickable:hover{background:color-mix(in srgb,var(--acid) 6%,transparent)}
  /* thumbnails picker (video/case/still) dentro del overlay */
  #contenido-sub-news .nw-pick{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:8px;max-height:360px;overflow-y:auto;margin-top:8px}
  .nw-pick-btn{border:1px solid var(--line);border-radius:9px;overflow:hidden;background:var(--navy-900);cursor:pointer;padding:0;text-align:left}
  .nw-pick-btn:hover{border-color:var(--acid)}
  .nw-pick-btn img{display:block;width:100%;aspect-ratio:16/9;object-fit:cover}
  .nw-pick-btn .cap{font-size:10.5px;color:var(--muted);padding:5px 7px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  /* input dentro de overlays del newsletter (fuera de #contenido-sub-news, no pueden usar .nw-inp scoped) */
  .nw-ov-inp{background:var(--navy-900);border:1px solid var(--line-strong);border-radius:10px;color:var(--text);font-family:inherit;font-size:14px;padding:10px 12px}
  .nw-ov-inp:focus{outline:none;border-color:var(--acid)}

  /* ---- rediseño tab Google Ads: veredicto, settings, pacing, search terms ---- */
  .warnbox{background:rgba(255,210,127,.08);border:1px solid rgba(255,210,127,.35);border-radius:12px;padding:12px 16px;font-size:13px;color:#ffd27f;margin-bottom:14px}
  :root[data-theme="light"] .warnbox{color:#8a5a00;background:rgba(255,180,60,.12);border-color:rgba(255,180,60,.5)}
  .gads-verdict{background:linear-gradient(135deg,color-mix(in srgb,var(--acid) 12%,transparent),color-mix(in srgb,var(--acid) 5%,transparent));border:1px solid var(--acid);border-radius:12px;padding:12px 16px;font-size:14px;margin:0}
  .gads-settings-pop{background:var(--navy-900);border:1px solid var(--line-strong);border-radius:12px;padding:14px 16px;margin:10px 0;display:flex;gap:16px;flex-wrap:wrap;align-items:flex-end}
  .gads-settings-pop .bf{margin:0;min-width:220px;flex:1}
  #ana-sub-gads .bf label{display:block;font-size:12.5px;font-weight:600;color:var(--muted);margin-bottom:6px}
  #ana-sub-gads .bf input{width:100%;background:var(--navy-800);border:1px solid var(--line-strong);border-radius:11px;color:var(--text);font-family:inherit;font-size:14.5px;padding:11px 13px}
  .gads-two{display:grid;grid-template-columns:1.3fr 1fr;gap:14px;margin-top:14px;align-items:start}
  @media(max-width:900px){.gads-two{grid-template-columns:1fr}}
  .gads-pace b{font-size:13.5px}
  .gads-pacebar{height:10px;background:var(--navy-900);border-radius:999px;border:1px solid var(--line);overflow:hidden;margin:9px 0 5px}
  .gads-pacebar i{display:block;height:100%;background:var(--acid);transition:width .3s}
  .gads-pacebar i.over{background:#ff8b8b}
  .gads-sem{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:7px;flex:none}
  .gads-sem.ok{background:#7ed957}.gads-sem.mid{background:#ffd27f}.gads-sem.bad{background:#ff8b8b}
  .gads-roas-ok{color:#7ed957;font-weight:800}
  .gads-roas-bad{color:#ff8b8b;font-weight:800}
  .gads-negflag{color:#ff8b8b;font-size:12px;white-space:nowrap}
  .gads-okflag{color:#7ed957;font-size:12px;white-space:nowrap}
  .gads-spark-svg{width:100%;height:64px;display:block;overflow:visible}
  .gads-camp-acts{display:flex;gap:4px;justify-content:flex-end}
  .gads-camp-acts button{background:transparent;border:1px solid var(--line-strong);border-radius:8px;color:var(--muted);font-size:12px;padding:4px 7px;cursor:pointer;line-height:1}
  .gads-camp-acts button:hover{border-color:var(--acid);color:var(--acid)}
  .gads-lead-x{background:transparent;border:1px solid var(--line-strong);border-radius:8px;color:var(--muted);font-size:11px;padding:4px 8px;cursor:pointer;white-space:nowrap}
  .gads-lead-x:hover{border-color:var(--acid);color:var(--acid)}

  /* ---- rediseño sub-tab Search Console: oportunidades de CTR, tendencia, canibalización, indexación ---- */
  #contenido-sub-seo .seo-money{color:var(--acid);font-weight:700;white-space:nowrap}
  #contenido-sub-seo .up{color:#7ed957;font-weight:700}
  #contenido-sub-seo .down{color:#ff8b8b;font-weight:700}
  #contenido-sub-seo .seo-okline{color:#7ed957;font-size:13px;margin-bottom:4px}
  #contenido-sub-seo .seo-warnline{color:#f0c060;font-size:13px;margin-bottom:4px}
  #contenido-sub-seo .seo-badline{color:#ff8b8b;font-size:13px;margin-bottom:4px}
