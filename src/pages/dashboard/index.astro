  /* ---------- Ventana de tiempo (filtro global) ---------- */
  let rangeDays = 30;      // preset: 1 / 7 / 30 / 90 / 365
  let rangeDay = null;     // 'YYYY-MM-DD' → un día puntual (pisa el preset)
  const rangeStart = () => rangeDay ? new Date(rangeDay + 'T00:00:00').getTime() : Date.now() - rangeDays * 864e5;
  const rangeEnd = () => rangeDay ? new Date(rangeDay + 'T23:59:59.999').getTime() : Date.now();
  const inRange = (d) => { const t = new Date(d).getTime(); return t >= rangeStart() && t <= rangeEnd(); };
  const rangeLabel = () => rangeDay
    ? new Date(rangeDay + 'T00:00:00').toLocaleDateString('es-CH', { day: '2-digit', month: 'long', year: 'numeric' })
    : (rangeDays === 1 ? 'Hoy' : 'Últimos ' + rangeDays + ' días');
  // nº de días que muestra el gráfico diario (acotado para que el SVG no explote)
  const rangeSpanDays = () => rangeDay ? 1 : rangeDays;
  const since = () => new Date(rangeStart()).toISOString();
  const until = () => new Date(rangeEnd()).toISOString();

  // Supabase/PostgREST cappea cada response a un máximo de filas (Max Rows del
  // proyecto) SIN avisar, aunque el cliente pida .limit(20000) — un .select()
  // sin paginar sobre una tabla que ya superó ese tope devuelve un subconjunto
  // arbitrario (no hay .order()) y todo lo que se cuenta desde ahí (sesiones,
  // canales, páginas) queda subestimado en silencio. Paginar con .range() +
  // .order() es la única forma de traer TODAS las filas del rango.
  async function fetchAllRows(table, cols, sinceIso, untilIso, dateCol){
    dateCol = dateCol || 'created_at';
    const PAGE = 1000;
    let all = [], from = 0;
    for (;;) {
      const { data, error } = await supabase.from(table).select(cols)
        .gte(dateCol, sinceIso).lte(dateCol, untilIso)
        .order(dateCol, { ascending: true })
        .range(from, from + PAGE - 1);
      if (error) return { data: null, error };
      all = all.concat(data || []);
      if (!data || data.length < PAGE) break;
      from += PAGE;
      if (from > 200000) break; // salvavidas: nunca debería llegar acá
    }
    return { data: all, error: null };
  }

  async function loadAll(){
    const [leadsQ, viewsQ, videosQ, offersQ, coQ, notesQ, tasksQ, propsQ, dealsQ, bookQ] = await Promise.all([
      supabase.from('leads').select('*').order('created_at', { ascending: false }).limit(2000),
      fetchAllRows('pageviews', 'created_at,path,device,session_id,channel,referrer,lang,is_entry,duration', since(), until()),
      fetchAllRows('video_plays', '*', since(), until()),
      supabase.from('offers').select('*').order('updated_at', { ascending: false }),
      supabase.from('companies').select('*'),
      // para "última actividad" (best-effort: si faltan las tablas, queda vacío)
      supabase.from('lead_notes').select('lead_id,created_at').order('created_at', { ascending: false }).limit(1000),
      supabase.from('lead_tasks').select('lead_id,created_at,done_at').order('created_at', { ascending: false }).limit(1000),
      supabase.from('proposals').select('*').limit(1000),
      supabase.from('deals').select('*').order('created_at', { ascending: false }),
      supabase.from('bookings').select('*').gte('start_at', new Date().toISOString()).eq('status', 'confirmed').order('start_at').limit(8)
    ]);
    if (leadsQ.error || viewsQ.error) {
      alert('Error cargando datos: ' + (leadsQ.error || viewsQ.error).message);
      return;
    }
    allLeads = leadsQ.data || [];
    window.__vvLoadedAt = Date.now();
    lastViews = viewsQ.data || [];
    // ofertas: best-effort (si no corrió el SQL 0003 todavía, seguimos sin romper el dashboard)
    if (offersQ && !offersQ.error) offersList = offersQ.data || [];
    // DEALS (SQL 0022): la entidad REAL del pipeline (varios proyectos por persona).
    // Sin la tabla → 1 deal sintético por persona (modo legado, mismo comportamiento).
    upBookings = (bookQ && !bookQ.error) ? (bookQ.data || []) : [];
    dealsReal = !!(dealsQ && !dealsQ.error);
    dealsList = dealsReal ? (dealsQ.data || []) : [];
    const _withDeal = new Set(dealsList.map((d) => String(d.lead_id)));
    allLeads.forEach((l) => { if (!_withDeal.has(String(l.id))) dealsList.push(synthDeal(l)); });
    // companies: best-effort (si no corrió el SQL 0011, coMeta queda vacío)
