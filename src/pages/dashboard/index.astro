  const PP_BLOCKS = [
    ['intro', '✉️ Carta intro'], ['overview', '🎯 Overview'], ['photo1', '🖼 Foto separador'], ['scope', '🔧 Scope'],
    ['tiers', '💎 Paquetes'], ['addons', '➕ Add-ons'], ['terms', '📜 Términos'], ['call', '📅 Book a call'],
    ['testimonial', '⭐ Testimonial + video'], ['videos', '🎬 Trabajos'],
