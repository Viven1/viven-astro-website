      // spam queda afuera de todas las vistas salvo que se pida explícitamente
      // (psStage==='spam') — "para que quede mas limpio" (pedido de Sebastián)
      const isSpam = /^spam$/i.test(r.status || '');
      if (isSpam && psStage !== 'spam') return false;
      if (!isSpam && psStage === 'spam') return false;
      if (!inRange(r.created_at)) return false;
      if (statusFilter === 'new' && !isNew(r.status)) return false;
      if (statusFilter === 'contacted' && !(r.status === 'contacted' || r.status === 'contactado')) return false;
      if (statusFilter === 'won' && !(r.status === 'won' || r.status === 'cerrado')) return false;
      if (channelFilter && (r.channel || 'direct') !== channelFilter) return false;
      if (landingFilter && (r.landing_path || '(sin dato)') !== landingFilter) return false;
      if (searchTerm) {
        const hay = ((r.name || '') + ' ' + (r.email || '') + ' ' + (r.message || '') + ' ' + (r.company || '') + ' ' + (companyName(leadDomain(r)) || '')).toLowerCase();
        if (hay.indexOf(searchTerm) === -1) return false;
      }
      return true;
    });
  }

  function renderLeads(){
    /* leads dentro de la ventana de tiempo seleccionada */
    const viewLeads = allLeads.filter((r) => inRange(r.created_at));
    $('kl-total').textContent = allLeads.length;                       // histórico
    $('tab-leads-count').textContent = allLeads.filter((r) => isNew(r.status)).length; // sin contactar SIEMPRE (accionable)
    $('kl-week').textContent = viewLeads.length;                       // en el período
    $('kl-week-l').textContent = rangeDay ? rangeLabel() : 'En el período (' + rangeLabel().toLowerCase() + ')';
    $('kl-new').textContent = viewLeads.filter((r) => isNew(r.status)).length;
    $('kl-ads').textContent = viewLeads.filter((r) => r.gclid).length;

    /* estado del pipeline + follow-ups — sobre los leads del período */
    /* usa la MISMA clasificación que el pipeline (stageOf) — si no, un lead arrastrado
       a "Ganado" queda con status 'ganado' y el KPI won ('won'/'cerrado') no lo contaba */
    const byStage = (k) => viewLeads.filter((r) => stageOf(r.status) === k).length;
    const contacted = byStage('contactado');
    const won = byStage('ganado');
    const lost = byStage('perdido');
    const decided = won + lost;
    const in7 = Date.now() + 7 * 864e5;
    const followWeek = allLeads.filter((r) => r.next_follow_up_at && new Date(r.next_follow_up_at).getTime() <= in7).length;
    $('kl-contacted').textContent = contacted;
    $('kl-won').textContent = won;
    $('kl-lost').textContent = lost;
    /* conversión = ganados sobre los ya decididos (ganado+perdido); más honesto que sobre el total */
    $('kl-convrate').innerHTML = decided ? (won / decided * 100).toFixed(0) + '<small>%</small>' : '–';
    $('kl-followup').textContent = followWeek;

    /* color-coding: ganados verde, perdidos rojo, el resto neutro (blanco) */
    ['kl-total', 'kl-week', 'kl-new', 'kl-ads', 'kl-contacted', 'kl-convrate', 'kl-followup'].forEach((id) => { $(id).style.color = 'var(--text)'; });
    $('kl-won').style.color = won ? '#7ed957' : 'var(--text)';
    $('kl-lost').style.color = lost ? '#ff6b6b' : 'var(--text)';

    renderFunnel(viewLeads);
    renderPeopleList();  // Personas (lista)
    renderPipeline();    // Deals (board)
  }
  // Personas: tabla de gente (lista) con filtro de etapa + orden por columna
  function renderPeopleList(){
    const cont = $('leads-list'); if (!cont) return;
    let rows = filteredLeads();
    // 'spam' no es una etapa del pipeline (stageOf nunca la devuelve) — filteredLeads()
    // ya separó spam/no-spam por r.status directo, acá no hay que filtrar de nuevo
    if (psStage !== 'all' && psStage !== 'spam') rows = rows.filter((r) => stageOf(r.status) === psStage);
    if (psAct !== 'all') rows = rows.filter((r) => (lastActivity(r) || {}).kind === psAct);
    const chNote = channelFilter ? '<p class="muted-note" style="margin-bottom:8px">Filtrado por canal: <b>' + esc(channelFilter) + '</b> · <a href="#" id="ps-clear-channel" style="color:var(--acid)">quitar filtro</a></p>' : '';
    const lpNote = landingFilter ? '<p class="muted-note" style="margin-bottom:8px">Filtrado por página de entrada: <b>' + esc(landingFilter) + '</b> · <a href="#" id="ps-clear-landing" style="color:var(--acid)">quitar filtro</a></p>' : '';
    cont.innerHTML = chNote + lpNote + leadsListHTML(rows);
    const clearCh = $('ps-clear-channel'); if (clearCh) clearCh.addEventListener('click', (ev) => { ev.preventDefault(); channelFilter = null; renderPeopleList(); });
    const clearLp = $('ps-clear-landing'); if (clearLp) clearLp.addEventListener('click', (ev) => { ev.preventDefault(); landingFilter = null; renderPeopleList(); });
    cont.querySelectorAll('.lead-table tbody tr').forEach((tr) => tr.addEventListener('click', () => openLead(tr.dataset.id)));
    bindPsSelection(); updatePsDelBtn();
    cont.querySelectorAll('.lead-table th[data-k]').forEach((th) => th.addEventListener('click', () => {
      const k = th.dataset.k;
      if (psSort.k === k) psSort.dir *= -1;
      else psSort = { k, dir: (k === 'name' || k === 'channel') ? 1 : -1 };
      renderPeopleList();
    }));
  }
  $('ps-stage').addEventListener('change', (e) => { psStage = e.target.value; renderPeopleList(); });
  $('seo-reload') && $('seo-reload').addEventListener('click', loadSeo);
  $('ps-act').addEventListener('change', (e) => { psAct = e.target.value; renderPeopleList(); });

  /* ---------- HOME "Hoy": centro de comando accionable (KPIs + Para hoy + señales + agenda/ads/IA) ----------
     Caches en módulo: loadAll corre cada 2 min y re-llama renderHome — sin estos TTLs cada
     render dispararía fetches nuevos (sparkline, gads-stats, IA) y martillaría las APIs. */
  let hmViews60 = null, hmViews60At = 0, hmViews60Busy = false;   // pageviews 60d: sparkline semanal + KPI visitas
  let hmAds = null, hmAdsBusy = false;                            // gasto de Ads: gads-stats 1 sola vez por día
  let hmAiTried = false, hmTodayCur = [], hmSigCur = [];
  // Agenda: 'mine' filtra por host_email===meEmail (default para todos, incluida Sofia).
  // Solo superadmin puede pasar a 'all' para overview — sin esto, todos veían las
  // reuniones de todo el equipo mezcladas (reporte: "asi uno se confunde y toca la equivocada").
  let hmAgendaScope = 'mine';
  const HM_AI_LS = 'vv_home_ai', HM_ADS_LS = 'vv_home_gads';

  // KPIs de deals con las MISMAS fórmulas que el board (renderPipeline) — números idénticos en todos lados
  function hmDealKpis(){
    const now = Date.now(), D = 864e5;
    const all = (dealsList || []).filter((d) => !d.archived);
    const open = all.filter((d) => DL_OPEN.includes(stageOf(d.stage)));
    const weighted = open.reduce((a, d) => a + dealValue(d) * ((STAGES.find((s) => s.key === stageOf(d.stage)) || {}).prob || 0), 0);
    const wonAge = (d) => { const t = Date.parse(d.won_at || d.last_stage_at || ''); return t ? now - t : Infinity; };
    const wonAll = all.filter((d) => stageOf(d.stage) === 'ganado');
    const won30 = wonAll.filter((d) => wonAge(d) <= 30 * D);
    const won3060 = wonAll.filter((d) => { const a = wonAge(d); return a > 30 * D && a <= 60 * D; });
    const won90 = wonAll.filter((d) => wonAge(d) <= 90 * D).length;
    const lost90 = all.filter((d) => { if (stageOf(d.stage) !== 'perdido') return false; const t = Date.parse(d.lost_at || d.last_stage_at || ''); return t && now - t <= 90 * D; }).length;
    const dec90 = won90 + lost90;
    return { openVal: dealsValue(open), openN: open.length, weighted, won30Val: dealsValue(won30), prev30Val: dealsValue(won3060),
      winRate: dec90 ? Math.round(won90 / dec90 * 100) : null, won90, dec90 };
  }

  /* ======= ROAS de Ads: CÁLCULO CANÓNICO ÚNICO (Home + Analytics·Google Ads) =======
     Antes había 3 implementaciones que podían contradecirse: esta (Home), la del
     tab de Ads (fetch propio a `leads` + won leído directo de leads.status/deal_value,
     sin pasar por dealsList/dealValue) y, implícitamente, ads-conversions-sync.
     Ahora TODO el frontend usa esta única función: lead con gclid (limpio de
     tests/spam/exclusión manual) → su deal, con la MISMA regla de valor que el
     pipeline (dealValue: ofertas ganadas > ofertas abiertas > deal_value crudo).
     `offsetDays` corre la ventana hacia atrás para poder comparar vs el período
     anterior (mismo patrón que setDelta/renderAnalytics). */
  const ADS_LEAD_TEST_RE = /@viven\.ch$|@entropia|@example\.|test/i;
  const adsLeadOk = (r) => !!r.gclid && !r.ads_exclude && !ADS_LEAD_TEST_RE.test(r.email || '') && !/spam|descartado|perdido-spam/i.test(r.status || '');
  function adsRoasFor(days, offsetDays){
    const end = Date.now() - (offsetDays || 0) * 864e5, win = (days || 30) * 864e5, start = end - win;
    const inWin = (iso) => { const t = Date.parse(iso || ''); return t && t > start && t <= end; };
    const leads = (allLeads || []).filter((r) => adsLeadOk(r) && inWin(r.created_at));
    const gset = new Set(leads.map((r) => String(r.id)));
    const leadFor = (d) => leads.find((r) => String(r.id) === String(d.lead_id));
    const won = (dealsList || []).filter((d) => !d.archived && gset.has(String(d.lead_id)) && stageOf(d.stage) === 'ganado' && inWin(d.won_at || d.last_stage_at));
    const openDeals = (dealsList || []).filter((d) => !d.archived && gset.has(String(d.lead_id)) && DL_OPEN.includes(stageOf(d.stage)));
    const wonVal = won.reduce((a, d) => a + dealValue(d), 0);
    const openVal = openDeals.reduce((a, d) => a + dealValue(d), 0);
    // desglose por campaña (utm_campaign del lead) — para la tabla merge Google+CRM
    const byCamp = {};
    const campOf = (l) => (l && l.utm_campaign) || '(sin campaña)';
    leads.forEach((r) => { const c = campOf(r); byCamp[c] = byCamp[c] || { leads: 0, won: 0, wonVal: 0, openVal: 0 }; byCamp[c].leads++; });
    won.forEach((d) => { const c = campOf(leadFor(d)); byCamp[c] = byCamp[c] || { leads: 0, won: 0, wonVal: 0, openVal: 0 }; byCamp[c].won++; byCamp[c].wonVal += dealValue(d); });
    openDeals.forEach((d) => { const c = campOf(leadFor(d)); byCamp[c] = byCamp[c] || { leads: 0, won: 0, wonVal: 0, openVal: 0 }; byCamp[c].openVal += dealValue(d); });
    return { days: days || 30, leads, won, wonVal, openVal, byCamp };
  }
  // compat: Home usa esta forma reducida hace tiempo — misma fuente canónica ahora
  function hmAdsStats(){
    const r = adsRoasFor(30, 0);
    return { leads: r.leads.length, wonVal: r.wonVal, wonN: r.won.length };
  }

  // "🎯 Para hoy": UNA lista por urgencia — cada fila sabe abrir lo suyo (openLead/openOffer/gotoTab)
  function hmTodayItems(){
    const now = Date.now(), D = 864e5, items = [];
    const busyLeads = new Set();   // leads ya cubiertos por (a)/(b): no repetir al mismo cliente en (c)
    // (a) ofertas enviadas esperando >10d (si abrió el email hace poco → seguir HOY)
    (offersList || []).filter((o) => !o.archived && !o.is_template && o.status === 'sent').forEach((o) => {
      const ref = Date.parse(o.sent_at || o.updated_at); if (!ref) return;
      const days = Math.floor((now - ref) / D); if (days <= 10) return;
      const l = leadById(o.lead_id) || {};
      const opened = o.last_open_at && (now - Date.parse(o.last_open_at)) < 2 * D;
      if (o.lead_id) busyLeads.add(String(o.lead_id));
      items.push({ rank: opened ? -1 : 0, sev: 'rojo', icon: '🧾', at: ref,
        t: o.title || ('Oferta ' + (o.number || '#' + o.id)),
        ctx: [l.name || l.email || o.client || '', 'esperando hace ' + days + ' d'].filter(Boolean).join(' · ') +
          (opened ? ' · abrió el email hace ' + timeAgo(o.last_open_at) + ' → seguir HOY' : ''),
        hint: 'Follow-up →', go: () => { gotoTab('offers'); openOffer(o.id); } });
    });
    // (b) propuestas publicadas: >8d sin respuesta (rojo) / >2d con 0 vistas (azul: ¿le llegó el link?)
    (propsAll || []).filter((p) => !p.archived && !p.is_template && p.status === 'sent').forEach((p) => {
      const ref = Date.parse(p.published_at || p.updated_at); if (!ref) return;
      const days = Math.floor((now - ref) / D);
      const l = leadById(p.lead_id) || {};
      const goP = p.lead_id ? () => openLead(p.lead_id) : () => gotoTab('props');
      if (days > 8){
        if (p.lead_id) busyLeads.add(String(p.lead_id));
        items.push({ rank: 1, sev: 'rojo', icon: '🌐', at: ref, t: p.title || 'Propuesta',
          ctx: [l.name || l.email || '', 'publicada hace ' + days + ' d sin respuesta'].filter(Boolean).join(' · '),
          hint: 'Follow-up →', go: goP });
      } else if (days > 2 && !p.last_view_at){
        items.push({ rank: 5, sev: 'azul', icon: '👁', at: ref, t: p.title || 'Propuesta',
          ctx: [l.name || l.email || '', 'publicada hace ' + days + ' d · 0 vistas — ¿le llegó el link?'].filter(Boolean).join(' · '),
          hint: 'Reenviar →', go: goP });
      }
    });
    // (c) deals estancados >14d SIN próximo paso — solo con el cache de tasks ya cargado
    //     (si no, marcaría "sin próximo paso" a todos en el primer render)
    if (dlTasksAt){
      (dealsList || []).filter((d) => !d.archived && DL_OPEN.includes(stageOf(d.stage))).forEach((d) => {
        const days = dealStageDays(d); if (days <= 14) return;
        if (busyLeads.has(String(d.lead_id))) return;
        const r = leadById(d.lead_id) || {};
        if (dlTasksMap[String(d.lead_id)] || r.next_follow_up_at) return;
        const stLabel = (STAGES.find((s) => s.key === stageOf(d.stage)) || {}).label || '';
        items.push({ rank: 2, sev: 'rojo', icon: '🤝', at: now - days * D, t: d.title || r.name || r.email || '(deal)',
          ctx: days + ' d en ' + stLabel + ' · sin próximo paso',
          hint: 'Definir paso →', go: () => (d.lead_id ? openLead(d.lead_id) : gotoTab('deals')) });
      });
    }
    // (d) leads nuevos sin contactar <72h (los manuales los cargamos nosotros — no urgen)
    (allLeads || []).filter((l) => !/^claude-/.test(l.session_id || '') && isNew(l.status) && l.channel !== 'manual' && (now - Date.parse(l.created_at)) < 72 * 36e5).forEach((l) => {
      items.push({ rank: 3, sev: 'ambar', icon: '📥', at: Date.parse(l.created_at), t: l.name || l.email || '(lead)',
        ctx: 'lead nuevo hace ' + timeAgo(l.created_at) + ' · sin contactar', hint: 'Contactar →', go: () => openLead(l.id) });
    });
    // (e) tasks para hoy o vencidas, mías o sin asignar (mismo criterio que la campana)
    if (dlTasksAt){
      const t0 = new Date(); t0.setHours(0, 0, 0, 0);
      const tEnd = t0.getTime() + D;
      const mine = (t) => !meEmail || !t.assignee || String(t.assignee).toLowerCase() === meEmail;
      Object.keys(dlTasksMap).forEach((lid) => {
        const t = dlTasksMap[lid];
        if (!t || !t.due_date || !mine(t)) return;
        const due = new Date(t.due_date + 'T' + (t.due_time || '23:59') + ':00').getTime();
        if (!(due < tEnd)) return;   // hoy o vencida
        const overdue = due < (t.due_time ? now : t0.getTime());
        const l = leadById(lid) || {};
        items.push({ rank: 4, sev: 'ambar', icon: '✅', at: due, t: t.title,
          ctx: [l.name || l.email || '', (overdue ? 'vencida' : 'para hoy') + (t.due_time ? ' · ' + t.due_time : '')].filter(Boolean).join(' · '),
          hint: 'Hacer →', go: () => openLead(lid) });
      });
    }
    return items.sort((a, b) => (a.rank - b.rank) || (a.at - b.at));
  }

  // "🔥 Señales calientes": aperturas de propuesta/oferta <48h + leads conocidos que volvieron a la web <24h
  function hmSignalItems(){
    const now = Date.now(), H48 = 48 * 36e5, sig = [];
    (propsAll || []).filter((p) => !p.archived && !p.is_template && p.last_view_at && now - Date.parse(p.last_view_at) < H48).forEach((p) => {
      const l = leadById(p.lead_id) || {};
      const who = l.name || l.email || 'Alguien';
      const nth = Number(p.view_count) > 1 ? ' · ' + p.view_count + 'ª vista' : '';
      sig.push({ at: Date.parse(p.last_view_at), icon: '🌐', lead: p.lead_id, t: who + ' abrió la propuesta',
        ctx: (p.title || '(sin título)') + ' · hace ' + timeAgo(p.last_view_at) + nth,
        plain: who + ' abrió la propuesta «' + (p.title || '') + '» hace ' + timeAgo(p.last_view_at) });
    });
    (offersList || []).filter((o) => !o.archived && !o.is_template && o.last_open_at && now - Date.parse(o.last_open_at) < H48).forEach((o) => {
      const l = leadById(o.lead_id) || {};
      const who = l.name || l.email || o.client || 'Alguien';
      sig.push({ at: Date.parse(o.last_open_at), icon: '🧾', lead: o.lead_id, t: who + ' abrió el email de la oferta',
        ctx: (o.title || o.number || '(sin título)') + ' · hace ' + timeAgo(o.last_open_at),
        plain: who + ' abrió el email de la oferta «' + (o.title || '') + '» hace ' + timeAgo(o.last_open_at) });
    });
    // web: sesiones de lastViews que pertenecen al session_id de un lead conocido (últimas 24h)
    const byS = {}; (allLeads || []).forEach((l) => { if (l.session_id && !/^claude-/.test(l.session_id)) byS[l.session_id] = l; });
    const acc = {};
    (lastViews || []).forEach((v) => {
      const l = v.session_id && byS[v.session_id]; if (!l) return;
      const t = Date.parse(v.created_at); if (!t || now - t > 864e5) return;
      const k = String(l.id); acc[k] = acc[k] || { l, n: 0, at: 0 };
      acc[k].n++; if (t > acc[k].at) acc[k].at = t;
    });
    Object.values(acc).forEach((c) => {
      const who = c.l.name || c.l.email || 'Un contacto';
      sig.push({ at: c.at, icon: '👀', lead: c.l.id, t: who + ' volvió a la web',
        ctx: c.n + ' página' + (c.n === 1 ? '' : 's') + ' · hace ' + timeAgo(new Date(c.at).toISOString()),
        plain: who + ' volvió a la web (' + c.n + ' páginas) hace ' + timeAgo(new Date(c.at).toISOString()) });
    });
    return sig.sort((a, b) => b.at - a.at);
  }

  function hmRenderToday(items){
    const box = $('hm-today'); if (!box) return;
    hmTodayCur = items;
    box.innerHTML = items.slice(0, 8).map((it, i) =>
      '<button class="hm-item ' + it.sev + '" type="button" data-i="' + i + '">' +
      '<span class="ic">' + it.icon + '</span>' +
      '<span class="tx"><b>' + esc(it.t) + '</b><small>' + esc(it.ctx) + '</small></span>' +
      '<span class="go">' + it.hint + '</span></button>'
    ).join('') || '<p class="muted-note">Todo al día 🎉</p>';
    if (items.length > 8) box.innerHTML += '<button class="hm-more" id="hm-today-more" type="button">ver todo (' + items.length + ') →</button>';
    box.querySelectorAll('.hm-item').forEach((b) => b.addEventListener('click', () => { const it = hmTodayCur[+b.dataset.i]; if (it && it.go) it.go(); }));
    const more = $('hm-today-more'); if (more) more.addEventListener('click', () => gotoTab('deals'));
  }

  function hmRenderSignals(){
    const box = $('hm-signals'); if (!box) return;
    hmSigCur = hmSignalItems();
    box.innerHTML = hmSigCur.slice(0, 8).map((s, i) =>
      '<button class="hm-item hot" type="button" data-i="' + i + '">' +
      '<span class="ic">' + s.icon + '</span>' +
      '<span class="tx"><b>' + esc(s.t) + '</b><small>' + esc(s.ctx) + '</small></span>' +
      '<span class="go">Abrir →</span></button>'
    ).join('') || '<p class="muted-note">Sin señales por ahora — acá aparecen aperturas de ofertas y propuestas y visitas a la web de contactos conocidos (tracking).</p>';
    box.querySelectorAll('.hm-item').forEach((b) => b.addEventListener('click', () => { const s = hmSigCur[+b.dataset.i]; if (s && s.lead) openLead(s.lead); }));
  }

  function hmRenderAgenda(){
    const box = $('hm-agenda'); if (!box) return;
    const seg = $('hm-agenda-seg');
    // el toggle Mías/Todas solo existe para superadmin — cualquier otra persona
    // (Sofia incluida) siempre queda forzada a 'mine', sin opción de ver la ajena
    if (seg){
      if (!isSuperadmin){ seg.innerHTML = ''; hmAgendaScope = 'mine'; }
      else {
        seg.innerHTML = ['mine', 'all'].map((k) =>
          '<button type="button" data-k="' + k + '" class="' + (hmAgendaScope === k ? 'on' : '') + '">' + (k === 'mine' ? 'Mías' : 'Todas') + '</button>').join('');
        seg.querySelectorAll('button').forEach((b) => b.addEventListener('click', () => { hmAgendaScope = b.dataset.k; hmRenderAgenda(); }));
      }
    }
    const lim = Date.now() + 7 * 864e5;
    const mine = (b) => (b.host_email || '').toLowerCase() === (meEmail || '').toLowerCase();
    const rows = (upBookings || []).filter((b) => Date.parse(b.start_at) <= lim && (hmAgendaScope === 'all' ? true : mine(b)));
    box.innerHTML = rows.map((b) => {
      const dt = new Date(b.start_at);
      const when = dt.toLocaleDateString('es-CH', { weekday: 'short', day: '2-digit', month: 'short' }) + ' · ' + dt.toLocaleTimeString('es-CH', { hour: '2-digit', minute: '2-digit' });
      // el badge de host solo aparece en la vista "Todas" — en "Mías" es redundante (ya sabés que son tuyas)
      const hostBadge = (hmAgendaScope === 'all' && b.host_email) ? '<span class="hc-host">' + esc(teamName(b.host_email).split(/\s+/)[0] || b.host_email) + '</span>' : '';
      return '<div class="hatt-call">' +
        '<span class="hc-when">📅 ' + esc(when) + '</span>' +
        '<button class="hc-who" type="button"' + (b.lead_id ? ' data-lead="' + esc(String(b.lead_id)) + '"' : '') + '>' + esc(b.name || b.email) + '</button>' +
        hostBadge +
        '<span class="hc-dur">' + (b.duration_m || 15) + ' min</span>' +
        (b.meet_url ? '<a class="hc-meet" href="' + esc(b.meet_url) + '" target="_blank" rel="noopener">Meet ↗</a>' : '') +
      '</div>';
    }).join('') || '<p class="muted-note">' + (hmAgendaScope === 'all' ? 'Sin video calls del equipo en los próximos 7 días.' : 'Sin video calls tuyos en los próximos 7 días.') + '</p>';
    box.querySelectorAll('.hc-who[data-lead]').forEach((b) => b.addEventListener('click', () => openLead(b.dataset.lead)));
  }

  // Video calls booked por persona, 30 días (pedido explícito: "en algún lugar tenemos que
  // trackear la cantidad de video calls booked per person, tmb es muy importante para los
  // steps"). Cuenta por host_email de bookings.created_at (cuándo se hizo la reserva).
  // Sofia (member) ve solo su propio número; superadmin ve el desglose de todo el equipo.
  function hmRenderCalls(){
    const box = $('hm-calls'); if (!box) return;
    const counts = {};
    (bookingsHist || []).forEach((b) => { const e = (b.host_email || '').toLowerCase(); if (!e) return; counts[e] = (counts[e] || 0) + 1; });
    if (!isSuperadmin){
      const mine = counts[(meEmail || '').toLowerCase()] || 0;
      box.innerHTML = '<div class="kpi" style="border:0;background:none;padding:0"><div class="n">' + mine + '</div><div class="l">video calls agendadas por vos</div></div>';
      return;
    }
    const emails = Object.keys(counts);
    if (!emails.length){ box.innerHTML = '<p class="muted-note">Sin video calls agendadas en los últimos 30 días.</p>'; return; }
    const total = emails.reduce((a, e) => a + counts[e], 0);
    const max = Math.max(1, ...emails.map((e) => counts[e]));
    const rows = emails.sort((a, b) => counts[b] - counts[a]).map((e) => {
      const pct = Math.round(counts[e] / max * 100);
      return '<div class="bar-row"><span class="lbl">' + esc(teamName(e) || e) + '</span><div class="track"><div class="fill" style="width:' + pct + '%"></div></div><span class="val">' + counts[e] + '</span></div>';
    }).join('');
    box.innerHTML = '<div class="bars">' + rows + '</div><p class="muted-note" style="margin-top:8px">Total equipo: ' + total + '</p>';
  }

  // sparkline: 8 semanas ISO (lunes a lunes), última barra = semana en curso (ácida)
  function hmRenderSpark(){
    const box = $('hm-spark'), cap = $('hm-spark-cap'); if (!box) return;
    if (!hmViews60){ box.innerHTML = ''; if (cap) cap.textContent = 'cargando…'; return; }
    const w0 = (() => { const x = new Date(); x.setHours(0, 0, 0, 0); x.setDate(x.getDate() - (x.getDay() + 6) % 7); return x.getTime(); })();
    const b = Array(8).fill(0);
    hmViews60.forEach((v) => {
      const t = Date.parse(v.created_at); if (!t) return;
      const i = 7 + Math.floor((t - w0) / (7 * 864e5));   // 7 = semana actual, 0 = hace 7 semanas
      if (i >= 0 && i <= 7) b[i]++;
    });
    const max = Math.max(1, ...b);
    box.innerHTML = b.map((n, i) => '<i class="' + (i === 7 ? 'on' : '') + '" style="height:' + Math.max(4, Math.round(n / max * 100)) + '%" title="' + n + ' vistas"></i>').join('');
    if (cap) cap.textContent = 'esta semana: ' + b[7].toLocaleString('de-CH');
  }

