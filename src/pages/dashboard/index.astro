---
// pool de fotos reales (stills de rodajes) para elegir los separadores de una propuesta
import projects from '../../data/projects.json';
const stillsPool = projects
  .filter((p) => p.lang === 'en' && Array.isArray(p.stills) && p.stills.length)
  .map((p) => ({ client: p.client || p.headline || 'Project', stills: p.stills }));
---
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<title>Viven — Dashboard</title>
<!-- Página privada: fuera de buscadores y del sitemap -->
<meta name="robots" content="noindex,nofollow" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="theme-color" content="#0f1826" />
<!-- App móvil: instalable desde Safari → Compartir → "Añadir a pantalla de inicio" -->
<link rel="manifest" href="/dashboard.webmanifest" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="Viven CRM" />
<link rel="apple-touch-icon" href="/assets/crm-icon.png" />
<link rel="preload" as="font" type="font/woff2" href="/assets/fonts/sg-var.woff2" crossorigin />
<link rel="preload" as="font" type="font/woff2" href="/assets/fonts/inter-var.woff2" crossorigin />
<link rel="stylesheet" href="/assets/site.css" />
<script is:inline>
  // aplicar el tema guardado ANTES del primer render (sin flash)
  try { var t = localStorage.getItem('viven_theme'); if (t === 'light') document.documentElement.dataset.theme = 'light'; } catch (e) {}
</script>
<style is:global>
  /* Tema del dashboard: dark = el navy de siempre (site.css). bright = gris claro
     estilo Claude Code, más descansado de día. Se alterna con el botón ◐ y persiste. */
  :root[data-theme="light"]{
    --navy-900:#faf9f5;   /* fondo (gris cálido claro) */
    --navy-800:#ffffff;   /* tarjetas / paneles */
    --navy-700:#f0efea;   /* elementos elevados */
    --navy-600:#e2e1db;   /* hover / bordes fuertes */
    --line:rgba(20,25,35,.09);
    --line-strong:rgba(20,25,35,.18);
    --text:#1f2430;
    --muted:#5b6472;
    --muted-2:#8a919e;
    --acid:#5f7a12;       /* verde marca oscurecido: legible sobre blanco */
    --acid-dim:#4e650f;
  }
  :root[data-theme="light"] body{background:var(--navy-900);color:var(--text)}
  /* botones/pills con fondo acid: en claro usar el verde de marca real con texto oscuro */
  :root[data-theme="light"] .btn-primary,
  :root[data-theme="light"] .lead-form button[type="submit"],
  :root[data-theme="light"] .toolbar .fpill.active,
  :root[data-theme="light"] .vt-btn.active{background:#dff28b;border-color:#dff28b;color:#1c2508}
  .dash-wrap{max-width:1220px;margin:0 auto;padding:32px 24px 80px}
  .bell-wrap{position:relative}
  .bell-btn{position:relative;background:var(--navy-800);border:1px solid var(--line-strong);color:var(--text);width:38px;height:38px;border-radius:10px;font-size:17px;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1}
  .bell-btn:hover{border-color:var(--acid)}
  .bell-badge{position:absolute;top:-6px;right:-6px;min-width:18px;height:18px;padding:0 4px;border-radius:9px;background:#ff5a5a;color:#fff;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;box-shadow:0 0 0 2px var(--navy-900)}
  .bell-panel{position:absolute;top:46px;right:0;width:360px;max-width:calc(100vw - 32px);max-height:min(70vh,520px);overflow:auto;background:var(--navy-800);border:1px solid var(--line-strong);border-radius:14px;box-shadow:0 18px 50px rgba(0,0,0,.5);z-index:120}
  .bell-h{display:flex;justify-content:space-between;align-items:center;padding:13px 15px;border-bottom:1px solid var(--line);font-weight:700;font-size:14px;position:sticky;top:0;background:var(--navy-800)}
  .bell-x{background:transparent;border:0;color:var(--muted);cursor:pointer;font-size:14px}
  .bell-pushbtn{background:transparent;border:1px solid var(--line-strong);border-radius:100px;color:var(--acid);cursor:pointer;font-family:inherit;font-size:11px;font-weight:600;padding:4px 10px}
  .bell-pushbtn:hover{border-color:var(--acid)}
  .bell-grp{font-size:11px;text-transform:uppercase;letter-spacing:.05em;font-weight:700;color:var(--muted-2);padding:11px 15px 4px}
  .bell-grp.od{color:#ff8b5e}
  .bell-item{display:flex;flex-direction:column;gap:2px;width:100%;text-align:left;background:transparent;border:0;border-top:1px solid var(--line);padding:10px 15px;cursor:pointer;color:inherit;font:inherit}
  .bell-item:hover{background:color-mix(in srgb,var(--acid) 8%,transparent)}
  .bell-item .bi-t{font-size:13.5px;font-weight:600}
  .bell-item .bi-s{font-size:11.5px;color:var(--muted)}
  .bell-item .bi-due{font-size:11px;font-weight:600;color:var(--muted-2)}
  .bell-item .bi-at{font-size:10.5px;color:var(--muted-2);opacity:.8}
  .bell-item .bi-due.od{color:#ff5a5a}
  .bell-row{display:flex;align-items:stretch}
  .bell-row .bell-item{flex:1;min-width:0}
  .bell-dis{flex:none;background:none;border:0;color:var(--muted-2);cursor:pointer;font-size:11px;padding:0 12px;opacity:.5;transition:.15s}
  .bell-row:hover .bell-dis{opacity:1}
  .bell-dis:hover{color:#ff8b8b}
  .bell-empty{padding:26px 15px;text-align:center;color:var(--muted);font-size:13px}
  @media(max-width:560px){.bell-panel{position:fixed;top:60px;left:16px;right:16px;width:auto;max-width:none}}
  .dash-head{display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;margin-bottom:24px}
  .dash-head h1{font-size:clamp(24px,3.4vw,32px)}
  .dash-head h1 span{color:var(--acid)}
  .dash-sub{color:var(--muted-2);font-size:13px;margin-top:4px}
  .login-card{max-width:420px;margin:12vh auto 0;border:1px solid var(--line-strong);border-radius:20px;background:var(--navy-800);padding:40px}
  .login-card h1{font-size:26px;margin-bottom:6px}
  .login-card p{color:var(--muted);font-size:14px;margin-bottom:24px}

  /* tabs */
  .tabs{display:flex;gap:8px;margin-bottom:28px;border-bottom:1px solid var(--line);padding-bottom:0}
  .tab{background:none;border:0;border-bottom:2px solid transparent;color:var(--muted);font-family:'Space Grotesk';font-size:16px;font-weight:600;padding:12px 18px;cursor:pointer;transition:.25s;display:inline-flex;align-items:center;gap:8px}
  .tab:hover{color:var(--text)}
  .tab.active{color:var(--acid);border-bottom-color:var(--acid)}
  .tab .pill{background:rgba(221,249,143,.14);color:var(--acid);border-radius:100px;font-size:11.5px;padding:2px 9px;font-family:'Inter'}

  .kpis{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:28px}
  .kpis.four{grid-template-columns:repeat(4,1fr)}
  .kpi{border:1px solid var(--line);border-radius:var(--radius);background:linear-gradient(180deg,var(--navy-700),var(--navy-800));padding:20px}
  .kpi .n{font-family:'Space Grotesk';font-weight:700;font-size:30px;color:var(--acid);line-height:1.1;white-space:nowrap}
  .kpi .n small{font-size:16px;color:var(--muted)}
  .kpi .l{color:var(--muted);font-size:12.5px;margin-top:6px}

  .panel{border:1px solid var(--line);border-radius:var(--radius);background:var(--navy-800);padding:24px;margin-bottom:22px;overflow-x:auto}
  .panel h2{font-size:17px;margin-bottom:16px;display:flex;align-items:center;gap:10px}
  .panel h2 .count{font-size:12px;color:var(--muted-2);font-weight:500}
  .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:22px}

  /* daily chart */
  .chart{display:flex;align-items:flex-end;gap:3px;height:120px;padding-top:8px}
  .chart .col{flex:1;display:flex;flex-direction:column;justify-content:flex-end;height:100%;position:relative;border-radius:4px 4px 0 0;background:rgba(255,255,255,.03)}
  .chart .col .fill{background:var(--acid);opacity:.85;border-radius:4px 4px 0 0;min-height:2px;transition:.3s}
  .chart .col:hover .fill{opacity:1}
  .chart .col .tip{display:none;position:absolute;bottom:calc(100% + 6px);left:50%;transform:translateX(-50%);background:var(--navy-900);border:1px solid var(--line-strong);border-radius:8px;padding:5px 9px;font-size:11px;color:var(--text);white-space:nowrap;z-index:5}
  .chart .col:hover .tip{display:block}
  .chart-labels{display:flex;justify-content:space-between;color:var(--muted-2);font-size:11px;margin-top:8px}

  /* bar rows */
  .bars{display:grid;gap:9px}
  .bar-row{display:grid;grid-template-columns:minmax(90px,160px) 1fr 88px;align-items:center;gap:12px;font-size:13px}
  .bar-row .lbl{color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .bar-row .track{height:9px;border-radius:100px;background:rgba(255,255,255,.05);overflow:hidden}
  .bar-row .fill{height:100%;border-radius:100px;background:var(--acid);min-width:2px}
  .bar-row .val{text-align:right;color:var(--text);font-weight:600;font-size:12.5px;white-space:nowrap}
  .bar-row .val small{color:var(--muted-2);font-weight:400}

  /* chart with conversion dots */
  .chart .col .dot{position:absolute;left:50%;transform:translateX(-50%);width:7px;height:7px;border-radius:50%;background:#ff9ec9;box-shadow:0 0 0 2px var(--navy-800);z-index:3}
  .chart-legend{display:flex;gap:18px;margin-top:10px;font-size:11.5px;color:var(--muted-2)}
  .chart-legend i{display:inline-block;width:10px;height:10px;border-radius:3px;margin-right:6px;vertical-align:-1px}
  .chart-legend .s{background:var(--acid)}
  .chart-legend .c{border-radius:50%;background:#ff9ec9}

  /* insight banner */
  .insights{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:22px}
  .insight{border:1px solid var(--line);border-radius:var(--radius);background:linear-gradient(180deg,var(--navy-700),var(--navy-800));padding:18px 20px}
  .insight .t{font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted-2);margin-bottom:8px;display:flex;align-items:center;gap:7px}
  .insight .v{font-family:'Space Grotesk';font-weight:700;font-size:19px;color:var(--text);line-height:1.25}
  .insight .v em{color:var(--acid);font-style:normal}
  .insight .d{color:var(--muted);font-size:12.5px;margin-top:6px}
  @media(max-width:980px){.insights{grid-template-columns:1fr}}

  /* performance table (canales / páginas que traen leads) */
  .perf{width:100%;border-collapse:collapse;font-size:13px;min-width:440px}
  .perf th{text-align:left;color:var(--muted-2);font-size:10.5px;letter-spacing:.09em;text-transform:uppercase;padding:7px 10px;border-bottom:1px solid var(--line-strong)}
  .perf th.num,.perf td.num{text-align:right}
  .perf td{padding:10px;border-bottom:1px solid var(--line);vertical-align:middle}
  .perf tr:last-child td{border-bottom:0}
  .perf .rate-cell{display:flex;align-items:center;gap:9px;justify-content:flex-end}
  .perf .rate-bar{width:56px;height:7px;border-radius:100px;background:rgba(255,255,255,.06);overflow:hidden;flex-shrink:0}
  .perf .rate-bar i{display:block;height:100%;background:var(--acid);border-radius:100px}
  .perf .rate-num{font-weight:700;color:var(--text);min-width:42px;text-align:right}
  .perf .lead-n{font-weight:700;color:var(--acid)}
  .perf .lead-n.zero{color:var(--muted-2);font-weight:400}

  /* tables */
  table.dt{width:100%;border-collapse:collapse;font-size:13.5px;min-width:820px}
  .dt th{text-align:left;color:var(--muted-2);font-size:11px;letter-spacing:.1em;text-transform:uppercase;padding:8px 12px;border-bottom:1px solid var(--line-strong)}
  .dt td{padding:11px 12px;border-bottom:1px solid var(--line);color:var(--text);vertical-align:top}
  .dt tr:hover td{background:rgba(255,255,255,.02)}
  .dt td .sub{color:var(--muted-2);font-size:12px;display:block;margin-top:2px}
  .dt .msg{max-width:260px;color:var(--muted);font-size:13px}
  .badge{display:inline-block;padding:3px 10px;border-radius:100px;font-size:11.5px;font-weight:600;background:rgba(255,255,255,.08);color:var(--muted)}
  .b-paid_search{background:rgba(66,133,244,.18);color:#8ab4f8}
  .b-paid_social{background:rgba(24,119,242,.18);color:#7ba9e8}
  .b-organic{background:rgba(52,168,83,.18);color:#81c995}
  .b-ai{background:rgba(221,249,143,.16);color:var(--acid)}
  .b-social{background:rgba(255,110,180,.16);color:#ff9ec9}
  .b-referral{background:rgba(255,190,90,.16);color:#ffd28a}
  .b-email{background:rgba(160,110,255,.18);color:#c4a7ff}
  .gclid-dot{color:var(--acid);font-weight:700;font-size:12.5px}
  select.status{background:var(--navy-900);border:1px solid var(--line-strong);border-radius:8px;color:var(--text);font-family:inherit;font-size:12.5px;padding:6px 9px;cursor:pointer}

  /* toolbar */
  .toolbar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:18px;align-items:center}
  .toolbar input[type="search"]{flex:1;min-width:180px;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:100px;padding:9px 18px;color:var(--text);font-family:inherit;font-size:13.5px}
  .toolbar input[type="search"]:focus{outline:none;border-color:var(--acid)}
  .toolbar .fpill{background:transparent;border:1px solid var(--line-strong);color:var(--muted);font-family:inherit;font-size:12.5px;font-weight:600;padding:8px 15px;border-radius:100px;cursor:pointer;transition:.25s}
  .toolbar .fpill:hover{border-color:var(--acid);color:var(--acid)}
  .toolbar .fpill.active{background:var(--acid);border-color:var(--acid);color:#142033}

  .muted-note{color:var(--muted-2);font-size:13px}
  .btn.small{padding:9px 18px;font-size:13px}
  .dt tbody tr{cursor:pointer}

  /* ---------- Lead detail modal ---------- */
  .lead-modal{position:fixed;inset:0;z-index:300;display:none;align-items:flex-start;justify-content:center;padding:5vh 20px;overflow-y:auto}
  .lead-modal.open{display:flex}
  .lead-modal .backdrop{position:fixed;inset:0;background:rgba(9,15,26,.86);backdrop-filter:blur(8px)}
  .lead-card{position:relative;z-index:2;width:min(760px,100%);background:var(--navy-800);border:1px solid var(--line-strong);border-radius:20px;padding:32px;animation:pop .35s var(--ease)}
  /* registro de contacto FULL SCREEN (como HubSpot): header/footer fijos,
     columnas laterales quietas — solo la del MEDIO scrollea */
  .lead-card-wide{width:100vw;height:100dvh;max-width:none;border-radius:0;border:0;margin:0;padding:16px 26px 12px;display:flex;flex-direction:column;overflow:hidden;animation:none}
  .lead-modal.open:has(.lead-card-wide){padding:0;overflow:hidden}
  /* header estilo HubSpot */
  .lm-top{display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;padding-bottom:16px;border-bottom:1px solid var(--line);margin-bottom:18px}
  .lm-id{display:flex;align-items:center;gap:13px;min-width:0}
  .lm-avatar{width:46px;height:46px;border-radius:50%;background:color-mix(in srgb,var(--acid) 18%,var(--navy-900));color:var(--acid);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;flex:none}
  .lm-idtext h3{margin:0;font-size:19px}
  .lm-sub{font-size:13.5px;color:var(--muted);margin-top:2px}
  .lm-sub a{color:var(--acid)}
  .lm-quick{display:flex;gap:8px;flex-wrap:wrap}
  .lm-qbtn{display:inline-flex;align-items:center;gap:6px;background:var(--navy-900);border:1px solid var(--line-strong);color:var(--text);border-radius:9px;font-size:13px;padding:8px 13px;cursor:pointer;text-decoration:none}
  .lm-qbtn:hover{border-color:var(--muted)}
  /* grid 3 columnas */
  .lm-grid{display:grid;grid-template-columns:300px 1fr 320px;gap:20px;align-items:stretch;flex:1;min-height:0}
  .lm-left,.lm-right{min-width:0;overflow-y:auto;padding-right:4px;scrollbar-width:thin}
  .lm-center{min-width:0;display:flex;flex-direction:column;gap:18px;overflow-y:auto;padding:0 6px 24px;scrollbar-width:thin;border-left:1px solid var(--line);border-right:1px solid var(--line);padding-left:22px;padding-right:22px}
  .lm-top{flex:none}
  .lead-card-wide .lead-actions{flex:none;border-top:1px solid var(--line);padding-top:10px;margin-top:10px}
  .ab-sec{margin-bottom:14px}
  .ab-sec .ab-h{font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--muted-2);font-weight:700;margin-bottom:7px}
  .ab-row{display:flex;justify-content:space-between;gap:10px;padding:4px 0;font-size:13px;line-height:1.4}
  .ab-row .ab-k{color:var(--muted);flex:none}
  .ab-row .ab-v{color:var(--text);text-align:right;word-break:break-word;min-width:0}
  .ab-row .ab-v a{color:var(--acid)}
  .ab-badge{border:1px solid;border-radius:999px;font-size:11px;font-weight:600;padding:2px 9px}
  .lm-stage-sel{background:var(--navy-800);border:1px solid;border-radius:999px;font-family:inherit;font-size:11.5px;font-weight:600;padding:3px 10px;cursor:pointer}
  .lm-stage-sel option{color:var(--text);background:var(--navy-800)}
  .lm-block{background:var(--navy-900);border:1px solid var(--line);border-radius:12px;padding:14px 16px}
  .lm-block-h{font-size:13px;font-weight:700;color:var(--text);margin-bottom:10px}
  .lm-deal{display:flex;flex-direction:column;gap:5px;width:100%;text-align:left;background:var(--navy-800);border:1px solid var(--line);border-radius:10px;padding:10px 12px;cursor:pointer;color:var(--text)}
  .lm-deal:hover{border-color:var(--muted)}
  .lm-deal-wrap{display:flex;flex-direction:column;gap:4px;margin-bottom:8px}
  .lm-conv{align-self:flex-end;background:transparent;border:0;color:var(--acid);font:inherit;font-size:11.5px;font-weight:600;cursor:pointer;padding:1px 2px}
  .lm-conv:hover{text-decoration:underline}
  .lm-mk{display:flex;gap:8px;margin-top:10px}
  .lm-mk .btn{flex:1;justify-content:center}
  .lm-dealval{width:100%;margin-top:8px;background:transparent;border:1px dashed var(--line-strong);border-radius:9px;color:var(--muted);font:inherit;font-size:12px;font-weight:600;padding:8px;cursor:pointer}
  .lm-dealval:hover{border-color:var(--acid);color:var(--acid)}
  .lm-deal-t{font-size:13px;font-weight:600}
  .lm-deal-b{display:flex;align-items:center;justify-content:space-between;gap:8px}
  .lm-deal-b b{font-family:'Space Grotesk'}
  .lm-score{border:1px solid;border-radius:999px;font-size:12px;font-weight:700;padding:2px 10px;white-space:nowrap;cursor:help}
  .lm-taskadd{margin-bottom:10px}
  .lm-taskadd input,.lm-taskadd select,.lm-block textarea,.ed-inp{width:100%;background:var(--navy-800);border:1px solid var(--line-strong);border-radius:9px;color:var(--text);font-family:inherit;font-size:13px;padding:8px 10px}
  .ed-hint{display:block;font-size:11px;color:var(--muted-2);margin-top:4px}
  .ed-hint b{color:var(--acid);font-weight:600}
  .lost-note{background:color-mix(in srgb,#ff6b6b 12%,transparent);border:1px solid color-mix(in srgb,#ff6b6b 40%,transparent);color:#ff8b8b;border-radius:10px;font-size:13px;padding:9px 13px;margin:10px 0 4px}
  .of-composer{position:fixed;inset:0;z-index:400;background:rgba(9,15,26,.8);backdrop-filter:blur(6px);display:flex;align-items:flex-start;justify-content:center;padding:6vh 16px;overflow-y:auto}
  .ofc-card{background:var(--navy-800);border:1px solid var(--line-strong);border-radius:16px;padding:22px 24px;max-width:560px;width:100%}
  .ofc-l{display:block;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--muted-2);font-weight:700;margin:12px 0 5px}
  .tpl-strip{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-top:14px;background:var(--navy-800);border:1px dashed var(--line-strong);border-radius:12px;padding:10px 14px}
  .tpl-strip .tpl-l{font-size:11.5px;font-weight:700;color:var(--muted-2);text-transform:uppercase;letter-spacing:.05em}
  .tpl-chip{display:inline-flex;align-items:center;background:var(--navy-700);border:1px solid var(--line);border-radius:100px;overflow:hidden}
  .tpl-chip .tpl-use{background:none;border:0;color:var(--text);font:inherit;font-size:12.5px;font-weight:600;padding:6px 6px 6px 13px;cursor:pointer}
  .tpl-chip .tpl-use:hover{color:var(--acid)}
  .tpl-chip .tpl-del{background:none;border:0;color:var(--muted-2);font-size:11px;padding:6px 10px 6px 4px;cursor:pointer}
  .tpl-chip .tpl-del:hover{color:#ff8b8b}
  .fu-row{border:1px solid var(--line);border-radius:11px;padding:11px 13px;margin-bottom:9px;background:var(--navy-800)}
  .fu-top{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:7px}
  .fu-top input[type="datetime-local"]{background:var(--navy-700);border:1px solid var(--line-strong);border-radius:8px;color:var(--text);font-family:inherit;font-size:12px;padding:5px 8px}
  .fu-subj{flex:1;min-width:160px;background:transparent;border:0;border-bottom:1px dashed var(--line-strong);color:var(--text);font-family:inherit;font-size:13.5px;font-weight:600;padding:3px 2px}
  .fu-st{font-size:10px;font-weight:800;letter-spacing:.04em;text-transform:uppercase;border:1px solid;border-radius:100px;padding:2px 9px;white-space:nowrap}
  .fu-body{width:100%;box-sizing:border-box;background:var(--navy-700);border:1px solid var(--line);border-radius:9px;color:var(--text);font-family:inherit;font-size:13px;line-height:1.55;padding:9px 11px;min-height:64px;resize:none;overflow:hidden}
  .fu-actions{display:flex;gap:7px;margin-top:8px;flex-wrap:wrap}
  .of-terms-box{margin-top:18px}
  .of-terms-box .pp-sec-h{margin-bottom:8px}
  .lm-taskadd-row{display:flex;gap:6px;margin-top:6px;flex-wrap:wrap}
  .lm-taskadd-row input[type=date]{flex:1 1 108px;min-width:0}
  .lm-taskadd-row input[type=time]{flex:0 0 92px;min-width:0}
  .lm-taskadd-row select{flex:1 1 100%;min-width:0}
  .lm-task{display:flex;align-items:flex-start;gap:9px;padding:7px 0;border-bottom:1px solid var(--line);font-size:13px}
  .lm-task input[type=checkbox]{margin-top:2px;width:15px;height:15px;accent-color:var(--acid);flex:none}
  .lm-task.done .lm-task-txt>div:first-child{text-decoration:line-through;color:var(--muted-2)}
  .lm-task-txt{flex:1;min-width:0}
  .lm-task-meta{color:var(--muted-2);font-size:11.5px;margin-top:2px}
  .lm-x{background:none;border:0;color:var(--muted-2);cursor:pointer;font-size:13px;padding:0 4px}
  .lm-x:hover{color:#ff8b8b}
  .lm-block textarea{min-height:64px;resize:vertical;margin-bottom:8px}
  .lm-noteadd{display:flex;gap:6px;margin-bottom:10px}.lm-noteadd select{flex:1;min-width:0}
  .lm-note{border-bottom:1px solid var(--line);padding:8px 0;font-size:13px}
  .lm-note-b{color:var(--text);white-space:pre-wrap;line-height:1.45}
  .lm-note-m{color:var(--muted-2);font-size:11px;margin-top:4px;display:flex;flex-wrap:wrap;gap:2px;align-items:center}
  .lm-note .lm-reply{border-bottom:0;border-left:2px solid var(--line-strong);margin:6px 0 0 8px;padding:6px 0 2px 10px}
  .lm-reply-btn{background:transparent;border:0;color:var(--acid);cursor:pointer;font:inherit;font-size:11px;padding:0;font-weight:600}
  .lm-reply-btn:hover{text-decoration:underline}
  .lm-reply-box{margin-top:6px}
  .lm-reply-ta{width:100%;background:var(--navy-800);border:1px solid var(--line-strong);border-radius:9px;color:var(--text);font-family:inherit;font-size:13px;padding:8px 10px;min-height:52px;resize:vertical;margin-bottom:6px}
  .lm-email{border:1px solid var(--line);border-radius:11px;padding:10px 13px;margin-bottom:8px;cursor:pointer}
  .lm-email-in{border-color:var(--acid);background:color-mix(in srgb,var(--acid) 7%,transparent)}
  .lm-email-h{display:flex;align-items:baseline;justify-content:space-between;gap:8px;font-size:13px}
  .lm-email-subj{color:var(--text);font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .lm-email-meta{color:var(--muted-2);font-size:11px;white-space:nowrap;flex:none}
  .lm-email-snip{color:var(--muted);font-size:12.5px;margin-top:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .lm-email-body{color:var(--text);font-size:13px;line-height:1.55;margin-top:8px;white-space:pre-wrap;border-top:1px solid var(--line);padding-top:8px;display:none}
  .lm-email.open .lm-email-body{display:block}
  .lm-email.open .lm-email-snip{display:none}
  .lm-center .lm-block .lead-msg{background:none;border:0;padding:0;margin:0;color:var(--text)}
  .lm-center .lm-block .draft-box{background:var(--navy-800);min-height:200px;margin-top:2px}
  .lm-center .lm-block .draft-head{margin-bottom:8px}
  @media(max-width:900px){
    .lm-grid{grid-template-columns:1fr;overflow-y:auto;display:flex;flex-direction:column}
    .lm-left,.lm-right,.lm-center{overflow:visible;border:0;padding-left:0;padding-right:0}
  }
  @keyframes pop{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
  .lead-card .close{position:absolute;top:18px;right:18px;width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,.08);border:1px solid var(--line-strong);color:#fff;font-size:18px;cursor:pointer;display:grid;place-items:center;transition:.25s}
  .lead-card .close:hover{background:var(--acid);color:#142033}
  .lead-card h3{font-size:24px;margin-bottom:2px}
  .lead-card .email-line{color:var(--muted);font-size:14px;margin-bottom:22px}
  .lead-card .email-line a{color:var(--acid)}
  .detail-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px}
  .detail{background:var(--navy-900);border:1px solid var(--line);border-radius:12px;padding:12px 14px}
  .detail .k{font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted-2);margin-bottom:4px}
  .detail .v{font-size:13.5px;color:var(--text);word-break:break-all}
  .lead-msg{background:var(--navy-900);border:1px solid var(--line);border-radius:12px;padding:16px;color:var(--muted);font-size:14px;line-height:1.6;margin-bottom:24px;white-space:pre-wrap}
  .lm-journey{background:var(--navy-900);border:1px solid var(--line);border-radius:12px;padding:14px 16px;margin-bottom:24px}
  .lm-journey .jr-h{font-size:12.5px;font-weight:700;color:var(--text);margin:6px 0 8px;letter-spacing:.01em}
  .lm-journey .jr-h span{color:var(--muted-2);font-weight:400}
  .lm-journey .jr-list{list-style:none;margin:0 0 6px;padding:0;counter-reset:jr}
  .lm-journey ol.jr-list li{counter-increment:jr}
  .lm-journey ol.jr-list li::before{content:counter(jr);display:inline-flex;align-items:center;justify-content:center;width:17px;height:17px;border-radius:50%;background:var(--navy-800);color:var(--muted-2);font-size:10px;margin-right:8px;flex:none}
  .lm-journey .jr-list li{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--muted);padding:3px 0}
  .lm-journey .jr-path{color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;min-width:0}
  .lm-journey .jr-dur{color:var(--muted-2);font-size:12px;white-space:nowrap}
  .draft-head{display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:10px}
  .draft-head h4{font-size:15px;display:flex;align-items:center;gap:8px}
  .draft-head h4 span{color:var(--acid)}
  .draft-box{width:100%;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:12px;padding:16px;color:var(--text);font-family:inherit;font-size:13.5px;line-height:1.6;min-height:230px;resize:vertical}
  .draft-box:focus{outline:none;border-color:var(--acid)}
  .lead-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:16px;justify-content:space-between}
  .lead-actions .left{display:flex;gap:10px;flex-wrap:wrap}
  .btn-danger{background:transparent;border:1px solid rgba(255,120,120,.4);color:#ff9a9a}
  .btn-danger:hover{background:rgba(255,90,90,.12);border-color:#ff9a9a;transform:translateY(-2px)}
  @media(max-width:680px){.detail-grid{grid-template-columns:1fr 1fr}}
  [hidden]{display:none!important}
  @media(max-width:980px){.kpis,.kpis.four{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:1280px){.grid-2{grid-template-columns:1fr}}
  /* ---------- Pipeline kanban ---------- */
  .pipe-pager{display:none;align-items:center;justify-content:space-between;gap:10px;margin-bottom:10px;background:var(--navy-800);border:1px solid var(--line);border-radius:12px;padding:6px 8px}
  .pipe-pager[hidden]{display:none!important}
  .pipe-pager button{width:42px;height:38px;border-radius:9px;border:1px solid var(--line-strong);background:transparent;color:var(--text);font-size:20px;line-height:1;cursor:pointer}
  .pipe-pager button:disabled{opacity:.3}
  .pipe-pager #pgr-label{font-family:'Space Grotesk';font-weight:600;font-size:13.5px;display:flex;align-items:center;gap:7px}
  .pipe-pager #pgr-label .dot{width:8px;height:8px;border-radius:2px;display:inline-block}
  .pipe-pager #pgr-label .n{color:var(--muted-2);font-weight:400}
  .mob-ver{text-align:center;color:var(--muted-2);font-size:10px;padding:8px 0 2px;letter-spacing:.04em}
  .pipe-bar{display:flex;align-items:center;gap:12px;margin-bottom:16px;flex-wrap:wrap}
  .pipe-bar input[type=search]{flex:1;min-width:220px;background:var(--navy-800);border:1px solid var(--line-strong);border-radius:10px;color:var(--text);font-family:inherit;font-size:14px;padding:10px 14px}
  .pipe-hint{color:var(--muted-2);font-size:12.5px}
  .pipeline{display:flex;gap:12px;overflow-x:auto;padding-bottom:12px;align-items:flex-start}
  .pipe-col{flex:0 0 256px;min-width:256px;display:flex;flex-direction:column;max-height:76vh;background:var(--navy-800);border:1px solid var(--line);border-radius:12px}
  .pipe-col-head{display:flex;align-items:center;gap:8px;padding:12px 14px 10px;border-bottom:1px solid var(--line)}
  .pipe-col-head .bar{width:8px;height:8px;border-radius:2px;flex:none}
  .pipe-col-head .st{font-family:'Space Grotesk';font-weight:600;font-size:13.5px}
  .pipe-col-head .cnt{color:var(--muted);font-weight:600;font-size:13px}
  .pipe-col-sums{display:flex;align-items:baseline;justify-content:space-between;gap:8px;padding:8px 14px 9px;border-bottom:1px solid var(--line)}
  .pipe-col-sums .tot{font-weight:700;font-family:'Space Grotesk';font-size:15px;letter-spacing:-.01em}
  .pipe-col-sums .wt{color:var(--muted-2);font-size:10.5px;white-space:nowrap}
  .pipe-col.drop{border-color:var(--acid);box-shadow:0 0 0 2px rgba(221,249,143,.2)}
  /* toggle de vista */
  .view-toggle{display:inline-flex;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:10px;padding:2px;gap:2px}
  .vt-btn{background:none;border:0;color:var(--muted);font-family:inherit;font-size:12.5px;font-weight:600;padding:6px 12px;border-radius:8px;cursor:pointer}
  .vt-btn.active{background:var(--acid);color:#10210a}
  /* vista lista */
  .lead-table{width:100%;border-collapse:collapse;font-size:14px}
  .lead-table th{text-align:left;color:var(--muted-2);font-size:11.5px;text-transform:uppercase;letter-spacing:.05em;font-weight:600;padding:10px 12px;border-bottom:1px solid var(--line)}
  .lead-table th.lt-sort{cursor:pointer;user-select:none;white-space:nowrap}
  .lead-table th.lt-sort:hover{color:var(--text)}
  .lead-table th.lt-sort.on{color:var(--acid)}
  .lead-table td{padding:12px;border-bottom:1px solid var(--line);color:var(--text)}
  .lead-table tr{cursor:pointer}
  .lead-table tbody tr:hover{background:var(--navy-800)}
  .lead-table .lt-name{font-weight:600}
  .lead-table .lt-mail{color:var(--muted);font-size:12.5px}
  .lead-table .lt-stage{display:inline-flex;align-items:center;gap:6px;font-size:12.5px;font-weight:600}
  .lead-table .lt-stage .dot{width:8px;height:8px;border-radius:50%}
  .lead-table .lt-val{font-family:'Space Grotesk';font-weight:700;white-space:nowrap}
  .lead-table .lt-act{color:var(--muted);font-size:12.5px;white-space:nowrap}
  .lead-table .lt-num{text-align:right;white-space:nowrap;color:var(--muted)}
  .lead-table .lt-chk{width:1%;white-space:nowrap;padding:12px 6px 12px 14px}
  .lead-table .lt-chk input{width:16px;height:16px;accent-color:var(--acid);cursor:pointer}
  /* Empresas rediseñadas: segment control sobre la tabla + detalle en 3 zonas (misma gramática que la Ficha V2) */
  .co-seg{display:flex;gap:6px;flex-wrap:wrap}
  .co-seg button{background:transparent;border:1px solid var(--line-strong);border-radius:100px;color:var(--muted);font:600 11px Inter,sans-serif;padding:6px 11px;cursor:pointer;white-space:nowrap}
  .co-seg button.on{border-color:var(--acid);color:var(--acid);background:rgba(221,249,143,.08)}
  .co2-tav{width:28px;height:28px;border-radius:8px;color:#0f1826;display:grid;place-items:center;font-weight:800;font-size:11px;font-family:'Space Grotesk';flex:none}
  .co2-hd{display:flex;align-items:center;gap:12px;flex-wrap:wrap;padding:14px 16px;border:1px solid var(--line);border-bottom:0;border-radius:14px 14px 0 0;background:var(--navy-800)}
  .co2-grid{display:grid;grid-template-columns:240px 1fr 300px;border:1px solid var(--line);border-radius:0 0 14px 14px;overflow:hidden;background:var(--navy-800)}
  .co2-l{border-right:1px solid var(--line);padding:16px}
  .co2-c{padding:16px 20px;background:rgba(0,0,0,.12);min-width:0}
  .co2-r{border-left:1px solid var(--line);padding:16px}
  @media(max-width:960px){
    .co2-grid{display:flex;flex-direction:column}
    .co2-l{order:2;border-right:0;border-top:1px solid var(--line)}
    .co2-c{order:1}
    .co2-r{order:3;border-left:0;border-top:1px solid var(--line)}
  }
  .lead-table-wrap{overflow-x:auto;border:1px solid var(--line);border-radius:14px}
  .pipe-list{display:flex;flex-direction:column;gap:9px;overflow-y:auto;min-height:50px;padding:11px}
  .pipe-card{background:var(--navy-700);border:1px solid var(--line);border-left:3px solid var(--stage,#8ab4ff);border-radius:8px;padding:11px 12px;cursor:grab;transition:transform .12s,border-color .2s,box-shadow .2s}
  .pipe-card:hover{border-color:var(--line-strong);box-shadow:0 6px 18px -10px rgba(0,0,0,.6);transform:translateY(-1px)}
  .pipe-card.dragging{opacity:.4;cursor:grabbing}
  .pipe-card .pc-name{font-family:'Space Grotesk';font-weight:600;font-size:13.5px;color:var(--acid);margin-bottom:8px;line-height:1.3}
  .pipe-card .pc-field{font-size:12px;color:var(--muted);margin-top:3px;display:flex;gap:5px;align-items:center}
  .pipe-card .pc-field .k{color:var(--muted-2);flex:none}
  .pipe-card .pc-field .v{color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:flex;align-items:center;gap:6px;min-width:0}
  .pipe-card .pc-field .v.amt{font-weight:700;font-family:'Space Grotesk'}
  .pipe-card .pc-act{font-size:11px;color:var(--muted-2);margin-top:6px}
  .pipe-card .pc-lost{font-size:12px;color:#ff8b8b;margin-top:6px;font-style:italic}
  .pipe-card .pc-foot{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-top:10px;padding-top:9px;border-top:1px solid var(--line)}
  .pc-tags{display:flex;gap:5px;align-items:center;flex-wrap:wrap;min-width:0}
  .pc-badge{font-size:10px;letter-spacing:.02em;text-transform:uppercase;font-weight:700;color:var(--muted);background:rgba(255,255,255,.06);border-radius:100px;padding:2px 7px}
  .lt-score{border:1px solid;border-radius:100px;font-size:11.5px;font-weight:800;padding:2px 9px;white-space:nowrap;cursor:help}
  .pc-score{border:1px solid;border-radius:100px;font-size:10px;font-weight:800;padding:1px 7px;cursor:help}
  .pc-ads{font-size:10px;font-weight:800;color:#0f1826;background:#8ab4ff;border-radius:100px;padding:2px 7px}
  .pc-ost{font-size:10px;font-weight:800;letter-spacing:.02em}
  .pc-co{width:22px;height:22px;border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:800;color:#0f1826;flex:none}
  .pc-owner{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9.5px;font-weight:700;color:#0f1826;flex:none}
  .deals-analytics{margin-top:22px;border-top:1px solid var(--line);padding-top:6px}
  .deals-analytics>summary{cursor:pointer;list-style:none;font-family:'Space Grotesk';font-weight:600;font-size:15px;padding:10px 2px;display:flex;align-items:center;gap:8px}
  .deals-analytics>summary::-webkit-details-marker{display:none}
  .deals-analytics>summary::before{content:'▸';color:var(--muted);transition:transform .15s}
  .deals-analytics[open]>summary::before{transform:rotate(90deg)}
  .deals-analytics>summary span{color:var(--muted-2);font-weight:400;font-size:12.5px}
  .deals-sum{display:flex;gap:10px;flex-wrap:wrap;margin:2px 0 18px}
  .deals-sum .ds{flex:1;min-width:150px;background:var(--navy-800);border:1px solid var(--line);border-radius:12px;padding:12px 15px}
  .deals-sum .ds .dv{font-family:'Space Grotesk';font-weight:700;font-size:21px;letter-spacing:-.02em}
  .deals-sum .ds .dl{font-size:11.5px;color:var(--muted);margin-top:2px}
  .pipe-empty{color:var(--muted-2);font-size:12px;text-align:center;padding:16px 6px;border:1px dashed var(--line);border-radius:10px;margin-top:10px}
  /* ---- Deals V2: toolbar propia, semáforo de días, chip de documento, drop-zones y vista Lista ---- */
  .dl-chip{background:transparent;border:1px solid var(--line-strong);color:var(--muted);font-family:inherit;font-size:12.5px;font-weight:600;padding:9px 15px;border-radius:100px;cursor:pointer;transition:.2s;white-space:nowrap}
  .dl-chip:hover{border-color:var(--acid);color:var(--acid)}
  .dl-chip.active{background:var(--acid);border-color:var(--acid);color:#142033}
  .dl-views{display:flex;border:1px solid var(--line-strong);border-radius:10px;overflow:hidden;flex:none}
  .dl-views button{background:transparent;border:0;color:var(--muted);font-family:inherit;font-size:12.5px;font-weight:600;padding:9px 14px;cursor:pointer}
  .dl-views button.on{background:var(--acid);color:#142033}
  .pc-head{display:flex;align-items:flex-start;justify-content:space-between;gap:6px}
  .pc-head .pc-name{margin-bottom:0;flex:1;min-width:0}
  .pc-dots{background:transparent;border:1px solid var(--line-strong);border-radius:7px;color:var(--muted);font-size:14px;line-height:1;padding:2px 7px;cursor:pointer;flex:none}
  .pc-dots:hover{color:var(--text);border-color:var(--acid)}
  .pc-sub{font-size:11.5px;color:var(--muted);margin-top:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .pc-row{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-top:8px}
  .pc-amt{font-weight:700;font-family:'Space Grotesk';font-size:13.5px}
  .pc-next{font-size:11.5px;color:var(--muted);margin-top:7px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .pc-next.warn{color:#f0c060}
  .pc-doc{display:inline-block;font-size:11px;font-weight:600;border:1px solid var(--line-strong);border-radius:999px;padding:3px 9px;margin-top:7px;color:var(--muted);max-width:100%;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .pc-doc.ok{color:#7ed957;border-color:rgba(126,217,87,.5)}
  .pc-doc.hot{color:var(--acid);border-color:rgba(221,249,143,.55)}
  .pc-doc.warn{color:#f0c060;border-color:rgba(240,192,96,.5)}
  /* borde de alerta según los días en etapa (ámbar 7-14d, rojo >14d) */
  .pipe-card.pc-mid{border-color:rgba(240,192,96,.5)}
  .pipe-card.pc-bad{border-color:rgba(255,107,107,.55)}
  .pipeline[hidden]{display:none!important}   /* la vista Lista lo esconde; sin esto el display:flex le gana al hidden */
  .pipe-drops{display:flex;gap:10px;margin-top:4px;flex-wrap:wrap}
  .pipe-drops[hidden]{display:none!important}
  .pipe-drop{flex:1;min-width:230px;border:2px dashed;border-radius:12px;padding:13px 16px;text-align:center;cursor:pointer;font-family:'Space Grotesk';font-weight:600;font-size:13.5px;transition:.2s;background:transparent}
  .pipe-drop .pd-sum{display:block;font-family:'Inter',sans-serif;font-weight:400;font-size:11.5px;color:var(--muted);margin-top:3px}
  .pipe-drop.win{border-color:rgba(126,217,87,.45);color:#7ed957}
  .pipe-drop.lose{border-color:rgba(255,107,107,.45);color:#ff8b8b}
  .pipe-drop.win.drop{background:rgba(126,217,87,.1);border-color:#7ed957}
  .pipe-drop.lose.drop{background:rgba(255,107,107,.1);border-color:#ff6b6b}
  .dl-lbar{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:12px}
  .dl-lbar select{margin-left:auto}

  /* ---------- Insights con IA ---------- */
  .ai-panel{background:linear-gradient(135deg,rgba(221,249,143,.06),var(--navy-800))}
  .ai-head{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:14px;flex-wrap:wrap}
  .ai-head h2{margin:0}
  .ai-insight{display:flex;gap:12px;padding:14px 0;border-top:1px solid var(--line)}
  .ai-insight:first-child{border-top:0}
  .ai-insight .ico{font-size:20px;flex:none;line-height:1.3}
  .ai-insight .txt h4{font-size:15px;margin:0 0 3px;color:var(--text);font-family:'Space Grotesk'}
  .ai-insight .txt p{font-size:13.5px;color:var(--muted);margin:0;line-height:1.5}
  .ai-loading{color:var(--muted);font-size:14px;padding:10px 0}

  /* ---------- Gráfico SVG (real) ---------- */
  #daily-chart{height:auto!important;display:block;padding-top:4px}
  .gsvg{width:100%;height:auto;display:block;overflow:visible}
  .g-grid{stroke:rgba(255,255,255,.07);stroke-width:1}
  .g-yl{fill:var(--muted-2);font-size:11px;text-anchor:end;font-family:'Inter'}
  .g-xl{fill:var(--muted-2);font-size:11px;font-family:'Inter'}
  .g-line{fill:none;stroke:var(--acid);stroke-width:2.5;stroke-linejoin:round;stroke-linecap:round}
  .g-lead{fill:#ff9ec9;stroke:var(--navy-800);stroke-width:2;transition:.2s}
  .gsvg circle:hover{opacity:.8}
  .chart-labels{display:none}

  /* ===== Funnel ===== */
  .funnel{display:grid;gap:10px;margin-top:6px}
  .fn-row{display:grid;grid-template-columns:110px 1fr 120px;align-items:center;gap:14px}
  .fn-label{font-size:13.5px;color:var(--text);font-weight:600}
  .fn-bar-wrap{background:var(--navy-900);border-radius:8px;overflow:hidden}
  .fn-bar{height:34px;border-radius:8px;display:flex;align-items:center;justify-content:flex-end;padding:0 12px;min-width:34px;transition:width .4s ease}
  .fn-n{font-weight:700;color:#10210a;font-size:14px}
  .fn-meta{text-align:right;font-size:12.5px;color:var(--muted)}
  .fn-meta b{display:block;color:var(--text);font-size:15px}
  .fn-meta span{font-size:11.5px;color:var(--muted-2)}
  .fn-foot{margin-top:14px;padding-top:12px;border-top:1px solid var(--line);font-size:13px;color:var(--muted)}
  .fn-foot b{color:var(--text)}
  .fn-hint{color:var(--muted-2);font-size:11.5px}
  @media(max-width:640px){.fn-row{grid-template-columns:80px 1fr 84px;gap:8px}}

  /* ===== Offer tool ===== */
  .of-bar{display:flex;justify-content:space-between;align-items:center;gap:14px;flex-wrap:wrap}
  .of-list{display:grid;gap:10px;margin-top:16px}
  .of-card{background:var(--navy-800);border:1px solid var(--line);border-radius:14px;color:var(--text);transition:border-color .15s;font-family:inherit;overflow:hidden}
  .of-card:hover{border-color:var(--muted)}
  .of-card.arch{opacity:.6}
  .of-card-open{display:flex;align-items:center;gap:16px;width:100%;text-align:left;padding:15px 18px;cursor:pointer}
  .of-actions{display:flex;gap:8px;padding:0 12px 12px;flex-wrap:wrap}
  .of-act{background:var(--navy-900);border:1px solid var(--line-strong);color:var(--muted);border-radius:9px;font-size:12.5px;padding:6px 11px;cursor:pointer;font-family:inherit;transition:border-color .15s,color .15s}
  .of-act:hover{border-color:var(--muted);color:var(--text)}
  .of-act.danger:hover{border-color:#ff6b6b;color:#ff8b8b}
  .of-arch-toggle{background:none;border:0;color:var(--muted);font-size:13px;cursor:pointer;padding:8px 4px;font-family:inherit;text-align:left;width:100%}
  .of-arch-toggle:hover{color:var(--text)}
  .of-arch-list{display:flex;flex-direction:column;gap:10px;margin-top:8px}
  /* ---- editor de propuestas ---- */
  #pp-editor .bf,#tab-blog .bf,#tab-services .bf{margin-bottom:14px}
  #pp-editor .bf label,#tab-blog .bf label,#tab-services .bf label,#tab-licenses .bf label{display:block;font-size:12.5px;font-weight:600;color:var(--muted);margin-bottom:6px}
  #pp-editor .bf input,#pp-editor .bf select,#pp-editor .bf textarea,#tab-blog .bf input,#tab-blog .bf select,#tab-blog .bf textarea,#tab-licenses .bf input,#tab-licenses .bf select,#tab-licenses .bf textarea{width:100%;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:11px;color:var(--text);font-family:inherit;font-size:14.5px;padding:11px 13px}
  .lic-days{font-size:11px;font-weight:700;letter-spacing:.3px;padding:3px 10px;border-radius:20px;flex:none}
  .lic-days.ok{color:#7ed957;border:1px solid #7ed957}
  .lic-days.soon{color:#f0c060;border:1px solid #f0c060}
  .lic-days.due{color:#ff8b8b;border:1px solid #ff8b8b}
  .lic-days.past{color:var(--muted-2);border:1px solid var(--line-strong)}
  .pp-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin:18px 0 8px;align-items:end}
  .pp-grid .bf{margin-bottom:0}
  .pp-grid3{display:grid;grid-template-columns:2fr 1fr;gap:18px;margin-bottom:6px;align-items:start}
  .pp-grid3 > div .bf:last-child{margin-bottom:0}
  .pp-ta{width:100%;min-height:80px;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:11px;color:var(--text);font-family:inherit;font-size:14.5px;padding:11px 13px;resize:vertical}
  .pp-sec-h{display:flex;align-items:center;gap:12px;font-weight:700;font-size:14px;margin:22px 0 10px;color:var(--text)}
  .pp-sec-h .count{font-weight:400;color:var(--muted-2);font-size:12.5px}
  .btn.xs{font-size:12px;padding:4px 10px}
  .pp-status-badge{border:1px solid var(--line-strong);border-radius:999px;font-size:12px;font-weight:600;padding:4px 12px;color:var(--muted)}
  .pp-status-badge.sent{color:#f0c060;border-color:#f0c060}
  .pp-status-badge.accepted{color:#7ed957;border-color:#7ed957}
  /* Propuestas V2 (lista): semáforo de espera + señal de interés en la tabla */
  .pp2-sem{display:inline-flex;align-items:center;border:1px solid;border-radius:999px;font-size:11.5px;font-weight:600;padding:3px 10px;white-space:nowrap}
  .pp2-sem.ok{color:#7ed957;border-color:rgba(126,217,87,.5)}
  .pp2-sem.mid{color:#f0c060;border-color:rgba(240,192,96,.5)}
  .pp2-sem.bad{color:#ff8b8b;border-color:rgba(255,107,107,.55)}
  .pp2-eye{font-size:12px;color:var(--muted);white-space:nowrap}
  .pp2-eye.hot{color:var(--acid);font-weight:700}
  .pp2-eye.warn{color:#f0c060}
  .pp2-dots{background:transparent;border:1px solid var(--line-strong);border-radius:8px;color:var(--muted);font-size:15px;line-height:1;padding:4px 9px;cursor:pointer}
  .pp2-dots:hover{color:var(--text);border-color:var(--acid)}
  #pp-list table{min-width:920px} /* móvil = scroll horizontal dentro del wrap, sin colapsar columnas */
  .pp-linkbox{display:flex;align-items:center;gap:20px;flex-wrap:wrap;background:color-mix(in srgb,var(--acid) 8%,var(--navy-800));border:1px solid color-mix(in srgb,var(--acid) 40%,var(--line));border-radius:12px;padding:14px 18px;margin:8px 0 18px}
  .pp-linkbox .k{display:block;font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--muted-2);margin-bottom:3px}
  .pp-linkbox a{color:var(--acid);word-break:break-all;font-size:14px}
  .pp-linkbox code{color:var(--text);font-size:14px;background:var(--navy-900);padding:2px 8px;border-radius:6px}
  .pp-row{background:var(--navy-800);border:1px solid var(--line);border-radius:12px;padding:12px 14px;margin-bottom:10px}
  .pp-row .rowtop{display:flex;gap:10px;align-items:center;margin-bottom:8px}
  .pp-row input,.pp-row textarea,.pp-row select{background:var(--navy-900);border:1px solid var(--line-strong);border-radius:9px;color:var(--text);font-family:inherit;font-size:14px;padding:9px 11px}
  /* bündig: el texto ocupa TODO el ancho y crece con el contenido — nunca scroll interno */
  .pp-row textarea,#tab-props textarea{width:100%;min-height:54px;resize:none;overflow:hidden;line-height:1.55;display:block;margin-top:8px}
  .pp-row .grow{flex:1;min-width:0}
  .pp-row .rm{background:none;border:0;color:var(--muted-2);cursor:pointer;font-size:16px;padding:2px 6px}
  .pp-row .rm:hover{color:#ff8b8b}
  .pp-tier-row .tnums{display:flex;gap:8px;flex-wrap:wrap}
  .pp-tier-row .tnums input{width:90px}
  .pp-tier-row .rec{display:flex;align-items:center;gap:6px;font-size:13px;color:var(--muted);white-space:nowrap}
  .pp-tier-row textarea{width:100%;min-height:90px}
  .pp-oflink{background:none;border:1px solid var(--line-strong);border-radius:8px;color:var(--acid);font-family:inherit;font-size:11.5px;font-weight:700;padding:5px 9px;cursor:pointer;margin-left:8px}
  .pp-oflink:hover{border-color:var(--acid)}
  .pp-tier-margin{font-size:12px;color:var(--muted-2);margin-top:6px}
  @media(max-width:820px){.pp-grid{grid-template-columns:1fr 1fr}.pp-grid3{grid-template-columns:1fr}}
  /* ---- preview de blog ---- */
  .post-preview{background:var(--navy-800);border:1px solid var(--line);border-radius:14px;padding:26px 30px;max-width:760px;line-height:1.65}
  .post-preview .eyebrow{font-size:11.5px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--acid)}
  .post-preview h1{font-size:26px;margin:8px 0 12px;color:var(--text);line-height:1.2}
  .post-preview .lead{font-size:16px;color:var(--muted);margin-bottom:18px}
  .gads-kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:14px}
  .gads-kpi{border:1px solid var(--line);border-radius:12px;padding:12px 14px;display:flex;flex-direction:column;gap:4px}
  .gads-kpi b{font-size:19px;line-height:1.1}
  .gads-kpi span{font-size:11.5px;color:var(--muted)}
  .gads-roi{display:flex;gap:10px;flex-wrap:wrap;align-items:stretch}
  .gads-roi .gads-kpi{min-width:128px;justify-content:center}
  .gads-table{width:100%;border-collapse:collapse;font-size:13px;min-width:460px}
  .gads-table th,.gads-table td{padding:8px 10px;text-align:left;border-bottom:1px solid var(--line)}
  .gads-table th{color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.5px}
  .au-flow-wrap{border:1px solid var(--line);border-radius:14px;padding:20px 16px;margin-top:14px;overflow-x:auto}
  .au-flow{display:flex;flex-direction:column;align-items:center;min-width:280px}
  .au-trig-node{background:color-mix(in srgb,var(--acid) 16%,transparent);border:1px solid var(--acid);color:var(--acid);font-weight:700;font-size:13px;border-radius:100px;padding:9px 18px;white-space:nowrap;max-width:100%;text-align:center}
  .au-split-node{background:var(--navy-800);border:1px solid var(--line-strong);font-weight:700;font-size:12.5px;border-radius:100px;padding:7px 16px}
  .au-connector{width:2px;height:20px;background:var(--line-strong)}
  .au-col{display:flex;flex-direction:column;align-items:center;width:100%}
  .au-col-h{font-size:11px;font-weight:800;letter-spacing:.5px;color:var(--muted-2);text-transform:uppercase;margin-bottom:8px}
  .au-branches{display:flex;gap:22px;align-items:flex-start;width:100%;justify-content:center}
  .au-branches .au-col{flex:1;min-width:230px;max-width:340px}
  .au-branch-mid{display:flex;align-items:center;padding-top:30px}
  .au-ins-row{height:18px;display:flex;align-items:center;justify-content:center;width:100%}
  .au-ins{width:20px;height:20px;border-radius:50%;background:var(--navy-800);border:1px dashed var(--line-strong);color:var(--muted);font-size:13px;line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.15s}
  .au-ins:hover{background:var(--acid);border-color:var(--acid);color:#0f1826}
  .au-ins-popup{display:flex;gap:6px;align-items:center;padding:6px 0;width:100%;justify-content:center}
  .au-node{width:100%;border:1px solid var(--line-strong);background:var(--navy-900);border-radius:12px;margin:2px 0;cursor:grab;transition:box-shadow .15s,border-color .15s}
  .au-node.dragging{opacity:.4}
  .au-node-h{display:flex;align-items:center;gap:8px;padding:10px 10px}
  .au-drag{cursor:grab;color:var(--muted-2);font-size:13px;flex:none}
  .au-node-ic{font-size:15px;flex:none}
  .au-node-tt{flex:1;min-width:0;display:flex;flex-direction:column;gap:1px}
  .au-node-tt .au-tag{font-size:9.5px;font-weight:800;letter-spacing:.5px;color:var(--muted-2)}
  .au-node-sum{font-size:12.5px;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:220px}
  .au-node-btn{background:none;border:0;color:var(--muted-2);cursor:pointer;font-size:12px;padding:2px 3px;flex:none}
  .au-node-btn:hover{color:var(--acid)}
  .au-node-body{border-top:1px solid var(--line);padding:10px 12px 12px}
  .au-node-body label{display:block;font-size:10.5px;letter-spacing:.5px;text-transform:uppercase;color:var(--muted-2);margin:8px 0 3px}
  .au-node-body label:first-child{margin-top:0}
  .au-node-body input,.au-node-body select,.au-node-body textarea{width:100%;background:var(--navy-800);border:1px solid var(--line);border-radius:8px;color:var(--text);font-family:inherit;font-size:13.5px;padding:8px 10px}
  .au-node-body textarea{min-height:140px;resize:vertical;line-height:1.55}
  .au-field-wrap{position:relative}
  .au-field-wrap label{display:flex;align-items:center;justify-content:space-between;gap:8px}
  .au-fs-toggle{background:none;border:1px solid var(--line);border-radius:6px;color:var(--muted-2);cursor:pointer;font-size:10.5px;letter-spacing:0;text-transform:none;padding:2px 7px;flex:none}
  .au-fs-toggle:hover{color:var(--acid);border-color:var(--acid)}
  .au-field-wrap.au-fs{position:fixed;inset:16px;z-index:9999;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:14px;padding:16px 18px;display:flex;flex-direction:column;box-shadow:0 24px 60px -12px rgba(0,0,0,.6)}
  .au-field-wrap.au-fs textarea{flex:1;min-height:0;font-size:14.5px}
  body.au-fs-open{overflow:hidden}
  .au-addsel{background:var(--navy-900);border:1px solid var(--line-strong);border-radius:10px;color:var(--text);font-family:inherit;font-size:13px;padding:6px 8px}
  #au-enroll-lead{background:var(--navy-900);border:1px solid var(--line-strong);border-radius:10px;color:var(--text);font-family:inherit;font-size:13px;padding:8px 10px}
  .au-enr-row{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--line)}
  .au-enr-row:last-child{border-bottom:0}
  .au-enr-main{flex:1;min-width:0}
  .au-enr-name{font-size:13.5px;color:var(--text);font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .au-enr-step{font-size:12px;color:var(--muted);margin-top:2px}
  .au-enr-badge{font-size:10.5px;font-weight:700;letter-spacing:.3px;padding:2px 8px;border-radius:20px;flex:none}
  .au-enr-badge.active{color:#7ed957;border:1px solid #7ed957}
  .au-enr-badge.stopped{color:#ff8b8b;border:1px solid #ff8b8b}
  .au-enr-badge.done{color:var(--muted-2);border:1px solid var(--line-strong)}
  .au-enr-actions{display:flex;gap:4px;flex:none}
  .au-enr-actions button{background:none;border:1px solid var(--line);border-radius:7px;color:var(--muted);cursor:pointer;font-size:11px;padding:4px 8px}
  .au-enr-actions button:hover{color:var(--acid);border-color:var(--acid)}
  @media(max-width:720px){.au-branches{flex-direction:column;align-items:stretch}.au-branch-mid{justify-content:center;padding:6px 0}}
  .bg-group{border:1px solid var(--line);border-radius:13px;padding:4px 12px;margin-bottom:10px}
  .bg-group summary{cursor:pointer;font-weight:700;font-size:14px;padding:9px 2px;list-style:none;display:flex;align-items:center;gap:8px;user-select:none}
  .bg-group summary::before{content:'▸';color:var(--muted-2);transition:transform .15s}
  .bg-group[open] summary::before{transform:rotate(90deg)}
  .bg-group summary .count{background:var(--navy-900);border:1px solid var(--line);border-radius:20px;font-size:11px;padding:2px 9px;color:var(--muted)}
  .bg-faq{position:relative;border:1px solid var(--line);border-radius:11px;padding:12px 40px 12px 14px;margin-bottom:9px}
  .bg-faq .q{font-weight:700;font-size:14px;margin-bottom:5px}
  .bg-faq .a{font-size:13.5px;color:var(--muted);line-height:1.6}
  .bg-faq-x{position:absolute;top:8px;right:8px;background:none;border:0;color:var(--muted-2);cursor:pointer;font-size:13px}
  .bg-faq-x:hover{color:#ff8b8b}
  .post-preview [contenteditable]{border-radius:8px;transition:box-shadow .15s}
  .post-preview [contenteditable]:hover{box-shadow:0 0 0 1px var(--line-strong)}
  .post-preview [contenteditable]:focus{outline:none;box-shadow:0 0 0 1.5px var(--acid)}
  .post-preview h2{font-size:19px;margin:22px 0 8px;color:var(--text)}
  .post-preview h3{font-size:16px;margin:16px 0 6px;color:var(--text)}
  .post-preview p{color:var(--muted);margin:0 0 12px;font-size:14.5px}
  .post-preview ul,.post-preview ol{color:var(--muted);margin:0 0 12px;padding-left:20px;font-size:14.5px}
  .post-preview li{margin-bottom:5px}
  .post-preview a{color:var(--acid);text-decoration:underline}
  .post-preview strong{color:var(--text)}
  /* alta manual (personas / empresas) */
  .crm-form{margin-top:14px}
  .crm-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:10px}
  .crm-grid label{display:flex;flex-direction:column;gap:5px;font-size:11.5px;color:var(--muted);font-weight:600}
  .crm-grid label.wide{grid-column:1/-1}
  /* Companies: grid de tarjetas compactas */
  .co-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:12px;margin-top:16px}
  .co-card{display:flex;flex-direction:column;gap:12px;text-align:left;background:var(--navy-800);border:1px solid var(--line);border-radius:13px;padding:15px 16px;cursor:pointer;color:var(--text);font-family:inherit;transition:border-color .15s,transform .12s,box-shadow .2s}
  .co-card:hover{border-color:var(--line-strong);transform:translateY(-1px);box-shadow:0 8px 22px -12px rgba(0,0,0,.6)}
  .co-card-top{display:flex;align-items:center;gap:11px;min-width:0}
  .co-av{width:40px;height:40px;border-radius:10px;color:#0f1826;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:13px;flex:none}
  .co-card-id{min-width:0}
  .co-card-name{font-family:'Space Grotesk';font-weight:600;font-size:14.5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:flex;align-items:center;gap:7px}
  .co-card-dom{color:var(--muted-2);font-size:12px;margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .co-card-stats{display:flex;align-items:center;justify-content:space-between;gap:8px;border-top:1px solid var(--line);padding-top:10px;font-size:12px;color:var(--muted)}
  .co-card-val{font-family:'Space Grotesk';font-weight:700;font-size:13.5px;color:var(--text)}
  .co-card-val.zero{color:var(--muted-2);font-weight:400}
  /* --- tab A/B Tests --- */
  .ab-urlrow{display:flex;gap:8px;flex-wrap:wrap}
  .ab-urlrow input{flex:1;min-width:260px;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:10px;color:var(--text);font-family:inherit;font-size:14px;padding:10px 13px}
  .ab-cand{display:grid;grid-template-columns:110px 1fr 1fr;gap:10px;align-items:start;border:1px solid var(--line);border-radius:11px;padding:10px 12px;margin-bottom:8px;background:var(--navy-800)}
  .ab-cand .k{font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--muted-2);padding-top:10px}
  .ab-cand .orig{font-size:13px;color:var(--muted);line-height:1.5;padding-top:9px;word-break:break-word}
  .ab-cand textarea{width:100%;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:9px;color:var(--text);font-family:inherit;font-size:13.5px;padding:9px 11px;min-height:40px;resize:vertical}
  .ab-cand textarea:focus{border-color:var(--acid);outline:none}
