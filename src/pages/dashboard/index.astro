---
// pool de fotos reales (stills de rodajes) para elegir los separadores de una propuesta
import projects from '../../data/projects.json';
import videos from '../../data/videos.json';
const stillsPool = projects
  .filter((p) => p.lang === 'en' && Array.isArray(p.stills) && p.stills.length)
  .map((p) => ({ client: p.client || p.headline || 'Project', stills: p.stills }));

// catálogo de videos (Vimeo) para las tarjetas de video del newsletter
const newsVideos = videos
  .filter((v) => v && v.id && v.thumb && (v.access ? v.access === 'public' : true))
  .map((v) => ({ id: String(v.id), title: v.title || v.name || v.client || 'Video', thumb: v.thumb, client: v.client || '' }));

// case studies para las cards de case study del newsletter (páginas ya publicadas)
const newsCases = [
  { slug: 'siemens', title: 'Siemens — Employer Branding', url: 'https://www.viven.ch/en/case-study-how-viven-helped-siemens-switzerland-amplify-their-employer-branding',
    thumb: '/projects/siemens-shaping-the-future-together-employer-branding-campaign/02-RORES_clean_VIVEN.00_13_13_20.Still042.jpg' },
  { slug: 'meteomatics', title: 'Meteomatics — Video Solutions', url: 'https://www.viven.ch/en/case-study-meteomatics-simplifying-complexity-with-viven-ags-video-solutions',
    thumb: '/projects/meteomatics-product-campaign-brand-video/02-Meteomatics_VIVEN_Video_Agentur_040.jpg' },
  { slug: 'sv-group', title: 'SV Group — IT & Hospitality', url: 'https://www.viven.ch/en/case-study-sv-group-bringing-it-operations-and-hospitality-together',
    thumb: '/projects/kanebo-sensai-skincare-how-to-video-campaign/01-re_How_To_Videos_Viven_Video_Agency_51.jpg' },
];
---
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<title>Viven — Dashboard</title>
<!-- Página privada: fuera de buscadores y del sitemap -->
<meta name="robots" content="noindex,nofollow" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="theme-color" content="#0f1826" />
<!-- App móvil: instalable desde Safari → Compartir → "Añadir a pantalla de inicio" -->
<link rel="manifest" href="/dashboard.webmanifest" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="Viven CRM" />
<link rel="apple-touch-icon" href="/assets/crm-icon.png" />
<link rel="preload" as="font" type="font/woff2" href="/assets/fonts/sg-var.woff2" crossorigin />
<link rel="preload" as="font" type="font/woff2" href="/assets/fonts/inter-var.woff2" crossorigin />
<link rel="stylesheet" href="/assets/site.css" />
<script is:inline>
  // aplicar el tema guardado ANTES del primer render (sin flash)
  try { var t = localStorage.getItem('viven_theme'); if (t === 'light') document.documentElement.dataset.theme = 'light'; } catch (e) {}
</script>
<style is:global>
  /* Tema del dashboard: dark = el navy de siempre (site.css). bright = gris claro
     estilo Claude Code, más descansado de día. Se alterna con el botón ◐ y persiste. */
  :root[data-theme="light"]{
    --navy-900:#faf9f5;   /* fondo (gris cálido claro) */
    --navy-800:#ffffff;   /* tarjetas / paneles */
    --navy-700:#f0efea;   /* elementos elevados */
    --navy-600:#e2e1db;   /* hover / bordes fuertes */
    --line:rgba(20,25,35,.09);
    --line-strong:rgba(20,25,35,.18);
    --text:#1f2430;
    --muted:#5b6472;
    --muted-2:#8a919e;
    --acid:#5f7a12;       /* verde marca oscurecido: legible sobre blanco */
    --acid-dim:#4e650f;
  }
  :root[data-theme="light"] body{background:var(--navy-900);color:var(--text)}
  /* botones/pills con fondo acid: en claro usar el verde de marca real con texto oscuro */
  :root[data-theme="light"] .btn-primary,
  :root[data-theme="light"] .lead-form button[type="submit"],
  :root[data-theme="light"] .toolbar .fpill.active,
  :root[data-theme="light"] .vt-btn.active{background:#dff28b;border-color:#dff28b;color:#1c2508}
  .dash-wrap{max-width:1220px;margin:0 auto;padding:32px 24px 80px}
  .bell-wrap{position:relative}
  .bell-btn{position:relative;background:var(--navy-800);border:1px solid var(--line-strong);color:var(--text);width:38px;height:38px;border-radius:10px;font-size:17px;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1}
  .bell-btn:hover{border-color:var(--acid)}
  .bell-badge{position:absolute;top:-6px;right:-6px;min-width:18px;height:18px;padding:0 4px;border-radius:9px;background:#ff5a5a;color:#fff;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;box-shadow:0 0 0 2px var(--navy-900)}
  .bell-panel{position:absolute;top:46px;right:0;width:360px;max-width:calc(100vw - 32px);max-height:min(70vh,520px);overflow:auto;background:var(--navy-800);border:1px solid var(--line-strong);border-radius:14px;box-shadow:0 18px 50px rgba(0,0,0,.5);z-index:120}
  .bell-h{display:flex;justify-content:space-between;align-items:center;padding:13px 15px;border-bottom:1px solid var(--line);font-weight:700;font-size:14px;position:sticky;top:0;background:var(--navy-800)}
  .bell-x{background:transparent;border:0;color:var(--muted);cursor:pointer;font-size:14px}
  .bell-pushbtn{background:transparent;border:1px solid var(--line-strong);border-radius:100px;color:var(--acid);cursor:pointer;font-family:inherit;font-size:11px;font-weight:600;padding:4px 10px}
  .bell-pushbtn:hover{border-color:var(--acid)}
  .bell-grp{font-size:11px;text-transform:uppercase;letter-spacing:.05em;font-weight:700;color:var(--muted-2);padding:11px 15px 4px}
  .bell-grp.od{color:#ff8b5e}
  .bell-item{display:flex;flex-direction:column;gap:2px;width:100%;text-align:left;background:transparent;border:0;border-top:1px solid var(--line);padding:10px 15px;cursor:pointer;color:inherit;font:inherit}
  .bell-item:hover{background:color-mix(in srgb,var(--acid) 8%,transparent)}
  .bell-item .bi-t{font-size:13.5px;font-weight:600}
  .bell-item .bi-s{font-size:11.5px;color:var(--muted)}
  .bell-item .bi-due{font-size:11px;font-weight:600;color:var(--muted-2)}
  .bell-item .bi-at{font-size:10.5px;color:var(--muted-2);opacity:.8}
  .bell-item .bi-due.od{color:#ff5a5a}
  .bell-row{display:flex;align-items:stretch}
  .bell-row .bell-item{flex:1;min-width:0}
  .bell-dis{flex:none;background:none;border:0;color:var(--muted-2);cursor:pointer;font-size:11px;padding:0 12px;opacity:.5;transition:.15s}
  .bell-row:hover .bell-dis{opacity:1}
  .bell-dis:hover{color:#ff8b8b}
  .bell-empty{padding:26px 15px;text-align:center;color:var(--muted);font-size:13px}
  @media(max-width:560px){.bell-panel{position:fixed;top:60px;left:16px;right:16px;width:auto;max-width:none}}
  .dash-head{display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;margin-bottom:24px}
  /* marca clickable (misma gramática que .bk-logo/.bk-fp del booking: wordmark + label chico
     debajo) — pedido explícito: "pone mejor el logo y que eso nos lleve al home" */
  .dash-brand{display:flex;flex-direction:column;align-items:flex-start;gap:0;background:none;border:0;padding:0;cursor:pointer;font-family:inherit;text-align:left;border-radius:6px}
  .dash-brand .logo-mark{height:26px;width:auto;aspect-ratio:1374/288;color:var(--acid);display:block;transition:opacity .15s}
  .dash-brand .db-sub{font-size:9.5px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--muted-2);margin-top:6px}
  .dash-brand:hover .logo-mark{opacity:.8}
  .dash-brand:focus-visible{outline:2px solid var(--acid);outline-offset:4px}
  .dash-sub{color:var(--muted-2);font-size:13px;margin-top:4px}
  .login-card{max-width:420px;margin:12vh auto 0;border:1px solid var(--line-strong);border-radius:20px;background:var(--navy-800);padding:40px}
  .login-card .logo-mark{height:32px;width:auto;aspect-ratio:1374/288;color:var(--acid);display:block}
  .login-card .lc-sub{font-size:10px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--muted-2);margin-top:8px;margin-bottom:18px}
  .login-card p{color:var(--muted);font-size:14px;margin-bottom:24px}

  /* tabs */
  .tabs{display:flex;gap:8px;margin-bottom:28px;border-bottom:1px solid var(--line);padding-bottom:0}
  .tab{background:none;border:0;border-bottom:2px solid transparent;color:var(--muted);font-family:'Space Grotesk';font-size:16px;font-weight:600;padding:12px 18px;cursor:pointer;transition:.25s;display:inline-flex;align-items:center;gap:8px}
  .tab:hover{color:var(--text)}
  .tab.active{color:var(--acid);border-bottom-color:var(--acid)}
  .tab .pill{background:rgba(221,249,143,.14);color:var(--acid);border-radius:100px;font-size:11.5px;padding:2px 9px;font-family:'Inter'}

  .kpis{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:28px}
  .kpis.four{grid-template-columns:repeat(4,1fr)}
  .kpi{border:1px solid var(--line);border-radius:var(--radius);background:linear-gradient(180deg,var(--navy-700),var(--navy-800));padding:20px}
  .kpi .n{font-family:'Space Grotesk';font-weight:700;font-size:30px;color:var(--acid);line-height:1.1;white-space:nowrap}
  .kpi .n small{font-size:16px;color:var(--muted)}
  .kpi .l{color:var(--muted);font-size:12.5px;margin-top:6px}

  .panel{border:1px solid var(--line);border-radius:var(--radius);background:var(--navy-800);padding:24px;margin-bottom:22px;overflow-x:auto}
  .panel h2{font-size:17px;margin-bottom:16px;display:flex;align-items:center;gap:10px}
  .panel h2 .count{font-size:12px;color:var(--muted-2);font-weight:500}
  .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:22px}

  /* daily chart */
  .chart{display:flex;align-items:flex-end;gap:3px;height:120px;padding-top:8px}
  .chart .col{flex:1;display:flex;flex-direction:column;justify-content:flex-end;height:100%;position:relative;border-radius:4px 4px 0 0;background:rgba(255,255,255,.03)}
  .chart .col .fill{background:var(--acid);opacity:.85;border-radius:4px 4px 0 0;min-height:2px;transition:.3s}
  .chart .col:hover .fill{opacity:1}
  .chart .col .tip{display:none;position:absolute;bottom:calc(100% + 6px);left:50%;transform:translateX(-50%);background:var(--navy-900);border:1px solid var(--line-strong);border-radius:8px;padding:5px 9px;font-size:11px;color:var(--text);white-space:nowrap;z-index:5}
  .chart .col:hover .tip{display:block}
  .chart-labels{display:flex;justify-content:space-between;color:var(--muted-2);font-size:11px;margin-top:8px}

  /* bar rows */
  .bars{display:grid;gap:9px}
  .bar-row{display:grid;grid-template-columns:minmax(90px,160px) 1fr 88px;align-items:center;gap:12px;font-size:13px}
  .bar-row .lbl{color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .bar-row .track{height:9px;border-radius:100px;background:rgba(255,255,255,.05);overflow:hidden}
  .bar-row .fill{height:100%;border-radius:100px;background:var(--acid);min-width:2px}
  .bar-row .val{text-align:right;color:var(--text);font-weight:600;font-size:12.5px;white-space:nowrap}
  .bar-row .val small{color:var(--muted-2);font-weight:400}

  /* chart with conversion dots */
  .chart .col .dot{position:absolute;left:50%;transform:translateX(-50%);width:7px;height:7px;border-radius:50%;background:#ff9ec9;box-shadow:0 0 0 2px var(--navy-800);z-index:3}
  .chart-legend{display:flex;gap:18px;margin-top:10px;font-size:11.5px;color:var(--muted-2)}
  .chart-legend i{display:inline-block;width:10px;height:10px;border-radius:3px;margin-right:6px;vertical-align:-1px}
  .chart-legend .s{background:var(--acid)}
  .chart-legend .c{border-radius:50%;background:#ff9ec9}
  .chart-legend .p{background:#8ab4ff;opacity:.55}
  /* línea punteada del período anterior en el gráfico diario */
  .g-prev{fill:none;stroke:#8ab4ff;stroke-width:1.5;stroke-dasharray:5 4;opacity:.5}
  /* ▲▼ vs período anterior en los KPIs */
  .kdelta{font-size:11px;font-weight:700;margin-top:4px;min-height:13px}
  .kdelta.up{color:#7ed957}
  .kdelta.down{color:#ff8b8b}
  .kdelta.flat{color:var(--muted-2)}
  /* sub-tabs de Analytics: pills en UNA fila, scrolleables en móvil */
  .ana-seg{margin:0 0 18px;flex-wrap:nowrap;overflow-x:auto;padding-bottom:2px;scrollbar-width:none}
  .ana-seg::-webkit-scrollbar{display:none}
  .ana-seg button{flex:none;font-size:12px;padding:7px 14px}

  /* insight banner */
  .insights{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:22px}
  .insight{border:1px solid var(--line);border-radius:var(--radius);background:linear-gradient(180deg,var(--navy-700),var(--navy-800));padding:18px 20px}
  .insight .t{font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted-2);margin-bottom:8px;display:flex;align-items:center;gap:7px}
  .insight .v{font-family:'Space Grotesk';font-weight:700;font-size:19px;color:var(--text);line-height:1.25}
  .insight .v em{color:var(--acid);font-style:normal}
  .insight .d{color:var(--muted);font-size:12.5px;margin-top:6px}
  @media(max-width:980px){.insights{grid-template-columns:1fr}}

  /* performance table (canales / páginas que traen leads) */
  .perf{width:100%;border-collapse:collapse;font-size:13px;min-width:440px}
  .perf th{text-align:left;color:var(--muted-2);font-size:10.5px;letter-spacing:.09em;text-transform:uppercase;padding:7px 10px;border-bottom:1px solid var(--line-strong)}
  .perf th.num,.perf td.num{text-align:right}
  .perf td{padding:10px;border-bottom:1px solid var(--line);vertical-align:middle}
  .perf tr:last-child td{border-bottom:0}
  .perf .rate-cell{display:flex;align-items:center;gap:9px;justify-content:flex-end}
  .perf .rate-bar{width:56px;height:7px;border-radius:100px;background:rgba(255,255,255,.06);overflow:hidden;flex-shrink:0}
  .perf .rate-bar i{display:block;height:100%;background:var(--acid);border-radius:100px}
  .perf .rate-num{font-weight:700;color:var(--text);min-width:42px;text-align:right}
  .perf .lead-n{font-weight:700;color:var(--acid)}
  .perf .lead-n.zero{color:var(--muted-2);font-weight:400}

  /* tables */
  table.dt{width:100%;border-collapse:collapse;font-size:13.5px;min-width:820px}
  .dt th{text-align:left;color:var(--muted-2);font-size:11px;letter-spacing:.1em;text-transform:uppercase;padding:8px 12px;border-bottom:1px solid var(--line-strong)}
  .dt td{padding:11px 12px;border-bottom:1px solid var(--line);color:var(--text);vertical-align:top}
  .dt tr:hover td{background:rgba(255,255,255,.02)}
  .dt td .sub{color:var(--muted-2);font-size:12px;display:block;margin-top:2px}
  .dt .msg{max-width:260px;color:var(--muted);font-size:13px}
  .badge{display:inline-block;padding:3px 10px;border-radius:100px;font-size:11.5px;font-weight:600;background:rgba(255,255,255,.08);color:var(--muted)}
  .b-paid_search{background:rgba(66,133,244,.18);color:#8ab4f8}
  .b-paid_social{background:rgba(24,119,242,.18);color:#7ba9e8}
  .b-organic{background:rgba(52,168,83,.18);color:#81c995}
  .b-ai{background:rgba(221,249,143,.16);color:var(--acid)}
  .b-social{background:rgba(255,110,180,.16);color:#ff9ec9}
  .b-referral{background:rgba(255,190,90,.16);color:#ffd28a}
  .b-email{background:rgba(160,110,255,.18);color:#c4a7ff}
  .gclid-dot{color:var(--acid);font-weight:700;font-size:12.5px}
  select.status{background:var(--navy-900);border:1px solid var(--line-strong);border-radius:8px;color:var(--text);font-family:inherit;font-size:12.5px;padding:6px 9px;cursor:pointer}

  /* toolbar */
  .toolbar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:18px;align-items:center}
  .toolbar input[type="search"]{flex:1;min-width:180px;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:100px;padding:9px 18px;color:var(--text);font-family:inherit;font-size:13.5px}
  .toolbar input[type="search"]:focus{outline:none;border-color:var(--acid)}
  .toolbar .fpill{background:transparent;border:1px solid var(--line-strong);color:var(--muted);font-family:inherit;font-size:12.5px;font-weight:600;padding:8px 15px;border-radius:100px;cursor:pointer;transition:.25s}
  .toolbar .fpill:hover{border-color:var(--acid);color:var(--acid)}
  .toolbar .fpill.active{background:var(--acid);border-color:var(--acid);color:#142033}

  .muted-note{color:var(--muted-2);font-size:13px}
  .btn.small{padding:9px 18px;font-size:13px}
  .dt tbody tr{cursor:pointer}

  /* ---------- Lead detail modal ---------- */
  .lead-modal{position:fixed;inset:0;z-index:300;display:none;align-items:flex-start;justify-content:center;padding:5vh 20px;overflow-y:auto}
  .lead-modal.open{display:flex}
  .lead-modal .backdrop{position:fixed;inset:0;background:rgba(9,15,26,.86);backdrop-filter:blur(8px)}
  .lead-card{position:relative;z-index:2;width:min(760px,100%);background:var(--navy-800);border:1px solid var(--line-strong);border-radius:20px;padding:32px;animation:pop .35s var(--ease)}
  /* registro de contacto FULL SCREEN (como HubSpot): header/footer fijos,
     columnas laterales quietas — solo la del MEDIO scrollea */
  .lead-card-wide{width:100vw;height:100dvh;max-width:none;border-radius:0;border:0;margin:0;padding:16px 26px 12px;display:flex;flex-direction:column;overflow:hidden;animation:none}
  .lead-modal.open:has(.lead-card-wide){padding:0;overflow:hidden}
  /* header estilo HubSpot */
  .lm-top{display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;padding-bottom:16px;border-bottom:1px solid var(--line);margin-bottom:18px}
  .lm-id{display:flex;align-items:center;gap:13px;min-width:0}
  .lm-avatar{width:46px;height:46px;border-radius:50%;background:color-mix(in srgb,var(--acid) 18%,var(--navy-900));color:var(--acid);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;flex:none}
  .lm-idtext h3{margin:0;font-size:19px}
  .lm-sub{font-size:13.5px;color:var(--muted);margin-top:2px}
  .lm-sub a{color:var(--acid)}
  .lm-quick{display:flex;gap:8px;flex-wrap:wrap}
  .lm-qbtn{display:inline-flex;align-items:center;gap:6px;background:var(--navy-900);border:1px solid var(--line-strong);color:var(--text);border-radius:9px;font-size:13px;padding:8px 13px;cursor:pointer;text-decoration:none}
  .lm-qbtn:hover{border-color:var(--muted)}
  /* grid 3 columnas */
  .lm-grid{display:grid;grid-template-columns:300px 1fr 320px;gap:20px;align-items:stretch;flex:1;min-height:0}
  .lm-left,.lm-right{min-width:0;overflow-y:auto;padding-right:4px;scrollbar-width:thin}
  .lm-center{min-width:0;display:flex;flex-direction:column;gap:18px;overflow-y:auto;padding:0 6px 24px;scrollbar-width:thin;border-left:1px solid var(--line);border-right:1px solid var(--line);padding-left:22px;padding-right:22px}
  .lm-top{flex:none}
  .lead-card-wide .lead-actions{flex:none;border-top:1px solid var(--line);padding-top:10px;margin-top:10px}
  .ab-sec{margin-bottom:14px}
  .ab-sec .ab-h{font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--muted-2);font-weight:700;margin-bottom:7px}
  .ab-row{display:flex;justify-content:space-between;gap:10px;padding:4px 0;font-size:13px;line-height:1.4}
  .ab-row .ab-k{color:var(--muted);flex:none}
  .ab-row .ab-v{color:var(--text);text-align:right;word-break:break-word;min-width:0}
  .ab-row .ab-v a{color:var(--acid)}
  .ab-badge{border:1px solid;border-radius:999px;font-size:11px;font-weight:600;padding:2px 9px}
  .lm-stage-sel{background:var(--navy-800);border:1px solid;border-radius:999px;font-family:inherit;font-size:11.5px;font-weight:600;padding:3px 10px;cursor:pointer}
  .lm-stage-sel option{color:var(--text);background:var(--navy-800)}
  .lm-block{background:var(--navy-900);border:1px solid var(--line);border-radius:12px;padding:14px 16px}
  .lm-block-h{font-size:13px;font-weight:700;color:var(--text);margin-bottom:10px}
  .lm-deal{display:flex;flex-direction:column;gap:5px;width:100%;text-align:left;background:var(--navy-800);border:1px solid var(--line);border-radius:10px;padding:10px 12px;cursor:pointer;color:var(--text)}
  .lm-deal:hover{border-color:var(--muted)}
  .lm-deal-wrap{display:flex;flex-direction:column;gap:4px;margin-bottom:8px}
  .lm-conv{align-self:flex-end;background:transparent;border:0;color:var(--acid);font:inherit;font-size:11.5px;font-weight:600;cursor:pointer;padding:1px 2px}
  .lm-conv:hover{text-decoration:underline}
  .lm-mk{display:flex;gap:8px;margin-top:10px}
