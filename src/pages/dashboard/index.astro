  async function abSave(status){
    if (!abEditing){ toast('Analizá una página primero'); return; }
    const changes = [];
    $('ab-cands').querySelectorAll('textarea').forEach((t3) => {
      const v = t3.value.trim(); if (!v) return;
      const c = abCands[+t3.dataset.i];
      if (v === c.from) return;
      changes.push({ sel: c.sel, idx: c.idx, type: c.type, name: c.name || undefined, from: c.from, to: v });
    });
    if (!changes.length){ toast('No cambiaste ningún elemento — la variante B sería idéntica'); return; }
    const row = {
      name: $('ab-name').value.trim() || null, url_path: abEditing.url_path, status,
