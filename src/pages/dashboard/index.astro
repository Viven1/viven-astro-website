  // [[slug|anchor]] → link interno; para el preview usamos viven.ch, para el .astro usamos p("slug")
  const blogPreviewHtml = (html) => (html || '').replace(/\[\[([^|\]]+)\|([^\]]+)\]\]/g, (_, s, a) => '<a href="https://www.viven.ch/' + s.trim() + '/">' + a.trim() + '</a>');

  async function blogsLoad(){
