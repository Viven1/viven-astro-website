  // PDF con la misma banda navy+acid que buildOfferPdfBase64 (§ Ofertas) pero en
  // layout simple de guía/checklist — doc.save() dispara la descarga del navegador
  // directo, no queda nada guardado en Supabase (SIN infra nueva, a propósito).
  async function buildLeadMagnetPdf(draft){
    const J = await loadJsPDF();
    const doc = new J({ unit: 'pt', format: 'a4' });
    const W = doc.internal.pageSize.getWidth(), H = doc.internal.pageSize.getHeight();
    const NAVY = [15, 24, 38], ACID = [221, 249, 143], MUT = [138, 148, 168], INK = [26, 34, 48], LINE = [232, 234, 239];
    doc.setFillColor(NAVY[0], NAVY[1], NAVY[2]); doc.rect(0, 0, W, 84, 'F');
    doc.setTextColor(ACID[0], ACID[1], ACID[2]); doc.setFont('helvetica', 'bold'); doc.setFontSize(24); doc.text('viven', 48, 46);
    doc.setTextColor(154, 166, 189); doc.setFont('helvetica', 'normal'); doc.setFontSize(7); doc.text('F I L M   P R O D U C T I O N', 48, 60);
    let y = 112;
    doc.setFont('helvetica', 'bold'); doc.setFontSize(18); doc.setTextColor(INK[0], INK[1], INK[2]);
    const titleLines = doc.splitTextToSize(draft.title || 'Guide', W - 96);
    doc.text(titleLines, 48, y); y += titleLines.length * 20 + 4;
    if (draft.subtitle){
      doc.setFont('helvetica', 'normal'); doc.setFontSize(11); doc.setTextColor(MUT[0], MUT[1], MUT[2]);
      const subLines = doc.splitTextToSize(draft.subtitle, W - 96);
      doc.text(subLines, 48, y); y += subLines.length * 14 + 10;
    }
    doc.setDrawColor(LINE[0], LINE[1], LINE[2]); doc.line(48, y, W - 48, y); y += 22;
    const need = (h) => { if (y + h > H - 60){ doc.addPage(); y = 60; } };
    (draft.sections || []).forEach((sec) => {
      need(30);
      doc.setFont('helvetica', 'bold'); doc.setFontSize(12.5); doc.setTextColor(INK[0], INK[1], INK[2]);
      const hLines = doc.splitTextToSize(sec.heading || '', W - 96);
      doc.text(hLines, 48, y); y += hLines.length * 15 + 4;
      if (sec.kind === 'checklist' && Array.isArray(sec.items)){
        sec.items.forEach((it) => {
          const lines = doc.splitTextToSize(String(it), W - 130);
          need(lines.length * 13 + 8);
          doc.setDrawColor(160, 170, 190); doc.roundedRect(48, y - 9, 10, 10, 2, 2);
          doc.setFont('helvetica', 'normal'); doc.setFontSize(9.5); doc.setTextColor(60, 68, 84);
          doc.text(lines, 66, y); y += lines.length * 13 + 8;
        });
      } else {
        doc.setFont('helvetica', 'normal'); doc.setFontSize(9.5); doc.setTextColor(60, 68, 84);
        const lines = doc.splitTextToSize(String(sec.body || ''), W - 96);
        need(lines.length * 13 + 6);
        doc.text(lines, 48, y); y += lines.length * 13 + 6;
      }
      y += 8;
    });
    need(40);
    doc.setDrawColor(LINE[0], LINE[1], LINE[2]); doc.line(48, y, W - 48, y); y += 14;
    doc.setFont('helvetica', 'normal'); doc.setFontSize(7); doc.setTextColor(MUT[0], MUT[1], MUT[2]);
    doc.text(COMPANY.name + ' · ' + COMPANY.web + ' · ' + COMPANY.email, W / 2, y, { align: 'center' });
    const fname = (draft.title || 'lead-magnet').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '').slice(0, 60) + '.pdf';
    doc.save(fname);
