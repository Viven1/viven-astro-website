        '<div class="lm-idtext">' +
          '<div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap"><h3>' + esc(data.name) + '</h3>' +
            '<span class="of-badge" style="color:' + st.color + ';border-color:' + st.color + '">' + st.label + '</span></div>' +
