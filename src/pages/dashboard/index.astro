  /* ---- bl2: ⋯ de la fila (mismo patrón fixed que dlOpenMenu) ---- */
  function bl2OpenMenu(btn){
    const menu = $('bl2-menu'); if (!menu) return;
    if (!menu.hidden && menu.dataset.k === String(btn.dataset.menu)){ menu.hidden = true; return; }
    const g = bl2Groups().find((x) => String(x.key) === String(btn.dataset.menu)); if (!g) return;
    menu.dataset.k = String(g.key);
    const live = g.pub.filter((r) => r.published_url);
    menu.innerHTML =
      '<button data-act="edit" type="button">✏️ Abrir y editar</button>' +
      live.map((r) => '<button data-act="live" data-url="' + esc(r.published_url) + '" type="button">↗ Ver live ' + LANGNAME[r.lang] + '</button>').join('') +
      '<hr /><button data-act="del" class="danger" type="button">🗑 Borrar (' + g.rows.length + ' idioma' + (g.rows.length === 1 ? '' : 's') + ')</button>';
    menu.hidden = false;
    const r = btn.getBoundingClientRect();
    menu.style.left = Math.max(8, Math.min(r.right - menu.offsetWidth, window.innerWidth - menu.offsetWidth - 8)) + 'px';
    menu.style.top = Math.min(r.bottom + 6, window.innerHeight - menu.offsetHeight - 8) + 'px';
    menu.querySelectorAll('button').forEach((mb) => mb.addEventListener('click', (ev) => {
      ev.stopPropagation(); menu.hidden = true;
      const act = mb.dataset.act;
      if (act === 'edit') loadBlog((g.pub[0] || g.main).id, true);
      else if (act === 'live') window.open(mb.dataset.url, '_blank', 'noopener');
      else if (act === 'del') bl2DeleteGroup(g.key);
    }));
  }
  document.addEventListener('click', (e) => { const m = $('bl2-menu'); if (m && !m.hidden && !e.target.closest('#bl2-menu') && !e.target.closest('.bl2-dots')) m.hidden = true; });

  // aprobar = el flujo de publicación existente (publish-blog por cada idioma del grupo)
  async function bl2ApproveGroup(key){
    const g = bl2Groups().find((x) => String(x.key) === String(key)); if (!g) return;
    const vars = g.rows.filter((b) => b.status !== 'published');
    if (!vars.length) { toast('Ya está todo publicado'); return; }
    const langs = vars.map((v) => LANGNAME[v.lang] || v.lang).join(' + ');
    if (!confirm('¿Aprobar y publicar "' + (g.main.title || '') + '" en ' + langs + '?\n\nSe commitea a GitHub y sale al aire en ~1-2 min.')) return;
    for (const v of vars){
      fillBlogEditor(v);
      const ok = await publishBlog({ skipConfirm: true });
      if (!ok) { toast('⚠️ Falló ' + (LANGNAME[v.lang] || v.lang) + ' — reintentá desde el editor'); break; }
    }
    await blogsLoad();
  }
  async function bl2RejectGroup(key){
    const g = bl2Groups().find((x) => String(x.key) === String(key)); if (!g) return;
    const vars = g.rows.filter((b) => b.status !== 'published');
    if (!vars.length) return;
    if (!confirm('¿Descartar el borrador "' + (g.main.title || '') + '" (' + vars.length + ' idioma' + (vars.length === 1 ? '' : 's') + ')?\n\nNo se puede deshacer. El tema NO vuelve a la cola.')) return;
    const { error } = await supabase.from('blogs').delete().in('id', vars.map((v) => v.id));
    if (error){ toast('No se pudo borrar: ' + error.message); return; }
    const ids = new Set(vars.map((v) => String(v.id)));
    blogsList = blogsList.filter((x) => !ids.has(String(x.id)));
    if (bgCur && ids.has(String(bgCur.id))) $('bg-result').hidden = true;
    toast('🗑 Borrador descartado'); renderBlogList();
  }
  async function bl2DeleteGroup(key){
    const g = bl2Groups().find((x) => String(x.key) === String(key)); if (!g) return;
    if (!confirm('¿Borrar "' + (g.main.title || '') + '" con sus ' + g.rows.length + ' idioma' + (g.rows.length === 1 ? '' : 's') + ' de la lista?\n\n(No lo saca de la web si ya lo publicaste)')) return;
    const { error } = await supabase.from('blogs').delete().in('id', g.rows.map((v) => v.id));
    if (error){ toast('No se pudo borrar: ' + error.message); return; }
    const ids = new Set(g.rows.map((v) => String(v.id)));
    blogsList = blogsList.filter((x) => !ids.has(String(x.id)));
    if (bgCur && ids.has(String(bgCur.id))) $('bg-result').hidden = true;
    renderBlogList();
  }

  /* ---- bl2: picker visual de imagen héroe + video ---- */
