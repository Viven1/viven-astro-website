  }
  // subir/bajar una posición DENTRO de su fase (pedido explícito: "poder mover los
  // items, subirlos o bajarlos en el orden, ya que el orden es importante") — swapea
  // con el vecino más cercano de la MISMA fase en el array (no el índice adyacente
  // crudo, porque otras fases pueden estar intercaladas y el swap se vería raro)
  function moveItem(i, dir){
    const ph = phaseOf(ofCur.items[i]);
    let j = i;
    do { j += dir; } while (j >= 0 && j < ofCur.items.length && phaseOf(ofCur.items[j]) !== ph);
    if (j < 0 || j >= ofCur.items.length) return;
    const tmp = ofCur.items[i]; ofCur.items[i] = ofCur.items[j]; ofCur.items[j] = tmp;
    renderRows();
  }
  // arrastrar y soltar (⠿) para reordenar más rápido que un click a la vez —
  // pedido explícito: "que uno lo pueda agarrar y subir como quiera o bajar como en
  // servicios, mas rapido que subir y bajar uno por uno". Mismo patrón que svReorder
  // (catálogo de Servicios): reordena SOLO dentro del grupo de la MISMA fase, y
  // reinserta ese grupo reordenado en los mismos índices absolutos que ocupaba —
  // así las posiciones de otras fases intercaladas en el array no se mueven.
  function offerReorder(fromI, toI){
    if (fromI == null || toI == null || fromI === toI) return;
    const items = ofCur.items, from = items[fromI], to = items[toI];
    if (!from || !to) return;
    const ph = phaseOf(from);
    if (phaseOf(to) !== ph) return; // el dragover ya lo evita, pero por las dudas
    const idxs = []; items.forEach((it, i) => { if (phaseOf(it) === ph) idxs.push(i); });
    const group = idxs.map((i) => items[i]);
    const fi = group.indexOf(from), ti = group.indexOf(to);
    group.splice(fi, 1); group.splice(ti, 0, from);
    idxs.forEach((absI, k) => { items[absI] = group[k]; });
    renderRows();
  }
  function renderRows(){
    const tb = $('of-rows');
    let html = '';
    // agrupado por fase, en el orden del catálogo, con subtotal por fase
    PHASES.filter((ph) => ofCur.items.some((it) => phaseOf(it) === ph)).forEach((ph) => {
      html += '<tr class="of-phase"><td colspan="9">' + esc(ph) + '</td></tr>';
      const idxs = []; ofCur.items.forEach((it, i) => { if (phaseOf(it) === ph) idxs.push(i); });
      idxs.forEach((i, k) => { html += rowHTML(ofCur.items[i], i, k === 0, k === idxs.length - 1); });
      const s = phaseSubtotal(ph);
      html += '<tr class="of-sub" data-phase="' + esc(ph) + '"><td colspan="6">Subtotal ' + esc(ph) + '</td><td class="num">' + fmtM(s.net) + '</td><td class="num">' + fmtM(s.net - s.cost) + '</td><td></td></tr>';
    });
    tb.innerHTML = html;
    tb.querySelectorAll('.ofi').forEach((inp) => inp.addEventListener('input', onRowInput));
    tb.querySelectorAll('.ofi[data-f="phase"]').forEach((s) => s.addEventListener('change', renderRows));
    tb.querySelectorAll('.of-del').forEach((b) => b.addEventListener('click', () => { ofCur.items.splice(+b.dataset.i, 1); renderRows(); }));
    tb.querySelectorAll('.of-up').forEach((b) => b.addEventListener('click', () => moveItem(+b.dataset.i, -1)));
    tb.querySelectorAll('.of-down').forEach((b) => b.addEventListener('click', () => moveItem(+b.dataset.i, 1)));
    tb.querySelectorAll('.of-drag').forEach((h) => {
      h.addEventListener('dragstart', (e) => {
        ofDragI = +h.closest('tr').dataset.i;
        e.dataTransfer.effectAllowed = 'move';
        try { e.dataTransfer.setData('text/plain', String(ofDragI)); } catch (_) { /* algunos navegadores */ }
        h.closest('tr').classList.add('of-dragging');
      });
      h.addEventListener('dragend', () => { tb.querySelectorAll('tr[data-i]').forEach((r) => r.classList.remove('of-dragging', 'of-dragover')); ofDragI = null; });
    });
    tb.querySelectorAll('tr[data-i]').forEach((row) => {
      row.addEventListener('dragover', (e) => {
        if (ofDragI == null) return;
        if (phaseOf(ofCur.items[ofDragI]) !== phaseOf(ofCur.items[+row.dataset.i])) return; // solo dentro de la misma fase
        e.preventDefault(); e.dataTransfer.dropEffect = 'move'; row.classList.add('of-dragover');
      });
      row.addEventListener('dragleave', () => row.classList.remove('of-dragover'));
      row.addEventListener('drop', (e) => { e.preventDefault(); row.classList.remove('of-dragover'); offerReorder(ofDragI, +row.dataset.i); });
    });
    recalc();
  }
  function onRowInput(e){
    const tr = e.target.closest('tr'), i = +tr.dataset.i, f = e.target.dataset.f;
    let v = e.target.value;
    if (['qty', 'price', 'cost'].includes(f)) v = parseFloat(v) || 0;
    ofCur.items[i][f] = v;
    if (['qty', 'price', 'cost'].includes(f)){
      const it = ofCur.items[i], total = (Number(it.qty) || 0) * (Number(it.price) || 0), margin = total - (Number(it.qty) || 0) * (Number(it.cost) || 0);
      tr.children[6].textContent = fmtM(total);
      tr.children[7].textContent = fmtM(margin);
      tr.children[7].style.color = margin >= 0 ? '#7ed957' : '#ff8b8b';
      // actualizar el subtotal de la fase en vivo (sin re-render, para no perder el foco)
      const s = phaseSubtotal(phaseOf(it));
      const sub = $('of-rows').querySelector('.of-sub[data-phase="' + phaseOf(it) + '"]');
      if (sub){ sub.children[1].textContent = fmtM(s.net); sub.children[2].textContent = fmtM(s.net - s.cost); }
      recalc();
    }
  }
  function recalc(){
    const net = offerNet(ofCur), cost = offerCost(ofCur);
    const sum0 = (ofCur.items || []).reduce((a, it) => a + (Number(it.qty) || 0) * (Number(it.price) || 0), 0);
    $('of-discamt').textContent = (sum0 - net) > 0.005 ? '− ' + fmtM(sum0 - net) : 'CHF 0.00';
    const vat = net * (parseFloat($('of-vat').value) || 0) / 100;
    const profit = net - cost, mp = net ? profit / net * 100 : 0;
    $('of-net').textContent = fmtM(net);
    $('of-vatamt').textContent = fmtM(vat);
    $('of-gross').textContent = fmtM(net + vat);
    $('of-cost').textContent = fmtM(cost);
    $('of-profit').textContent = fmtM(profit);
    $('of-profit').className = profit >= 0 ? 'pos' : 'neg';
    $('of-marginpct').textContent = Math.round(mp) + '%';
    $('of-marginpct').className = mp >= 50 ? 'pos' : mp >= 30 ? '' : 'neg';
    $('of-bep').textContent = cost > 0
      ? 'Breakeven en ' + fmtM(cost) + ' de costo externo. Podés descontar hasta ' + fmtM(profit) + ' (' + Math.round(mp) + '%) antes de perder plata.'
      : 'Sin costo externo cargado — todo el neto es margen.';
  }

