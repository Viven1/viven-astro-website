      CO_FIELDS.map(([k, l]) => '<div><div class="k">' + l + '</div><div class="v lm2-edit co2-fld" data-f="' + k + '" title="Click para editar">' + (m[k] ? esc(String(m[k])) : '<span style="color:var(--muted-2)">—</span>') + '</div></div>').join('') + '</div>' +
      (!coMeta[domain] ? '<p class="muted-note" style="margin-top:12px;font-size:11px">Empresa agrupada por dominio: al editar un campo se crea su ficha en la base.</p>' : '');
