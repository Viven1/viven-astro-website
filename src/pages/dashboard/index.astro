  function renderBlogList(){
    const box = $('bg-list'); $('bg-list-h').hidden = !blogsList.length;
    const badge = { draft: ['Borrador', '#8ab4ff'], published: ['Publicado', '#7ed957'] };
    // agrupar por group_id para ver qué idiomas ya existen
    const langsByGroup = {}; blogsList.forEach((b) => { (langsByGroup[b.group_id] = langsByGroup[b.group_id] || new Set()).add(b.lang); });
    box.innerHTML = blogsList.map((b) => { const bd = badge[b.status] || badge.draft;
      const have = langsByGroup[b.group_id] || new Set();
      const missing = ['en', 'de', 'es'].filter((l) => l !== b.lang && !have.has(l));
      const langBtns = missing.map((l) => '<button class="of-act" data-act="loc" data-l="' + l + '" data-id="' + b.id + '" type="button">+ ' + LANGNAME[l] + '</button>').join('');
      return '<div class="of-card"><div class="of-card-open" data-id="' + b.id + '">' +
        '<div class="of-card-main"><div class="of-card-title">' + esc(b.title || '(sin título)') + ' <span class="of-badge" style="color:#c58af9;border-color:#c58af9;font-size:10px">' + LANGNAME[b.lang] + '</span></div>' +
        '<div class="of-card-sub">' + esc(b.topic || b.slug || '') + ' · ' + new Date(b.updated_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short' }) + '</div></div>' +
        '<span class="of-badge" style="color:' + bd[1] + ';border-color:' + bd[1] + '">' + bd[0] + '</span></div>' +
        '<div class="of-actions">' + langBtns +
          '<button class="of-act danger" data-act="del" data-id="' + b.id + '" type="button">🗑 Borrar</button>' +
        '</div></div>';
    }).join('');
    box.querySelectorAll('.of-card-open').forEach((c) => c.addEventListener('click', () => loadBlog(c.dataset.id)));
    box.querySelectorAll('.of-act').forEach((btn) => btn.addEventListener('click', (e) => {
      e.stopPropagation(); const id = btn.dataset.id, act = btn.dataset.act;
