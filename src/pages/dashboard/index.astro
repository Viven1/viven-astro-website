  const PHASES = Object.keys(RATECARD);   // Development · Pre-Production · Production · Post-Production · Delivery
  const fmtM = (n) => 'CHF ' + (Number(n) || 0).toLocaleString('de-CH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  // Facturación y Portal del cliente: pausadas a pedido de Sebastián (2026-07-12)
  // — demasiadas features nuevas juntas, las retomamos más adelante mejor
  // pulidas. El código y las tablas quedan intactos, solo se ocultan los
  // botones/paneles — reactivar es cambiar estos dos a true.
  const FEATURE_INVOICING = false;
  const FEATURE_PORTAL = false;
  let offersList = [], ofCur = null, offersBuilt = false, inquiryFromLead = '', showArchived = false, curInvoice = null;

  function offersInit(){ buildPresetSelect(); if (!offersBuilt){ offersBuilt = true; bindOffers(); } showEditor(false); offersLoad(); }

  /* ================= A/B TESTS: variantes servidas por site.js =================
     El wizard analiza la página (fetch same-origin + DOMParser), extrae H1/lead/
     CTAs/imágenes editables, guarda los cambios en ab_tests y el sitio hace el
     resto: split por visitante, exposiciones en ab_hits y leads taggeados (.ab). */
  let abBuilt = false, abTests = [], abCands = [], abEditing = null;
  function abInit(){
    if (!abBuilt){
      abBuilt = true;
      $('ab-new').addEventListener('click', () => { abEditing = null; $('ab-wiz').hidden = false; $('ab-editor').hidden = true; $('ab-url').value = ''; $('ab-wiz-note').textContent = ''; });
      $('ab-cancel').addEventListener('click', () => { $('ab-wiz').hidden = true; });
      $('ab-analyze').addEventListener('click', abAnalyze);

      // Google Ads — conversiones offline (CSV con el formato exacto del import oficial)
      const adsIsWon = (r) => /ganado|won|cerrado/i.test(r.status || '');
      const ADS_TEST = /@viven\.ch$|@entropia|@example\.|test/i;   // mismos patrones anti-test que review-request
      const adsOk = (r) => !r.ads_exclude && !ADS_TEST.test(r.email || '') && !/spam|descartado|perdido-spam/i.test(r.status || '');
      const adsFetch = async () => {
        let q = await supabase.from('leads').select('id,gclid,name,email,deal_value,status,created_at,won_at,last_stage_at,utm_campaign,ads_exclude').not('gclid', 'is', null);
        if (q.error && /column/.test(q.error.message || '')) q = await supabase.from('leads').select('id,gclid,name,email,deal_value,status,created_at,won_at,last_stage_at,utm_campaign').not('gclid', 'is', null);
        return q;
      };
      const chf = (n) => 'CHF ' + (+n || 0).toLocaleString('de-CH');
      window.gadsLoad = async () => {
        adsInfoLoad();
        const { data } = await adsFetch();
        const all = data || [];
        const rows = all.filter(adsOk), won = rows.filter(adsIsWon);
        const wonVal = won.reduce((a2, r) => a2 + (+r.deal_value || 0), 0);
        const openVal = rows.filter((r) => !adsIsWon(r) && !/perdido|lost/i.test(r.status || '')).reduce((a2, r) => a2 + (+r.deal_value || 0), 0);
        let sess = 0; const sessByCamp = {};
        try {
          const { data: pv } = await supabase.from('pageviews').select('session_id,utm_campaign,gclid,channel').or('channel.eq.paid_search,gclid.not.is.null').limit(20000);
          const seen = new Set();
          (pv || []).forEach((p) => { if (p.session_id && !seen.has(p.session_id)){ seen.add(p.session_id); sess++; const c = p.utm_campaign || '(sin campaña)'; sessByCamp[c] = (sessByCamp[c] || 0) + 1; } });
        } catch (e) { /* pageviews aún sin esas columnas */ }
        $('gads-sess').textContent = sess || '–';
        $('gads-leads').textContent = rows.length;
        $('gads-cr').textContent = sess ? Math.round((rows.length / sess) * 100) + '%' : '–';
        $('gads-won').textContent = won.length;
        $('gads-wonval').textContent = chf(wonVal);
        $('gads-pipe').textContent = chf(openVal);
        // datos oficiales de la API (si el token ya fue aprobado, mandan sobre lo manual)
        let official = null;
        try { const { data: gs } = await supabase.functions.invoke('gads-stats', { body: {} }); if (gs && gs.ok) official = gs; else if (gs && gs.pending && $('gads-official')) $('gads-official').innerHTML = '<p class="muted-note">⏳ Esperando la aprobación del developer token por parte de Google (' + esc(gs.reason || 'Basic access pendiente') + '). Este bloque se enciende solo cuando llegue el mail — sin tocar nada.</p>'; } catch (e) { /* función aún no deployada */ }
        if (official && $('gads-official')){
          $('gads-official').innerHTML = '<div class="gads-kpis" style="margin-bottom:12px">' +
            '<div class="gads-kpi"><b>' + chf(Math.round(official.total.cost)) + '</b><span>Gasto (30d)</span></div>' +
            '<div class="gads-kpi"><b>' + official.total.clicks.toLocaleString('de-CH') + '</b><span>Clicks</span></div>' +
            '<div class="gads-kpi"><b>' + official.total.impressions.toLocaleString('de-CH') + '</b><span>Impresiones</span></div>' +
            '<div class="gads-kpi"><b>' + (official.total.clicks ? chf((official.total.cost / official.total.clicks).toFixed(2)) : '–') + '</b><span>CPC medio</span></div>' +
          '</div>' +
          '<table class="gads-table"><thead><tr><th>Campaña</th><th>Estado</th><th>Gasto</th><th>Clicks</th><th>Impresiones</th><th>Conv.</th></tr></thead><tbody>' +
          official.campaigns.map((c) => '<tr><td>' + esc(c.name) + '</td><td>' + (c.status === 'ENABLED' ? '🟢' : '⏸') + '</td><td>' + chf(Math.round(c.cost)) + '</td><td>' + c.clicks + '</td><td>' + c.impressions.toLocaleString('de-CH') + '</td><td>' + c.conversions + '</td></tr>').join('') +
          '</tbody></table>';
        }
        let spend = 0;
        if (official) spend = Math.round(official.total.cost);
        if (!spend){ try { const { data: st } = await supabase.from('ads_settings').select('spend').eq('id', 1).maybeSingle(); spend = +((st || {}).spend || 0); } catch (e) { /* tabla pendiente (SQL 0037) */ } }
        if (!spend) spend = +(localStorage.getItem('vv_ads_spend') || 0);
        if ($('gads-spend-in') && document.activeElement !== $('gads-spend-in')) $('gads-spend-in').value = spend || '';
        $('gads-cpl').textContent = spend && rows.length ? chf(Math.round(spend / rows.length)) : '–';
        $('gads-cpa').textContent = spend && won.length ? chf(Math.round(spend / won.length)) : '–';
        $('gads-roas').textContent = spend ? (wonVal / spend).toFixed(1) + '×' : '–';
        const camps = {};
        rows.forEach((r) => { const c = r.utm_campaign || '(sin campaña)'; camps[c] = camps[c] || { leads: 0, won: 0, val: 0 }; camps[c].leads++; if (adsIsWon(r)){ camps[c].won++; camps[c].val += (+r.deal_value || 0); } });
        Object.keys(sessByCamp).forEach((c) => { camps[c] = camps[c] || { leads: 0, won: 0, val: 0 }; });
        const names = Object.keys(camps);
        $('gads-camps').innerHTML = !names.length ? '<p class="muted-note">Sin datos todavía — aparecen solos cuando lleguen sesiones o leads con gclid.</p>' :
          '<table class="gads-table"><thead><tr><th>Campaña</th><th>Sesiones</th><th>Leads</th><th>Ganados</th><th>Valor</th></tr></thead><tbody>' +
          names.sort((a2, b2) => (camps[b2].leads - camps[a2].leads) || ((sessByCamp[b2] || 0) - (sessByCamp[a2] || 0))).map((c) =>
            '<tr><td>' + esc(c) + '</td><td>' + (sessByCamp[c] || 0) + '</td><td>' + camps[c].leads + '</td><td>' + camps[c].won + '</td><td>' + chf(camps[c].val) + '</td></tr>').join('') +
          '</tbody></table>';
        $('gads-nlist').textContent = all.length;
        $('gads-list').innerHTML = all.map((r) => {
          const out = !adsOk(r);
          return '<div class="of-card"><div class="of-card-open" data-glead="' + r.id + '">' +
            '<div class="of-card-main"><div class="of-card-title">' + (out ? '🚫 ' : '🎯 ') + esc(r.name || r.email || '(sin nombre)') + (adsIsWon(r) ? ' <span class="of-badge" style="color:#7ed957;border-color:#7ed957">Ganado</span>' : '') + '</div>' +
            '<div class="of-card-sub">' + esc(r.email || '') + ' · ' + esc(r.utm_campaign || 'sin campaña') + ' · ' + new Date(r.created_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short' }) + (out ? ' · <b>no se reporta</b>' : '') + '</div></div>' +
            '<span class="of-badge">' + chf(r.deal_value) + '</span></div></div>';
        }).join('') || '<p class="muted-note">Todavía no llegó ningún lead desde Ads.</p>';
        $('gads-list').querySelectorAll('[data-glead]').forEach((c) => c.addEventListener('click', () => { gotoTab('leads'); openLead(c.dataset.glead); }));
      };
      $('gads-spend-save') && $('gads-spend-save').addEventListener('click', async () => {
        const v = +($('gads-spend-in').value || 0);
        localStorage.setItem('vv_ads_spend', String(v));
        try { const { error } = await supabase.from('ads_settings').upsert({ id: 1, spend: v, updated_at: new Date().toISOString() }); if (error) throw error; toast('💾 Inversión guardada'); }
        catch (e) { toast('Guardada en este dispositivo (corré el SQL 0037 para sincronizarla entre dispositivos)'); }
        window.gadsLoad();
      });

      // Newsletter
      $('nw-count') && $('nw-count').addEventListener('click', nwShowRecipients);
      $('nw-blog') && $('nw-blog').addEventListener('click', async () => {
        const { data } = await supabase.from('blogs').select('title,lead,published_url,lang,published_at').eq('status', 'published').order('published_at', { ascending: false }).limit(1);
        const b = (data || [])[0]; if (!b){ toast('Todavía no hay artículos publicados'); return; }
        $('nw-subject').value = b.title; if (b.lang) $('nw-lang').value = b.lang;
        $('nw-body').value = (b.lead || '') + '\n\n' + ((b.lang === 'de' ? 'Weiterlesen: ' : b.lang === 'es' ? 'Leé el artículo completo: ' : 'Read the full article: ') + (b.published_url || 'https://www.viven.ch/blog/'));
        nwCur = null; nwExcludeIds = new Set(); nwExtraEmails = []; $('nw-note').textContent = 'Prefill con el último artículo — editá y mandá.';
      });
      $('nw-test') && $('nw-test').addEventListener('click', async () => {
        const id = await nwSave(); if (!id) return;
        const { data: s2 } = await supabase.auth.getUser();
        const me = s2 && s2.user && s2.user.email; if (!me){ toast('Sin email de sesión'); return; }
        $('nw-note').textContent = 'Enviando test…';
        const { data, error } = await supabase.functions.invoke('newsletter-send', { body: { id, test_to: me } });
        $('nw-note').textContent = error ? '⚠️ ' + error.message : (data && data.error) ? '⚠️ ' + data.error : '✉️ Test enviado a ' + me + ' — revisá tu inbox.';
      });
      $('nw-mode') && $('nw-mode').addEventListener('change', () => {
        $('nw-one-wrap').hidden = $('nw-mode').value !== 'one';
      });
      $('nw-ai') && $('nw-ai').addEventListener('click', async () => {
        const topic = $('nw-subject').value.trim();
        if (!topic){ toast('Poné un tema/título en Asunto primero'); return; }
        const btn = $('nw-ai'), prev = btn.textContent; btn.disabled = true; btn.textContent = '✨ Escribiendo…';
        try {
          const lg = $('nw-lang').value === 'all' ? 'en' : $('nw-lang').value;
          const { data, error } = await supabase.functions.invoke('ai-newsletter', { body: { topic, notes: $('nw-ai-notes').value.trim(), lang: lg } });
          if (error || (data && data.error)){ toast('⚠️ ' + (error ? error.message : data.error)); return; }
          $('nw-subject').value = data.subject; $('nw-body').value = data.body;
          $('nw-note').textContent = '✨ Borrador generado (' + lg.toUpperCase() + ') — revisá y editá antes de mandar.';
        } finally { btn.disabled = false; btn.textContent = prev; }
      });
      $('nw-send') && $('nw-send').addEventListener('click', async () => {
        const toOne = $('nw-mode').value === 'one';
        const oneEmail = $('nw-one-email').value.trim();
        if (toOne && (!oneEmail || !oneEmail.includes('@'))){ toast('Poné un email válido'); return; }
        const id = await nwSave(); if (!id) return;
        if (!confirm(toOne ? '¿Enviar directo a ' + oneEmail + '?' : '¿Enviar esta campaña al segmento seleccionado?\n\nNo se puede deshacer.')) return;
        $('nw-note').textContent = 'Enviando…'; $('nw-send').disabled = true;
