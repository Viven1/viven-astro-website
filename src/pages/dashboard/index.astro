  async function saveProp(publish, opts){
    const auto = !!(opts && opts.auto);   // autosave: silencioso, sin diálogos, sin re-render (no romper el foco)
    collectEditor();
    if (!ppCur.title){ if (!auto) toast('Ponele un título a la propuesta'); return; }
    if (publish){
      // validación de publish: lo que el cliente necesita sí o sí para abrir/aceptar
      const missing = [];
      if (!ppCur.client_name) missing.push('nombre del cliente');
      if (!/\S+@\S+\.\S+/.test(ppCur.client_email || '')) missing.push('email del cliente');
      if (!(ppCur.tiers || []).some((t) => Number(t.price) > 0)) missing.push('al menos 1 paquete con precio > 0');
      if (!ppCur.password) missing.push('password');
      if (missing.length){ toast('Antes de publicar falta: ' + missing.join(' · ')); return; }
    }
    if (!ppCur.slug) ppCur.slug = makeSlug(ppCur.title);
    if (publish) ppCur.status = 'sent';
    // sync pipeline: sin lead ligado, ofrecer crear la persona con el email del cliente (nunca en autosave: abre un confirm)
    if (!auto && !ppCur.lead_id && ppCur.client_name){
      const lid = await ensureLeadFor(ppCur.client_name, ppCur.client_email || null, ppCur.status === 'accepted' ? 'won' : 'sent');
      if (lid){ ppCur.lead_id = lid; $('pp-lead').innerHTML = leadOptions(lid); }
    }
    if (!auto && dealsReal && ppCur.lead_id && !ppCur.deal_id){
      let od4 = openDealOf(ppCur.lead_id);
      if (od4 && od4.synthetic) od4 = await ensureRealDeal(od4);
      if (od4) ppCur.deal_id = od4.id;
    }
    const payload = { slug: ppCur.slug, password: ppCur.password || '', title: ppCur.title, client_name: ppCur.client_name, client_email: ppCur.client_email, lead_id: ppCur.lead_id, deal_id: ppCur.deal_id || null, status: ppCur.status, content: buildContent() };
    // primer publish: estampar published_at (base del semáforo "esperando hace" de la lista) —
    // solo la primera vez: re-publicar una propuesta ya enviada NO reinicia el reloj
    const rowPrev = ppCur.id ? (ppList || []).find((x) => String(x.id) === String(ppCur.id)) : null;
    if (publish && !(rowPrev && rowPrev.published_at)) payload.published_at = new Date().toISOString();
    const btn = publish ? $('pp-publish') : $('pp-save'), prev = btn.textContent;
    if (!auto){ btn.disabled = true; btn.textContent = '…'; }
    ppSaving = true;
    const doProp = (p) => ppCur.id
      ? supabase.from('proposals').update(p).eq('id', ppCur.id).select().single()
      : supabase.from('proposals').insert(p).select().single();
    let res = await doProp(payload);
    if (res.error && /deal_id/.test(res.error.message || '')) { delete payload.deal_id; res = await doProp(payload); }
    // resiliente: si la columna published_at todavía no existe (falta la migración 0058), guardar igual sin ella
    if (res.error && /published_at/.test(res.error.message || '')) { delete payload.published_at; res = await doProp(payload); }
    ppSaving = false;
    if (!auto){ btn.disabled = false; btn.textContent = prev; }
    if (res.error){ if (!auto) toast('No se pudo guardar (¿corriste el SQL 0004?): ' + res.error.message); return; }
    ppCur.id = res.data.id; ppCur.status = res.data.status;
    ppLastSaved = Date.now(); autosaveNote('pp3-autosave', ppLastSaved);
    if (auto){
      // refrescar la fila en memoria sin re-dibujar el editor (el usuario sigue tipeando)
      const i = (ppList || []).findIndex((x) => String(x.id) === String(res.data.id));
      if (i >= 0) ppList[i] = res.data; else ppList.unshift(res.data);
      return;
    }
    toast(publish ? 'Propuesta publicada ✅' : 'Guardada');
    fillPropEditor(); ppLoad();
  }
