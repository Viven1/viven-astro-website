  // en táctil el drag nativo secuestra el scroll (iOS): ahí la etapa se cambia desde el contacto
  const PIPE_DRAG = !(window.matchMedia && window.matchMedia('(pointer: coarse)').matches);
  // pager móvil: navegación por etapas con flechas (funciona aunque el touch-scroll falle)
  let pgrIdx = 0, pgrBound = false;
  function pipePager(){
    const pager = $('pipe-pager'); if (!pager) return;
    const cols = [...document.querySelectorAll('#pipeline .pipe-col')];
    const mobile = window.matchMedia('(max-width: 820px)').matches;
    pager.hidden = !mobile || cols.length < 2;
    if (pager.hidden) return;
    if (!pgrBound){
      pgrBound = true;
      $('pgr-prev').addEventListener('click', () => pgrGo(-1));
      $('pgr-next').addEventListener('click', () => pgrGo(1));
      $('pipeline').addEventListener('scroll', () => { clearTimeout(pipePager._t); pipePager._t = setTimeout(pgrSync, 120); }, { passive: true });
    }
    pgrIdx = Math.min(pgrIdx, cols.length - 1);
    pgrPaint(cols);
  }
  function pgrGo(dir){
    const cols = [...document.querySelectorAll('#pipeline .pipe-col')];
    pgrIdx = Math.max(0, Math.min(cols.length - 1, pgrIdx + dir));
    const col = cols[pgrIdx];
    if (col) $('pipeline').scrollTo({ left: col.offsetLeft - 14, behavior: 'smooth' });
    pgrPaint(cols);
  }
  function pgrSync(){
    const pipe = $('pipeline'); const cols = [...document.querySelectorAll('#pipeline .pipe-col')];
    if (!cols.length) return;
    let best = 0, bd = Infinity;
    cols.forEach((c, i) => { const d = Math.abs(c.offsetLeft - 14 - pipe.scrollLeft); if (d < bd){ bd = d; best = i; } });
    pgrIdx = best; pgrPaint(cols);
  }
  function pgrPaint(cols){
    const col = cols[pgrIdx]; if (!col) return;
    const st = STAGES.find((x) => x.key === col.dataset.stage) || {};
    const cnt = col.querySelectorAll('.pipe-card').length;
    $('pgr-label').innerHTML = '<span class="dot" style="background:' + (st.color || 'var(--muted)') + '"></span>' + esc(st.label || col.dataset.stage) + ' <span class="n">' + cnt + '</span> · ' + (pgrIdx + 1) + '/' + cols.length;
    $('pgr-prev').disabled = pgrIdx === 0;
    $('pgr-next').disabled = pgrIdx === cols.length - 1;
