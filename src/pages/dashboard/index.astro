  // timeline agregada: emails + notas + tasks (por DB, sobre TODOS los contactos) + ofertas ganadas (memoria)
  async function coLoadTimeline(data){
    const box = $('co-tl'); if (!box) return;
    const ids = data.contacts.map((l) => String(l.id));
    if (!ids.length){ box.innerHTML = '<p class="muted-note">Sin contactos — la actividad de sus personas va a aparecer acá.</p>'; return; }
    const nameOf = (id) => { const l = data.contacts.find((c) => String(c.id) === String(id)); return l ? (l.name || l.email) : ''; };
    const q = (t) => t.then((x) => (x && !x.error && x.data) || []).catch(() => []);
    const [emails, notes, tasks] = await Promise.all([
      q(supabase.from('email_log').select('*').in('lead_id', ids).order('created_at', { ascending: false }).limit(100)),
      q(supabase.from('lead_notes').select('*').in('lead_id', ids).order('created_at', { ascending: false }).limit(100)),
      q(supabase.from('lead_tasks').select('*').in('lead_id', ids).order('created_at', { ascending: false }).limit(100)),
    ]);
    if (coCur !== data.domain) return; // cambió de empresa mientras cargaba
    const ev = [];
    emails.forEach((e2) => ev.push({ t: e2.created_at, chip: ['email', e2.direction === 'in' ? '📥 Recibido' : '✉️ Enviado'], title: '<b>' + esc(e2.subject || '(sin asunto)') + '</b>', meta: esc(e2.sender_label || ''), who: nameOf(e2.lead_id) }));
    notes.forEach((n) => ev.push({ t: n.created_at, chip: ['nota', '📝 Nota'], title: esc((n.body || '').slice(0, 140)) + ((n.body || '').length > 140 ? '…' : ''), meta: esc(n.author || ''), who: nameOf(n.lead_id) }));
    tasks.forEach((t) => ev.push({ t: t.created_at, chip: ['task', t.done ? '✅ Task hecha' : '⏳ Task'], title: esc(t.title), who: nameOf(t.lead_id) }));
    data.contacts.forEach((l) => offersForLead(l.id).filter((o) => o.status === 'won').forEach((o) => ev.push({ t: o.updated_at || o.created_at, chip: ['sys', '🏆 Ganada'], title: '<b>' + esc(o.title || 'Oferta') + '</b> · ' + fmtChf(offerNet(o)), who: l.name || l.email })));
    ev.sort((a, b) => new Date(b.t) - new Date(a.t));
    box.innerHTML = ev.length
      ? '<div class="lm2-tl">' + ev.slice(0, 100).map((e2) => '<div class="lm2-ev"><div class="when">hace ' + timeAgo(e2.t) + '</div><div class="card"><span class="lm2-chip ' + e2.chip[0] + '">' + e2.chip[1] + '</span>' + e2.title + ((e2.meta || e2.who) ? '<div class="meta">' + [e2.meta, e2.who ? 'en ' + esc(e2.who) : ''].filter(Boolean).join(' · ') + '</div>' : '') + '</div></div>').join('') + '</div>'
      : '<p class="muted-note">Sin actividad todavía — los emails, notas y tasks de sus contactos van a aparecer acá.</p>';
  }
  // rail izquierdo: ficha editable inline (click en el valor → input; Enter guarda, Esc cancela).
