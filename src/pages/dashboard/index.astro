  // gráfico SVG — reusa las mismas clases .gsvg/.g-grid/.g-yl/.g-xl/.g-line del chart de Analytics,
  // + línea punteada roja del umbral mínimo (no existe en Analytics, se agrega inline)
  function cfRenderChart(){
    const series = cfPeriod === 'weekly' ? cfWeeks : cfMonths;
    const box = $('cf-chart'); if (!box) return;
    if (!series.length){ box.innerHTML = '<p class="muted-note">Sin datos suficientes — cargá un saldo bancario en Configuración.</p>'; return; }
    const n = series.length, W = 1000, H = 260, padL = 66, padR = 14, padT = 16, padB = 28;
    const pw = W - padL - padR, ph = H - padT - padB;
    const threshold = Number((cfSettings && cfSettings.min_balance_threshold_chf) || 0);
    const vals = series.map((s) => s.balance);
    const minV = Math.min(0, threshold, ...vals), maxV = Math.max(threshold, ...vals, 1);
    const range = (maxV - minV) || 1;
    const X = (i) => padL + (n <= 1 ? pw / 2 : (i / (n - 1)) * pw);
    const Y = (v) => padT + (1 - (v - minV) / range) * ph;
    const pts = series.map((s, i) => [X(i), Y(s.balance)]);
    const linePath = pts.map((p, i) => (i ? 'L' : 'M') + p[0].toFixed(1) + ' ' + p[1].toFixed(1)).join(' ');
    const thY = Y(threshold);
    const grid = [minV, (minV + maxV) / 2, maxV].map((v) => {
      const y = Y(v);
      return '<line x1="' + padL + '" y1="' + y.toFixed(1) + '" x2="' + (W - padR) + '" y2="' + y.toFixed(1) + '" class="g-grid"/>' +
        '<text x="' + (padL - 8) + '" y="' + (y + 4).toFixed(1) + '" class="g-yl">' + cfCHF(v) + '</text>';
    }).join('');
    const step = Math.max(1, Math.ceil(n / 8));
    const xls = series.map((s, i) => ((i % step === 0) || i === n - 1) ? '<text x="' + X(i).toFixed(1) + '" y="' + (H - 8) + '" class="g-xl" text-anchor="middle">' + s.label + '</text>' : '').join('');
    const hover = series.map((s, i) => '<circle cx="' + X(i).toFixed(1) + '" cy="' + Y(s.balance).toFixed(1) + '" r="10" fill="transparent"><title>' + s.label + ': ' + cfCHF(s.balance) + '</title></circle>').join('');
    box.innerHTML = '<svg viewBox="0 0 ' + W + ' ' + H + '" class="gsvg">' + grid +
      '<line x1="' + padL + '" y1="' + thY.toFixed(1) + '" x2="' + (W - padR) + '" y2="' + thY.toFixed(1) + '" stroke="#ff8b8b" stroke-width="1.5" stroke-dasharray="5,4"/>' +
      '<path d="' + linePath + '" class="g-line"/>' + hover + xls + '</svg>';
    $('cf-chart-cap').textContent = 'Línea punteada roja = umbral mínimo (' + cfCHF(threshold) + ') · saldo proyectado en verde';
  }

  function cfRenderTable(){
    const box = $('cf-table'); if (!box) return;
