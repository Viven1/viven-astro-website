    const isActive = (r) => ['running', 'stopped', 'draft'].includes(r.eff);
    // primario = test activo con más sesiones; el resto colapsa
    const active = rows.filter(isActive);
    if (abExpandedId == null || !rows.some((r) => String(r.t.id) === String(abExpandedId))){
      const prim = active.slice().sort((a, b) => (b.ea + b.eb) - (a.ea + a.eb))[0] || rows[0];
      abExpandedId = prim.t.id;
