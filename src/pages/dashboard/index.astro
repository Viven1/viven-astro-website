      if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(em)){ toast('Poné un email válido'); return; }
      if (matched.some((r) => (r.email || '').toLowerCase() === em) || nwExtraEmails.includes(em)){ toast('Ese email ya está en la lista'); return; }
