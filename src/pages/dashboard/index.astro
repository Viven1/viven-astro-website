  function renderAbList(exp, abLeads){
    const box = $('ab-list');
    if (!abTests.length){ box.innerHTML = '<p class="muted-note">Sin tests todavía. Creá el primero con ➕ — probá un H1 distinto en una página de servicio.</p>'; return; }
    // color por estado (no hay vars --won/--warn en este dashboard, se usan los hex del resto del tab)
    const chip = { draft: ['Borrador', '#8ab4ff'], running: ['● Corriendo', '#7ed957'], stopped: ['⏹ Terminado (auto-stop)', '#f0c060'], done_a: ['Ganó A (original)', '#8a94a8'], done_b: ['✓ B desplegado', '#ddf98f'] };
