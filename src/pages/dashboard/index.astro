          return '<button class="co-tr co-tr-deals" data-oid="' + o.id + '" type="button"><span class="co-td-name">' + esc(o.title || '(sin título)') + '</span><span class="co-td-amt">' + fmtM(offerNet(o)) + '</span><span><span class="of-badge" style="color:' + b[1] + ';border-color:' + b[1] + '">' + b[0] + '</span></span></button>'; }).join('') + '</div>'
      : '<p class="muted-note">Sin ofertas todavía.</p>';
    $('co-deals').querySelectorAll('[data-oid]').forEach((d) => d.addEventListener('click', () => { gotoTab('offers'); openOffer(d.dataset.oid); }));
    // actividad agregada de toda la empresa (tasks + notas de todos los contactos)
    $('co-right').innerHTML = '<div class="lm-block"><div class="lm-block-h">📌 Actividad de la empresa</div><div id="co-activity"><p class="muted-note">Cargando…</p></div></div>';
    loadCompanyActivity(data.contacts);
