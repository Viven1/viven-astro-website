    let acts = '';
    if (isPreviewable){
      acts += '<button class="btn btn-ghost small" data-act="cmp" type="button" title="Original y variante LADO A LADO">🆚 Comparar A | B</button>' +
        '<a class="btn btn-ghost small" href="https://www.viven.ch' + esc(t.url_path) + '?vvab=' + t.id + ':a" target="_blank" rel="noopener" title="Abrir solo la variante A">👁 Ver A</a>' +
        '<a class="btn btn-ghost small" href="https://www.viven.ch' + esc(t.url_path) + '?vvab=' + t.id + ':b" target="_blank" rel="noopener" title="Abrir solo la variante B">👁 Ver B</a>';
    } else {
      acts += '<span class="muted-note" style="align-self:center">▶ Inicialo para previsualizar</span>';
    }
    acts += '<span style="flex:1"></span>';
    if (t.status === 'draft') acts += '<button class="btn btn-primary small" data-act="run" type="button">▶ Iniciar</button>';
    if (t.status === 'running' && r.eff === 'running') acts += '<button class="btn btn-ghost small" data-act="pause" type="button">⏸ Pausar</button>';
    if (['running', 'stopped'].includes(r.eff)){
      acts += '<button class="btn btn-ghost small" data-act="wina" type="button" title="Se mantiene la página original">Mantener A</button>';
      const dis = canDeclare && bWins ? '' : ' disabled style="opacity:.45"';
      const tip = canDeclare && bWins ? 'La variante B pasa a servirse al 100% del tráfico' : 'Se habilita solo cuando B gana con ≥95% de confianza — protege contra decidir por ruido' + (aWins ? ' (ahora mismo va ganando A)' : '');
      acts += '<button class="btn btn-primary small" data-act="winb" type="button"' + dis + ' title="' + esc(tip) + '">🏆 Declarar ganador B</button>';
    }
    if (t.status === 'done_b') acts += '<button class="btn btn-ghost small" data-act="wina" type="button" title="Volver a la original">↩ Volver a A</button>';
    acts += '<button class="btn btn-ghost small danger" data-act="del" type="button">🗑</button>';
    return '<div class="ab-card" data-id="' + t.id + '">' +
      '<div class="top"><div><span class="nm">' + esc(t.name || '(sin nombre)') + '</span>' +
        '<span class="status-chip" style="color:' + c[1] + ';border-color:' + c[1] + '">' + c[0] + '</span>' +
        '<div class="subline">' + sub + '</div></div></div>' +
      '<div class="ab-vs">' + cell('a', abVariantTxt(changes, 'a'), r.ea, r.la, r.ca) +
        '<div class="ab-vsmid">VS</div>' + cell('b', abVariantTxt(changes, 'b'), r.eb, r.lb, r.cb) + '</div>' +
      verdict +
      '<div class="ab-actions" style="margin-top:12px">' + acts + '</div></div>';
  }
