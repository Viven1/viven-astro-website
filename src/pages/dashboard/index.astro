  // nombre de empresa/persona para prellenar cliente
  function clientNameFor(r){ const d = leadDomain(r); return (d && companyName(d)) || r.company || r.name || ''; }
  // Desde el contacto: crear una oferta ya ligada a este lead
  function makeOfferForLead(r){
    const client = clientNameFor(r);
    closeLead(); gotoTab('offers');
    const od = openDealOf(r.id);
    ofCur = { title: 'Video para ' + (client || 'cliente'), client: client, lead_id: r.id, deal_id: (od && !od.synthetic) ? od.id : null, vat_rate: 8.1, status: 'draft', items: [] };
    fillEditor(); showEditor(true);
