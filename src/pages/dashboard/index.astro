      supabase.from('lead_followups').update({ status: 'canceled' }).eq('lead_id', String(d.lead_id)).in('status', ['draft', 'approved']).then(() => { if (currentLead && String(currentLead.id) === String(d.lead_id)) loadFollowups(currentLead); });
