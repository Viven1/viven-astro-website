  // AI lead scoring (heurístico, instantáneo): intención + fit B2B + engagement + recencia
  function leadScore(r){
    let s = 0; const f = [];
    const ch = (r.channel || '').toLowerCase();
    if (r.gclid || /paid|cpc|ppc|sem/.test(ch)) { s += 28; f.push('+28 Google Ads (alta intención)'); }
    else if (/organic|search/.test(ch)) { s += 14; f.push('+14 búsqueda orgánica'); }
    else if (/direct/.test(ch)) { s += 10; f.push('+10 directo'); }
    else if (/social|referr/.test(ch)) { s += 6; f.push('+6 social/referral'); }
    const dom = (r.email || '').split('@')[1] || '';
    if (dom && !/gmail|hotmail|outlook|yahoo|icloud|gmx|bluewin|proton/i.test(dom)) { s += 20; f.push('+20 email corporativo (B2B)'); }
    if (r.company) { s += 8; f.push('+8 empresa cargada'); }
    if (r.phone) { s += 10; f.push('+10 dejó teléfono'); }
    const msg = (r.message || '');
    if (msg.length > 120) { s += 8; f.push('+8 mensaje detallado'); }
    if (/budget|presupuesto|urg|asap|deadline|invest|proyecto|project|quote|offert/i.test(msg)) { s += 12; f.push('+12 señales de compra en el mensaje'); }
    if (new Date(r.created_at).getTime() >= Date.now() - 7 * 864e5) { s += 8; f.push('+8 nuevo (esta semana)'); }
    if (r.videocall_at || r.proposal_at) { s += 10; f.push('+10 avanzó en el pipeline'); }
    s = Math.min(100, s);
    const tier = s >= 60 ? { t: 'Hot', c: '#ff8b5e' } : s >= 35 ? { t: 'Warm', c: '#f0c060' } : { t: 'Cold', c: '#8ab4ff' };
    return { score: s, tier, factors: f };
  }
  function renderLeadScore(r){
    const el = $('lm-score'); if (!el) return;
    const { score, tier, factors } = leadScore(r);
    el.textContent = '🔥 ' + tier.t + ' · ' + score;
    el.style.color = tier.c; el.style.borderColor = tier.c;
    el.title = 'AI lead score ' + score + '/100\n' + factors.join('\n');
  }

  async function loadTasksNotes(r){
    try {
      const [tq, nq] = await Promise.all([
        supabase.from('lead_tasks').select('*').eq('lead_id', String(r.id)).order('done').order('due_date', { ascending: true, nullsFirst: false }).limit(50),
        supabase.from('lead_notes').select('*').eq('lead_id', String(r.id)).order('created_at', { ascending: false }).limit(50)
      ]);
      renderTasks(tq.data || []); renderNotes(nq.data || []);
    } catch (e) { $('lm-tasks').innerHTML = '<p class="muted-note">¿Corriste el SQL 0010?</p>'; $('lm-notes').innerHTML = ''; }
  }
  function renderTasks(tasks){
    const box = $('lm-tasks'); if (!box) return;
    if (!tasks.length) { box.innerHTML = '<p class="muted-note">Sin tasks.</p>'; return; }
    const now = Date.now();
    box.innerHTML = tasks.map((t) => {
      const dueTs = t.due_date ? new Date(t.due_date + 'T' + (t.due_time || '23:59') + ':00').getTime() : null;
      const overdue = !t.done && dueTs && dueTs < now;
      const dueTxt = t.due_date ? ('📅 ' + t.due_date + (t.due_time ? ' · 🕒 ' + t.due_time : '')) : '';
      return '<div class="lm-task' + (t.done ? ' done' : '') + '"><input type="checkbox" data-tid="' + t.id + '"' + (t.done ? ' checked' : '') + '/>' +
        '<div class="lm-task-txt"><div>' + esc(t.title) + '</div>' +
        '<div class="lm-task-meta">' + (dueTxt ? '<span' + (overdue ? ' style="color:#ff8b8b"' : '') + '>' + dueTxt + '</span>' : '') + (t.assignee ? ' · ' + esc(teamName(t.assignee)) : '') + '</div></div>' +
        '<button class="lm-x" data-del-task="' + t.id + '" type="button">✕</button></div>';
    }).join('');
    box.querySelectorAll('input[type=checkbox]').forEach((c) => c.addEventListener('change', () => toggleTask(c.dataset.tid, c.checked)));
    box.querySelectorAll('[data-del-task]').forEach((b) => b.addEventListener('click', () => delTask(b.dataset.delTask)));
  }
  function renderNotes(notes){
    const box = $('lm-notes'); if (!box) return;
    if (!notes.length) { box.innerHTML = '<p class="muted-note">Sin notas.</p>'; return; }
    const fmtN = (d) => new Date(d).toLocaleDateString('es-CH', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
    const byParent = {}; const roots = [];
    notes.forEach((n) => { if (n.parent_id) (byParent[n.parent_id] = byParent[n.parent_id] || []).push(n); else roots.push(n); });
    const noteHTML = (n, isReply) => {
      const replies = (byParent[n.id] || []).slice().sort((a, b) => new Date(a.created_at) - new Date(b.created_at));
      return '<div class="lm-note' + (isReply ? ' lm-reply' : '') + '">' +
        '<div class="lm-note-b">' + esc(n.body) + '</div>' +
        '<div class="lm-note-m">' + esc(n.author || '') + ' · ' + fmtN(n.created_at) + (n.mention ? ' · avisó a ' + esc(teamName(n.mention)) : '') +
          ' · <button class="lm-reply-btn" data-nid="' + n.id + '" data-author="' + esc(n.author || '') + '" type="button">↩ Responder</button></div>' +
        '<div class="lm-reply-box" id="lm-reply-' + n.id + '" hidden></div>' +
        replies.map((rp) => noteHTML(rp, true)).join('') +
      '</div>';
    };
    box.innerHTML = roots.map((n) => noteHTML(n, false)).join('');
    box.querySelectorAll('.lm-reply-btn').forEach((b) => b.addEventListener('click', () => openReply(b.dataset.nid, b.dataset.author)));
  }
  function openReply(nid, author){
    const box = $('lm-reply-' + nid); if (!box) return;
    if (!box.hidden) { box.hidden = true; box.innerHTML = ''; return; }
    box.hidden = false;
