    const stB = (key) => { const s = STAGES.find((x) => x.key === stageOf(key)) || STAGES[0]; return '<span class="stb" style="color:' + s.color + ';border-color:' + s.color + '">' + s.label + '</span>'; };
    const ofB = (st) => { const b = { draft: ['Borrador', '#8ab4ff'], sent: ['Enviada', '#f0c060'], won: ['Ganada', '#7ed957'], lost: ['Perdida', '#ff6b6b'], accepted: ['Aceptada', '#7ed957'], published: ['Publicada', '#f0c060'] }[st] || ['Borrador', '#8ab4ff']; return '<span class="stb" style="color:' + b[1] + ';border-color:' + b[1] + '">' + b[0] + '</span>'; };
    $('lm2-r').innerHTML =
