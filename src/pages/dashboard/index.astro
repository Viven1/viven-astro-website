      ov.querySelector('#nw-recip-total').textContent = total + ' destinatario' + (total === 1 ? '' : 's') + ' (de ' + matched.length + ' en el segmento' + (nwExtraEmails.length ? ' + ' + nwExtraEmails.length + ' agregados' : '') + ')';
