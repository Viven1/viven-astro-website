  .dash-body.dash-collapsed .dash-side{flex-basis:56px;width:56px}
  .dash-body.dash-collapsed .side-rail-btn{align-self:center}
  .dash-body.dash-collapsed .side-item{font-size:0;gap:0;justify-content:center;padding:9px 0}
  .dash-body.dash-collapsed .side-item .si-ic{font-size:16px}
  .dash-body.dash-collapsed .side-item .pill{display:none}
  .dash-body.dash-collapsed .side-sec{font-size:0;padding:9px 0 4px;pointer-events:none;justify-content:center}
  .dash-body.dash-collapsed .side-chev{display:none}
  /* en riel los grupos “colapsados” igual muestran sus íconos (si no, desaparecerían del riel) */
  .dash-body.dash-collapsed .side-group.collapsed .side-group-items{display:flex}
  /* -- búsqueda global: pastilla con ⌘K en la barra superior (abre el palette al click) -- */
  .vv-search{display:flex;align-items:center;gap:8px;background:var(--navy-800);border:1px solid var(--line-strong);border-radius:100px;padding:8px 14px;color:var(--muted-2);font-family:inherit;font-size:13px;cursor:pointer;min-width:190px;transition:border-color .12s,color .12s}
  .vv-search:hover{border-color:var(--acid);color:var(--muted)}
  .vv-search .vv-search-t{margin-right:auto}
  .vv-kbd{font:600 10px Inter,system-ui,sans-serif;color:var(--muted-2);border:1px solid var(--line-strong);border-radius:5px;padding:1px 5px;white-space:nowrap}
  /* -- ➕ Crear ▾ global -- */
  .vv-create{position:relative}
  .vv-create-menu{position:absolute;top:calc(100% + 6px);right:0;z-index:130;min-width:190px;background:var(--navy-800);border:1px solid var(--line-strong);border-radius:12px;box-shadow:0 18px 50px rgba(0,0,0,.5);padding:6px;display:flex;flex-direction:column;gap:2px}
  .vv-create-menu button{display:flex;align-items:center;gap:10px;width:100%;text-align:left;background:none;border:0;color:var(--text);font-family:inherit;font-size:13.5px;font-weight:500;padding:9px 11px;border-radius:8px;cursor:pointer}
  .vv-create-menu button:hover,.vv-create-menu button:focus-visible{background:color-mix(in srgb,var(--acid) 14%,transparent);color:var(--acid);outline:none}
  /* -- ⌘K command palette -- */
  .vv-cmdk{position:fixed;inset:0;z-index:500;display:none;align-items:flex-start;justify-content:center;padding:12vh 20px 20px}
  .vv-cmdk.open{display:flex}
  .vv-cmdk-bd{position:fixed;inset:0;background:rgba(9,15,26,.72);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px)}
  .vv-cmdk-panel{position:relative;z-index:2;width:min(600px,100%);background:var(--navy-800);border:1px solid var(--line-strong);border-radius:16px;box-shadow:0 30px 80px -20px rgba(0,0,0,.7);overflow:hidden;animation:vvCmdkIn .18s ease}
  .vv-cmdk-top{display:flex;align-items:center;gap:10px;padding:14px 16px;border-bottom:1px solid var(--line)}
  .vv-cmdk-top .ci-ic{font-size:16px;color:var(--muted-2)}
  .vv-cmdk-input{flex:1;background:none;border:0;outline:none;color:var(--text);font-family:inherit;font-size:15px;min-width:0}
  .vv-cmdk-input::placeholder{color:var(--muted-2)}
  .vv-cmdk-esc{font:600 10px Inter,system-ui,sans-serif;color:var(--muted-2);border:1px solid var(--line-strong);border-radius:5px;padding:2px 6px;white-space:nowrap}
  .vv-cmdk-results{max-height:min(52vh,420px);overflow:auto;padding:6px}
  .vv-cmdk-grp{font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted-2);font-weight:700;padding:10px 10px 4px}
  .vv-cmdk-item{display:flex;align-items:center;gap:11px;width:100%;text-align:left;background:none;border:0;color:var(--text);font-family:inherit;font-size:13.5px;padding:9px 11px;border-radius:9px;cursor:pointer}
  .vv-cmdk-item .ci-ic{font-size:15px;width:20px;text-align:center;flex:none}
  .vv-cmdk-item .ci-main{display:flex;flex-direction:column;min-width:0}
  .vv-cmdk-item .ci-t{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .vv-cmdk-item .ci-sub{color:var(--muted-2);font-size:11.5px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .vv-cmdk-item.sel,.vv-cmdk-item:hover{background:color-mix(in srgb,var(--acid) 14%,transparent)}
  .vv-cmdk-item.sel .ci-t,.vv-cmdk-item:hover .ci-t{color:var(--acid)}
  .vv-cmdk-empty{padding:24px 12px;text-align:center;color:var(--muted-2);font-size:13px}
  @keyframes vvCmdkIn{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:none}}
  @media(prefers-reduced-motion:reduce){.vv-cmdk-panel{animation:none}.dash-side{transition:none}}
  /* en móvil la barra ya usa el bottom-nav: la pastilla de búsqueda queda compacta (solo lupa) */
  @media(max-width:820px){
    .vv-search{min-width:0;padding:0;width:38px;height:38px;justify-content:center;border-radius:10px}
    .vv-search .vv-search-t,.vv-search .vv-kbd{display:none}
  }
  /* ---------- Modo app en móvil: sidebar → barra inferior fija ---------- */
  .mob-nav,.mob-sheet{display:none}
  @media(max-width:820px){
    /* clave: en columna, los hijos deben ESTIRARSE al ancho del viewport —
       con el align-items:flex-start del desktop, .dash-main tomaba el ancho del
       CONTENIDO (980px con el board) y toda la página quedaba ancha → iOS no scrolleaba */
    .dash-body{flex-direction:column;align-items:stretch}
    .dash-main{width:100%;max-width:100%;min-width:0}
    .dash-side{display:none}                          /* fuera la lista gigante de arriba */
    .dash-wrap{padding:calc(14px + env(safe-area-inset-top)) 14px calc(84px + env(safe-area-inset-bottom));overflow-x:hidden}
    body{overflow-x:clip}
    /* cards de ofertas/propuestas: nada cortado a la derecha — el monto baja a su propia línea */
    .of-card-open{flex-wrap:wrap;gap:6px 12px;padding:13px 14px}
    .of-card-main{flex:1 1 100%}
    .of-card-nums{text-align:left;display:flex;align-items:baseline;gap:10px;flex-wrap:wrap}
    .of-card-net{font-size:16px}
    .of-actions{padding:0 10px 10px;gap:6px}
    .of-act{font-size:12px;padding:7px 10px}
    /* modal de contacto: header respeta el notch */
    .lead-card-wide{padding-top:calc(10px + env(safe-area-inset-top))}
    .dash-head{margin-bottom:12px;flex-wrap:nowrap;gap:8px}
    .dash-brand .logo-mark{height:19px}
    .dash-brand .db-sub{display:none}
    .dash-sub{display:none}
    .dash-head .btn.small{padding:8px 11px;font-size:12.5px;white-space:nowrap}
    /* ➕ Crear ▾ era el único botón de texto sin compactar en la barra — quedaba
       empujando/cortando al resto en pantallas angostas (mismo trato que refresh/logout) */
    #vv-create-btn{font-size:0;width:38px;height:38px;padding:0;display:grid;place-items:center;border-radius:10px}
    #vv-create-btn::before{content:'➕';font-size:16px}
    #refresh-btn{font-size:0;width:38px;height:38px;padding:0;display:grid;place-items:center;border-radius:10px}
    #refresh-btn::before{content:'↻';font-size:17px}
    .dash-actions{gap:7px;flex-wrap:nowrap!important}
    #logout-btn{font-size:0;width:38px;height:38px;padding:0;display:grid;place-items:center;border-radius:10px}
    #logout-btn::before{content:'⏻';font-size:16px}
    /* inputs a 16px: iOS no hace zoom al enfocar */
    input,select,textarea{font-size:16px!important}
    .tabs{overflow-x:auto;scrollbar-width:none;margin-bottom:18px;flex-wrap:nowrap}
    .tabs::-webkit-scrollbar{display:none}
    .tab{padding:10px 12px;font-size:14.5px;white-space:nowrap;flex:none}
    .panel{padding:16px 14px}
    .kpis,.kpis.four{grid-template-columns:repeat(2,1fr);gap:10px}
    .kpi{padding:14px 15px}
    .kpi .n{font-size:clamp(19px,6.5vw,26px)}
    .home-kpis{gap:8px}
    .hk{flex-basis:120px;padding:11px 13px}
    .hk-n{font-size:19px}
    .hm-card{padding:14px 15px}
    /* pipeline: una columna por pantalla, con snap como un carrusel */
    .pipe-pager{display:flex!important}
    /* iOS: sin snap (se pelea con el scroll vertical anidado de las columnas) — scroll libre y robusto */
    .pipeline{touch-action:pan-x pan-y;overscroll-behavior-x:contain}
    .pipe-col{flex:0 0 85vw;min-width:85vw;max-height:68dvh;touch-action:pan-x pan-y}
    .pipe-list{touch-action:pan-x pan-y}
    .pipe-card{cursor:default;touch-action:pan-x pan-y}
    /* tabla de Personas/Empresas → cards apiladas (nada de scroll horizontal).
       OJO: el mapeo es POSICIONAL y la 1ª celda ahora es el CHECKBOX de selección (batch delete)
       — antes era el nombre y el card quedaba sin título. El nombre vive en la 2ª celda;
       el checkbox va absoluto arriba a la derecha (el "seleccionar todos" del thead se pierde
       en móvil, aceptado). */
    .lead-table-hs table{min-width:0;width:100%}
    .lead-table-hs thead{display:none}
    .lead-table-hs tbody tr{position:relative;display:flex;flex-wrap:wrap;align-items:center;gap:3px 10px;padding:12px 44px 12px 14px;border-bottom:1px solid var(--line)}
    .lead-table-hs tbody td{display:none;padding:0;border:0;white-space:normal}
    .lead-table-hs tbody td.lt-chk{display:block;position:absolute;top:12px;right:12px;width:auto;padding:0}
    .lead-table-hs tbody td:nth-child(2){display:block;flex:1 1 100%}   /* nombre (persona/empresa): título del card */
    .lead-table-hs tbody td:nth-child(2) .lt-name{font-size:14.5px}
    .lead-table-hs tbody td:nth-child(5){display:block;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;color:var(--muted);font-size:12px}
    .lead-table-hs tbody td:nth-child(6){display:block}
    .lead-table-hs tbody td.lt-val{display:block;font-weight:700;font-family:'Space Grotesk';font-size:13px;color:var(--text)}
    /* contacto apilado en orden útil: conversación → proyectos/ofertas → ficha */
    .lm-center{order:1}
    .lm-right{order:2}
    .lm-left{order:3}
    /* acciones rápidas: TODAS visibles (envuelven en filas), nada escondido en scroll */
    .lm-quick{flex-wrap:wrap;overflow:visible;margin-right:0}
    .lm-quick .lm-qbtn{flex:0 1 auto}
    /* header del contacto compacto y sin pisar el notch */
    .lead-card-wide .close{top:calc(8px + env(safe-area-inset-top));right:14px}
    .lead-card h3{font-size:19px}
    .lm-top{padding-right:52px}
    /* botonera final: los útiles se estiran, BORRAR queda chico y al final — no un banner rojo */
    .lead-actions .btn{flex:1 1 auto}
    .lead-actions .btn-danger{flex:0 0 auto;margin-left:auto;font-size:12.5px;padding:9px 14px}
    /* barras de título (Deals/Ofertas/etc): que el texto envuelva y el botón baje */
    .of-bar{flex-wrap:wrap}
    .of-bar > div{min-width:0;flex:1 1 100%}
    .of-bar .muted-note{white-space:normal}
    /* editor de OFERTA: la tabla de posiciones se vuelve cards (adiós scroll lateral) */
    .of-table{min-width:0}
    .of-table thead{display:none}
    .of-table tr[data-i]{display:grid;grid-template-columns:repeat(4,1fr);gap:7px 8px;padding:11px 12px;border-bottom:1px solid var(--line)}
    .of-table tr[data-i] td{display:block;padding:0;border:0;min-width:0}
    .of-table tr[data-i] td:nth-child(1){grid-area:1/1/2/4}
    .of-table tr[data-i] td:nth-child(9){grid-area:1/4/2/5;justify-self:end}
    .of-table tr[data-i] td:nth-child(2){grid-area:2/1/3/3}
    .of-table tr[data-i] td:nth-child(3){grid-area:2/3/3/4}
    .of-table tr[data-i] td:nth-child(4){grid-area:2/4/3/5}
    .of-table tr[data-i] td:nth-child(5){grid-area:3/1/4/2}
    .of-table tr[data-i] td:nth-child(6){grid-area:3/2/4/3}
    .of-table tr[data-i] td:nth-child(7){grid-area:3/3/4/4;align-self:end;text-align:right;font-weight:700;font-family:'Space Grotesk'}
    .of-table tr[data-i] td:nth-child(8){grid-area:3/4/4/5;align-self:end;text-align:right;font-size:12px}
    .of-table tr[data-i] td:nth-child(n+3)::before{display:block;font-size:9.5px;text-transform:uppercase;letter-spacing:.06em;color:var(--muted-2);margin-bottom:3px}
    .of-table tr[data-i] td:nth-child(3)::before{content:'Cant.'}
    .of-table tr[data-i] td:nth-child(4)::before{content:'Unidad'}
    .of-table tr[data-i] td:nth-child(5)::before{content:'Precio'}
    .of-table tr[data-i] td:nth-child(6)::before{content:'Costo int.'}
    .of-table tr[data-i] td:nth-child(7)::before{content:'Total';font-weight:400;font-family:'Inter'}
    .of-table tr[data-i] td:nth-child(8)::before{content:'Margen'}
    .of-table tr.of-phase,.of-table tr.of-sub{display:flex;justify-content:space-between;gap:10px;padding:9px 12px;border-bottom:1px solid var(--line)}
    .of-table tr.of-phase td,.of-table tr.of-sub td{display:block;padding:0;border:0}
    #bg-result .pp-grid{grid-template-columns:1fr!important}
    .of-add{flex-direction:column;align-items:stretch}
    .of-add select{min-width:0;width:100%}
    .of-add .btn{width:100%}
    .mob-nav{display:flex;position:fixed;left:0;right:0;bottom:0;z-index:250;background:color-mix(in srgb,var(--navy-800) 88%,transparent);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-top:1px solid var(--line-strong);padding:6px 4px calc(6px + env(safe-area-inset-bottom))}
    .mob-nav button{flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;background:none;border:0;color:var(--muted-2);font-family:inherit;cursor:pointer;padding:4px 2px;border-radius:10px}
    .mob-nav button .mi{font-size:19px;line-height:1}
    .mob-nav button .ml{font-size:10px;font-weight:600;letter-spacing:.01em}
    .mob-nav button.active{color:var(--acid)}
    .mob-sheet{position:fixed;left:12px;right:12px;bottom:calc(66px + env(safe-area-inset-bottom));z-index:249;background:var(--navy-800);border:1px solid var(--line-strong);border-radius:16px;box-shadow:0 18px 50px rgba(0,0,0,.5);padding:8px;display:flex;flex-direction:column}
    .mob-sheet[hidden]{display:none}
    .mob-sheet button{background:none;border:0;color:var(--text);font-family:inherit;font-size:14.5px;font-weight:600;text-align:left;padding:13px 14px;border-radius:10px;cursor:pointer}
    .mob-sheet button.active,.mob-sheet button:hover{background:color-mix(in srgb,var(--acid) 10%,transparent);color:var(--acid)}
    /* modal de contacto a pantalla completa */
    .lead-modal{padding:0}
    .lead-modal .lead-card{width:100%;min-height:100dvh;border-radius:0;margin:0}
  }
  /* tablas genéricas (no la de Personas) en pantallas chicas: ocultar columnas 5 y 6 */
  @media(max-width:560px){
    .lead-table-wrap:not(.lead-table-hs) .lead-table th:nth-child(5),.lead-table-wrap:not(.lead-table-hs) .lead-table td:nth-child(5),
    .lead-table-wrap:not(.lead-table-hs) .lead-table th:nth-child(6),.lead-table-wrap:not(.lead-table-hs) .lead-table td:nth-child(6){display:none}
  }
  /* ---- home ---- */
  /* flex-wrap (no grid): con 7 KPIs, un grid de columnas fijas deja huecos vacíos en la
     última fila — flex reparte el ancho sobrante entre las tarjetas que sí hay en cada
     fila (incluida la última, aunque quede incompleta), así nunca queda un agujero
     (pedido explícito: "tiene info por todos lados pero muchos agujeros, mejor mas
     compacto que se lea mejor el overview") */
  .home-kpis{display:flex;flex-wrap:wrap;gap:10px}
  .hk{flex:1 1 128px;background:var(--navy-800);border:1px solid var(--line);border-radius:12px;padding:12px 14px}
  .hk-l{color:var(--muted);font-size:11.5px}
  .hk-n{font-family:'Space Grotesk';font-weight:700;font-size:21px;color:var(--text);line-height:1.15;margin-top:3px}
  .hk-t{font-size:11.5px;margin-top:3px;font-weight:600}
  .hk-t.up{color:#7ed957}
  .hk-t.down{color:#ff8b8b}
  .hk-t.muted{color:var(--muted-2);font-weight:400}
  /* Hoy: KPIs + cards — cards compactas, sin el padding/margin de .panel default
     (24px) que hacía sentir todo muy espaciado */
  .hm-grid{display:grid;grid-template-columns:1.25fr 1fr 1fr;gap:12px;margin-top:14px;align-items:start}
  .hm-grid .panel{margin-bottom:0}
  .hm-card{padding:15px 17px}
  .hm-card h2{font-size:14px;margin-bottom:8px}
  /* masonry con CSS multi-column (no grid): con un grid de 3 columnas fijas, "Para
     hoy"/"Señales calientes" (cortas) dejaban un agujero enorme debajo mientras la
     3ª columna (Visitas/Ads/IA apiladas) seguía mucho más abajo — acá el browser
     reparte las 5 cards entre columnas balanceando la altura total, así no queda
     una columna corta con espacio muerto al lado de una larga (pedido explícito,
     con captura: "mira todo el dead space") */
  .hm-masonry{columns:280px 3;column-gap:12px;margin-top:14px}
  .hm-masonry .hm-card{break-inside:avoid;margin-bottom:12px}
  .hm-list{display:flex;flex-direction:column}
  /* fila accionable: barra de severidad a la izquierda (rojo/ámbar/azul) */
  .hm-item{position:relative;display:flex;align-items:center;gap:10px;width:100%;background:none;border:0;border-top:1px solid var(--line);padding:10px 6px 10px 14px;cursor:pointer;text-align:left;color:var(--text);font-family:inherit}
  .hm-item:first-child{border-top:0}
  .hm-item:hover{background:var(--navy-900)}
  .hm-item::before{content:'';position:absolute;left:2px;top:13px;bottom:13px;width:3px;border-radius:2px;background:var(--muted-2)}
  .hm-item.rojo::before{background:#ff6b6b}
  .hm-item.ambar::before{background:#f0c060}
  .hm-item.azul::before{background:#8ab4ff}
  .hm-item.hot::before{background:#ff8b5e}
  .hm-item .ic{flex:none;font-size:15px}
  .hm-item .tx{flex:1;min-width:0}
  .hm-item .tx b{display:block;font-size:13.5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .hm-item .tx small{display:block;color:var(--muted);font-size:12px;margin-top:1px;line-height:1.35}
  .hm-item .go{flex:none;color:var(--acid);font-size:11.5px;font-weight:700;white-space:nowrap}
  .hm-more{width:100%;background:none;border:0;border-top:1px solid var(--line);color:var(--acid);font-family:inherit;font-weight:600;font-size:12.5px;padding:10px 6px;cursor:pointer;text-align:left}
  .hm-spark{display:flex;align-items:flex-end;gap:5px;height:62px}
  .hm-spark i{flex:1;background:color-mix(in srgb,var(--acid) 28%,transparent);border-radius:3px 3px 0 0;min-height:3px}
  .hm-spark i.on{background:var(--acid)}
  .hm-spark-cap{color:var(--muted);font-size:12px;margin-top:8px}
  .hm-ads-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
  .hm-ads-grid div b{display:block;font-family:'Space Grotesk';font-size:16px}
  .hm-ads-grid div span{color:var(--muted);font-size:11.5px}
  .hm-verdict{font-weight:700;font-size:12.5px;margin-top:10px}
  @media(max-width:1280px){.hm-grid{grid-template-columns:1fr 1fr}}
  @media(max-width:920px){.hm-grid{grid-template-columns:1fr}}
</style>
</head>
<body>

<!-- sprite del logo real (mismo símbolo que usa el sitio público — SiteHeader/SiteFooter/
     Base.astro — inline acá porque el dashboard es un documento standalone, no pasa por
