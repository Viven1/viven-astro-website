    const segDefs = [['new', 'Nuevas', counts.new], ['actioned', 'Accionadas', counts.actioned], ['dismissed', 'Descartadas', counts.dismissed], ['all', 'Todas', kwOpps.length]];
    $('kw-seg').innerHTML = segDefs.map(([k, l, n]) => '<button type="button" data-k="' + k + '" class="' + (kwSeg === k ? 'on' : '') + '">' + l + ' ' + n + '</button>').join('');
    $('kw-seg').querySelectorAll('button').forEach((b) => b.addEventListener('click', () => { kwSeg = b.dataset.k; kwRenderPersist(); }));
    let rows = kwSeg === 'all' ? kwOpps.slice() : kwOpps.filter((o) => o.status === kwSeg);
    if (!rows.length) { wrap.innerHTML = '<p class="muted-note">Sin oportunidades' + (kwSeg !== 'all' ? ' en este filtro' : ' todavía — tocá «✨ Buscar oportunidades» o esperá al lunes') + '.</p>'; return; }
    const sv = (r, k) => k === 'keyword' ? (r.keyword || '').toLowerCase() : (r[k] || 0);
    rows = rows.sort((a, b) => { const av = sv(a, kwSort.k), bv = sv(b, kwSort.k); return av < bv ? -kwSort.dir : av > bv ? kwSort.dir : 0; });
    const th = (label, key) => '<th class="lt-sort' + (kwSort.k === key ? ' on' : '') + '" data-k="' + key + '">' + label + (kwSort.k === key ? (kwSort.dir > 0 ? ' ▲' : ' ▼') : '') + '</th>';
    let html = '<table class="lead-table"><thead><tr>' + th('Keyword', 'keyword') + th('Tipo', 'type') + '<th>Por qué</th>' + th('Fuente', 'source') + th('Estado', 'status') + '<th></th></tr></thead><tbody>';
    rows.forEach((o) => {
      const t = KW_TY[o.type] || KW_TY.new_content;
      html += '<tr><td><b>' + esc(o.keyword || '') + '</b> <span class="muted-note">' + esc((o.lang || '').toUpperCase()) + '</span></td>' +
        '<td><span class="kw-type-badge" style="border:1px solid ' + t[1] + ';color:' + t[1] + '">' + t[0] + '</span></td>' +
        '<td class="kw-why">' + esc(o.why || o.action || '') + '</td>' +
        '<td class="muted-note">' + (o.source === 'gsc+ads' ? 'GSC + Ads' : 'GSC') + '</td>' +
        '<td><span class="kw-status ' + esc(o.status) + '">' + (KW_ST_LABEL[o.status] || o.status) + '</span></td>' +
        '<td><div class="kw-acts">' +
          (o.type === 'new_content' ? '<button type="button" class="kw-q" data-id="' + o.id + '">⚡ a la cola del blog</button>' : '') +
          (o.status !== 'actioned' ? '<button type="button" class="kw-act" data-id="' + o.id + '">✓ accionada</button>' : '') +
          (o.status !== 'dismissed' ? '<button type="button" class="kw-dis" data-id="' + o.id + '">✕ descartar</button>' : '') +
        '</div></td></tr>';
    });
    wrap.innerHTML = html + '</tbody></table>';
    wrap.querySelectorAll('th.lt-sort').forEach((t2) => t2.addEventListener('click', () => {
      const k = t2.dataset.k; if (kwSort.k === k) kwSort.dir = -kwSort.dir; else { kwSort.k = k; kwSort.dir = -1; }
      kwRenderPersist();
    }));
    wrap.querySelectorAll('.kw-q').forEach((b) => b.addEventListener('click', async () => {
      const o = kwOpps.find((x) => String(x.id) === b.dataset.id); if (!o) return;
      // llevamos la keyword+why+priority como datos separados (no solo colapsados
      // en "topic") — así content-engine puede hacer el lookup de ranking real
      // y mostrar el veredicto data-backed en el tab Blog, no solo prosa de IA.
      let row = { topic: o.action || o.keyword, priority: Math.min(10, o.priority || 5), target_keyword: o.keyword, keyword_why: o.why || null, keyword_priority: o.priority || null };
      let ins = await supabase.from('content_queue').insert(row);
      for (let tries = 0; ins.error && tries < 3; tries++) {
        const m = /'([^']+)' column/.exec(ins.error.message || '');
        if (!m || !(m[1] in row)) break;
        delete row[m[1]];
        ins = await supabase.from('content_queue').insert(row);
      }
      if (ins.error) { toast('¿SQL 0032/0076? ' + ins.error.message); return; }
      toast('📝 «' + (o.action || o.keyword).slice(0, 60) + '…» en la cola con keyword objetivo: ' + o.keyword + ' — escribilo ya con ⚡ desde el tab Blog');
    }));
    wrap.querySelectorAll('.kw-act').forEach((b) => b.addEventListener('click', () => kwSetStatus(b.dataset.id, 'actioned')));
    wrap.querySelectorAll('.kw-dis').forEach((b) => b.addEventListener('click', () => kwSetStatus(b.dataset.id, 'dismissed')));
  }
  async function kwSetStatus(id, status){
    const { error } = await supabase.from('keyword_opportunities').update({ status, updated_at: new Date().toISOString() }).eq('id', id);
    if (error) { toast('No se pudo actualizar: ' + error.message); return; }
    const o = kwOpps.find((x) => String(x.id) === String(id)); if (o) o.status = status;
    kwRenderPersist();
    toast(status === 'actioned' ? '✓ Marcada como accionada' : '✕ Descartada');
  }
  function seoInit(){
    kwInit(); if (!seoLoaded) loadSeo(); }

  // ---- estado de sort + cache de la última respuesta de gsc-stats (para re-ordenar sin refetch) ----
  let seoData = null;
  let seoQSort = { k: 'clicks', dir: -1 };
  let seoPSort = { k: 'clicks', dir: -1 };
  let seoOppSort = { k: 'lost', dir: -1 };
  let seoOppRows = [];
  function seoSortTh(state, label, key, num){
    return '<th class="lt-sort' + (num ? ' lt-num' : '') + (state.k === key ? ' on' : '') + '" data-k="' + key + '">' + label + (state.k === key ? (state.dir > 0 ? ' ▲' : ' ▼') : '') + '</th>';
  }
  function seoBindSort(cont, state, renderFn){
    cont.querySelectorAll('th.lt-sort').forEach((th) => th.addEventListener('click', () => {
      const k2 = th.dataset.k;
      if (state.k === k2) state.dir = -state.dir; else { state.k = k2; state.dir = -1; }
      renderFn();
    }));
  }

  // curva estándar de CTR esperado por posición (industria — no exacta, sirve para priorizar)
  function seoExpectedCtr(pos){
    if (pos <= 1.5) return 0.28;
    if (pos <= 2.5) return 0.15;
    if (pos <= 3.5) return 0.11;
    if (pos <= 5.5) return 0.08;
    if (pos <= 10.5) return 0.04;
    return 0.02;
  }

  function seoRenderQP(kind){
    const cont = $(kind === 'q' ? 'seo-q-wrap' : 'seo-p-wrap');
    const cnt = $(kind === 'q' ? 'seo-q-count' : 'seo-p-count');
    if (!cont || !seoData) return;
    const state = kind === 'q' ? seoQSort : seoPSort;
    const src = (kind === 'q' ? seoData.queries : seoData.pages) || [];
    if (cnt) cnt.textContent = src.length ? '(' + src.length + ')' : '';
    if (!src.length){ cont.innerHTML = '<p class="muted-note">Sin datos todavía</p>'; return; }
    const val = (r, k) => k === 'key' ? (r.key || '').toLowerCase() : (r[k] || 0);
    const rows = src.slice().sort((a, b) => { const av = val(a, state.k), bv = val(b, state.k); return av < bv ? -state.dir : av > bv ? state.dir : 0; });
    const fmtN = (n) => (n || 0).toLocaleString('de-CH');
    let html = '<table class="lead-table seo-table"><thead><tr>' +
      seoSortTh(state, kind === 'q' ? 'Búsqueda' : 'Página', 'key') + seoSortTh(state, 'Clicks', 'clicks', 1) +
      seoSortTh(state, 'Impresiones', 'impressions', 1) + seoSortTh(state, 'CTR', 'ctr', 1) + seoSortTh(state, 'Posición', 'position', 1) +
      '</tr></thead><tbody>';
    rows.forEach((q) => {
      const label = kind === 'q' ? esc(q.key) : '<span style="white-space:normal;word-break:break-all">' + esc(q.key.replace(/^https?:\/\/[^/]+/, '')) + '</span>';
      html += '<tr><td>' + label + '</td><td class="lt-num">' + fmtN(q.clicks) + '</td><td class="lt-num">' + fmtN(q.impressions) + '</td><td class="lt-num">' + (q.ctr * 100).toFixed(1) + '%</td><td class="lt-num">' + q.position.toFixed(1) + '</td></tr>';
    });
    cont.innerHTML = html + '</tbody></table>';
    seoBindSort(cont, state, () => seoRenderQP(kind));
  }

  // oportunidad de CTR: 100% determinístico a partir de lo que ya trae gsc-stats (sin IA, sin llamada extra)
  function seoComputeOpp(data){
    const days = data.days || Math.max(7, Math.min(90, rangeSpanDays()));
    const scale = 30 / days; // clicks perdidos escalados a "por mes"
    return (data.queries || [])
      .filter((q) => q.impressions >= 50)
      .map((q) => {
        const exp = seoExpectedCtr(q.position);
        const lost = Math.max(0, exp * q.impressions - q.clicks) * scale;
        return { query: q.key, impressions: q.impressions, position: q.position, ctr: q.ctr, expCtr: exp, lost, page: q.page || '' };
      })
      .filter((r) => r.lost > 0.5 && r.ctr < r.expCtr * 0.75) // "meaningfully" por debajo de lo esperado
      .sort((a, b) => b.lost - a.lost)
      .slice(0, 15);
  }
  function seoRenderOpp(){
    const cont = $('seo-opp-wrap'); if (!cont) return;
    if (!seoOppRows.length){ cont.innerHTML = '<p class="muted-note">Sin oportunidades claras en este período — buena señal, tus CTR están cerca de lo esperado para cada posición (o todavía no hay suficiente volumen de impresiones).</p>'; return; }
    const rows = seoOppRows.slice();
    const val = (r, k) => k === 'query' ? r.query.toLowerCase() : (r[k] || 0);
    rows.sort((a, b) => { const av = val(a, seoOppSort.k), bv = val(b, seoOppSort.k); return av < bv ? -seoOppSort.dir : av > bv ? seoOppSort.dir : 0; });
    let html = '<table class="lead-table"><thead><tr>' +
      seoSortTh(seoOppSort, 'Búsqueda', 'query') + seoSortTh(seoOppSort, 'Impresiones', 'impressions', 1) + seoSortTh(seoOppSort, 'Pos.', 'position', 1) +
      seoSortTh(seoOppSort, 'CTR', 'ctr', 1) + seoSortTh(seoOppSort, 'CTR esperado', 'expCtr', 1) + seoSortTh(seoOppSort, 'Clicks perdidos/mes', 'lost', 1) +
      '<th>Página</th><th></th></tr></thead><tbody>';
    rows.forEach((r, i) => {
      html += '<tr><td>' + esc(r.query) + '</td><td class="lt-num">' + r.impressions.toLocaleString('de-CH') + '</td>' +
        '<td class="lt-num">' + r.position.toFixed(1) + '</td><td class="lt-num">' + (r.ctr * 100).toFixed(1) + '%</td>' +
        '<td class="lt-num">' + (r.expCtr * 100).toFixed(1) + '%</td><td class="lt-num seo-money">~' + Math.round(r.lost) + '</td>' +
        '<td style="white-space:normal;word-break:break-all;font-size:11.5px">' + (r.page ? esc(r.page.replace(/^https?:\/\/[^/]+/, '')) : '<span class="muted-note">—</span>') + '</td>' +
        '<td>' + (r.page ? '<button type="button" class="btn btn-ghost small seo-opp-title" data-i="' + i + '">✏️ ver title</button>' : '') + '</td></tr>' +
        '<tr class="seo-opp-detail" id="seo-opp-detail-' + i + '" hidden><td colspan="8"></td></tr>';
    });
    cont.innerHTML = html + '</tbody></table>';
    seoBindSort(cont, seoOppSort, seoRenderOpp);
    cont.querySelectorAll('.seo-opp-title').forEach((b) => b.addEventListener('click', () => seoShowTitle(+b.dataset.i, rows[+b.dataset.i])));
  }
  // "✏️ ver title actual": fetch client-side de la página real (mismo origen — sin CORS) +
  // extracción de <title>/meta description + sugerencia estática (sin IA — v1 rápido y gratis).
  async function seoShowTitle(i, row){
    const tr = $('seo-opp-detail-' + i); if (!tr) return;
    const td = tr.querySelector('td');
    tr.hidden = false;
    td.innerHTML = '<div class="seo-title-box">Leyendo ' + esc(row.page) + '…</div>';
    try {
      const res = await fetch(row.page, { cache: 'no-store' });
      const html = await res.text();
      const tm = html.match(/<title[^>]*>([^<]*)<\/title>/i);
      const dm = html.match(/<meta[^>]+name=["']description["'][^>]+content=["']([^"']*)["']/i) || html.match(/<meta[^>]+content=["']([^"']*)["'][^>]+name=["']description["']/i);
      const title = tm ? tm[1].trim() : '(sin title)';
      const desc = dm ? dm[1].trim() : '(sin meta description)';
      td.innerHTML = '<div class="seo-title-box">' +
        '<div><b>Title actual</b> <span class="muted-note">(' + title.length + ' car.)</span>: ' + esc(title) + '</div>' +
        '<div style="margin-top:6px"><b>Meta description actual</b> <span class="muted-note">(' + desc.length + ' car.)</span>: ' + esc(desc) + '</div>' +
        '<div style="margin-top:8px;color:var(--acid)">💡 Meté «' + esc(row.query) + '» cerca del inicio del title (≤60 car.) y un beneficio/CTA claro en la description (≤155 car.) — editalo directo en el <code>.astro</code> de la página.</div>' +
        '</div>';
    } catch (e) {
      td.innerHTML = '<div class="seo-title-box">No pude leer la página en vivo: ' + esc(e.message || String(e)) + '</div>';
    }
  }

  // ⚔️ Canibalización: además de listar las páginas que compiten, cada página débil
  // (todas menos la dominante, r.pages[0]) tiene un botón "🔗 Sugerir link" — llama a
  // ai-link-suggest para proponer anchor + oración + dónde insertarlo. Solo SUGIERE
  // (pedido explícito de Sebastián: "sugerir el link, yo lo apruebo") — nunca edita ni
  // commitea nada solo, él lo copia y lo mete a mano en el .astro correspondiente.
  function seoRenderCannib(data){
    const cont = $('seo-cannib-wrap'); if (!cont) return;
    const rows = data.cannibalization || [];
    if (!rows.length){ cont.innerHTML = '<p class="muted-note">Sin canibalización detectada — cada búsqueda top tiene una sola página dominante.</p>'; return; }
    let html = '<table class="lead-table"><thead><tr><th>Query</th><th>Páginas compitiendo</th></tr></thead><tbody>';
    rows.forEach((r, ri) => {
      const [strong, ...weak] = r.pages;
      html += '<tr><td>' + esc(r.query) + '</td><td class="seo-cannib-pages">' +
        '<div>🏆 ' + esc(strong.page.replace(/^https?:\/\/[^/]+/, '')) + ' (pos ' + strong.position.toFixed(1) + ', ' + strong.impressions + ' impr.)</div>' +
        weak.map((p, pi) => '<div>' + esc(p.page.replace(/^https?:\/\/[^/]+/, '')) + ' (pos ' + p.position.toFixed(1) + ', ' + p.impressions + ' impr.) ' +
          '<button type="button" class="btn btn-ghost small seo-cannib-link" data-ri="' + ri + '" data-pi="' + pi + '">🔗 Sugerir link</button></div>').join('') +
        '</td></tr>' +
        '<tr class="seo-cannib-detail" id="seo-cannib-detail-' + ri + '" hidden><td colspan="2"></td></tr>';
    });
    cont.innerHTML = html + '</tbody></table>';
    cont.querySelectorAll('.seo-cannib-link').forEach((b) => b.addEventListener('click', () =>
      seoLinkSuggest(+b.dataset.ri, +b.dataset.pi, rows)));
  }
  async function seoLinkSuggest(ri, pi, rows){
    const tr = $('seo-cannib-detail-' + ri); if (!tr) return;
    const td = tr.querySelector('td');
    const r = rows[ri];
    const strong = r.pages[0], weakP = r.pages.slice(1)[pi];
    tr.hidden = false;
    td.innerHTML = '<div class="seo-title-box">Leyendo ambas páginas y pensando el link…</div>';
    try {
      // title/description en vivo de la página débil (mismo origen, sin CORS) — mismo
      // patrón que seoShowTitle, le da a la IA contexto real en vez de solo la URL.
      const fetchMeta = async (url) => {
        try {
          const res = await fetch(url, { cache: 'no-store' });
          const html = await res.text();
          const tm = html.match(/<title[^>]*>([^<]*)<\/title>/i);
          const dm = html.match(/<meta[^>]+name=["']description["'][^>]+content=["']([^"']*)["']/i) || html.match(/<meta[^>]+content=["']([^"']*)["'][^>]+name=["']description["']/i);
          return { title: tm ? tm[1].trim() : '', desc: dm ? dm[1].trim() : '' };
        } catch (_e) { return { title: '', desc: '' }; }
      };
      const [weakMeta, strongMeta] = await Promise.all([fetchMeta(weakP.page), fetchMeta(strong.page)]);
      const { data, error } = await supabase.functions.invoke('ai-link-suggest', {
        body: {
          query: r.query, weakUrl: weakP.page, weakTitle: weakMeta.title, weakDesc: weakMeta.desc,
          strongUrl: strong.page, strongTitle: strongMeta.title,
        },
      });
      if (error || !data || data.error) throw new Error((data && data.error) || (error && error.message) || 'error desconocido');
      td.innerHTML = '<div class="seo-title-box">' +
        '<div><b>Anchor sugerido</b>: ' + esc(data.anchor) + '</div>' +
        '<div style="margin-top:6px"><b>Oración</b>: ' + esc(data.snippet) + '</div>' +
        (data.placement ? '<div style="margin-top:6px"><b>Dónde</b>: ' + esc(data.placement) + '</div>' : '') +
        '<div style="margin-top:10px"><button type="button" class="btn btn-primary small" id="seo-cannib-preview-' + ri + '-' + pi + '">👁️ Ver cambio antes de aplicar</button></div>' +
        '<div id="seo-cannib-diff-' + ri + '-' + pi + '"></div>' +
        '</div>';
      $('seo-cannib-preview-' + ri + '-' + pi).addEventListener('click', () =>
        seoLinkPreview(ri, pi, weakP.page, strong.page, r.query, data.anchor, data.snippet, data.placement));
    } catch (e) {
      td.innerHTML = '<div class="seo-title-box">No se pudo generar la sugerencia: ' + esc(e.message || String(e)) + '</div>';
    }
  }
  // "👁️ Ver cambio antes de aplicar": genera el archivo editado SIN commitear nada
  // (mode:'preview') y muestra el diff real (líneas agregadas/contexto) — recién con
  // eso a la vista aparece el botón para deployar. Pedido explícito: "a mano no hace
  // sentido, dame opción de confirmar y vos lo deployás" — pero confirmar tiene que
  // ser sobre algo concreto, no un confirm() genérico sin mostrar qué cambia.
  async function seoLinkPreview(ri, pi, weakUrl, strongUrl, query, anchor, snippet, placement){
    const btn = $('seo-cannib-preview-' + ri + '-' + pi);
    const box = $('seo-cannib-diff-' + ri + '-' + pi);
    btn.disabled = true; btn.textContent = '⏳ Generando el cambio…';
    try {
      const { data, error } = await supabase.functions.invoke('apply-link-suggest', {
        body: { mode: 'preview', weakUrl, strongUrl, anchor, snippet, placement, query },
      });
      if (error || !data || data.error) throw new Error((data && data.error) || (error && error.message) || 'error desconocido');
      btn.remove();
      const d = data.diff;
      const line = (s, cls) => '<div class="' + cls + '">' + esc(s || '(línea vacía)') + '</div>';
      box.innerHTML = '<div class="seo-title-box" style="margin-top:8px">' +
        '<div style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--muted-2);margin-bottom:6px">Diff real de ' + esc(weakUrl.replace(/^https?:\/\/[^/]+/, '')) + '</div>' +
        '<div style="font-family:monospace;font-size:12px;line-height:1.6;background:var(--navy-900);border-radius:8px;padding:10px;overflow-x:auto">' +
        d.ctxBefore.map((l) => line(l, 'muted-note')).join('') +
        d.removed.map((l) => line('− ' + l, 'seo-diff-rm')).join('') +
        d.added.map((l) => line('+ ' + l, 'seo-diff-add')).join('') +
        d.ctxAfter.map((l) => line(l, 'muted-note')).join('') +
        '</div>' +
        '<div style="margin-top:10px;display:flex;gap:8px;align-items:center">' +
        '<button type="button" class="btn btn-primary small" id="seo-cannib-commit-' + ri + '-' + pi + '">✅ Confirmar y deployar</button>' +
        '<button type="button" class="btn btn-ghost small" id="seo-cannib-cancel-' + ri + '-' + pi + '">Cancelar</button>' +
        '</div><div class="muted-note" style="margin-top:6px" id="seo-cannib-apply-status-' + ri + '-' + pi + '"></div>' +
        '</div>';
      $('seo-cannib-cancel-' + ri + '-' + pi).addEventListener('click', () => { box.innerHTML = ''; });
      $('seo-cannib-commit-' + ri + '-' + pi).addEventListener('click', () =>
        seoLinkCommit(ri, pi, data.path, data.sha, data.updated, weakUrl, strongUrl, anchor, query));
    } catch (e) {
      btn.disabled = false; btn.textContent = '👁️ Ver cambio antes de aplicar';
      box.innerHTML = '<div class="muted-note" style="margin-top:6px">❌ No se pudo generar el cambio: ' + esc(e.message || String(e)) + '</div>';
    }
  }
  // "✅ Confirmar y deployar": commitea EXACTAMENTE el contenido que ya se mostró en
  // el diff (mode:'commit', sin volver a llamar la IA) — lo que se aprueba es lo que
  // se publica, sin margen para que un segundo call devuelva algo distinto.
  async function seoLinkCommit(ri, pi, path, sha, updated, weakUrl, strongUrl, anchor, query){
    const btn = $('seo-cannib-commit-' + ri + '-' + pi);
    const status = $('seo-cannib-apply-status-' + ri + '-' + pi);
    btn.disabled = true; btn.textContent = '⏳ Deployando…';
    try {
      const { data, error } = await supabase.functions.invoke('apply-link-suggest', {
        body: { mode: 'commit', path, sha, updated, weakUrl, strongUrl, anchor, query },
      });
      if (error || !data || data.error) throw new Error((data && data.error) || (error && error.message) || 'error desconocido');
      btn.remove();
      $('seo-cannib-cancel-' + ri + '-' + pi)?.remove();
      status.innerHTML = '✅ Aplicado y deployado — <a href="' + esc(data.liveUrl) + '" target="_blank" rel="noopener">ver página</a>' +
        (data.commitUrl ? ' · <a href="' + esc(data.commitUrl) + '" target="_blank" rel="noopener">ver commit</a>' : '') +
        '<br><span class="muted-note">Puede tardar 1-2 min en reflejarse (deploy de Cloudflare).</span>';
    } catch (e) {
      btn.disabled = false; btn.textContent = '✅ Confirmar y deployar';
      status.textContent = '❌ No se pudo aplicar: ' + (e.message || String(e));
    }
  }

  // tendencia por keyword: lee la historia diaria guardada en gsc_daily (SQL 0069, la llena
  // gsc-sitemap-submit por cron) para las top keywords del período — sin eso, cero tendencia.
  async function loadSeoTrend(queries){
    const wrap = $('seo-trend-wrap'); if (!wrap) return;
    const topQ = (queries || []).slice(0, 10).map((q) => q.key).filter(Boolean);
    if (!topQ.length){ wrap.innerHTML = '<p class="muted-note">Sin búsquedas en el período.</p>'; return; }
    try {
      const since = new Date(Date.now() - 60 * 864e5).toISOString().slice(0, 10);
      const { data, error } = await supabase.from('gsc_daily').select('date,query,position').in('query', topQ).gte('date', since).order('date', { ascending: true });
      if (error) throw error;
      if (!data || !data.length){ wrap.innerHTML = '<p class="muted-note">Sin historia guardada todavía — arranca sola con el próximo cron diario de <code>gsc-sitemap-submit</code> (¿corriste el SQL 0069?). Necesita al menos 2 días de datos por keyword.</p>'; return; }
      const byQ = new Map();
      data.forEach((r) => { if (!byQ.has(r.query)) byQ.set(r.query, []); byQ.get(r.query).push(r); });
      const rows = [];
      byQ.forEach((pts, q) => {
        if (pts.length < 2) return;
        const mid = Math.max(1, Math.floor(pts.length / 2));
        const older = pts.slice(0, mid), recent = pts.slice(mid).length ? pts.slice(mid) : pts.slice(-1);
        const avg = (arr) => arr.reduce((a, r) => a + (+r.position || 0), 0) / arr.length;
        rows.push({ query: q, posNew: avg(recent), posOld: avg(older), delta: avg(older) - avg(recent), n: pts.length });
      });
      if (!rows.length){ wrap.innerHTML = '<p class="muted-note">Todavía no hay suficiente historia (mín. 2 días) para calcular tendencia.</p>'; return; }
      rows.sort((a, b) => Math.abs(b.delta) - Math.abs(a.delta));
      wrap.innerHTML = '<table class="lead-table"><thead><tr><th>Keyword</th><th class="lt-num">Pos.</th><th></th></tr></thead><tbody>' +
        rows.slice(0, 8).map((r) => {
          const up = r.delta > 0.3, down = r.delta < -0.3;
          const cls = up ? 'up' : down ? 'down' : '';
          const arrow = up ? '▲' : down ? '▼' : '=';
          const warn = down && Math.abs(r.delta) > 3 ? ' ⚠' : '';
          return '<tr><td>' + esc(r.query) + '</td><td class="lt-num">' + r.posNew.toFixed(1) + '</td>' +
            '<td class="' + cls + '">' + arrow + (Math.abs(r.delta) > 0.3 ? ' desde ' + r.posOld.toFixed(1) : '') + warn + '</td></tr>';
        }).join('') + '</tbody></table>';
    } catch (e) {
      wrap.innerHTML = '<p class="muted-note">¿Corriste el SQL 0069 (gsc_daily)? ' + esc(e.message || String(e)) + '</p>';
    }
  }

  // estado de indexación: última corrida de gsc-sitemap-submit (resubmit + spot-check URL Inspection), gsc_status (SQL 0069)
