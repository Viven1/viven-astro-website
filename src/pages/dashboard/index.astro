            <div class="lm-block-h" style="margin:0">✍️ Responder <span class="muted-note" id="lm-status-note" style="font-weight:400"></span></div>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
              <label style="font-size:12.5px;color:var(--muted)">De:
                <select id="lm-sender" class="status" style="margin-left:4px">
                  <option value="sofia">Sofia</option>
                  <option value="sebastian">Sebastian</option>
                </select>
              </label>
              <button class="btn btn-ghost small" id="lm-ai" type="button" title="Sugerencia personalizada con IA">✨ IA</button>
              <button class="btn btn-ghost small" id="lm-copy" type="button">📋 Copiar</button>
              <button class="btn btn-primary small" id="lm-send" type="button">📨 Enviar al lead</button>
            </div>
          </div>
          <textarea class="draft-box" id="lm-draft"></textarea>
        </div>
        <div class="lm-journey" id="lm-journey" hidden></div>
      </main>

      <aside class="lm-right" id="lm-right"></aside>
    </div>

    <div class="lead-actions">
      <div class="left"><span class="muted-note">ID: <span id="lm-id-txt"></span></span></div>
      <button class="btn btn-danger small" id="lm-delete" type="button">🗑 Borrar lead</button>
    </div>
  </div>
</div>

<script>
  import { createClient } from '@supabase/supabase-js';

  /* misma URL + publishable key que usa el sitio (públicas por diseño);
     los datos solo se pueden LEER tras login gracias a las policies RLS */
  const supabase = createClient(
    'https://lumoevaotokgqnpybkyf.supabase.co',
    'sb_publishable_ORGL5_FNZTXcGKwvjs-ymw_Y8DV_4ca'
  );

  const $ = (id) => document.getElementById(id);
  const esc = (s) => String(s ?? '').replace(/[&<>"']/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  const fmtTime = (secs) => {
    if (!secs || secs <= 0) return '—';
    const m = Math.floor(secs / 60), s = Math.round(secs % 60);
    return m ? m + 'm ' + (s < 10 ? '0' : '') + s + 's' : s + 's';
  };
  const STATUSES = ['new', 'nuevo', 'contacted', 'contactado', 'qualified', 'won', 'cerrado', 'lost', 'perdido'];
  const THANKS = /^\/(thank-you|danke|gracias)\/?$/;
  let allLeads = [], statusFilter = 'all', searchTerm = '', insightsData = null, lastViews = [], leadsView = 'board', coMeta = {}, coCur = null, coBound = false, meEmail = '';
  // última actividad por lead (notas/tasks/propuestas/web) — se llena en loadAll
  let actNotes = {}, actTasks = {}, actProps = {}, actWeb = {};

  function show(view){
    $('login-view').hidden = view !== 'login';
    $('dash-view').hidden = view !== 'dash';
  }

  /* ---------- Navegación (sidebar) ---------- */
  const TABS = ['home', 'leads', 'deals', 'companies', 'offers', 'props', 'blog', 'analytics'];
  function gotoTab(tab){
    document.querySelectorAll('.side-item').forEach((x) => x.classList.toggle('active', x.dataset.tab === tab));
    // barra inferior móvil: marcar activo ("Más" queda activo si el tab está en la hoja)
    const SHEET_TABS = ['companies', 'props', 'analytics', 'blog'];
    document.querySelectorAll('.mob-nav [data-tab], .mob-sheet [data-tab]').forEach((b) => b.classList.toggle('active', b.dataset.tab === tab));
    const more = $('mob-more'); if (more) more.classList.toggle('active', SHEET_TABS.includes(tab));
    const sheet = $('mob-sheet'); if (sheet) sheet.hidden = true;
    TABS.forEach((k) => { const el = $('tab-' + k); if (el) el.hidden = k !== tab; });
    if (tab === 'home') renderHome();
    if (tab === 'companies') renderCompanies();
    if (tab === 'offers') offersInit();
    if (tab === 'props') proposalsInit();
    if (tab === 'blog') blogInit();
    window.scrollTo(0, 0);
  }
  document.querySelectorAll('.side-item[data-tab]').forEach((t) => {
    if (t.classList.contains('disabled')) return;
    t.addEventListener('click', () => gotoTab(t.dataset.tab));
  });
  // barra inferior móvil + hoja "Más"
  document.querySelectorAll('.mob-nav [data-tab], .mob-sheet [data-tab]').forEach((b) => b.addEventListener('click', () => gotoTab(b.dataset.tab)));
  $('mob-more') && $('mob-more').addEventListener('click', (e) => { e.stopPropagation(); const s = $('mob-sheet'); s.hidden = !s.hidden; });
  document.addEventListener('click', (e) => { const s = $('mob-sheet'); if (s && !s.hidden && !s.contains(e.target)) s.hidden = true; });

  /* ---------- Login ---------- */
  $('login-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const f = e.target;
    f.classList.remove('has-error');
    const { error } = await supabase.auth.signInWithPassword({
      email: f.email.value.trim(),
      password: f.password.value
    });
    if (error) { f.classList.add('has-error'); return; }
    meEmail = (f.email.value.trim() || '').toLowerCase();
    show('dash');
    loadAll();
  });
  $('logout-btn').addEventListener('click', async () => {
    await supabase.auth.signOut();
    show('login');
  });
  $('refresh-btn').addEventListener('click', loadAll);
  /* tema oscuro (navy) / claro (gris estilo Claude Code) */
  $('theme-btn').addEventListener('click', () => {
    const next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
    if (next === 'light') document.documentElement.dataset.theme = 'light';
    else delete document.documentElement.dataset.theme;
    try { localStorage.setItem('viven_theme', next); } catch (e) {}
  });
  /* filtro global de período */
  $('range-sel').addEventListener('change', (e) => {
    rangeDays = parseInt(e.target.value, 10) || 30;
    rangeDay = null; $('range-day').value = '';
    loadAll();
  });
  $('range-day').addEventListener('change', (e) => {
    rangeDay = e.target.value || null;
    loadAll();
  });

  /* ---------- Insights con IA (Edge Function ai-insights → Claude) ---------- */
  // genérico: se usa en Analytics, Leads y Ofertas con distintos resúmenes
  async function runInsights(btnId, bodyId, buildSummary, loadingMsg){
    const btn = $(btnId), body = $(bodyId);
    const summary = buildSummary();
    if (!summary) { body.innerHTML = '<p class="muted-note">Todavía no hay datos suficientes.</p>'; return; }
    const prev = btn.textContent; btn.disabled = true; btn.textContent = '✨ Analizando…';
    body.innerHTML = '<p class="ai-loading">' + (loadingMsg || 'La IA está analizando tus datos…') + '</p>';
    try {
      const { data, error } = await supabase.functions.invoke('ai-insights', { body: { summary, lang: 'es' } });
      if (error || !data || !Array.isArray(data.insights)) throw new Error(data?.error || error?.message || 'sin respuesta');
      body.innerHTML = data.insights.map((i) =>
        '<div class="ai-insight"><span class="ico">' + esc(i.icon || '💡') + '</span>' +
        '<div class="txt"><h4>' + esc(i.title || '') + '</h4><p>' + esc(i.detail || '') + '</p></div></div>'
      ).join('') || '<p class="muted-note">La IA no devolvió sugerencias.</p>';
    } catch (e) {
      body.innerHTML = '<p class="muted-note">No se pudo generar (¿deployaste ai-insights y hay crédito en Anthropic?): ' + esc(e.message) + '</p>';
    } finally { btn.disabled = false; btn.textContent = prev; }
  }

  // resumen del funnel de leads (conversión + tiempos entre etapas)
  function leadsSummary(){
    const set = (allLeads || []).filter((l) => inRange(l.created_at) && !/^claude-/.test(l.session_id || ''));
    if (!set.length) return null;
    const steps = [
      { k: 'leads', ts: (l) => l.created_at }, { k: 'contactado', ts: (l) => l.contacted_at },
      { k: 'videocall', ts: (l) => l.videocall_at }, { k: 'propuesta', ts: (l) => l.proposal_at }, { k: 'ganado', ts: (l) => l.won_at },
    ];
    const counts = steps.map((s) => set.filter((l) => s.ts(l)).length);
    const avgDays = (a, b) => { const ds = set.map((l) => { const x = Date.parse(b(l)), y = Date.parse(a(l)); return (x && y && x >= y) ? (x - y) / 864e5 : null; }).filter((v) => v != null); return ds.length ? +(ds.reduce((p, c) => p + c, 0) / ds.length).toFixed(1) : null; };
    const chan = {}; set.forEach((l) => { const c = l.channel || 'direct'; chan[c] = (chan[c] || 0) + 1; });
    const lost = set.filter((l) => l.lost_at).length;
    return {
      contexto: 'Funnel de leads de Viven (productora de video). Conversión y días promedio entre etapas.',
      periodo: rangeLabel(),
      leads: counts[0], contactados: counts[1], video_calls: counts[2], propuestas: counts[3], ganados: counts[4], perdidos: lost,
      conv_lead_a_contactado_pct: counts[0] ? Math.round(counts[1] / counts[0] * 100) : 0,
      conv_contactado_a_videocall_pct: counts[1] ? Math.round(counts[2] / counts[1] * 100) : 0,
      conv_videocall_a_propuesta_pct: counts[2] ? Math.round(counts[3] / counts[2] * 100) : 0,
      conv_propuesta_a_ganado_pct: counts[3] ? Math.round(counts[4] / counts[3] * 100) : 0,
      cierre_ganado_sobre_decididos_pct: (counts[4] + lost) ? Math.round(counts[4] / (counts[4] + lost) * 100) : 0,
      dias_lead_a_contactado: avgDays((l) => l.created_at, (l) => l.contacted_at),
      dias_contactado_a_videocall: avgDays((l) => l.contacted_at, (l) => l.videocall_at),
      dias_videocall_a_propuesta: avgDays((l) => l.videocall_at, (l) => l.proposal_at),
      dias_propuesta_a_ganado: avgDays((l) => l.proposal_at, (l) => l.won_at),
      canales: chan,
      sin_contactar: set.filter((l) => isNew(l.status)).length,
    };
  }

  // resumen de ofertas (conversión, semanas para cerrar, margen)
  function offersSummary(){
    if (!offersList || !offersList.length) return null;
    const won = offersList.filter((o) => o.status === 'won'), lost = offersList.filter((o) => o.status === 'lost'), open = offersList.filter((o) => o.status === 'sent');
    const dec = won.length + lost.length;
    const margins = offersList.map(offerMarginPct).filter((m) => isFinite(m));
    const closeW = won.map((o) => (Date.parse(o.updated_at) - Date.parse(o.created_at)) / 6048e5).filter((d) => d >= 0);
    return {
      contexto: 'Ofertas/presupuestos de Viven (productora de video). Precio al cliente vs costo interno.',
      ofertas_totales: offersList.length, enviadas_esperando: open.length, ganadas: won.length, perdidas: lost.length,
      conversion_ganadas_sobre_decididas_pct: dec ? Math.round(won.length / dec * 100) : 0,
      semanas_promedio_para_cerrar: closeW.length ? +(closeW.reduce((a, b) => a + b, 0) / closeW.length).toFixed(1) : null,
      valor_ganado_neto_chf: Math.round(won.reduce((a, o) => a + offerNet(o), 0)),
      margen_medio_pct: margins.length ? Math.round(margins.reduce((a, b) => a + b, 0) / margins.length) : null,
      ticket_medio_ganado_chf: won.length ? Math.round(won.reduce((a, o) => a + offerNet(o), 0) / won.length) : null,
    };
  }

  $('ai-insights-btn').addEventListener('click', () => runInsights('ai-insights-btn', 'ai-insights-body',
    () => insightsData ? { ...insightsData, ...leadsSummary(), contexto: 'Tráfico web + funnel de leads de Viven.' } : null,
    'La IA está analizando tu tráfico, canales y conversión…'));
  $('ai-leads-btn').addEventListener('click', () => runInsights('ai-leads-btn', 'ai-leads-body', leadsSummary,
    'La IA está analizando tu funnel de leads…'));
  $('ai-offers-btn').addEventListener('click', () => runInsights('ai-offers-btn', 'ai-offers-body', offersSummary,
    'La IA está analizando tus ofertas…'));

  /* ---------- Data ---------- */
  /* ---------- Ventana de tiempo (filtro global) ---------- */
  let rangeDays = 30;      // preset: 1 / 7 / 30 / 90 / 365
  let rangeDay = null;     // 'YYYY-MM-DD' → un día puntual (pisa el preset)
  const rangeStart = () => rangeDay ? new Date(rangeDay + 'T00:00:00').getTime() : Date.now() - rangeDays * 864e5;
  const rangeEnd = () => rangeDay ? new Date(rangeDay + 'T23:59:59.999').getTime() : Date.now();
  const inRange = (d) => { const t = new Date(d).getTime(); return t >= rangeStart() && t <= rangeEnd(); };
  const rangeLabel = () => rangeDay
    ? new Date(rangeDay + 'T00:00:00').toLocaleDateString('es-CH', { day: '2-digit', month: 'long', year: 'numeric' })
    : (rangeDays === 1 ? 'Hoy' : 'Últimos ' + rangeDays + ' días');
  // nº de días que muestra el gráfico diario (acotado para que el SVG no explote)
  const rangeSpanDays = () => rangeDay ? 1 : rangeDays;
  const since = () => new Date(rangeStart()).toISOString();
  const until = () => new Date(rangeEnd()).toISOString();

  async function loadAll(){
    const [leadsQ, viewsQ, videosQ, offersQ, coQ, notesQ, tasksQ, propsQ] = await Promise.all([
      supabase.from('leads').select('*').order('created_at', { ascending: false }).limit(2000),
      supabase.from('pageviews')
        .select('created_at,path,device,session_id,channel,referrer,lang,is_entry,duration')
        .gte('created_at', since()).lte('created_at', until()).limit(20000),
      supabase.from('video_plays').select('video_id,label').gte('created_at', since()).lte('created_at', until()).limit(20000),
      supabase.from('offers').select('*').order('updated_at', { ascending: false }),
      supabase.from('companies').select('*'),
      // para "última actividad" (best-effort: si faltan las tablas, queda vacío)
      supabase.from('lead_notes').select('lead_id,created_at').order('created_at', { ascending: false }).limit(1000),
      supabase.from('lead_tasks').select('lead_id,created_at,done_at').order('created_at', { ascending: false }).limit(1000),
      supabase.from('proposals').select('lead_id,updated_at').limit(1000)
    ]);
    if (leadsQ.error || viewsQ.error) {
      alert('Error cargando datos: ' + (leadsQ.error || viewsQ.error).message);
      return;
    }
    allLeads = leadsQ.data || [];
    lastViews = viewsQ.data || [];
    // ofertas: best-effort (si no corrió el SQL 0003 todavía, seguimos sin romper el dashboard)
    if (offersQ && !offersQ.error) offersList = offersQ.data || [];
    // companies: best-effort (si no corrió el SQL 0011, coMeta queda vacío)
    coMeta = {}; if (coQ && !coQ.error) (coQ.data || []).forEach((c) => { if (c.domain) coMeta[c.domain] = c; });
    // última actividad: mapa lead_id → timestamp más reciente por tipo
    const maxTo = (map, key, iso) => { const t = Date.parse(iso); if (t && (!map[key] || t > map[key])) map[key] = t; };
    actNotes = {}; if (notesQ && !notesQ.error) (notesQ.data || []).forEach((n) => maxTo(actNotes, String(n.lead_id), n.created_at));
    actTasks = {}; if (tasksQ && !tasksQ.error) (tasksQ.data || []).forEach((t) => { maxTo(actTasks, String(t.lead_id), t.created_at); if (t.done_at) maxTo(actTasks, String(t.lead_id), t.done_at); });
    actProps = {}; if (propsQ && !propsQ.error) (propsQ.data || []).forEach((p) => { if (p.lead_id) maxTo(actProps, String(p.lead_id), p.updated_at); });
    actWeb = {}; (viewsQ.data || []).forEach((v) => { if (v.session_id) maxTo(actWeb, v.session_id, v.created_at); });
    renderLeads();
    renderAnalytics(lastViews, allLeads);
    renderHome();
    // reproducciones de video + top 3 más vistos (si no corrió el SQL 0008, queda en 0)
    const plays = (videosQ && !videosQ.error) ? (videosQ.data || []) : [];
    $('ka-videos').textContent = plays.length;
    const vc = {}; plays.forEach((p) => { const k = p.label || p.video_id; vc[k] = (vc[k] || 0) + 1; });
    const top = Object.entries(vc).sort((a, b) => b[1] - a[1]).slice(0, 3).map(([k, n]) => esc(String(k).slice(0, 30)) + ' (' + n + ')');
    $('ka-videos-top').textContent = top.length ? 'Top: ' + top.join(', ') : '';
    $('updated-at').textContent = rangeLabel() + ' · actualizado ' + new Date().toLocaleTimeString('es-CH', { hour: '2-digit', minute: '2-digit' });
    loadBell();
    subscribeRealtime();
  }

  /* ---------- Realtime: leads nuevos aparecen solos (gratis, sin polling) ---------- */
  let rtSubscribed = false;
  function subscribeRealtime(){
    if (rtSubscribed) return;
    rtSubscribed = true;
    supabase.channel('leads-live')
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'leads' }, (payload) => {
        const r = payload.new;
        if (allLeads.some((l) => l.id === r.id)) return;
        allLeads.unshift(r);
        renderLeads();
        renderAnalytics(lastViews, allLeads);
        toast('🎬 Nuevo lead: ' + (r.name || r.email));
      })
      .on('postgres_changes', { event: 'UPDATE', schema: 'public', table: 'leads' }, (payload) => {
        const i = allLeads.findIndex((l) => l.id === payload.new.id);
        if (i > -1) { allLeads[i] = payload.new; renderLeads(); renderAnalytics(lastViews, allLeads); }
      })
      .on('postgres_changes', { event: '*', schema: 'public', table: 'lead_tasks' }, () => { loadBell(); })
      .subscribe();
  }
  function toast(msg){
    let t = document.getElementById('dash-toast');
    if (!t) {
      t = document.createElement('div'); t.id = 'dash-toast';
      t.style.cssText = 'position:fixed;bottom:24px;right:24px;z-index:9999;background:var(--acid);color:#142033;font-weight:700;font-family:Space Grotesk;padding:14px 20px;border-radius:12px;box-shadow:0 12px 40px -10px rgba(0,0,0,.6);transition:.3s;opacity:0;transform:translateY(10px)';
      document.body.appendChild(t);
    }
    t.textContent = msg;
    requestAnimationFrame(() => { t.style.opacity = '1'; t.style.transform = 'none'; });
    clearTimeout(t._h);
    t._h = setTimeout(() => { t.style.opacity = '0'; t.style.transform = 'translateY(10px)'; }, 6000);
  }

  /* ================= CAMPANA: tareas y avisos (mobile/desktop/tablet) ================= */
  let bellItems = [], bellBound = false;
  function leadName(id){ const l = allLeads.find((x) => String(x.id) === String(id)); return l ? (l.name || l.email) : 'Lead'; }
  const startOfToday = () => { const d = new Date(); d.setHours(0, 0, 0, 0); return d; };
  async function loadBell(){
    if (!bellBound){ bellBound = true;
      $('bell-btn').addEventListener('click', (e) => { e.stopPropagation(); toggleBell(); });
      $('bell-x').addEventListener('click', (e) => { e.stopPropagation(); $('bell-panel').hidden = true; });
      $('bell-panel').addEventListener('click', (e) => e.stopPropagation());
      document.addEventListener('click', () => { $('bell-panel').hidden = true; });
    }
    try {
      const [tq, nq] = await Promise.all([
        supabase.from('lead_tasks').select('*').eq('done', false).order('due_date', { ascending: true }).limit(60),
        supabase.from('lead_notes').select('*').not('mention', 'is', null).order('created_at', { ascending: false }).limit(30)
      ]);
      const tasks = (tq && !tq.error && tq.data) || [];
      const notes = (nq && !nq.error && nq.data) || [];
      const mine = (t) => !meEmail || !t.assignee || String(t.assignee).toLowerCase() === meEmail; // sin asignar o para mí
      const t0 = startOfToday(), tEnd = new Date(t0.getTime() + 86400000);
      bellItems = [];
      const nowTs = Date.now();
      tasks.filter(mine).forEach((t) => {
        const due = t.due_date ? new Date(t.due_date + 'T' + (t.due_time || '00:00') + ':00') : null;
        let bucket = 'later', overdue = false;
        if (due) { if (t.due_time ? due.getTime() < nowTs : due < t0) { bucket = 'overdue'; overdue = true; } else if (due < tEnd) bucket = 'today'; else bucket = 'later'; }
        else bucket = 'nodate';
        bellItems.push({ kind: 'task', id: t.id, lead_id: t.lead_id, title: t.title, due, time: t.due_time || '', bucket, overdue });
      });
      // notas donde me mencionaron a mí (últimas 24-72h no filtramos, mostramos como aviso)
      notes.filter((n) => meEmail && String(n.mention || '').toLowerCase() === meEmail).slice(0, 8).forEach((n) => {
        bellItems.push({ kind: 'mention', id: n.id, lead_id: n.lead_id, title: (n.body || '').slice(0, 80), due: null, bucket: 'mention', overdue: false });
      });
      renderBell();
    } catch (e) { /* si no corrió el SQL 0010, la campana queda vacía */ renderBell(); }
  }
  function renderBell(){
    const badge = $('bell-badge');
    const urgent = bellItems.filter((i) => i.bucket === 'overdue' || i.bucket === 'today' || i.bucket === 'mention').length;
    if (urgent > 0) { badge.hidden = false; badge.textContent = urgent > 99 ? '99+' : urgent; } else badge.hidden = true;
    const order = { overdue: 0, today: 1, mention: 2, later: 3, nodate: 4 };
    const labels = { overdue: ['⚠️ Vencidas', true], today: ['📅 Para hoy', false], mention: ['💬 Te mencionaron', false], later: ['🕒 Próximas', false], nodate: ['📌 Sin fecha', false] };
    const list = $('bell-list');
    if (!bellItems.length) { list.innerHTML = '<div class="bell-empty">Nada pendiente 🎉<br>Las tareas que crees en un lead aparecen acá.</div>'; return; }
    const grouped = {};
    bellItems.forEach((i) => { (grouped[i.bucket] = grouped[i.bucket] || []).push(i); });
    const fmtDue = (i) => i.due ? (i.due.toLocaleDateString('es-CH', { day: '2-digit', month: 'short' }) + (i.time ? ' ' + i.time : '')) : '';
    let html = '';
    Object.keys(grouped).sort((a, b) => (order[a] ?? 9) - (order[b] ?? 9)).forEach((b) => {
      const [lbl, od] = labels[b] || [b, false];
      html += '<div class="bell-grp' + (od ? ' od' : '') + '">' + lbl + ' (' + grouped[b].length + ')</div>';
      grouped[b].forEach((i) => {
        html += '<button class="bell-item" data-lead="' + esc(i.lead_id) + '" type="button"><span class="bi-t">' + (i.kind === 'mention' ? '💬 ' : '') + esc(i.title || '(sin título)') + '</span><span class="bi-s">' + esc(leadName(i.lead_id)) + (i.due ? ' · <span class="bi-due' + (i.overdue ? ' od' : '') + '">' + fmtDue(i) + '</span>' : '') + '</span></button>';
      });
    });
    list.innerHTML = html;
    list.querySelectorAll('.bell-item').forEach((b) => b.addEventListener('click', () => { $('bell-panel').hidden = true; gotoTab('leads'); openLead(b.dataset.lead); }));
  }
  function toggleBell(){ const p = $('bell-panel'); const willOpen = p.hidden; document.querySelectorAll('.bell-panel').forEach((x) => x.hidden = true); p.hidden = !willOpen; if (willOpen) loadBell(); }

  /* ---------- LEADS ---------- */
  const isNew = (s) => s === 'new' || s === 'nuevo';
  $('lead-search').addEventListener('input', (e) => { searchTerm = e.target.value.toLowerCase(); renderLeads(); });
  document.querySelectorAll('.toolbar .fpill').forEach((p) => {
    p.addEventListener('click', () => {
      document.querySelectorAll('.toolbar .fpill').forEach((x) => x.classList.toggle('active', x === p));
      statusFilter = p.dataset.status;
      renderLeads();
    });
  });

  function filteredLeads(){
    return allLeads.filter((r) => {
      if (!inRange(r.created_at)) return false;
      if (statusFilter === 'new' && !isNew(r.status)) return false;
      if (statusFilter === 'contacted' && !(r.status === 'contacted' || r.status === 'contactado')) return false;
      if (statusFilter === 'won' && !(r.status === 'won' || r.status === 'cerrado')) return false;
      if (searchTerm) {
        const hay = ((r.name || '') + ' ' + (r.email || '') + ' ' + (r.message || '')).toLowerCase();
        if (hay.indexOf(searchTerm) === -1) return false;
      }
      return true;
    });
  }

  function renderLeads(){
    /* leads dentro de la ventana de tiempo seleccionada */
    const viewLeads = allLeads.filter((r) => inRange(r.created_at));
    $('kl-total').textContent = allLeads.length;                       // histórico
    $('tab-leads-count').textContent = allLeads.filter((r) => isNew(r.status)).length; // sin contactar SIEMPRE (accionable)
    $('kl-week').textContent = viewLeads.length;                       // en el período
    $('kl-week-l').textContent = rangeDay ? rangeLabel() : 'En el período (' + rangeLabel().toLowerCase() + ')';
    $('kl-new').textContent = viewLeads.filter((r) => isNew(r.status)).length;
    $('kl-ads').textContent = viewLeads.filter((r) => r.gclid).length;

    /* estado del pipeline + follow-ups — sobre los leads del período */
    /* usa la MISMA clasificación que el pipeline (stageOf) — si no, un lead arrastrado
       a "Ganado" queda con status 'ganado' y el KPI won ('won'/'cerrado') no lo contaba */
    const byStage = (k) => viewLeads.filter((r) => stageOf(r.status) === k).length;
    const contacted = byStage('contactado');
    const won = byStage('ganado');
    const lost = byStage('perdido');
    const decided = won + lost;
    const in7 = Date.now() + 7 * 864e5;
    const followWeek = allLeads.filter((r) => r.next_follow_up_at && new Date(r.next_follow_up_at).getTime() <= in7).length;
    $('kl-contacted').textContent = contacted;
    $('kl-won').textContent = won;
    $('kl-lost').textContent = lost;
    /* conversión = ganados sobre los ya decididos (ganado+perdido); más honesto que sobre el total */
    $('kl-convrate').innerHTML = decided ? (won / decided * 100).toFixed(0) + '<small>%</small>' : '–';
    $('kl-followup').textContent = followWeek;

    /* color-coding: ganados verde, perdidos rojo, el resto neutro (blanco) */
    ['kl-total', 'kl-week', 'kl-new', 'kl-ads', 'kl-contacted', 'kl-convrate', 'kl-followup'].forEach((id) => { $(id).style.color = 'var(--text)'; });
    $('kl-won').style.color = won ? '#7ed957' : 'var(--text)';
    $('kl-lost').style.color = lost ? '#ff6b6b' : 'var(--text)';

    renderFunnel(viewLeads);
    renderPeopleList();  // Personas (lista)
    renderPipeline();    // Deals (board)
  }
  // Personas: tabla de gente (lista) con filtro de etapa + orden por columna
  function renderPeopleList(){
    const cont = $('leads-list'); if (!cont) return;
    let rows = filteredLeads();
    if (psStage !== 'all') rows = rows.filter((r) => stageOf(r.status) === psStage);
    if (psAct !== 'all') rows = rows.filter((r) => (lastActivity(r) || {}).kind === psAct);
    cont.innerHTML = leadsListHTML(rows);
    cont.querySelectorAll('.lead-table tbody tr').forEach((tr) => tr.addEventListener('click', () => openLead(tr.dataset.id)));
    cont.querySelectorAll('.lead-table th[data-k]').forEach((th) => th.addEventListener('click', () => {
      const k = th.dataset.k;
      if (psSort.k === k) psSort.dir *= -1;
      else psSort = { k, dir: (k === 'name' || k === 'channel') ? 1 : -1 };
      renderPeopleList();
    }));
  }
  $('ps-stage').addEventListener('change', (e) => { psStage = e.target.value; renderPeopleList(); });
  $('ps-act').addEventListener('change', (e) => { psAct = e.target.value; renderPeopleList(); });

  /* ---------- HOME: KPIs globales + tendencia vs semana anterior ---------- */
  function renderHome(){
    const now = Date.now(), W = 7 * 864e5;
    const real = (allLeads || []).filter((l) => !/^claude-/.test(l.session_id || ''));
    const inA = (d) => { if (!d) return false; const t = new Date(d).getTime(); return t >= now - W && t <= now; };
    const inB = (d) => { if (!d) return false; const t = new Date(d).getTime(); return t >= now - 2 * W && t < now - W; };
    const cnt = (arr, p) => arr.filter(p).length;
    const tr = (a, b) => { if (b === 0) return a > 0 ? { t: '▲ nuevo', up: true } : { t: '—', muted: true }; const p = Math.round((a - b) / b * 100); return { t: (p >= 0 ? '▲ ' : '▼ ') + Math.abs(p) + '%', up: p >= 0 }; };
    const setT = (id, x) => { const el = $(id); if (!el) return; el.textContent = x.t + ' vs sem. ant.'; el.className = 'hk-t ' + (x.muted ? 'muted' : (x.up ? 'up' : 'down')); };

    const leadsA = cnt(real, (l) => inA(l.created_at)), leadsB = cnt(real, (l) => inB(l.created_at));
    const wonA = cnt(real, (l) => inA(l.won_at)), wonB = cnt(real, (l) => inB(l.won_at));
    const revOf = (pred) => (offersList || []).filter((o) => o.status === 'won' && pred(o.updated_at)).reduce((a, o) => a + offerNet(o), 0);
    const revA = revOf(inA), revB = revOf(inB);
    const sess = (pred) => new Set((lastViews || []).filter((v) => pred(v.created_at) && !/^claude-/.test(v.session_id || '')).map((v) => v.session_id)).size;
    const sessA = sess(inA), sessB = sess(inB);
    const pipe = (offersList || []).filter((o) => o.status === 'sent').reduce((a, o) => a + offerNet(o), 0);
    const won = real.filter((l) => stageOf(l.status) === 'ganado').length, lost = real.filter((l) => stageOf(l.status) === 'perdido').length;

    $('h-leads').textContent = leadsA; setT('h-leads-t', tr(leadsA, leadsB));
    $('h-won').textContent = wonA; setT('h-won-t', tr(wonA, wonB));
    $('h-rev').textContent = fmtChf(revA); setT('h-rev-t', tr(revA, revB));
    $('h-sess').textContent = sessA.toLocaleString('de-CH'); setT('h-sess-t', tr(sessA, sessB));
    $('h-pipe').textContent = fmtChf(pipe);
    $('h-conv').textContent = (won + lost) ? Math.round(won / (won + lost) * 100) + '%' : '–';

    renderFunnel(real.filter((l) => new Date(l.created_at).getTime() >= now - 30 * 864e5), 'home-funnel');

    const in7 = now + W;
    const att = (c, ic, txt, n, tab) => '<div class="att" data-tab="' + tab + '"><span class="ai" style="background:color-mix(in srgb,' + c + ' 18%,transparent);color:' + c + '">' + ic + '</span>' + txt + '<b>' + n + '</b></div>';
    $('home-att').innerHTML =
      att('#8ab4ff', '📥', 'Leads sin contactar', cnt(real, (l) => isNew(l.status)), 'leads') +
      att('#f0c060', '⏰', 'Follow-ups esta semana', cnt(real, (l) => l.next_follow_up_at && new Date(l.next_follow_up_at).getTime() <= in7), 'leads') +
      att('#7ed957', '🧾', 'Ofertas esperando respuesta', (offersList || []).filter((o) => o.status === 'sent').length, 'offers') +
      att('#c58af9', '🌐', 'Propuestas enviadas', (real.filter((l) => stageOf(l.status) === 'propuesta').length), 'props');
    $('home-att').querySelectorAll('.att').forEach((a) => a.addEventListener('click', () => gotoTab(a.dataset.tab)));
  }

  /* ---------- Pipeline kanban (drag & drop entre etapas) ---------- */
  const STAGES = [
    { key: 'nuevo',      label: 'Nuevo',        color: '#8ab4ff', prob: 0.2,  match: ['new', 'nuevo', '', 'pending'] },
    { key: 'contactado', label: 'Contactado',   color: '#f0c060', prob: 0.4,  match: ['contacted', 'contactado'] },
    { key: 'videocall',  label: 'Video Call',   color: '#c58af9', prob: 0.6,  match: ['videocall', 'video call booked', 'call', 'agendada', 'booked'] },
    { key: 'propuesta',  label: 'Propuesta',    color: '#f0904e', prob: 0.8,  match: ['proposal', 'propuesta', 'qualified'] },
    { key: 'ganado',     label: 'Ganado',       color: '#7ed957', prob: 1,    match: ['won', 'cerrado', 'ganado'] },
    { key: 'perdido',    label: 'Perdido',      color: '#ff6b6b', prob: 0,    match: ['lost', 'perdido'] },
  ];
  // color determinista del chip de empresa (por nombre)
  const CO_PALETTE = ['#8ab4ff', '#c58af9', '#7ed957', '#f0c060', '#ff8b5e', '#5ec7d1', '#e08ac5'];
  function coColor(name){ let h = 0; const s = String(name || ''); for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) >>> 0; return CO_PALETTE[h % CO_PALETTE.length]; }
  // columna de timestamp por etapa (para el funnel: conversión y tiempos)
  const STAGE_TS = { contactado: 'contacted_at', videocall: 'videocall_at', propuesta: 'proposal_at', ganado: 'won_at', perdido: 'lost_at' };
  const STAGE_ORDER = ['nuevo', 'contactado', 'videocall', 'propuesta', 'ganado'];
  function stageOf(status){
    const s = (status || '').toLowerCase();
    for (const st of STAGES) if (st.match.includes(s)) return st.key;
    return 'nuevo';
  }
  function timeAgo(iso){
    const s = (Date.now() - new Date(iso).getTime()) / 1000;
    if (s < 3600) return Math.max(1, Math.round(s / 60)) + 'm';
    if (s < 86400) return Math.round(s / 3600) + 'h';
    return Math.round(s / 86400) + 'd';
  }
  const OF_ST = { draft: 'Borrador', sent: 'Enviada', won: 'Ganada', lost: 'Perdida' };
  // ofertas (no archivadas) ligadas a un lead
  const offersForLead = (id) => (offersList || []).filter((o) => o.lead_id && String(o.lead_id) === String(id) && !o.archived);
  // motivo de pérdida heredado del contacto (si el lead está perdido y la oferta/propuesta no tiene el suyo)
  const leadLostReason = (lead_id) => { const l = (allLeads || []).find((x) => String(x.id) === String(lead_id)); return (l && stageOf(l.status) === 'perdido' && l.lost_reason) || null; };
  // Última actividad con el cliente (como HubSpot): lo más reciente entre visitar la web,
  // email enviado (contactado), video call, oferta, propuesta, nota o task.
  function lastActivity(r){
    const cand = [];
    const push = (ts, kind, label) => { const t = typeof ts === 'number' ? ts : Date.parse(ts || ''); if (t) cand.push({ t, kind, label }); };
    push(r.created_at, 'form', '📥 Lead creado');
    push(r.contacted_at, 'email', '✉️ Email enviado');
    push(r.videocall_at, 'call', '📞 Video call');
    push(r.proposal_at, 'prop', '📄 Propuesta');
    push(r.won_at, 'won', '🏆 Ganado');
    push(r.lost_at, 'lost', '✕ Perdido');
    offersForLead(r.id).forEach((o) => push(o.updated_at, 'offer', '🧾 Oferta'));
    push(actProps[String(r.id)], 'prop', '📄 Propuesta');
    push(actNotes[String(r.id)], 'note', '📝 Nota');
    push(actTasks[String(r.id)], 'task', '✅ Task');
    if (r.session_id && actWeb[r.session_id]) push(actWeb[r.session_id], 'web', '🌐 Visitó la web');
    if (!cand.length) return null;
    return cand.sort((a, b) => b.t - a.t)[0];
  }
  const actLabel = (a) => a ? a.label + ' · ' + timeAgo(new Date(a.t).toISOString()) : '—';
  const OF_COLOR = { draft: '#8ab4ff', sent: '#f0c060', won: '#7ed957', lost: '#ff6b6b' };
  const OWN_COLOR = { 'sofia@viven.ch': '#ddf98f', 'sebastian@viven.ch': '#8ab4ff', 'info@viven.ch': '#f0c060' };
  function ownerAvatar(r){
    const e = r.owner; if (!e) return '';
    const nm = teamName(e); const ini = (nm.split(/\s+/).map((w) => w[0]).slice(0, 2).join('') || '?').toUpperCase();
    return '<span class="pc-owner" title="' + esc(nm) + '" style="background:' + (OWN_COLOR[e] || '#8ab4ff') + '">' + esc(ini) + '</span>';
  }
  const fmtDMY = (d) => d ? new Date(d).toLocaleDateString('es-CH', { day: '2-digit', month: '2-digit', year: 'numeric' }) : '';
  function cardHTML(r, st){
    const ofs = offersForLead(r.id);
    const total = ofs.reduce((a, o) => a + offerNet(o), 0);
    const ost = ofs.length ? '<span class="pc-ost" style="color:' + (OF_COLOR[ofs[0].status] || '#8ab4ff') + '">' + (OF_ST[ofs[0].status] || '') + '</span>' : '';
    // nombre del deal: título de la oferta ligada, o el de la persona
    const dealName = (ofs[0] && ofs[0].title) ? ofs[0].title : (r.name || r.first_name || '(sin nombre)');
    const field = (k, v, cls) => v ? '<div class="pc-field"><span class="k">' + k + '</span><span class="v ' + (cls || '') + '">' + v + '</span></div>' : '';
    // empresa asociada con chip de logo
    const dom = leadDomain(r);
    let coField = '';
    if (dom) { const cn = companyName(dom); coField = '<div class="pc-field"><span class="k">Empresa:</span><span class="v"><span class="pc-co" style="background:' + coColor(cn) + '">' + esc(cn.slice(0, 2).toUpperCase()) + '</span>' + esc(cn) + '</span></div>'; }
    const ownerF = r.owner ? field('Owner:', esc(teamName(r.owner))) : '';
    // última actividad real con el cliente (web, email, oferta, nota…) + próximo paso
    const la = lastActivity(r);
    let act = la ? '<div class="pc-act">' + esc(actLabel(la)) + '</div>' : '';
    if (st.key === 'contactado' && r.next_follow_up_at) act += '<div class="pc-act">⏰ Follow-up: ' + fmtDMY(r.next_follow_up_at) + '</div>';
    else if (st.key === 'perdido' && r.lost_reason) act += '<div class="pc-lost">✕ ' + esc(r.lost_reason) + '</div>';
    const ch = r.channel ? '<span class="pc-badge">' + esc(r.channel) + '</span>' : '';
    const ads = r.gclid ? '<span class="pc-ads">Ads</span>' : '';
    return '<div class="pipe-card" draggable="true" data-id="' + r.id + '" style="--stage:' + st.color + '">' +
      '<div class="pc-name">' + esc(dealName) + '</div>' +
      field('Importe:', total ? fmtChf(total) : '—', 'amt') +
      coField + ownerF +
      field('Creado:', fmtDMY(r.created_at)) +
      act +
      '<div class="pc-foot"><div class="pc-tags">' + ch + ads + ost + '</div>' + ownerAvatar(r) + '</div>' +
    '</div>';
  }
  // valor total de las ofertas (no archivadas) ligadas a un conjunto de leads
  const leadsValue = (leads) => leads.reduce((a, l) => a + offersForLead(l.id).reduce((b, o) => b + offerNet(o), 0), 0);
  const fmtChf = (n) => n ? 'CHF ' + Math.round(n).toLocaleString('de-CH') : '—';

  function renderPipeline(){
    const rows = filteredLeads();
    $('leads-empty').hidden = rows.length > 0;
    const byStage = {}; STAGES.forEach((s) => byStage[s.key] = []);
    rows.forEach((r) => byStage[stageOf(r.status)].push(r));
    Object.values(byStage).forEach((a) => a.sort((x, y) => new Date(y.created_at) - new Date(x.created_at)));
    // resumen del pipeline (tipo HubSpot): abierto, ponderado (forecast), ganado, total
    const OPEN = ['nuevo', 'contactado', 'videocall', 'propuesta'];
    const openVal = OPEN.reduce((a, k) => a + leadsValue(byStage[k]), 0);
    const openCnt = OPEN.reduce((a, k) => a + byStage[k].length, 0);
    const weighted = OPEN.reduce((a, k) => a + leadsValue(byStage[k]) * (STAGES.find((s) => s.key === k).prob), 0);
    const wonVal = leadsValue(byStage['ganado']);
    const sum = $('deals-sum');
    if (sum) sum.innerHTML =
      '<div class="ds"><div class="dv">' + fmtChf(openVal) + '</div><div class="dl">Pipeline abierto · ' + openCnt + ' deal' + (openCnt !== 1 ? 's' : '') + '</div></div>' +
      '<div class="ds"><div class="dv" style="color:var(--acid)">' + fmtChf(Math.round(weighted)) + '</div><div class="dl">Ponderado (forecast)</div></div>' +
      '<div class="ds"><div class="dv" style="color:#7ed957">' + fmtChf(wonVal) + '</div><div class="dl">Ganado (' + byStage['ganado'].length + ')</div></div>' +
      '<div class="ds"><div class="dv">' + rows.length + '</div><div class="dl">Deals en total</div></div>';
    const pipe = $('pipeline');
    pipe.className = 'pipeline';
    pipe.innerHTML = STAGES.map((s) => {
      const n = byStage[s.key].length;
      const cards = byStage[s.key].map((r) => cardHTML(r, s)).join('') || '<div class="pipe-empty">Sin deals</div>';
      const val = leadsValue(byStage[s.key]);
      const wt = Math.round(val * s.prob);
      return '<div class="pipe-col" data-stage="' + s.key + '">' +
        '<div class="pipe-col-head"><span class="bar" style="background:' + s.color + '"></span><span class="st">' + s.label + '</span><span class="cnt">' + n + '</span></div>' +
        '<div class="pipe-list">' + cards + '</div>' +
        '<div class="pipe-col-foot"><div class="tot">' + fmtChf(val) + ' · Total</div><div class="wt">' + fmtChf(wt) + ' (' + Math.round(s.prob * 100) + '%) · Ponderado</div></div>' +
      '</div>';
    }).join('');
    bindPipeline();
  }
  // orden de la tabla de Personas: click en el encabezado alterna ↑/↓
  let psSort = { k: 'created', dir: -1 }, psStage = 'all', psAct = 'all';
  function leadsListHTML(rows){
    if (!rows.length) return '<p class="muted-note" style="padding:14px">Sin personas que coincidan con la búsqueda o el filtro.</p>';
    const stageIdx = (r) => STAGES.findIndex((s) => s.key === stageOf(r.status));
    const actMap = new Map(rows.map((r) => [r.id, lastActivity(r)]));
    const CMP = {
      name:    (a, b) => String(a.name || a.email || '').localeCompare(String(b.name || b.email || '')),
      stage:   (a, b) => stageIdx(a) - stageIdx(b),
      value:   (a, b) => leadsValue([a]) - leadsValue([b]),
      channel: (a, b) => String(a.channel || '').localeCompare(String(b.channel || '')),
      activity: (a, b) => ((actMap.get(a.id) || {}).t || 0) - ((actMap.get(b.id) || {}).t || 0),
      created: (a, b) => new Date(a.created_at) - new Date(b.created_at)
    };
    const sorted = rows.slice().sort((a, b) => (CMP[psSort.k] || CMP.created)(a, b) * psSort.dir);
    const body = sorted.map((r) => {
      const s = STAGES.find((x) => x.key === stageOf(r.status)) || STAGES[0];
      const val = leadsValue([r]);
      const act = actMap.get(r.id);
      return '<tr data-id="' + esc(r.id) + '"><td><div class="lt-name">' + esc(r.name || r.first_name || '(sin nombre)') + '</div><div class="lt-mail">' + esc(r.email || '') + '</div></td>' +
        '<td><span class="lt-stage" style="color:' + s.color + '"><span class="dot" style="background:' + s.color + '"></span>' + s.label + '</span></td>' +
        '<td class="lt-val">' + (val ? fmtChf(val) : '<span class="lt-num">—</span>') + '</td>' +
        '<td class="lt-act">' + esc(actLabel(act)) + '</td>' +
        '<td>' + esc(r.channel || '—') + (r.gclid ? ' · Ads' : '') + '</td>' +
        '<td class="lt-num">' + new Date(r.created_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short', year: '2-digit' }) + '</td></tr>';
    }).join('');
    const TH = (k, l) => '<th data-k="' + k + '" class="lt-sort' + (psSort.k === k ? ' on' : '') + '" title="Ordenar por ' + l.toLowerCase() + '">' + l + (psSort.k === k ? (psSort.dir === 1 ? ' ↑' : ' ↓') : '') + '</th>';
    return '<div class="lead-table-wrap"><table class="lead-table"><thead><tr>' +
      TH('name', 'Persona') + TH('stage', 'Etapa') + TH('value', 'Valor (ofertas)') + TH('activity', 'Última actividad') + TH('channel', 'Canal') + TH('created', 'Creado') +
      '</tr></thead><tbody>' + body + '</tbody></table></div>';
  }
  function bindLeadRows(){ document.querySelectorAll('.lead-table tbody tr').forEach((tr) => tr.addEventListener('click', () => openLead(tr.dataset.id))); }
  let dragId = null;
  function bindPipeline(){
    document.querySelectorAll('.pipe-card').forEach((card) => {
      card.addEventListener('dragstart', (e) => { dragId = card.dataset.id; card.classList.add('dragging'); e.dataTransfer.effectAllowed = 'move'; });
      card.addEventListener('dragend', () => { card.classList.remove('dragging'); dragId = null; });
      card.addEventListener('click', () => openLead(card.dataset.id));
    });
    document.querySelectorAll('.pipe-col').forEach((col) => {
      col.addEventListener('dragover', (e) => { e.preventDefault(); col.classList.add('drop'); });
      col.addEventListener('dragleave', () => col.classList.remove('drop'));
      col.addEventListener('drop', async (e) => {
        e.preventDefault(); col.classList.remove('drop');
        if (dragId) setLeadStage(dragId, col.dataset.stage);
      });
    });
  }
  // Cambia la etapa de un lead (desde el board o desde el contacto): pregunta motivo
  // si es Perdido, sella el hito de la etapa y persiste. Devuelve true si movió.
  async function setLeadStage(id, stage){
    const lead = allLeads.find((l) => String(l.id) === String(id));
    if (!lead || stageOf(lead.status) === stage) return false;
    const prev = lead.status;
    let lostReason;
    if (stage === 'perdido') {
      lostReason = prompt('¿Por qué se perdió este lead? (opcional)', lead.lost_reason || '');
      if (lostReason === null) return false;   // canceló → no mover
    }
    lead.status = stage;               // optimista
    const patch = { status: stage };
    const tsCol = STAGE_TS[stage];
    if (tsCol && !lead[tsCol]) { const now = new Date().toISOString(); patch[tsCol] = now; lead[tsCol] = now; }
    if (stage === 'perdido') { patch.lost_reason = lostReason || null; lead.lost_reason = lostReason || null; }
    renderLeads();
    const { error } = await supabase.from('leads').update(patch).eq('id', id);
    if (error) { lead.status = prev; if (tsCol) lead[tsCol] = null; renderLeads(); toast('No se pudo mover: ' + error.message); return false; }
    // Perdido: el motivo queda grabado en TODO — nota en el contacto + ofertas y propuestas ligadas
    if (stage === 'perdido') cascadeLost(lead, lostReason || null);
    return true;
  }
  // Registra la pérdida donde haga falta (best-effort: nada de esto bloquea el cambio de etapa)
  async function cascadeLost(lead, reason){
    const rTxt = reason || 'sin especificar';
    // 1) nota automática en el contacto → historial permanente aunque la etapa cambie después
    supabase.from('lead_notes').insert({ lead_id: String(lead.id), author: teamName(myEmail()), body: '❌ Deal perdido — motivo: ' + rTxt })
      .then(() => { if (currentLead && String(currentLead.id) === String(lead.id)) loadTasksNotes(lead); });
    // 2) ofertas ligadas (no ganadas) → lost + motivo
    const ofs = (offersList || []).filter((o) => o.lead_id && String(o.lead_id) === String(lead.id) && o.status !== 'won');
    for (const o of ofs) {
      let { error } = await supabase.from('offers').update({ status: 'lost', lost_reason: reason }).eq('id', o.id);
      if (error && /lost_reason/.test(error.message || '')) ({ error } = await supabase.from('offers').update({ status: 'lost' }).eq('id', o.id));
      if (!error) { o.status = 'lost'; o.lost_reason = reason; }
    }
    if (ofs.length && typeof renderOffersList === 'function') try { renderOffersList(); } catch (e) {}
    // 3) propuestas ligadas → guardar el motivo (sin tocar su status público)
    supabase.from('proposals').update({ lost_reason: reason }).eq('lead_id', String(lead.id)).then(() => {});
  }

