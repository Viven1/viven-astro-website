  function renderScopeRows(){
    $('pp-scope-list').innerHTML = (ppCur.scope || []).map((s, i) =>
      '<div class="pp-row"><div class="rowtop"><input class="s-title grow" placeholder="Título (Pre-Production)" value="' + esc(s.title || '') + '"/><button class="rm" type="button" data-i="' + i + '">✕</button></div>' +
      '<textarea class="s-text" placeholder="Descripción">' + esc(s.text || '') + '</textarea></div>').join('');
    $('pp-scope-list').querySelectorAll('.rm').forEach((b) => b.addEventListener('click', () => { collectEditor(); ppCur.scope.splice(+b.dataset.i, 1); renderScopeRows(); }));
  }
  function renderTierRows(){
    $('pp-tiers-list').innerHTML = (ppCur.tiers || []).map((t, i) => {
      const net = tierNet(t), cost = tierCostSum(t), mp = net ? Math.round((net - cost) / net * 100) : 0;
      return '<div class="pp-row pp-tier-row"><div class="rowtop"><input class="t-name grow" placeholder="Nombre paquete" value="' + esc(t.name || '') + '"/>' +
        '<input class="t-sub grow" placeholder="Subtítulo (1 shooting day)" value="' + esc(t.subtitle || '') + '"/><button class="rm" type="button" data-i="' + i + '">✕</button></div>' +
        '<div class="rowtop tnums"><label class="rec"><input type="checkbox" class="t-rec"' + (t.recommended ? ' checked' : '') + '/> recomendado</label>' +
        '<input class="t-price" type="number" placeholder="Precio" value="' + (t.price || 0) + '"/>' +
        '<input class="t-disc" type="number" placeholder="% OFF" value="' + (t.discount_pct || 0) + '"/>' +
        '<span class="pp-tier-margin">' + (cost ? 'margen ' + mp + '% · costo interno CHF ' + cost.toLocaleString('de-CH') : 'sin costo interno cargado') + '</span></div>' +
        '<textarea class="t-inc" placeholder="Qué incluye (uno por línea)">' + esc((t.includes || []).join('\n')) + '</textarea></div>';
    }).join('') || '<p class="muted-note">Sin paquetes. Generá con IA o agregá uno.</p>';
    $('pp-tiers-list').querySelectorAll('.rm').forEach((b) => b.addEventListener('click', () => { collectEditor(); ppCur.tiers.splice(+b.dataset.i, 1); renderTierRows(); }));
  }
  function renderAddonRows(){
    $('pp-addons-list').innerHTML = (ppCur.addons || []).map((a, i) =>
      '<div class="pp-row"><div class="rowtop"><input class="a-name grow" placeholder="Nombre (Drone)" value="' + esc(a.name || '') + '"/>' +
      '<input class="a-price" type="number" placeholder="CHF" value="' + (a.price || 0) + '" style="width:110px"/><button class="rm" type="button" data-i="' + i + '">✕</button></div>' +
      '<input class="a-note grow" placeholder="Nota (opcional)" value="' + esc(a.note || '') + '" style="width:100%"/></div>').join('');
