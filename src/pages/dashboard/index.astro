      '<td><div class="lt-name">🧾 ' + (o.number ? '<span style="color:var(--acid);font-size:12px;margin-right:7px">' + esc(o.number) + '</span>' : '') + esc(o.title || '(sin título)') + '</div><div class="lt-sub">' + sub + '</div></td>' +
      '<td>' + esc(o.client || lname || '—') + (lname && o.client ? '<div class="lt-sub">' + esc(lname) + '</div>' : '') + '</td>' +
      '<td><span class="of-badge" style="color:' + b[1] + ';border-color:' + b[1] + '">' + b[0] + '</span></td>' +
      '<td>' + wait + '</td><td>' + eye + '</td>' +
