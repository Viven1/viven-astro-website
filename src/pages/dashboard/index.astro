      const sub = (l.amount ? licCHF(l.amount) + '/mes · ' : '') + (l.start_date ? 'desde ' + esc(l.start_date) + ' · ' : '') +
        'renueva ' + esc(l.renewal_date || '—') + (lead ? ' · ' + esc(lead.name || lead.email) : '');
      const actions = l.status === 'active'
