  // popover ⋯ por fila (mismo patrón que ppOpenMenu: fixed, pegado al botón, sin salirse de la pantalla)
  function ofOpenMenu(btn){
    const menu = $('of-menu');
    if (!menu.hidden && menu.dataset.id === String(btn.dataset.id)){ menu.hidden = true; return; }
    const o = offersList.find((x) => String(x.id) === String(btn.dataset.id)); if (!o) return;
    // → Propuesta necesita el lead completo (offerToProp arma título/idioma/email desde él)
    const lead = o.lead_id ? allLeads.find((l) => String(l.id) === String(o.lead_id)) : null;
    menu.dataset.id = String(o.id);
    menu.innerHTML =
      '<button data-act="open" type="button">✏️ Abrir</button>' +
      '<button data-act="dup" type="button">⧉ Duplicar</button>' +
      (lead ? '<button data-act="prop" type="button">🌐 → Propuesta</button>' : '') +
      '<button data-act="send" type="button">📨 Enviar</button>' +
      '<button data-act="arch" type="button">' + (o.archived ? '↩ Desarchivar' : '🗄 Archivar') + '</button>' +
      '<hr /><button data-act="del" class="danger" type="button">🗑 Borrar</button>';
    menu.hidden = false;
    const r = btn.getBoundingClientRect();
    menu.style.left = Math.max(8, Math.min(r.right - menu.offsetWidth, window.innerWidth - menu.offsetWidth - 8)) + 'px';
    menu.style.top = Math.min(r.bottom + 6, window.innerHeight - menu.offsetHeight - 8) + 'px';
    menu.querySelectorAll('button').forEach((mb) => mb.addEventListener('click', (ev) => {
      ev.stopPropagation(); menu.hidden = true;
      const act = mb.dataset.act;
      if (act === 'open') openOffer(o.id);
      else if (act === 'dup') duplicateOffer(o.id);
      else if (act === 'prop') offerToProp(o.id, lead);
      else if (act === 'send') { openOffer(o.id); sendOfferEmail(); }   // el compositor lee los campos del editor → abrirlo primero
      else if (act === 'arch') archiveOffer(o.id, !o.archived);
      else if (act === 'del') deleteOfferById(o.id);
    }));
  }

