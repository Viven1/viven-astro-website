      }).join('') || '<p class="muted-note">Nadie matchea este segmento.</p>';
      const extraRows = nwExtraEmails.map((em, i) => '<div style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(--line);font-size:13.5px"><span style="flex:1">' + esc(em) + '</span><span class="muted-note">agregado a mano</span><button type="button" class="nw-recip-x" data-i="' + i + '" style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:15px">✕</button></div>').join('');
      const total = matched.length - nwExcludeIds.size + nwExtraEmails.length;
