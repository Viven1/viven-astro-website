      '<div class="lm2-as"><div class="top">🤝 Proyectos <span class="n">' + ldeals.length + '</span></div>' +
        ldeals.map((d) => { const v = stageOf(d.stage) === 'perdido' ? dealLostValue(d) : dealValue(d);
          return '<div class="row" style="cursor:default">' + esc(d.title || '(proyecto)') + ' ' + stB(d.stage) + '<span class="amt">' + (v ? fmtChf(v) : '—') + '</span></div>'; }).join('') +
        '<button class="add" id="lm2-add-deal" type="button">➕ Nuevo proyecto</button></div>' +
      '<div class="lm2-as"><div class="top">🧾 Ofertas y propuestas <span class="n">' + (ofs.length + props.length) + '</span></div>' +
        ofs.map((o) => '<button class="row lm2-of" data-oid="' + o.id + '" type="button">' + esc(o.title || '(sin título)') + ' ' + ofB(o.status) + '<span class="amt">' + fmtM(offerNet(o)) + '</span></button>').join('') +
        props.map((p) => '<button class="row lm2-pp" data-pid="' + p.id + '" type="button">🌐 ' + esc(p.title || '(propuesta)') + ' ' + ofB(p.status) + '</button>').join('') +
        '<button class="add" id="lm2-add-of" type="button">➕ Oferta · 🌐 Propuesta</button></div>' +
      // enriquecido con IA: misma data que la clásica (r.enrichment/r.enriched_at) pero como tarjeta plegable acá
      (lm2Enriching || r.enrichment
        ? '<div class="lm2-as" id="lm2-en-card">' +
            (lm2Enriching
              ? '<div class="top">🔎 Enriquecido</div><div class="row" style="color:var(--muted);cursor:default">🔎 Buscando en la web…</div>'
              : '<details><summary class="top" style="cursor:pointer;list-style:none">🔎 Enriquecido <span class="n">' + (r.enriched_at ? esc(fmtDMY(r.enriched_at)) : '') + '</span></summary><div style="font-size:12px;padding:4px 2px 2px">' + enrichHTML(r.enrichment || {}) + '</div></details>') +
          '</div>'
        : '') +
      '<div class="lm2-as" id="lm2-brief-card" hidden><div class="top">📋 Brief <span class="n" id="lm2-brief-when"></span></div><div class="row" id="lm2-brief-row" style="color:var(--muted)"></div></div>' +
      '<div class="lm2-as" id="lm2-fu-card" hidden><div class="top">📬 Automación <span class="n" id="lm2-fu-n"></span></div><div class="row" id="lm2-fu-row" style="color:var(--muted);cursor:default"></div></div>';
    $('lm2-add-deal').addEventListener('click', async () => { const t = prompt('Nombre del nuevo proyecto:', 'Nuevo proyecto — ' + (r.name || r.email || '')); if (t === null) return; const d = await newDealForLead(r.id, t.trim() || 'Nuevo proyecto', 'nuevo'); if (d) { toast('🤝 Proyecto creado'); openLeadV2(r.id); } });
    $('lm2-add-of').addEventListener('click', () => { closeLead2(); makeOfferForLead(r); });
    $('lm2-r').querySelectorAll('.lm2-of').forEach((b) => b.addEventListener('click', () => { closeLead2(); gotoTab('offers'); openOffer(b.dataset.oid); }));
    $('lm2-r').querySelectorAll('.lm2-pp').forEach((b) => b.addEventListener('click', () => { closeLead2(); gotoTab('props'); }));
    // brief y automación llegan async
    latestBriefFor(r).then((b) => { if (!b || !lm2Lead || String(lm2Lead.id) !== String(r.id)) return;
      $('lm2-brief-card').hidden = false;
      $('lm2-brief-when').textContent = new Date(b.created_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short' });
      $('lm2-brief-row').textContent = [b.goal, b.budget, b.timeline].filter(Boolean).join(' · ') || 'ver en la timeline';
    });
    supabase.from('lead_followups').select('status,send_at').eq('lead_id', String(r.id)).order('send_at').then(({ data }) => {
      if (!data || !data.length || !lm2Lead || String(lm2Lead.id) !== String(r.id)) return;
      const appr = data.filter((f) => f.status === 'approved'), draft = data.filter((f) => f.status === 'draft');
      if (!appr.length && !draft.length) return;
      $('lm2-fu-card').hidden = false;
      $('lm2-fu-n').textContent = appr.length ? 'activa' : 'borradores';
      $('lm2-fu-row').textContent = appr.length ? (appr.length + ' programado' + (appr.length === 1 ? '' : 's') + ' · próximo: ' + new Date(appr[0].send_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short' })) : (draft.length + ' borrador' + (draft.length === 1 ? '' : 'es') + ' sin aprobar — ver en ficha clásica');
    });
  }

