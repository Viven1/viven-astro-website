  const AU_TYPE_META = {
    email: { ic: '📧', tag: 'EMAIL' }, ai_email: { ic: '🤖', tag: 'EMAIL IA → BANDEJA' }, wait: { ic: '⏱', tag: 'ESPERAR' },
    task: { ic: '✅', tag: 'TAREA' }, push: { ic: '🔔', tag: 'PUSH' }, status: { ic: '🔀', tag: 'CAMBIAR ETAPA' },
  };
  const AU_TYPE_OPTS = '<option value="email">📧 Email</option><option value="ai_email">🤖 Email IA (a bandeja)</option><option value="wait">⏱ Esperar días</option><option value="task">✅ Tarea para el team</option><option value="push">🔔 Push al team</option><option value="status">🔀 Cambiar etapa</option>';
  let auOpenIdx = null;   // 'a-2' | 'b-0' | null — qué nodo tiene el panel de edición abierto
  let auDrag = null;      // { v, i } del nodo que se está arrastrando
  function auStepSummary(st){
    if (st.type === 'email' || st.type === 'ai_email') return st.type === 'email' ? esc(st.subject || '(sin asunto)') : '"' + esc((st.prompt || '').slice(0, 46)) + (st.prompt && st.prompt.length > 46 ? '…' : '') + '"';
    if (st.type === 'wait') return (st.days || 1) + ' día' + ((st.days || 1) == 1 ? '' : 's');
    if (st.type === 'task' || st.type === 'push') return esc(st.title || '(sin texto)');
    return '→ ' + (st.value || 'contactado');
  }
  function auInsertBtn(v, i){ return '<div class="au-ins-row"><button class="au-ins" data-v="' + v + '" data-i="' + i + '" type="button" title="Insertar paso acá">+</button></div>'; }
  function auNodeHtml(st, v, i){
    const m = AU_TYPE_META[st.type] || AU_TYPE_META.email;
    const open = auOpenIdx === (v + '-' + i);
    const F = (cur) => '<select class="f-from"><option value="sofia"' + (cur === 'sofia' ? ' selected' : '') + '>Sofia</option><option value="sebastian"' + (cur === 'sebastian' ? ' selected' : '') + '>Sebastian</option><option value="team"' + (!cur || cur === 'team' ? ' selected' : '') + '>VIVEN (team)</option></select>';
    let fields = '';
    if (st.type === 'email') fields = '<label>Sale de</label>' + F(st.from) + '<label>Asunto</label><input class="f-subject" value="' + esc(st.subject || '') + '" /><div class="au-field-wrap"><label>Cuerpo (párrafos con línea en blanco) <button type="button" class="au-fs-toggle" data-act="fs">⤢ Expandir</button></label><textarea class="f-body">' + esc(st.body || '') + '</textarea></div>';
    else if (st.type === 'ai_email') fields = '<label>Sale de</label>' + F(st.from) + '<div class="au-field-wrap"><label>Instrucción para la IA (usa el contexto real del contacto y escribe en su idioma) <button type="button" class="au-fs-toggle" data-act="fs">⤢ Expandir</button></label><textarea class="f-prompt">' + esc(st.prompt || '') + '</textarea></div><p class="muted-note" style="margin-top:6px">No se envía solo: cae en 📤 Bandeja para tu aprobación.</p>';
    else if (st.type === 'wait') fields = '<label>Días</label><input class="f-days" type="number" min="0" value="' + (+st.days || 1) + '" />';
    else if (st.type === 'task' || st.type === 'push') fields = '<label>Texto</label><input class="f-title" value="' + esc(st.title || '') + '" />';
    else fields = '<label>Nueva etapa</label><select class="f-status"><option value="contactado"' + (st.value === 'contactado' ? ' selected' : '') + '>Contactado</option><option value="propuesta"' + (st.value === 'propuesta' ? ' selected' : '') + '>Propuesta</option><option value="perdido"' + (st.value === 'perdido' ? ' selected' : '') + '>Perdido</option></select>';
    return '<div class="au-node" draggable="true" data-v="' + v + '" data-i="' + i + '" data-type="' + st.type + '">' +
      '<div class="au-node-h"><span class="au-drag" title="Arrastrar para reordenar">⠿</span><span class="au-node-ic">' + m.ic + '</span>' +
      '<div class="au-node-tt"><span class="au-tag">' + m.tag + '</span><span class="au-node-sum">' + auStepSummary(st) + '</span></div>' +
      '<button class="au-node-btn" data-act="edit" title="Editar">✏️</button><button class="au-node-btn" data-act="dup" title="Duplicar">📋</button><button class="au-node-btn" data-act="del" title="Borrar">🗑</button></div>' +
      (open ? '<div class="au-node-body">' + fields + '</div>' : '') +
    '</div>';
  }
  function auColHtml(v, label){
    const steps = auSteps[v] || [];
    let html = '<div class="au-col" data-col="' + v + '">' + (label ? '<div class="au-col-h">' + label + '</div>' : '');
    html += auInsertBtn(v, 0);
    steps.forEach((st, i) => { html += auNodeHtml(st, v, i); html += auInsertBtn(v, i + 1); });
    html += '</div>';
    return html;
  }
  function auRenderFlow(){
    document.body.classList.remove('au-fs-open'); // el re-render destruye el wrap .au-fs si había uno expandido
    const ab = $('au-ab').value === '50';
    const trig = $('au-trigger').value;
    const trigLbl = trig === 'stage' ? 'Lead llega a etapa: ' + (AU_STAGE_L[$('au-cfg-stage').value] || $('au-cfg-stage').value)
      : trig === 'inactivity' ? 'Inactivo ' + ($('au-cfg-days').value || 7) + ' días' + ($('au-cfg-scope').value === 'dormant' ? ' (dormidos)' : '')
      : 'Entra un lead nuevo' + ($('au-cfg-source').value !== 'any' ? ' · ' + $('au-cfg-source').value : '');
    let html = '<div class="au-trig-node">🎯 SI ' + esc(trigLbl) + '</div><div class="au-connector"></div>';
    if (ab) {
      html += '<div class="au-split-node">🔀 50/50</div><div class="au-connector"></div>' +
        '<div class="au-branches">' + auColHtml('a', 'Camino A · 50%') +
        '<div class="au-branch-mid"><button class="btn btn-ghost small" id="au-copy-ab" type="button" title="Copiar A → B">📋→B</button></div>' +
        auColHtml('b', 'Camino B · 50%') + '</div>';
    } else {
      html += auColHtml('a', '');
    }
    $('au-flow').innerHTML = html;
    auWireFlow();
  }
  function auWireFlow(){
    const flow = $('au-flow');
    flow.querySelectorAll('.au-ins').forEach((b) => b.addEventListener('click', () => {
      const sel = document.createElement('select'); sel.className = 'au-addsel'; sel.innerHTML = AU_TYPE_OPTS;
      const popup = document.createElement('div'); popup.className = 'au-ins-popup';
      const ok = document.createElement('button'); ok.className = 'btn btn-primary small'; ok.type = 'button'; ok.textContent = 'Agregar';
      popup.append(sel, ok);
      b.replaceWith(popup);
      ok.addEventListener('click', () => { auSteps[b.dataset.v].splice(+b.dataset.i, 0, { type: sel.value }); auOpenIdx = b.dataset.v + '-' + b.dataset.i; auRenderFlow(); });
    }));
    flow.querySelectorAll('.au-node-btn').forEach((btn) => btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const node = btn.closest('.au-node'); const v = node.dataset.v, i = +node.dataset.i, act = btn.dataset.act;
      if (act === 'edit') { auCollect(); auOpenIdx = auOpenIdx === (v + '-' + i) ? null : (v + '-' + i); auRenderFlow(); }
      else if (act === 'dup') { auCollect(); auSteps[v].splice(i + 1, 0, JSON.parse(JSON.stringify(auSteps[v][i]))); auRenderFlow(); }
      else if (act === 'del') { auCollect(); auSteps[v].splice(i, 1); if (auOpenIdx === v + '-' + i) auOpenIdx = null; auRenderFlow(); }
    }));
    flow.querySelectorAll('.au-node').forEach((node) => {
      node.addEventListener('dragstart', (e) => { auDrag = { v: node.dataset.v, i: +node.dataset.i }; node.classList.add('dragging'); e.dataTransfer.effectAllowed = 'move'; });
      node.addEventListener('dragend', () => { node.classList.remove('dragging'); auDrag = null; });
      node.addEventListener('dragover', (e) => { if (auDrag && auDrag.v === node.dataset.v) e.preventDefault(); });
      node.addEventListener('drop', (e) => {
        e.preventDefault(); if (!auDrag || auDrag.v !== node.dataset.v) return;
        auCollect(); const v = node.dataset.v; const to = +node.dataset.i;
        const arr = auSteps[v]; const [moved] = arr.splice(auDrag.i, 1);
        arr.splice(auDrag.i < to ? to - 1 : to, 0, moved);
        auOpenIdx = null; auRenderFlow();
      });
    });
    $('au-copy-ab') && $('au-copy-ab').addEventListener('click', () => { auCollect(); auSteps.b = JSON.parse(JSON.stringify(auSteps.a)); toast('📋 Camino A copiado a B'); auRenderFlow(); });
    flow.querySelectorAll('.au-fs-toggle').forEach((btn) => btn.addEventListener('click', (e) => {
      e.preventDefault(); e.stopPropagation();
      const wrap = btn.closest('.au-field-wrap');
      const fs = wrap.classList.toggle('au-fs');
      document.body.classList.toggle('au-fs-open', fs);
      btn.textContent = fs ? '✕ Cerrar' : '⤢ Expandir';
      if (fs) wrap.querySelector('textarea').focus();
    }));
  }
  function auCollect(){
    ['a', 'b'].forEach((v) => {
      const nodes = document.querySelectorAll('.au-node[data-v="' + v + '"]');
      const arr = [];
      nodes.forEach((el) => {
        const t = el.dataset.type;
        const cur = (auSteps[v] || [])[+el.dataset.i] || {};
        const q = (sel) => el.querySelector(sel);
        if (t === 'email') arr.push({ type: 'email', from: (q('.f-from') || {}).value || cur.from, subject: (q('.f-subject') || {}).value ?? cur.subject, body: (q('.f-body') || {}).value ?? cur.body });
        else if (t === 'ai_email') arr.push({ type: 'ai_email', from: (q('.f-from') || {}).value || cur.from, prompt: (q('.f-prompt') || {}).value ?? cur.prompt });
        else if (t === 'wait') arr.push({ type: 'wait', days: q('.f-days') ? (+q('.f-days').value || 1) : cur.days });
        else if (t === 'task') arr.push({ type: 'task', title: (q('.f-title') || {}).value ?? cur.title });
        else if (t === 'push') arr.push({ type: 'push', title: (q('.f-title') || {}).value ?? cur.title });
        else arr.push({ type: 'status', value: (q('.f-status') || {}).value ?? cur.value });
      });
      if (nodes.length) auSteps[v] = arr;
    });
  }
