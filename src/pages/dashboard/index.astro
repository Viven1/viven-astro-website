        ponderado_chf: Math.round(k.weighted), ganado_30d_chf: Math.round(k.won30Val),
        win_rate_90d_pct: k.winRate, roas_ads_30d: spend ? +(hmAdsStats().wonVal / spend).toFixed(2) : null,
        leads_ads_30d: ads.leads,
      },
    };
  }
  async function hmAi(force){
    const body = $('hm-ai'); if (!body) return;
    const today = new Date().toISOString().slice(0, 10);
    if (!force){
      try {
        const c = JSON.parse(localStorage.getItem(HM_AI_LS) || 'null');
        if (c && c.date === today && c.insight){ hmAiRender(c.insight); return; }
      } catch (e) { /* cache corrupto → regenerar */ }
      if (hmAiTried) return;   // ya falló hoy en esta sesión: no martillar la función
    }
    hmAiTried = true;
    const btn = $('hm-ai-btn'); if (btn) btn.disabled = true;
    body.innerHTML = '<p class="ai-loading">La IA está eligiendo la prioridad del día…</p>';
    try {
      const { data, error } = await supabase.functions.invoke('ai-insights', { body: { summary: hmAiSummary(), lang: 'es' } });
      const ins = data && Array.isArray(data.insights) && data.insights[0];
      if (error || !ins) throw new Error(data?.error || error?.message || 'sin respuesta');
      try { localStorage.setItem(HM_AI_LS, JSON.stringify({ date: today, insight: ins })); } catch (e) { /* sin espacio */ }
      hmAiRender(ins);
    } catch (e) {
      body.innerHTML = '<p class="muted-note">No se pudo generar (¿deployaste ai-insights y hay crédito en Anthropic?): ' + esc(e.message) + '</p>';
    } finally { if (btn) btn.disabled = false; }
  }
  $('hm-ai-btn').addEventListener('click', () => hmAi(true));

  function renderHome(){
    const now = Date.now(), D = 864e5;
    /* --- KPIs --- */
    const k = hmDealKpis();
    $('hm-pipe').textContent = fmtChf(k.openVal);
    $('hm-pipe-t').textContent = k.openN + (k.openN === 1 ? ' deal abierto' : ' deals abiertos');
    // Enviados, esperando respuesta (pedido explícito: "no veo los enviado y por ende los
    // abiertos" en el Home) — mismo criterio que el KPI ya existente en Ofertas+Propuestas
    const offSentH = (offersList || []).filter((o) => !o.archived && !o.is_template && o.status === 'sent');
    const propSentH = (ppList || []).filter((p) => !p.archived && !p.is_template && p.status === 'sent');
    const sentCount = offSentH.length + propSentH.length;
    const sentVal = offSentH.reduce((a, o) => a + offerNet(o), 0) + propSentH.reduce((a, p) => a + propVal(p), 0);
    $('hm-sent').textContent = fmtChf(sentVal);
    $('hm-sent-t').textContent = sentCount ? sentCount + (sentCount === 1 ? ' enviado' : ' enviados') : 'nada pendiente';
    $('hm-weight').textContent = fmtChf(Math.round(k.weighted));
    $('hm-won30').textContent = fmtChf(k.won30Val);
    setDelta('hm-won30-d', k.won30Val, k.prev30Val);
    $('hm-wr').textContent = k.winRate === null ? '–' : k.winRate + '%';
    $('hm-wr-t').textContent = k.dec90 ? 'ganado / decidido: ' + k.won90 + '/' + k.dec90 : 'sin decididos en 90 d';
    // visitas 30d: con el rango global en 30d uso lastViews/prevViews (ya en memoria); si no, el cache de 60d
    let visCur = null, visPrev = null;
    if (!rangeDay && rangeDays === 30){
      visCur = (lastViews || []).filter((v) => !/^claude-/.test(v.session_id || '')).length;
      visPrev = (prevViews || []).filter((v) => !/^claude-/.test(v.session_id || '')).length;
    } else if (hmViews60){
      visCur = hmViews60.filter((v) => now - Date.parse(v.created_at) <= 30 * D).length;
      visPrev = hmViews60.filter((v) => { const a = now - Date.parse(v.created_at); return a > 30 * D && a <= 60 * D; }).length;
    }
    $('hm-vis').textContent = visCur == null ? '–' : visCur.toLocaleString('de-CH');
    if (visCur == null){ const d = $('hm-vis-d'); if (d){ d.textContent = ''; d.className = 'kdelta'; } }
    else setDelta('hm-vis-d', visCur, visPrev);
    // ROAS Ads: verde ≥1×, rojo <1×, '–' sin datos de gasto
    const ads = hmAdsStats();
    const spend = hmAds ? (+hmAds.spend || 0) : 0;
    const roasEl = $('hm-roas');
    if (spend){
      const x = ads.wonVal / spend;
      roasEl.textContent = '×' + x.toFixed(1);
      roasEl.style.color = x >= 1 ? '#7ed957' : '#ff8b8b';
      $('hm-roas-t').textContent = fmtChf(spend) + ' invertidos (30 d)';
    } else {
      roasEl.textContent = '–'; roasEl.style.color = '';
      $('hm-roas-t').textContent = 'sin datos de Ads';
    }

    /* --- listas --- */
    const items = hmTodayItems();
    $('hm-today-n').textContent = items.length ? '(' + items.length + ')' : '';
    hmRenderToday(items);
    hmRenderSignals();
    hmRenderAgenda();
    hmRenderCalls();
    hmRenderSpark();
    hmRenderAds();

    /* --- datos async con cache (los TTLs evitan refetch en cada auto-refresh) --- */
    hmFetchWeeks();
    hmFetchAds();
    hmAi(false);
    // tasks abiertas por lead (mismo cache que el board de Deals) — alimenta (c) y (e) de Para hoy
    dlFetchNextTasks([...new Set((dealsList || []).filter((d) => !d.archived && DL_OPEN.includes(stageOf(d.stage))).map((d) => String(d.lead_id)).filter((x) => x && x !== 'undefined' && x !== 'null'))]);
  }

  /* ---------- Pipeline kanban (drag & drop entre etapas) ---------- */
  const STAGES = [
    { key: 'nuevo',      label: 'Nuevo',        color: '#8ab4ff', prob: 0.2,  match: ['new', 'nuevo', '', 'pending'] },
    { key: 'contactado', label: 'Contactado',   color: '#f0c060', prob: 0.4,  match: ['contacted', 'contactado'] },
    { key: 'videocall',  label: 'Video Call',   color: '#c58af9', prob: 0.6,  match: ['videocall', 'video call booked', 'call', 'agendada', 'booked'] },
    { key: 'propuesta',  label: 'Propuesta enviada', color: '#f0904e', prob: 0.8,  match: ['proposal', 'propuesta', 'qualified'] },
    { key: 'ganado',     label: 'Ganado',       color: '#7ed957', prob: 1,    match: ['won', 'cerrado', 'ganado'] },
    { key: 'perdido',    label: 'Perdido',      color: '#ff6b6b', prob: 0,    match: ['lost', 'perdido'] },
  ];
  // color determinista del chip de empresa (por nombre)
  const CO_PALETTE = ['#8ab4ff', '#c58af9', '#7ed957', '#f0c060', '#ff8b5e', '#5ec7d1', '#e08ac5'];
  function coColor(name){ let h = 0; const s = String(name || ''); for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) >>> 0; return CO_PALETTE[h % CO_PALETTE.length]; }
  // columna de timestamp por etapa (para el funnel: conversión y tiempos)
  const STAGE_TS = { contactado: 'contacted_at', videocall: 'videocall_at', propuesta: 'proposal_at', ganado: 'won_at', perdido: 'lost_at' };
  const STAGE_ORDER = ['nuevo', 'contactado', 'videocall', 'propuesta', 'ganado'];
  function stageOf(status){
    const s = (status || '').toLowerCase();
    for (const st of STAGES) if (st.match.includes(s)) return st.key;
    return 'nuevo';
  }
  function timeAgo(iso){
    const s = (Date.now() - new Date(iso).getTime()) / 1000;
    if (s < 3600) return Math.max(1, Math.round(s / 60)) + 'm';
    if (s < 86400) return Math.round(s / 3600) + 'h';
    return Math.round(s / 86400) + 'd';
  }
  const OF_ST = { draft: 'Borrador', sent: 'Enviada', won: 'Ganada', lost: 'Perdida' };
  // ofertas (no archivadas) ligadas a un lead
  const offersForLead = (id) => (offersList || []).filter((o) => o.lead_id && String(o.lead_id) === String(id) && !o.archived && !o.is_template);
  // motivo de pérdida heredado del contacto (si el lead está perdido y la oferta/propuesta no tiene el suyo)
  const leadLostReason = (lead_id) => { const l = (allLeads || []).find((x) => String(x.id) === String(lead_id)); return (l && stageOf(l.status) === 'perdido' && l.lost_reason) || null; };
  // Última actividad con el cliente (como HubSpot): lo más reciente entre visitar la web,
  // email enviado (contactado), video call, oferta, propuesta, nota o task.
  function lastActivity(r){
    const cand = [];
    const push = (ts, kind, label) => { const t = typeof ts === 'number' ? ts : Date.parse(ts || ''); if (t) cand.push({ t, kind, label }); };
    push(r.created_at, 'form', '📥 Lead creado');
    push(r.last_stage_at, 'stage', '🔁 Etapa → ' + ((STAGES.find((s) => s.key === stageOf(r.status)) || {}).label || ''));
    push(r.contacted_at, 'email', '✉️ Email enviado');
    push(r.videocall_at, 'call', '📞 Video call');
    push(r.proposal_at, 'prop', '📄 Propuesta');
    push(r.won_at, 'won', '🏆 Ganado');
    push(r.lost_at, 'lost', '✕ Perdido');
    offersForLead(r.id).forEach((o) => push(o.updated_at, 'offer', '🧾 Oferta'));
    push(actProps[String(r.id)], 'prop', '📄 Propuesta');
    push(actNotes[String(r.id)], 'note', '📝 Nota');
    push(actTasks[String(r.id)], 'task', '✅ Task');
    if (r.session_id && actWeb[r.session_id]) push(actWeb[r.session_id], 'web', '🌐 Visitó la web');
    if (!cand.length) return null;
    return cand.sort((a, b) => b.t - a.t)[0];
  }
  const actLabel = (a) => a ? a.label + ' · ' + timeAgo(new Date(a.t).toISOString()) : '—';
  const OF_COLOR = { draft: '#8ab4ff', sent: '#f0c060', won: '#7ed957', lost: '#ff6b6b' };
  const fmtDMY = (d) => d ? new Date(d).toLocaleDateString('es-CH', { day: '2-digit', month: '2-digit', year: 'numeric' }) : '';
  // sin persona ligada, una oferta/propuesta NO aparece en el pipeline y los números no cuadran.
  // Este guard crea la persona (con la etapa acorde) y la liga en un click.
  async function ensureLeadFor(clientName, email, status){
    const name = (clientName || '').trim(); if (!name) return null;
    if (!confirm('Esta ' + (email !== undefined ? 'propuesta' : 'oferta') + ' no está ligada a ninguna persona → NO aparece en el pipeline.\n\n¿Crear la persona «' + name + '» y ligarla ahora?')) return null;
    const stage = { won: 'ganado', sent: 'propuesta' }[status] || 'contactado';
    const row = { name, first_name: name.split(/\s+/)[0], email: email || null, status: stage, channel: 'manual', last_stage_at: new Date().toISOString() };
    try {
      const res = await sbWriteRowsResilient('leads', [row], null);
      const created = res.rows[0];
      if (created && !allLeads.some((l) => l.id === created.id)) allLeads.unshift(created);
      renderLeads();
      toast('👤 Persona creada y ligada — ya está en el pipeline');
      return created ? created.id : null;
    } catch (e) { toast('No se pudo crear la persona: ' + e.message); return null; }
  }
  // días que el deal lleva en su etapa actual (last_stage_at se sella en cada movimiento; fallback created_at)
  function dealStageDays(d){
    const t = Date.parse(d.last_stage_at || d.created_at || '');
    return t ? Math.max(0, Math.floor((Date.now() - t) / 864e5)) : 0;
  }
  // semáforo: verde <7d, ámbar 7-14d, rojo >14d
  const dealStageSem = (days) => days > 14 ? 'bad' : days >= 7 ? 'mid' : 'ok';
  const dealDaysChip = (days) => '<span class="pp2-sem ' + dealStageSem(days) + '">' + days + 'd en etapa</span>';
  // próximo paso del deal: task abierta más cercana de su persona (dlTasksMap), sino el follow-up automático
  function dealNextStep(d, asHTML){
    const r = leadById(d.lead_id) || {};
    const t = dlTasksMap[String(d.lead_id)];
    if (t) { const txt = '→ ' + t.title + (t.due_date ? ' · ' + fmtDMY(t.due_date) : ''); return asHTML ? '<div class="pc-next">' + esc(txt) + '</div>' : esc(txt); }
    if (r.next_follow_up_at) { const txt = '→ Follow-up automático ' + fmtDMY(r.next_follow_up_at); return asHTML ? '<div class="pc-next">' + esc(txt) + '</div>' : esc(txt); }
    return asHTML ? '<div class="pc-next warn">⚠ sin próximo paso</div>' : '<span class="pc-next warn" style="margin-top:0">⚠ sin próximo paso</span>';
  }
  // chip de DOCUMENTO: estado del papel de venta pendiente (propuesta web u oferta PDF) — el pipeline
  // como overview completo: qué le mandamos al cliente y si lo miró (last_view_at / last_open_at)
  function dealDocChip(d, stKey){
    const newest = (arr) => arr.slice().sort((a, b) => new Date(b.updated_at || b.created_at || 0) - new Date(a.updated_at || a.created_at || 0))[0];
    const ofs = offersForDeal(d).filter((o) => o.status !== 'tier');
    const props = (propsAll || []).filter((p) => !p.archived && !p.is_template && p.lead_id && String(p.lead_id) === String(d.lead_id));
    const pAcc = newest(props.filter((p) => p.status === 'accepted'));
    if (pAcc) return '<div class="pc-doc ok">✅ Propuesta aceptada</div>';   // raro acá: el deal debería estar en Ganado
    const pSent = newest(props.filter((p) => p.status === 'sent'));
    if (pSent){
      if (pSent.last_view_at){
        const hot = (Date.now() - Date.parse(pSent.last_view_at)) < 864e5;   // la miró hace <24h → caliente
        return '<div class="pc-doc' + (hot ? ' hot' : '') + '">🌐 publicada · 👁 vista hace ' + timeAgo(pSent.last_view_at) + '</div>';
      }
      return '<div class="pc-doc">🌐 publicada · sin vistas</div>';
    }
    const oSent = newest(ofs.filter((o) => o.status === 'sent'));
    if (oSent){
      if (oSent.last_open_at) return '<div class="pc-doc">🧾 enviada · 👁 abrió hace ' + timeAgo(oSent.last_open_at) + '</div>';
      const ref = oSent.sent_at || oSent.updated_at;
      return '<div class="pc-doc">🧾 enviada' + (ref ? ' hace ' + timeAgo(ref) : '') + '</div>';
    }
    const oDraft = newest(ofs.filter((o) => o.status === 'draft'));
    const pDraft = newest(props.filter((p) => p.status === 'draft'));
    if (oDraft || pDraft) return '<div class="pc-doc">' + (oDraft ? '🧾' : '🌐') + ' borrador listo para enviar</div>';
    // en etapas tempranas todavía no hace falta la alarma
    if (stKey === 'videocall' || stKey === 'propuesta') return '<div class="pc-doc warn">⚠ sin documento</div>';
    return '';
  }
  function cardHTML(d, st){
    const r = leadById(d.lead_id) || {};
    const PRIO = { won: 0, sent: 1, draft: 2, lost: 3 };
    const ofs = offersForDeal(d).slice().sort((a, b) => (PRIO[a.status] ?? 9) - (PRIO[b.status] ?? 9));
    let total = st.key === 'perdido' ? dealLostValue(d) : dealValue(d);
    let est = '';
    if (!ofs.some((o) => o.status !== 'lost') && Number(d.deal_value)) est = ' <span style="font-weight:400;font-size:10px;color:var(--muted-2)">est.</span>';
    // nombre del deal: su título, o el de la oferta más relevante, o el de la persona
    const dealName = d.title || ((ofs[0] && ofs[0].title) ? ofs[0].title : (r.name || r.first_name || '(sin nombre)'));
    // empresa · persona en una sola línea (el detalle vive en la ficha)
    const dom = leadDomain(r);
    const co = (dom && companyName(dom)) || r.company || '';
    const who = [co, r.name || r.first_name || ''].filter(Boolean).join(' · ');
    const days = dealStageDays(d);
    const sem = dealStageSem(days);
    const alarm = sem === 'bad' ? ' pc-bad' : sem === 'mid' ? ' pc-mid' : '';
    const lost = st.key === 'perdido' && (d.lost_reason || r.lost_reason) ? '<div class="pc-lost">✕ ' + esc(d.lost_reason || r.lost_reason) + '</div>' : '';
    return '<div class="pipe-card' + alarm + '" draggable="' + (PIPE_DRAG ? 'true' : 'false') + '" data-id="' + esc(String(d.id)) + '" data-lead="' + esc(String(d.lead_id)) + '" style="--stage:' + st.color + '">' +
      '<div class="pc-head"><div class="pc-name">' + esc(dealName) + '</div><button class="pc-dots" type="button" data-id="' + esc(String(d.id)) + '" title="Acciones">⋯</button></div>' +
      (who ? '<div class="pc-sub">' + esc(who) + '</div>' : '') +
      '<div class="pc-row"><span class="pc-amt">' + (total ? fmtChf(total) + est : '—') + '</span>' + dealDaysChip(days) + '</div>' +
      dealNextStep(d, true) +
      dealDocChip(d, st.key) +
      lost +
