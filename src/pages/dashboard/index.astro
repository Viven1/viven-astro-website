  // ---------- LISTA UNIFICADA "Ofertas y propuestas": Ofertas y Propuestas son documentos separados
  // (tablas/editores distintos) pero comparten una sola lista con badge 🧾/🌐 como destino final ----------
  const ofDaysAgo = (iso) => Math.floor((Date.now() - new Date(iso).getTime()) / 86400000);
  const fmtDShort = (iso) => new Date(iso).toLocaleDateString('es-CH', { day: '2-digit', month: 'short' });
  const ofLeadNm = (o) => o.lead_id ? ((allLeads.find((l) => String(l.id) === String(o.lead_id)) || {}).name || '') : '';
  const ofBadge = { draft: ['Borrador', '#8ab4ff'], sent: ['Enviada', '#f0c060'], won: ['Ganada', '#7ed957'], lost: ['Perdida', '#ff6b6b'], tier: ['Paquete propuesta', '#c58af9'] };
  // <tr> de una OFERTA — misma lógica/clases de siempre (semáforo pp2-sem, ojo pp2-eye, badge of-badge), con 🧾 delante del título
  function ofRowHtml(o){
    const b = ofBadge[o.status] || ofBadge.draft, net = offerNet(o), lname = ofLeadNm(o);
    const nPos = (o.items || []).length;
    let sub = nPos + ' posici' + (nPos === 1 ? 'ón' : 'ones') + (o.status !== 'draft' && o.sent_at ? ' · enviada ' + fmtDShort(o.sent_at) : ' · editada ' + fmtDShort(o.updated_at));
    if (o.status === 'lost' && (o.lost_reason || leadLostReason(o.lead_id))) sub += ' · <span style="color:#ff8b8b">✕ ' + esc(o.lost_reason || leadLostReason(o.lead_id)) + '</span>';
    if (!o.lead_id) sub += ' · <span style="color:#f0c060">⚠ sin persona (fuera del pipeline)</span>';
    // "Esperando hace": semáforo desde sent_at (real; fallback updated_at para lo enviado antes del tracking)
    let wait = '<span class="lt-num">—</span>';
    if (o.status === 'sent'){
      const d = ofDaysAgo(o.sent_at || o.updated_at);
      wait = d > 10 ? '<span class="pp2-sem bad">' + d + 'd · ⚠ seguir</span>' : d >= 5 ? '<span class="pp2-sem mid">' + d + 'd</span>' : '<span class="pp2-sem ok">' + d + 'd</span>';
    } else if (o.status === 'won'){
      const n = Math.max(0, Math.round((Date.parse(o.updated_at) - Date.parse(o.created_at)) / 86400000));
      wait = '<span class="pp2-eye" style="color:#7ed957">cerró en ' + n + ' día' + (n === 1 ? '' : 's') + '</span>';
    }
    // "Interés": last_open_at lo estampa el webhook de Resend cuando el cliente abre el mail de la oferta
    let eye = '<span class="lt-num">—</span>';
    if (o.status === 'sent'){
      if (o.last_open_at) eye = '<span class="pp2-eye' + ((Date.now() - Date.parse(o.last_open_at)) < 86400000 ? ' hot' : '') + '">👁 abrió hace ' + timeAgo(o.last_open_at) + '</span>';
