    $('lm-email').textContent = r.email; $('lm-email').href = 'mailto:' + r.email;
    $('lm-company-line').textContent = company ? '· ' + company : '';
    $('lm-id-txt').textContent = r.id;
    const phoneClean = (r.phone || '').replace(/[^\d+]/g, '');
    const call = $('lm-call'), wa = $('lm-wa');
    const rvb = $('lm-review'); if (rvb) rvb.hidden = stageOf(r.status) !== 'ganado';   // ⭐ solo en ganados
    const axb = $('lm-ads-x'); if (axb){ axb.hidden = !r.gclid; axb.textContent = r.ads_exclude ? '🚫 Ads: excluido' : '🎯 Ads: se envía'; }
    call.hidden = !r.phone; if (r.phone) call.href = 'tel:' + phoneClean;
    wa.hidden = !r.phone; if (r.phone) wa.href = 'https://wa.me/' + phoneClean.replace(/^\+/, '');

    const fmtD = (d) => d ? new Date(d).toLocaleDateString('es-CH', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) : '—';
    const st = STAGES.find((s) => s.key === stageOf(r.status)) || {};
    const nextF = r.next_follow_up_at ? new Date(r.next_follow_up_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short' })
      : ((r.status === 'contacted' || r.status === 'contactado') ? 'programando…' : '—');
    const row = (k, v, always) => (v && v !== '—') || always ? '<div class="ab-row"><span class="ab-k">' + k + '</span><span class="ab-v">' + (v || '—') + '</span></div>' : '';
    const sec = (t, rows, open) => rows ? '<details class="ab-sec lm-fold"' + (open ? ' open' : '') + '><summary class="ab-h">' + t + '</summary>' + rows + '</details>' : '';
    const telV = r.phone ? '<a href="tel:' + esc(phoneClean) + '">' + esc(r.phone) + '</a>' : '';
    $('lm-about').innerHTML =
      sec('Contacto',
        row('Nombre', esc(r.name), true) +
        row('Cargo / rol', esc(r.job_title || '')) +
        row('Email', '<a href="mailto:' + esc(r.email) + '">' + esc(r.email) + '</a>', true) +
        row('Teléfono', telV) +
        row('Empresa', ldom ? '<a href="#" class="lm-coclink" data-d="' + esc(ldom) + '">' + esc(companyName(ldom)) + '</a>' : esc(company)) +
        row('Idioma', (r.lang || '—').toUpperCase(), true), true) +
      sec('Estado y seguimiento',
        row('Etapa', '<select id="lm-stage-sel" class="lm-stage-sel" style="color:' + (st.color || 'var(--text)') + ';border-color:' + (st.color || 'var(--line-strong)') + '">' +
          STAGES.map((s) => '<option value="' + s.key + '"' + (s.key === stageOf(r.status) ? ' selected' : '') + '>' + s.label + '</option>').join('') + '</select>', true) +
        row('Última actividad', esc(actLabel(lastActivity(r))), true) +
        row('Próximo follow-up', nextF, true) +
        (stageOf(r.status) === 'perdido' ? row('Motivo de pérdida', esc(r.lost_reason || '(sin especificar)'), true) : ''), true) +
      sec('Origen',
        row('Canal', esc(r.channel)) + row('Fuente (UTM)', esc(r.utm_source)) + row('Campaña (UTM)', esc(r.utm_campaign)) +
        row('Google Ads (GCLID)', r.gclid ? 'sí' : '') + row('Página de entrada', esc(r.landing_path)) +
        row('Convirtió en', esc(r.form_path)) +
        (r.referred_by ? row('Referido por', (() => { const ref = (allLeads || []).find((l) => l.referral_code === r.referred_by); return esc(ref ? (ref.name || ref.email) : r.referred_by); })()) : '') +
        (() => { const n = (allLeads || []).filter((l) => l.referred_by && l.referred_by === r.referral_code).length; return n ? row('🎁 Refirió a', n + ' persona' + (n === 1 ? '' : 's')) : ''; })()) +
      sec('Fechas',
        row('Creado', fmtD(r.created_at), true) + row('Contactado', fmtD(r.contacted_at)) +
        row('Video call', fmtD(r.videocall_at)) + row('Propuesta', fmtD(r.proposal_at)) +
        row('Ganado', fmtD(r.won_at)) + row('Perdido', fmtD(r.lost_at)));
    $('lm-about').querySelectorAll('.lm-coclink').forEach((a) => a.addEventListener('click', (e) => { e.preventDefault(); closeLead(); gotoTab('companies'); openCompany(a.dataset.d); }));
    // etapa editable desde el contacto: mismo flujo que arrastrar en el board
    const stSel = $('lm-stage-sel');
    if (stSel) stSel.addEventListener('change', async () => {
      const top = latestDealOf(r.id);
      const ok = top ? await setDealStage(top.id, stSel.value) : await setLeadStage(r.id, stSel.value);
      if (ok) { toast('Etapa → ' + (STAGES.find((s) => s.key === stSel.value) || {}).label); openLead(r.id); }
      else stSel.value = stageOf(r.status);   // canceló o falló → volver
    });

    renderLeadScore(r);
    // columna derecha: PROYECTOS (deals) + ofertas + tasks + notas
    const ldeals = dealsForLead(r.id).slice().sort((a, b) => new Date(b.created_at) - new Date(a.created_at));
    const PORTAL_STATUSES = [['pre_production', 'Pre-producción'], ['filming', 'Rodaje'], ['editing', 'Edición'], ['client_review', 'Revisión cliente'], ['delivered', 'Entregado']];
    const projBlock = '<details class="lm-block lm-fold" open><summary class="lm-block-h">🤝 Proyectos <span class="count">(' + ldeals.length + ')</span></summary>' +
      ldeals.map((d) => { const st2 = STAGES.find((x) => x.key === stageOf(d.stage)) || STAGES[0];
        const v = stageOf(d.stage) === 'perdido' ? dealLostValue(d) : dealValue(d);
        const won = stageOf(d.stage) === 'ganado';
        return '<div class="lm-dealrow">' +
          '<div class="lm-dealrow-t">' + esc(d.title || '(proyecto)') + '<b>' + (v ? fmtChf(v) : '—') + '</b></div>' +
          '<select class="lm-stage-sel lm-deal-st" data-did="' + esc(String(d.id)) + '" style="color:' + st2.color + ';border-color:' + st2.color + '">' +
          STAGES.map((x) => '<option value="' + x.key + '"' + (x.key === stageOf(d.stage) ? ' selected' : '') + '>' + x.label + '</option>').join('') + '</select>' +
          (won && FEATURE_PORTAL ? '<details class="lm-portal" data-did="' + esc(String(d.id)) + '"><summary style="cursor:pointer;font-size:11.5px;color:var(--muted-2);margin-top:6px">📺 Portal del cliente</summary>' +
            '<div style="margin-top:8px;display:flex;flex-direction:column;gap:6px">' +
              '<select class="lm-portal-status" style="font-size:12.5px;padding:6px 8px">' + PORTAL_STATUSES.map((s) => '<option value="' + s[0] + '"' + ((d.production_status || 'pre_production') === s[0] ? ' selected' : '') + '>' + s[1] + '</option>').join('') + '</select>' +
              '<input class="lm-portal-video" placeholder="Link del video (Vimeo/YouTube)" value="' + esc(d.deliverable_url || '') + '" style="font-size:12.5px;padding:6px 8px" />' +
              '<textarea class="lm-portal-note" placeholder="Nota para el cliente (opcional)" style="font-size:12.5px;padding:6px 8px;min-height:44px">' + esc(d.portal_note || '') + '</textarea>' +
              '<div style="display:flex;gap:6px"><button class="btn btn-ghost xs lm-portal-save" type="button">💾 Guardar</button><button class="btn btn-ghost xs lm-portal-link" type="button">🔗 Copiar link</button></div>' +
            '</div></details>' : '') + '</div>'; }).join('') +
      '<button class="btn btn-ghost xs" id="lm-mk-newdeal" type="button" style="margin-top:8px" title="Nuevo proyecto para esta persona — aparece como deal nuevo en el board (los ganados/perdidos quedan intactos)">➕ Nuevo proyecto</button></details>';
    const ofs = offersForLead(r.id);
    const dealsBlock = '<details class="lm-block lm-fold"' + (ofs.length ? ' open' : '') + '><summary class="lm-block-h">🧾 Ofertas ligadas <span class="count">(' + ofs.length + ')</span></summary>' +
      (ofs.length ? ofs.map((o) => { const b = { draft: ['Borrador', '#8ab4ff'], sent: ['Enviada', '#f0c060'], won: ['Ganada', '#7ed957'], lost: ['Perdida', '#ff6b6b'] }[o.status] || ['Borrador', '#8ab4ff'];
        return '<div class="lm-deal-wrap"><button class="lm-deal" data-oid="' + o.id + '" type="button"><span class="lm-deal-t">' + esc(o.title || '(sin título)') + '</span><span class="lm-deal-b"><b>' + fmtM(offerNet(o)) + '</b><span class="of-badge" style="color:' + b[1] + ';border-color:' + b[1] + '">' + b[0] + '</span></span></button>' +
          '<button class="lm-conv" data-conv="' + o.id + '" type="button" title="Convertir esta oferta en una propuesta (queda como una de las opciones)">→ Propuesta</button></div>'; }).join('')
        : '<p class="muted-note">Sin ofertas ligadas todavía.</p>') +
      '<div class="lm-mk"><button class="btn btn-ghost xs" id="lm-mk-offer" type="button">➕ Hacer oferta</button><button class="btn btn-primary xs" id="lm-mk-prop" type="button">🌐 Hacer propuesta</button></div>' +
      '<button class="lm-dealval" id="lm-mk-deal" type="button">🤝 ' + (Number(r.deal_value) ? 'Valor estimado: ' + fmtChf(Number(r.deal_value)) + ' — cambiar' : 'Poner valor estimado del deal') + '</button>' +
      '</details>';
    $('lm-right').innerHTML = projBlock + dealsBlock +
      '<details class="lm-block lm-fold" open><summary class="lm-block-h">✅ Tasks</summary>' +
        '<div class="lm-taskadd"><input id="lm-task-t" placeholder="Nueva task…"/><div class="lm-taskadd-row"><input id="lm-task-d" type="date" title="Vence (fecha)"/><input id="lm-task-h" type="time" title="Hora (opcional)"/><select id="lm-task-a">' + teamOptions('', 'Responsable') + '</select><button class="btn btn-ghost xs" id="lm-task-add" type="button">+ Task</button></div></div>' +
        '<div id="lm-tasks"><p class="muted-note">Cargando…</p></div></details>' +
      '<details class="lm-block lm-fold" open><summary class="lm-block-h">📝 Notas</summary>' +
        '<textarea id="lm-note-b" placeholder="Agregar una nota… (contexto, objeción, próximo paso)"></textarea>' +
        '<div class="lm-noteadd"><select id="lm-note-m">' + teamOptions('', 'Avisar a…') + '</select><button class="btn btn-primary xs" id="lm-note-add" type="button">Guardar nota</button></div>' +
        '<div id="lm-notes"><p class="muted-note">Cargando…</p></div></details>';
    $('lm-right').querySelectorAll('.lm-deal').forEach((d) => d.addEventListener('click', () => { closeLead(); gotoTab('offers'); openOffer(d.dataset.oid); }));
    $('lm-right').querySelectorAll('.lm-conv').forEach((c) => c.addEventListener('click', () => offerToProp(c.dataset.conv, r)));
    $('lm-mk-offer').addEventListener('click', () => makeOfferForLead(r));
    $('lm-mk-deal').addEventListener('click', async () => {
      const v = prompt('Valor estimado del deal en CHF (vacío para quitar):', r.deal_value || '');
      if (v === null) return;
      const val = v.trim() === '' ? null : Math.round(parseFloat(v.replace(/[^0-9.]/g, ''))) || null;
      const { error, stripped } = await updateLeadResilient(r.id, { deal_value: val });
      if (error) { toast('No se pudo guardar: ' + error.message); return; }
      if (stripped.length) { toast('Corré el SQL 0017 para guardar el valor estimado'); return; }
      r.deal_value = val; const i = allLeads.findIndex((l) => l.id === r.id); if (i > -1) allLeads[i].deal_value = val;
      toast(val ? '🤝 Deal estimado en ' + fmtChf(val) + ' — ya se ve en el board' : 'Valor estimado quitado');
      renderLeads(); openLead(r.id);
    });
    $('lm-mk-prop').addEventListener('click', () => makePropForLead(r));
    $('lm-right').querySelectorAll('.lm-deal-st').forEach((sel) => sel.addEventListener('change', async () => {
      const ok = await setDealStage(sel.dataset.did, sel.value);
      if (ok) toast('Deal → ' + (STAGES.find((x) => x.key === sel.value) || {}).label);
      openLead(r.id);
    }));
    $('lm-right').querySelectorAll('.lm-portal').forEach((box) => {
      const did = box.dataset.did;
      const saveBtn = box.querySelector('.lm-portal-save'), linkBtn = box.querySelector('.lm-portal-link');
      saveBtn.addEventListener('click', async (e) => {
        e.preventDefault();
        const patch = {
          production_status: box.querySelector('.lm-portal-status').value,
          deliverable_url: box.querySelector('.lm-portal-video').value.trim() || null,
          portal_note: box.querySelector('.lm-portal-note').value.trim() || null,
        };
        const { error } = await supabase.from('deals').update(patch).eq('id', did);
        if (error){ toast(/does not exist|column/i.test(error.message) ? 'Falta correr el SQL 0052' : '⚠️ ' + error.message); return; }
        toast('💾 Portal actualizado');
      });
      linkBtn.addEventListener('click', async (e) => {
        e.preventDefault();
        let { data: d } = await supabase.from('deals').select('portal_token').eq('id', did).maybeSingle();
        let token = d && d.portal_token;
        if (!token) {
          // crypto.randomUUID(): este token es el ÚNICO control de acceso al
          // portal del cliente — Math.random() no es un CSPRNG y su salida no
          // tiene largo fijo (podía salir bien corta), débil para ese rol
          token = crypto.randomUUID().replace(/-/g, '');
          const { error } = await supabase.from('deals').update({ portal_token: token }).eq('id', did);
          if (error){ toast(/does not exist|column/i.test(error.message) ? 'Falta correr el SQL 0052' : '⚠️ ' + error.message); return; }
        }
        const link = 'https://www.viven.ch/portal/?id=' + did + '&t=' + token;
        try { await navigator.clipboard.writeText(link); toast('🔗 Link copiado — ' + link); }
        catch (e2) { prompt('Copiá el link:', link); }
      });
    });
    const ndBtn = $('lm-mk-newdeal');
    if (ndBtn) ndBtn.addEventListener('click', async () => {
      const t = prompt('Nombre del nuevo proyecto:', 'Nuevo proyecto — ' + (r.name || r.email || ''));
      if (t === null) return;
      const d = await newDealForLead(r.id, t.trim() || 'Nuevo proyecto', 'nuevo');
      if (d) { toast('🤝 Proyecto creado — ya está en el board en «Nuevo»'); openLead(r.id); }
    });
    $('lm-task-add').addEventListener('click', () => addTask(r));
