      ov.querySelectorAll('.nw-recip-x').forEach((b) => b.addEventListener('click', () => { nwExtraEmails.splice(+b.dataset.i, 1); renderList(); }));
    };
    ov.innerHTML = '<div class="ofc-card" style="max-width:480px">' +
      '<h3 style="margin:0 0 4px">👥 Destinatarios</h3>' +
      '<p class="muted-note" style="margin:0 0 10px" id="nw-recip-total"></p>' +
      '<div style="display:flex;gap:8px;margin-bottom:10px"><input id="nw-recip-add" class="nw-ov-inp" type="email" placeholder="agregar un email suelto" style="flex:1" /><button class="btn btn-ghost small" id="nw-recip-add-btn" type="button">➕</button></div>' +
      '<div id="nw-recip-extra"></div>' +
      '<div id="nw-recip-list" style="max-height:320px;overflow-y:auto;margin-top:6px"></div>' +
      '<p class="muted-note" style="margin-top:10px">Destildar saca a esa persona de este envío. La selección se guarda con el borrador.</p>' +
      '<div style="display:flex;gap:8px;margin-top:10px"><button class="btn btn-primary small" id="nw-recip-close" type="button">Listo</button></div>' +
      '</div>';
    renderList();
    ov.querySelector('#nw-recip-close').addEventListener('click', async () => { if ($('nw-subject').value.trim() && $('nw-body').value.trim()) await nwSave(); ov.remove(); });
    ov.addEventListener('click', (e) => { if (e.target === ov) ov.remove(); });
    ov.querySelector('#nw-recip-add-btn').addEventListener('click', () => {
