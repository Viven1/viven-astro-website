    actNotes = {}; if (notesQ && !notesQ.error) (notesQ.data || []).forEach((n) => maxTo(actNotes, String(n.lead_id), n.created_at));
    actTasks = {}; if (tasksQ && !tasksQ.error) (tasksQ.data || []).forEach((t) => { maxTo(actTasks, String(t.lead_id), t.created_at); if (t.done_at) maxTo(actTasks, String(t.lead_id), t.done_at); });
    actProps = {}; if (propsQ && !propsQ.error) (propsQ.data || []).forEach((p) => { if (p.lead_id) maxTo(actProps, String(p.lead_id), p.updated_at); });
    propsAll = (propsQ && !propsQ.error) ? (propsQ.data || []) : [];
    servicesLoad();   // catálogo de servicios (best-effort; sin tabla → RATECARD)
    // SELF-HEAL de ganados: los syncs (deal→ofertas, oferta→deal) existen desde hoy,
    // pero los datos viejos quedaron a medias — esta pasada los reconcilia y de ahí
    // en más Propuestas, Home y Deals muestran SIEMPRE los mismos números.
    (async () => {
      try {
        let dirty = false;
        // (la dirección "deal ganado → borradores won" se ELIMINÓ el 12/07: promovía
        //  cotizaciones nuevas de clientes ya ganados — como los paquetes de propuesta)
        for (const o of (offersList || []).filter((x) => x.status === 'won' && !x.archived && !x.is_template)) {
          const d = o.deal_id ? (dealsList || []).find((x) => String(x.id) === String(o.deal_id)) : (o.lead_id ? openDealOf(o.lead_id) : null);
          if (d && !d.synthetic && !['ganado', 'perdido'].includes(stageOf(d.stage))) {
            const now = new Date().toISOString();
            await supabase.from('deals').update({ stage: 'ganado', won_at: d.won_at || now, last_stage_at: now }).eq('id', d.id);
            d.stage = 'ganado'; d.won_at = d.won_at || now; dirty = true;
            mirrorLeadStatus(d.lead_id);
