    opts = opts || {};   // ojo: el click del botón pasa el MouseEvent — ahí opts.skipConfirm es undefined y se confirma como siempre
    let sibs = {};
    if (bgCur && bgCur.group_id){
      const { data: sb } = await supabase.from('blogs').select('lang,slug').eq('group_id', bgCur.group_id).eq('status', 'published');
      (sb || []).forEach((r) => { if (r.lang !== bgCur.lang) sibs[r.lang] = r.slug; });
    }
    const b = buildBlogAstro(sibs); if (!b) return false;
    if (!/^[a-z0-9-]+$/.test(b.slug)) { toast('El slug solo puede tener letras, números y guiones'); return false; }
    if (!opts.skipConfirm && !confirm('¿Publicar "' + $('bg-title').value + '" en la web?\n\nSe commitea a GitHub y Netlify lo publica en ~1-2 min en viven.ch/blog/' + b.slug + '/')) return false;
    const btn = $('bg-publish'), prev = btn.textContent; btn.disabled = true; btn.textContent = '🚀 Publicando…';
    $('bg-pub-note').textContent = 'Commiteando a GitHub… (' + (LANGNAME[b.lang] || b.lang) + ')';
    let ok = false;
    try {
      const { data, error } = await supabase.functions.invoke('publish-blog', { body: { path: b.path, content: b.content, message: 'blog: ' + $('bg-title').value } });
      if (error || !data || !data.ok) throw new Error(data?.error || error?.message || 'sin respuesta');
      const liveUrl = 'https://www.viven.ch/' + b.lang + '/blog/' + b.slug + '/';
      // marcar como publicado en la lista
      if (bgCur && bgCur.id) { await supabase.from('blogs').update({ status: 'published', published_at: new Date().toISOString(), published_url: liveUrl }).eq('id', bgCur.id); blogsLoad(); }
      $('bg-pub-note').innerHTML = (data.updated ? '✅ Actualizado' : '✅ Publicado') + ' — Netlify lo está deployando (~1-2 min). Va a estar en <a href="' + esc(liveUrl) + '" target="_blank" style="color:var(--acid)">' + esc(liveUrl) + '</a>' + (data.commit ? ' · <a href="' + esc(data.commit) + '" target="_blank" style="color:var(--muted)">ver commit</a>' : '');
      toast('🚀 Publicado — deployando en Netlify');
      ok = true;
    } catch (e) {
      $('bg-pub-note').textContent = 'No se pudo publicar (¿deployaste publish-blog + seteaste GITHUB_TOKEN?): ' + e.message;
    } finally { btn.disabled = false; btn.textContent = prev; }
    return ok;
  }

  /* ================= COMPANIES (empresas, modelo HubSpot) ================= */
  function domainOf(email){ const d = (email || '').split('@')[1]; if (!d || /gmail|hotmail|outlook|yahoo|icloud|gmx|bluewin|proton|me\.com/i.test(d)) return ''; return d.toLowerCase(); }
  // empresa a la que pertenece la persona: override manual (company_domain) o dominio del email
  function leadDomain(l){ return (l && (l.company_domain || domainOf(l.email))) || ''; }
  function slugKey(s){ return String(s || '').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 48); }
  function companyName(domain){ return (coMeta[domain] && coMeta[domain].name) || (domain ? domain.split('.')[0].charAt(0).toUpperCase() + domain.split('.')[0].slice(1) : ''); }
  // todas las empresas conocidas (con o sin contactos) para el picker connect-or-create
  function allCompanyNames(){ return [...new Set([...companiesData().map((c) => c.name), ...Object.values(coMeta).map((c) => c.name).filter(Boolean)])].sort((a, b) => a.localeCompare(b)); }
  function companiesData(){
    const map = new Map();
    (allLeads || []).filter((l) => !/^claude-/.test(l.session_id || '')).forEach((l) => { const d = leadDomain(l); if (!d) return; if (!map.has(d)) map.set(d, []); map.get(d).push(l); });
    // empresas creadas a mano o importadas que todavía no tienen contactos
    Object.keys(coMeta).forEach((d) => { if (!map.has(d)) map.set(d, []); });
    return [...map.entries()].map(([domain, contacts]) => ({
      domain, name: companyName(domain), contacts,
      value: contacts.reduce((a, l) => a + offersForLead(l.id).reduce((b, o) => b + offerNet(o), 0), 0),
      won: contacts.some((l) => stageOf(l.status) === 'ganado'), meta: coMeta[domain] || null
    })).sort((a, b) => b.value - a.value || b.contacts.length - a.contacts.length || a.name.localeCompare(b.name));
  }
  // estado comercial de la empresa, derivado de sus contactos (no se guarda: se calcula siempre)
  function coStatus(c){
    if (!c.contacts.length) return { k: 'empty', label: 'Sin contactos', color: '#f0c060' };
    if (c.won) return { k: 'client', label: 'Cliente', color: '#7ed957' };
    if (c.contacts.every((l) => stageOf(l.status) === 'perdido')) return { k: 'lost', label: 'Perdido', color: '#9aa4b5' };
    return { k: 'prospect', label: 'Prospecto', color: '#8ab4ff' };
  }
  // plata de la empresa: en juego (draft+sent) y ganado (won) sobre las ofertas de todos sus
  // contactos — los paquetes de propuesta (status 'tier') quedan afuera, como en el pipeline
  function coMoney(c){
    const ofs = c.contacts.flatMap((l) => offersForLead(l.id)).filter((o) => o.status !== 'tier');
    return {
      open: ofs.filter((o) => o.status === 'draft' || o.status === 'sent').reduce((a, o) => a + offerNet(o), 0),
      won: ofs.filter((o) => o.status === 'won').reduce((a, o) => a + offerNet(o), 0),
      offers: ofs
    };
  }
  let coSeg = 'all'; // segmento activo del filtro de la lista (all/client/prospect/empty)
  function renderCompanies(){
    if (!coBound){ coBound = true;
      $('co-back').addEventListener('click', () => { coCur = null; $('co-detail').hidden = true; $('co-list-view').hidden = false; });
      $('co-search').addEventListener('input', renderCompaniesList);
      $('co-del-btn').addEventListener('click', deleteCompany);
      $('co-del-sel').addEventListener('click', deleteSelectedCompanies);
      // popovers del header (➕ Crear / ⋯): cada botón togglea el suyo y cierra el otro; click afuera cierra los dos
      $('co-create-btn').addEventListener('click', () => { $('co-more-menu').hidden = true; $('co-create-menu').hidden = !$('co-create-menu').hidden; });
      $('co-more-btn').addEventListener('click', () => { $('co-create-menu').hidden = true; $('co-more-menu').hidden = !$('co-more-menu').hidden; });
      document.addEventListener('click', (e) => { if (!e.target.closest('#co-actions')){ $('co-create-menu').hidden = true; $('co-more-menu').hidden = true; } });
      $('co-new-person').addEventListener('click', coNewPerson);
      $('co-new-offer').addEventListener('click', () => coNewOfferProp('offer'));
      $('co-new-prop').addEventListener('click', () => coNewOfferProp('prop'));
    }
    // la lista queda siempre atrás; el detalle ahora es el modal fullscreen V3 (co3-modal)
    $('co-detail').hidden = true; $('co-list-view').hidden = false; renderCompaniesList();
    co3SafeRefresh();   // si el modal está abierto, refrescarlo con los datos nuevos (sin pisar ediciones en curso)
  }
  async function deleteCompany(){
    const domain = coCur; if (!domain) return;
    const data = companiesData().find((c) => c.domain === domain);
    const n = data ? data.contacts.length : 0;
    const warn = n ? '\n\nOjo: tiene ' + n + ' contacto' + (n === 1 ? '' : 's') + ' — la tarjeta va a seguir apareciendo (agrupada por dominio), pero sin la ficha/notas que cargaste.' : '';
    if (!confirm('¿Borrar la empresa "' + (data ? data.name : domain) + '"?' + warn)) return;
    const { error } = await supabase.from('companies').delete().eq('domain', domain);
    if (error) { alert('No se pudo borrar: ' + error.message); return; }
    delete coMeta[domain];
    coCur = null;
    toast('🗑 Empresa borrada');
    renderCompanies();
  }
  function renderCompaniesList(){
    let data = companiesData();
    const q = ($('co-search').value || '').toLowerCase().trim();
    if (q) data = data.filter((c) => (c.name + ' ' + c.domain).toLowerCase().includes(q));
    $('co-k-count').textContent = data.length;
    $('co-k-contacts').textContent = data.reduce((a, c) => a + c.contacts.length, 0);
    $('co-k-value').textContent = fmtChf(data.reduce((a, c) => a + c.value, 0));
    $('co-k-multi').textContent = data.filter((c) => c.contacts.length >= 2).length;
    // segment control con contadores vivos (sobre lo que quedó de la búsqueda)
    const segN = (k) => k === 'all' ? data.length : data.filter((c) => coStatus(c).k === k).length;
    $('co-seg').innerHTML = [['all', 'Todas'], ['client', 'Clientes'], ['prospect', 'Prospectos'], ['empty', 'Sin contactos']]
      .map(([k, l]) => '<button type="button" data-k="' + k + '" class="' + (coSeg === k ? 'on' : '') + '">' + l + ' ' + segN(k) + '</button>').join('');
    $('co-seg').querySelectorAll('button').forEach((b) => b.addEventListener('click', () => { coSeg = b.dataset.k; renderCompaniesList(); }));
    if (coSeg !== 'all') data = data.filter((c) => coStatus(c).k === coSeg);
    $('co-empty').hidden = data.length > 0;
    $('co-list').className = '';
    // tabla estilo Personas (lead-table-hs mantiene todas las columnas en móvil con scroll horizontal)
    const allChecked = data.length > 0 && data.every((c) => coSelected.has(c.domain));
    $('co-list').innerHTML = data.length ? '<div class="lead-table-wrap lead-table-hs"><table class="lead-table"><thead><tr>' +
      '<th class="lt-chk"><input type="checkbox" id="co-chk-all"' + (allChecked ? ' checked' : '') + ' title="Seleccionar todas las visibles" /></th>' +
      '<th>Empresa</th><th>Estado</th><th class="lt-num">Contactos</th><th class="lt-num">En juego</th><th class="lt-num">Ganado</th><th>Última actividad</th>' +
      '</tr></thead><tbody>' + data.map((c) => {
        const st = coStatus(c), mo = coMoney(c);
        // última actividad de la empresa = la más reciente entre todos sus contactos
        const act = c.contacts.map((l) => lastActivity(l)).filter(Boolean).sort((a, b) => b.t - a.t)[0] || null;
        return '<tr data-d="' + esc(c.domain) + '">' +
          '<td class="lt-chk"><input type="checkbox" class="co-row-chk" data-domain="' + esc(c.domain) + '"' + (coSelected.has(c.domain) ? ' checked' : '') + ' onclick="event.stopPropagation()" /></td>' +
          '<td><div class="lt-person"><span class="co2-tav" style="background:' + coColor(c.name) + '">' + esc(c.name.slice(0, 2).toUpperCase()) + '</span><div><div class="lt-name">' + esc(c.name) + '</div><div class="lt-sub">' + esc(c.domain) + '</div></div></div></td>' +
          '<td><span class="of-badge" style="color:' + st.color + ';border-color:' + st.color + '">' + st.label + '</span></td>' +
          '<td class="lt-num">' + c.contacts.length + '</td>' +
          '<td class="lt-val" style="text-align:right">' + (mo.open ? fmtChf(mo.open) : '<span class="lt-num">—</span>') + '</td>' +
          '<td class="lt-val" style="text-align:right;color:#7ed957">' + (mo.won ? fmtChf(mo.won) : '<span class="lt-num" style="color:var(--muted)">—</span>') + '</td>' +
          '<td class="lt-act">' + esc(actLabel(act)) + '</td></tr>';
      }).join('') + '</tbody></table></div>' : '';
    $('co-list').querySelectorAll('tbody tr').forEach((tr) => tr.addEventListener('click', () => openCompany(tr.dataset.d)));
    bindCoSelection(); updateCoDelBtn();
  }
  // Empresas: selección múltiple para borrar en batch (espejo del patrón de Personas)
  let coSelected = new Set();
  function updateCoDelBtn(){
    const btn = $('co-del-sel'); if (!btn) return;
    btn.hidden = coSelected.size === 0;
    btn.textContent = '🗑 Borrar seleccionadas (' + coSelected.size + ')';
  }
  function bindCoSelection(){
    document.querySelectorAll('.co-row-chk').forEach((cb) => cb.addEventListener('change', () => {
      if (cb.checked) coSelected.add(cb.dataset.domain); else coSelected.delete(cb.dataset.domain);
      updateCoDelBtn();
      const all = $('co-chk-all'); if (all) all.checked = [...document.querySelectorAll('.co-row-chk')].every((c) => c.checked);
    }));
    // el "todas" vive en el header de la tabla (se re-renderiza con cada lista, igual que en Personas)
    const allBox = $('co-chk-all');
    if (allBox) allBox.addEventListener('change', () => {
      document.querySelectorAll('.co-row-chk').forEach((cb) => { cb.checked = allBox.checked; if (allBox.checked) coSelected.add(cb.dataset.domain); else coSelected.delete(cb.dataset.domain); });
      updateCoDelBtn();
    });
  }
  async function deleteSelectedCompanies(){
    const doms = [...coSelected]; if (!doms.length) return;
    // (a) con ficha manual en la tabla companies → borrable; (b) solo agrupadas por dominio → no hay fila en DB,
    // la tarjeta existe porque sus contactos comparten dominio y solo desaparece borrando esos contactos
    const withMeta = doms.filter((d) => coMeta[d]);
    const grouped = doms.filter((d) => !coMeta[d]);
    if (!withMeta.length){
      toast('Nada que borrar: esas empresas solo están agrupadas por dominio (sin ficha manual) — para que desaparezcan hay que borrar sus contactos en Personas');
      return;
    }
    const byDom = new Map(companiesData().map((c) => [c.domain, c]));
    const regen = withMeta.filter((d) => { const c = byDom.get(d); return c && c.contacts.length > 0; });
    let msg = '¿Borrar ' + withMeta.length + ' ficha' + (withMeta.length === 1 ? '' : 's') + ' manual' + (withMeta.length === 1 ? '' : 'es') + ' de empresa? Esta acción no se puede deshacer.';
    if (regen.length) msg += '\n\n⚠️ ' + regen.length + ' todavía ' + (regen.length === 1 ? 'tiene' : 'tienen') + ' contactos: su tarjeta va a seguir apareciendo (agrupada por dominio), pero sin la ficha/notas que cargaste.';
    if (grouped.length) msg += '\n\nℹ️ ' + grouped.length + ' seleccionada' + (grouped.length === 1 ? ' se salta' : 's se saltan') + ': solo ' + (grouped.length === 1 ? 'está agrupada' : 'están agrupadas') + ' por dominio, sin ficha manual en la base — para que ' + (grouped.length === 1 ? 'desaparezca' : 'desaparezcan') + ' hay que borrar sus contactos en Personas.';
    if (!confirm(msg)) return;
    const { error } = await supabase.from('companies').delete().in('domain', withMeta);
    if (error) { alert('No se pudo borrar: ' + error.message); return; }
    withMeta.forEach((d) => { delete coMeta[d]; });
    if (coCur && withMeta.includes(coCur)) coCur = null; // si el detalle abierto era una borrada, volver a la lista
    coSelected.clear();
    toast('🗑 ' + withMeta.length + ' ficha' + (withMeta.length === 1 ? ' borrada' : 's borradas'));
    renderCompanies();
  }
  // entry point de siempre: abrir una empresa dispara la ficha V3 fullscreen (misma gramática que Persona V2)
  function openCompany(domain){
    coCur = domain;   // los helpers existentes (coNewPerson, coNewOfferProp, deleteCompany) leen coCur
    co3Open(domain);
  }

  /* ================= EMPRESA V3 (co3-): detalle de empresa con la MISMA gramática visual =================
     que la ficha de PERSONA clásica (pedido de Sebastián: "no puede haber cambios tan grandes").
     Header .lm-top (avatar + nombre + badge + .lm-quick), izquierda .ab-sec con filas label→valor
     (inline-edit al click), centro timeline en un .lm-block, derecha .lm-block cards como la persona. */
  const co3Modal = $('co3-modal');
  let co3Cur = null, co3Filter = 'all', co3Events = [], co3Tasks = [];
  const co3Mobile = () => window.matchMedia('(max-width:960px)').matches;
  function co3Close(keepCur){
    co3Modal.classList.remove('open'); co3Modal.setAttribute('aria-hidden', 'true'); document.body.style.overflow = '';
    co3Cur = null;
    if (!keepCur) coCur = null;
  }
  co3Modal.querySelectorAll('[data-close3]').forEach((el) => el.addEventListener('click', () => co3Close()));
  $('co3-enrich-btn') && $('co3-enrich-btn').addEventListener('click', () => co3Cur && co3RunEnrich(co3Cur));
  // ✨ enriquecimiento de EMPRESA con IA (SQL 0072) — mismo ai-enrich que Personas, pero
  // con solo company/domain (sin name/email). Auto-fill: solo pisa campos VACÍOS (nunca lo
  // que Sebastián ya cargó a mano) — mapeo empresa.nombre→name, industria→industry, web→website,
  // empleados→employees, ubicacion→city, primer redes[].tipo==='linkedin'→linkedin.
  let co3Enriching = false;
  function co3RenderEnrich(domain){
    const box = $('co3-enrich'); if (!box || co3Cur !== domain) return;
    const m = coMeta[domain] || {};
    const when = $('co3-en-when'); if (when) when.textContent = m.enriched_at ? '· actualizado ' + fmtDMY(m.enriched_at) : '';
    box.innerHTML = co3Enriching
      ? '<p class="muted-note">🔎 Buscando info en la web…</p>'
      : (m.enrichment ? enrichHTML(m.enrichment) : '<p class="muted-note">Sin datos todavía — tocá «Buscar info actual» (busca en la web en vivo).</p>');
  }
  async function co3RunEnrich(domain){
    if (!domain || co3Enriching) return;
    co3Enriching = true;
    const btn = $('co3-enrich-btn'); if (btn){ btn.disabled = true; btn.textContent = '🔎 Buscando…'; }
    co3RenderEnrich(domain);
    try {
      const m = coMeta[domain] || {};
      const { data, error } = await supabase.functions.invoke('ai-enrich', { body: { lead: { company: m.name || companyName(domain) || domain, domain } } });
      if (error || (data && data.error)) { toast('No se pudo: ' + ((data && data.error) || error.message)); return; }
      const em = (data.enrichment && data.enrichment.empresa) || {};
      const patch = { enrichment: data.enrichment, enriched_at: new Date().toISOString() };
      if (!m.name && em.nombre) patch.name = em.nombre;
      if (!m.industry && em.industria) patch.industry = em.industria;
      if (!m.website && em.web) patch.website = em.web;
      if (!m.employees && em.empleados) patch.employees = String(em.empleados);
      if (!m.city && em.ubicacion) patch.city = em.ubicacion;
      if (!m.linkedin) { const li = (em.redes || []).find((x) => x.tipo === 'linkedin'); if (li && li.url) patch.linkedin = li.url; }
      const ok = await coSaveMeta(domain, patch);
      if (!ok) return;
      toast('🔎 Empresa enriquecida y guardada');
      if (co3Cur === domain){ co3RenderLeft(domain); }
      renderCompaniesList();
    } catch (e) { toast('No se pudo: ' + (e && e.message || e)); }
    finally {
      co3Enriching = false;
      const btn2 = $('co3-enrich-btn'); if (btn2){ btn2.disabled = false; btn2.textContent = '✨ Buscar info actual'; }
      co3RenderEnrich(domain);
    }
  }
  // la misma lista filtrada que ve el tab Empresas — alimenta la navegación ←/→
  function co3Order(){
    let data = companiesData();
    const q = (($('co-search') && $('co-search').value) || '').toLowerCase().trim();
    if (q) data = data.filter((c) => (c.name + ' ' + c.domain).toLowerCase().includes(q));
    if (coSeg !== 'all') data = data.filter((c) => coStatus(c).k === coSeg);
    return data.map((c) => c.domain);
  }
  function co3Data(domain){
    return companiesData().find((c) => c.domain === domain) || { domain, name: companyName(domain), contacts: [], value: 0, won: false };
