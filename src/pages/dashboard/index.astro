      // OFERTA POR PAQUETE: cada tier vive como oferta real (A26xxxx, margen, costos)
      // → las editás en Ofertas y la propuesta se refresca desde ahí. Fuente de verdad: la oferta.
      try {
        // si regenerás, los drafts auto-creados de la corrida anterior se archivan (no basura)
        for (const oid of (ppCur._genOffers || [])) {
          const old = offersList.find((x) => String(x.id) === String(oid));
          if (old && old.status === 'draft') { await supabase.from('offers').update({ archived: true }).eq('id', oid); old.archived = true; }
        }
        ppCur._genOffers = [];
        const baseName = ($('pp-cname').value || $('pp-title').value || 'Propuesta').trim();
        for (const t of ppCur.tiers) {
          const row = { title: baseName + ' — ' + (t.name || 'Paquete'), client: $('pp-cname').value || null,
            lead_id: ppCur.lead_id || null, deal_id: ppCur.deal_id || null, vat_rate: 8.1, status: 'tier',
            items: t.items || [], terms: DEFAULT_TERMS };
          const { data: od, error: oe } = await supabase.from('offers').insert(row).select().single();
          if (!oe && od) { t.offer_id = od.id; ppCur._genOffers.push(od.id); offersList.unshift(od); }
        }
        $('pp-ai-note').textContent += ' Cada paquete quedó como OFERTA ligada (' + ppCur.tiers.filter((t) => t.offer_id).length + ') — editalas en Ofertas y acá se actualizan.';
      } catch (e) { /* sin ofertas ligadas no bloqueamos la propuesta */ }
      renderTierRows();
      ppCur.addons = (data.addon_groups || []).flatMap((g) => g.items || []).map((it) => ({ name: it.name, note: it.note || '', price: Math.round((Number(it.qty) || 1) * (Number(it.price) || 0)) })); renderAddonRows();
      await saveProp(false);
      $('pp-ai-note').textContent = '✨ Propuesta generada y guardada — revisá todo, ajustá precios/textos, poné password y publicá.';
    } catch (e) { $('pp-ai-note').textContent = 'No se pudo generar (¿deployaste ai-proposal + crédito Anthropic?): ' + e.message; }
    finally { btn.disabled = false; btn.textContent = prev; }
  }
