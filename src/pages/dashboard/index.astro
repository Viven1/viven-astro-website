        '</div>' +
      '</div>' +
      '<div class="lm-quick" style="position:relative">' +
        '<a class="lm-qbtn" id="co3-web" href="' + esc(web) + '" target="_blank" rel="noopener">🌐 Web</a>' +
        '<button class="lm-qbtn" id="co3-crear" type="button">➕ Crear ▾</button>' +
        '<button class="lm-qbtn" id="co3-nav-prev" type="button" title="Empresa anterior"' + (oi <= 0 ? ' disabled' : '') + '>‹</button>' +
        '<button class="lm-qbtn" id="co3-nav-next" type="button" title="Empresa siguiente"' + (oi < 0 || oi >= order.length - 1 ? ' disabled' : '') + '>›</button>' +
        '<button class="lm-qbtn" id="co3-dots" type="button" title="Más acciones">⋯</button>' +
