  /* ---- PDF adjunto: jsPDF + autotable servidos desde /assets (sin CDN), cargados on-demand ---- */
  let jsPdfPromise = null;
  function loadScriptOnce(src){
    return new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = src; s.onload = resolve; s.onerror = () => reject(new Error('no se pudo cargar ' + src));
      document.head.appendChild(s);
    });
  }
  function loadJsPDF(){
    if (!jsPdfPromise) jsPdfPromise = (async () => {
      if (!(window.jspdf && window.jspdf.jsPDF)) await loadScriptOnce('/assets/jspdf.umd.min.js');
      if (!(window.jspdf && window.jspdf.jsPDF)) throw new Error('jsPDF no disponible');
      const J = window.jspdf.jsPDF;
      if (!J.API.autoTable && !window.autoTable) await loadScriptOnce('/assets/jspdf.plugin.autotable.min.js');
      if (!J.API.autoTable && window.applyPlugin) window.applyPlugin(J);   // autotable v5: registrar doc.autoTable
      return J;
    })().catch((e) => { jsPdfPromise = null; throw e; });
    return jsPdfPromise;
  }
