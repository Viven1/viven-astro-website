  // 🧾 Factura: snapshot de la oferta GANADA al momento de facturar (si la
  // oferta cambia después, la factura ya emitida no se mueve). Una por oferta —
  // si ya existe, la reutiliza en vez de duplicar numeración.
  async function ensureInvoice(){
    if (!ofCur || !ofCur.id){ toast('Guardá la oferta primero'); return null; }
    if (curInvoice) return curInvoice;
    const vatRate = parseFloat($('of-vat').value) || 0;
    const net = offerNet(ofCur);
    const gross = net * (1 + vatRate / 100);
    const year = new Date().getFullYear().toString().slice(-2);
    const { count } = await supabase.from('invoices').select('id', { count: 'exact', head: true }).like('number', 'R' + year + '-%');
    const number = 'R' + year + '-' + String((count || 0) + 1).padStart(4, '0');
    const row = {
      offer_id: ofCur.id, lead_id: ofCur.lead_id || null, number, title: ofCur.title || null,
      items: ofCur.items || [], vat_rate: vatRate, net, gross,
      client_company: ofCur.client_company || null, client_contact: ofCur.client_contact || null, client_address: ofCur.client_address || null,
      client_zip_city: ofCur.client_zip_city || null, client_phone: ofCur.client_phone || null, client_email: ofCur.client_email || null,
      due_date: new Date(Date.now() + 30 * 864e5).toISOString().slice(0, 10), status: 'draft',
    };
    const { data, error } = await supabase.from('invoices').insert(row).select().single();
    if (error){ toast(/does not exist|relation/i.test(error.message) ? 'Falta correr el SQL 0050' : '⚠️ ' + error.message); return null; }
    curInvoice = data;
    toast('🧾 Factura ' + number + ' creada');
    refreshInvoiceBtn();
    return data;
  }
