#lead-modal2{padding:0;overflow:hidden}
/* padding:0 es CLAVE: .lead-card-wide trae padding interno (16px 26px + safe-area en móvil) que
   dejaba aire arriba del header sticky y a los costados — el fullscreen es del header a los bordes */
#lead-modal2 .lead-card{position:fixed;inset:0;width:100%;height:100vh;height:100dvh;max-width:none;max-height:none;border-radius:0!important;margin:0;padding:0}
#lead-modal2 .close{z-index:8} /* por encima del header sticky (z-index 6) */
/* Empresa V3 (co3): usa la MISMA gramática que la ficha de persona clásica (lm-top/lm-grid/
   ab-sec/lm-block) — cero estilos propios salvo el avatar cuadrado-redondeado (empresa ≠ persona) */
#co3-modal .lm-avatar{border-radius:12px}
.lm2-card{display:flex;flex-direction:column;height:100%;max-height:none;overflow:hidden}
.lm2-hd{position:sticky;top:0;z-index:6;display:flex;align-items:center;gap:12px;padding:14px 20px;border-bottom:1px solid var(--line);background:var(--navy-800);flex-wrap:wrap}
.lm2-avatar{width:42px;height:42px;border-radius:50%;background:var(--acid);color:#142033;display:grid;place-items:center;font-weight:800;font-family:'Space Grotesk';font-size:15px;flex:none}
.lm2-who{min-width:0}
.lm2-who .nm{font-family:'Space Grotesk';font-weight:700;font-size:16.5px;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.lm2-who .sub{font-size:12px;color:var(--muted)}
.lm2-back{border:1px solid var(--line-strong);background:transparent;color:var(--muted);border-radius:100px;font:600 12px Inter,sans-serif;padding:7px 13px;cursor:pointer;white-space:nowrap}
.lm2-back:hover{color:var(--text);border-color:var(--muted)}
.lm2-nav{display:flex;align-items:center;border:1px solid var(--line-strong);border-radius:100px;overflow:hidden}
.lm2-nav button{width:30px;height:30px;border:0;background:transparent;color:var(--muted);cursor:pointer;font-size:15px;line-height:1}
.lm2-nav button:hover:not(:disabled){color:var(--text);background:rgba(255,255,255,.05)}
.lm2-nav button:disabled{opacity:.3;cursor:default}
.lm2-nav .lm2-nav-n{font-size:10.5px;color:var(--muted-2);padding:0 6px;font-variant-numeric:tabular-nums;font-weight:600;white-space:nowrap}
.lm2-pipe{display:flex;border:1px solid var(--line-strong);border-radius:100px;overflow:hidden;font-size:10.5px;font-weight:700}
.lm2-pipe span{padding:6px 11px;color:var(--muted-2);cursor:pointer;white-space:nowrap}
.lm2-pipe span.done{color:#142033;background:var(--acid)}
.lm2-pipe span.cur{color:var(--acid);background:rgba(221,249,143,.13)}
.lm2-pipe span:hover:not(.done):not(.cur){color:var(--text)}
.lm2-lost{font-size:10.5px;font-weight:700;color:#ff6b6b;border:1px solid #ff6b6b;border-radius:100px;padding:6px 11px}
.lm2-actions{margin-left:auto;display:flex;gap:8px;align-items:center;position:relative}
.lm2-menu{position:absolute;right:0;top:40px;z-index:9;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:12px;padding:6px;width:230px;box-shadow:0 18px 50px -12px rgba(0,0,0,.8);font-size:12.5px}
.lm2-menu button{display:block;width:100%;text-align:left;background:transparent;border:0;color:var(--text);font:inherit;padding:8px 10px;border-radius:8px;cursor:pointer}
.lm2-menu button:hover{background:rgba(255,255,255,.06)}
.lm2-menu button.danger{color:#ff8b8b}
.lm2-menu hr{border:none;border-top:1px solid var(--line);margin:4px 0}
.lm2-grid{display:grid;grid-template-columns:240px 1fr 280px;gap:0;overflow-y:auto;flex:1}
.lm2-l{border-right:1px solid var(--line);padding:16px}
.lm2-c{padding:16px 20px;background:rgba(0,0,0,.12);min-width:0}
.lm2-r{border-left:1px solid var(--line);padding:16px}
.lm2-sech{font-size:10px;letter-spacing:.11em;text-transform:uppercase;color:var(--muted-2);font-weight:700;margin:0 0 10px}
.lm2-kv{display:grid;gap:9px;font-size:12.5px}
.lm2-kv .k{color:var(--muted-2);font-size:10px;text-transform:uppercase;letter-spacing:.06em}
.lm2-kv .v{font-weight:600;word-break:break-word}
.lm2-kv .v a{color:var(--acid);text-decoration:none}
.lm2-edit{cursor:pointer;border-radius:6px;margin:-2px -5px;padding:2px 5px}
.lm2-edit:hover{background:rgba(255,255,255,.05);outline:1px dashed var(--line-strong)}
.lm2-morefields{margin-top:12px;font-size:11.5px;color:var(--muted)}
.lm2-morefields summary{cursor:pointer;text-decoration:underline dotted}
.lm2-morefields .lm2-kv{margin-top:10px}
.lm2-composer{border:1px solid var(--line-strong);border-radius:13px;background:var(--navy-800);margin-bottom:16px;overflow:hidden}
.lm2-ctabs{display:flex;border-bottom:1px solid var(--line);font-size:12px;font-weight:700}
.lm2-ctabs button{background:transparent;border:0;color:var(--muted);font:inherit;font-weight:700;padding:9px 14px;cursor:pointer}
.lm2-ctabs button.on{color:var(--acid);box-shadow:inset 0 -2px var(--acid)}
.lm2-cbody{padding:10px 12px}
.lm2-cbody textarea{width:100%;background:var(--navy-900);border:1px solid var(--line-strong);border-radius:10px;color:var(--text);font:13px/1.5 Inter,sans-serif;padding:9px 11px;min-height:64px;resize:vertical}
.lm2-cbody input,.lm2-cbody select{background:var(--navy-900);border:1px solid var(--line-strong);border-radius:8px;color:var(--text);font:12.5px Inter,sans-serif;padding:7px 9px}
.lm2-crow{display:flex;gap:8px;margin-top:8px;flex-wrap:wrap;align-items:center}
.lm2-crow .sp{flex:1}
.lm2-chips{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap}
.lm2-chips button{background:transparent;border:1px solid var(--line-strong);border-radius:100px;color:var(--muted);font:600 11px Inter,sans-serif;padding:5px 11px;cursor:pointer}
.lm2-chips button.on{border-color:var(--acid);color:var(--acid);background:rgba(221,249,143,.08)}
.lm2-tl{position:relative;padding-left:18px}
.lm2-tl::before{content:"";position:absolute;left:4px;top:6px;bottom:6px;width:1.5px;background:var(--line-strong)}
.lm2-ev{position:relative;padding:0 0 14px 10px}
.lm2-ev::before{content:"";position:absolute;left:-18px;top:5px;width:10px;height:10px;border-radius:50%;background:var(--navy-800);border:2px solid var(--muted-2)}
.lm2-ev.hot::before{border-color:var(--acid);background:var(--acid)}
.lm2-ev .when{font-size:10px;color:var(--muted-2);text-transform:uppercase;letter-spacing:.05em}
.lm2-ev .card{margin-top:4px;border:1px solid var(--line);border-radius:11px;background:var(--navy-800);padding:9px 12px;font-size:12.5px;word-break:break-word}
.lm2-ev .card .meta{color:var(--muted);font-size:11.5px;margin-top:3px}
.lm2-ev .card details summary{cursor:pointer;color:var(--muted);font-size:11.5px;margin-top:4px}
.lm2-ev .card details div{margin-top:6px;white-space:pre-wrap;color:var(--text);font-size:12.5px}
.lm2-chip{display:inline-block;font-size:9.5px;font-weight:700;border-radius:20px;padding:1px 7px;margin-right:6px;vertical-align:1px}
.lm2-chip.email{background:rgba(138,180,255,.15);color:#8ab4ff}
.lm2-chip.nota{background:rgba(240,192,96,.15);color:#f0c060}
.lm2-chip.brief{background:rgba(221,249,143,.14);color:var(--acid)}
.lm2-chip.sys{background:rgba(255,255,255,.08);color:var(--muted)}
.lm2-chip.task{background:rgba(126,217,87,.15);color:#7ed957}
.lm2-chip.web{background:rgba(94,199,209,.15);color:#5ec7d1}
/* hilos de notas estilo chat: raíz arriba, respuestas con sangría y borde (feedback: el quoteo anidado era ilegible) */
.lm2-msg{margin-top:7px}
.lm2-msg .a{font-size:11px;font-weight:700}
.lm2-msg .a .w{color:var(--muted-2);font-weight:400;font-size:10px}
.lm2-msg .b{font-size:12.5px;white-space:pre-wrap;word-break:break-word;margin-top:1px}
.lm2-msg.rep{border-left:2px solid var(--line-strong);padding-left:9px;margin-left:4px;margin-top:9px}
.lm2-next{border:1px solid rgba(221,249,143,.4);border-radius:12px;background:rgba(221,249,143,.07);padding:11px 13px;margin-bottom:12px}
.lm2-next .t{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--acid);font-weight:700}
.lm2-next .v{font-size:12.5px;font-weight:600;margin-top:4px}
.lm2-next .v small{display:block;color:var(--muted);font-weight:400;font-size:11px;margin-top:2px}
.lm2-as{border:1px solid var(--line);border-radius:12px;background:var(--navy-800);margin-bottom:11px;overflow:hidden}
.lm2-as .top{display:flex;align-items:center;gap:7px;padding:10px 13px;font-weight:700;font-size:12.5px}
.lm2-as .top .n{margin-left:auto;font-size:10.5px;color:var(--muted);font-weight:600}
.lm2-as .row{border-top:1px solid var(--line);padding:9px 13px;font-size:12px;display:flex;align-items:center;gap:7px;cursor:pointer;background:transparent;width:100%;border-left:0;border-right:0;border-bottom:0;color:var(--text);font-family:inherit;text-align:left}
.lm2-as .row:hover{background:rgba(255,255,255,.03)}
.lm2-as .row .amt{margin-left:auto;font-weight:700;font-variant-numeric:tabular-nums;white-space:nowrap}
.lm2-as .row .stb{font-size:9.5px;font-weight:700;border:1px solid;border-radius:20px;padding:1px 6px;white-space:nowrap}
.lm2-as .add{border-top:1px solid var(--line);padding:8px 13px;font-size:11.5px;color:var(--acid);cursor:pointer;font-weight:600;background:transparent;border-left:0;border-right:0;border-bottom:0;width:100%;text-align:left;font-family:inherit}
.lm2-as .row select{background:var(--navy-900);border:1px solid var(--line-strong);border-radius:7px;color:var(--text);font:600 10.5px Inter,sans-serif;padding:3px 5px;max-width:110px}
@media(max-width:960px){
  .lm2-grid{display:flex;flex-direction:column}
  .lm2-l{order:3;border:none;border-top:1px solid var(--line)}
  .lm2-c{order:1}
  .lm2-r{order:2;border:none;border-top:1px solid var(--line)}
  .lm2-pipe span{padding:6px 8px}
  /* móvil menos crowded (feedback de Sebastián): header comprimido, chips y pipeline en una sola
     fila scrolleable, timeline más densa, y el botón Crear pierde el texto (queda ➕ ▾) */
  /* sin el padding del card, el header sticky toca el borde: que respete el notch él mismo */
  .lm2-hd{padding:calc(10px + env(safe-area-inset-top)) 12px 10px;gap:8px}
  .lm2-avatar{width:36px;height:36px;font-size:13px}
  .lm2-who .nm{font-size:15px}
  .lm2-who .sub{white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:calc(100vw - 120px)}
  .lm2-actions .btn{padding:7px 10px}
  #lm2-crear .lbl{display:none}
  .lm2-chips{flex-wrap:nowrap;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;padding-bottom:2px}
  .lm2-chips::-webkit-scrollbar{display:none}
  .lm2-chips button{padding:5px 10px;flex:none}
  .lm2-pipe{overflow-x:auto;max-width:100%;flex-wrap:nowrap;scrollbar-width:none}
  .lm2-pipe::-webkit-scrollbar{display:none}
  .lm2-ev{padding-bottom:11px}
  .lm2-ev .card{padding:8px 10px}
  .lm2-ev .when{font-size:9.5px}
  .lm2-l-fold>summary{display:block}
}
/* rail izquierdo plegable en móvil: en desktop el summary se oculta y el details queda abierto */
.lm2-l-fold>summary{display:none;cursor:pointer;font-size:12.5px;font-weight:700;padding:4px 0;list-style:none}
.lm2-l-fold>summary::-webkit-details-marker{display:none}
/* composer colapsado en móvil: una sola barra finita hasta que lo tocás */
.lm2-cbar{display:block;width:100%;text-align:left;background:transparent;border:0;color:var(--muted);font:600 12.5px Inter,sans-serif;padding:12px 14px;cursor:pointer}
</style>
