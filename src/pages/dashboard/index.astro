  function kwRenderNextRun(){
    const el = $('kw-nextrun-txt'); if (!el) return;
    // próximo lunes 05:00 UTC (cron 'viven-keyword-research', SQL 0071)
    const now = new Date();
    const d = new Date(now);
    const addDays = (1 - d.getUTCDay() + 7) % 7;
    d.setUTCDate(d.getUTCDate() + addDays); d.setUTCHours(5, 0, 0, 0);
    if (d <= now) d.setUTCDate(d.getUTCDate() + 7);
    const days = Math.max(1, Math.round((d - now) / 864e5));
    el.textContent = 'en ' + days + ' día' + (days === 1 ? '' : 's');
  }
  function kwRenderPersist(){
