    sel.innerHTML = Object.keys(cat).map((ph) =>
      '<optgroup label="' + ph + '">' +
      cat[ph].map((it, i) => '<option value="' + ph + '::' + i + '">' + esc(it.name) + ' — ' + fmtM(it.price) + '/' + it.unit + '</option>').join('') +
      '</optgroup>').join('');
  }

  const offerNet = (o) => (o.items || []).reduce((a, it) => a + (Number(it.qty) || 0) * (Number(it.price) || 0), 0) * (1 - (Number(o && o.discount_pct) || 0) / 100);
  const offerCost = (o) => (o.items || []).reduce((a, it) => a + (Number(it.qty) || 0) * (Number(it.cost) || 0), 0);
  const offerMarginPct = (o) => { const n = offerNet(o); return n ? (n - offerCost(o)) / n * 100 : NaN; };

  async function offersLoad(){
    const { data, error } = await supabase.from('offers').select('*').order('updated_at', { ascending: false });
    if (error){ $('opl-empty').hidden = false; $('opl-empty').textContent = 'No se pudo cargar ofertas (¿corriste el SQL 0003_offers?): ' + error.message; return; }
