  // ===== panel de envío (conteo, tandas, cupo, progreso) =====
  function nwRecipCount(){
    const seen = new Set(); let n = 0;
    (allLeads || []).forEach((r) => { const e = (r.email || '').toLowerCase(); if (!e || seen.has(e) || !nwSegFilter(r)) return; seen.add(e); if (nwExcludeIds.has(String(r.id))) return; n++; });
    (nwExtraEmails || []).forEach((em) => { if (!seen.has(em)){ seen.add(em); n++; } });
    return n;
  }
  function nwSubsCount(){
    const seen = new Set(); let n = 0; const TEST = /@viven\.ch$|@entropia|@example\.|test/i;
    (allLeads || []).forEach((r) => { const e = (r.email || '').toLowerCase(); if (!e || seen.has(e) || TEST.test(e) || r.unsubscribed) return; if (/spam|descartado/i.test(r.status || '')) return; seen.add(e); n++; });
    return n;
  }
  function nwUpdateSendPanel(){
    const title = $('nw-send-title'), info = $('nw-send-info'); if (!title || !info) return;
    if ($('nw-mode') && $('nw-mode').value === 'one'){ title.textContent = '📤 Envío directo a 1 persona'; info.innerHTML = 'Queda registrado en el historial (con utm y link de baja). El self-test rápido NO deja rastro.'; const b0 = $('nw-send'); if (b0) b0.textContent = '📤 Enviar ahora'; return; }
    const n = nwRecipCount();
    const batches = Math.max(1, Math.ceil(n / 100));
    const secs = Math.max(1, Math.round(batches * 0.6 + n * 0.02));
    const CAP = 100;
    const cap = n > CAP
      ? '<br/><span class="cap-over">⚠️ ' + n + " supera el tope diario del plan Free (100/día) — conviene Pro (USD 20/mes = 50'000).</span>"
      : "<br/>Cupo Free: <b>" + n + " de 3'000 este mes</b> ✓";
    const sched = $('nw-sched-mode') && $('nw-sched-mode').value === 'at';
    title.textContent = '📤 Listo para enviar a ' + n + ' persona' + (n === 1 ? '' : 's');
    info.innerHTML = 'En <b>' + batches + ' tanda' + (batches === 1 ? '' : 's') + ' de 100</b> (API batch de Resend) · duración estimada: <b>~' + secs + 's</b>' + cap +
      '<br/>Si el envío se corta, se retoma solo sin duplicar a nadie ✓' + (sched ? '<br/>⏰ Programado — se enviará cuando el despachador esté activo.' : '');
    const btn = $('nw-send'); if (btn) btn.textContent = sched ? '⏰ Programar' : '📤 Enviar ahora';
  }

  // ===== atribución de ventas por campaña =====
  function nwWonDeal(leadId){ return (dealsList || []).find((d) => String(d.lead_id) === String(leadId) && stageOf(d.stage) === 'ganado'); }
  function nwMoneyShort(v){ v = Number(v) || 0; return v >= 1000 ? 'CHF ' + (v / 1000).toLocaleString('de-CH', { maximumFractionDigits: 1 }) + 'k' : 'CHF ' + v.toLocaleString('de-CH', { maximumFractionDigits: 0 }); }

  async function newsInit(){
    const [nlRes, sendsRes] = await Promise.all([
      supabase.from('newsletters').select('*').order('created_at', { ascending: false }),
      supabase.from('newsletter_sends').select('newsletter_id,lead_id,opened_at,clicked_at'),
    ]);
    if (nlRes.error){ $('nw-list').innerHTML = '<p class="muted-note">Falta correr el SQL 0039 — ' + esc(nlRes.error.message) + '</p>'; return; }
    nwList = nlRes.data || [];
    const sends = sendsRes.error ? [] : (sendsRes.data || []);   // sin columnas de tracking (SQL 0075) → sin métricas
    $('nw-listcount').textContent = nwList.length || '';
    // editor: inicializar si está vacío
    if (!$('nw-editor').children.length) nwRenderEditor();
    nwUpdateSendPanel();

    (async () => { try {
      const [{ data: st }, { data: lg }] = await Promise.all([
        supabase.from('app_settings').select('value').eq('key', 'nurture').maybeSingle(),
        supabase.from('nurture_log').select('step'),
      ]);
      const on = !(st && st.value && st.value.enabled === false);
      const btn = $('nur-toggle'); if (btn){ btn.textContent = on ? '🟢 Pasos ②③ activos — apagar' : '⚪ Pasos ②③ apagados — encender'; btn.dataset.on = on ? '1' : ''; }
      const c = { 1: 0, 2: 0, 3: 0 }; (lg || []).forEach((x) => c[x.step] = (c[x.step] || 0) + 1);
      if ($('nur-stats')) $('nur-stats').textContent = '① ' + c[1] + ' · ② ' + c[2] + ' · ③ ' + c[3] + ' enviados';
    } catch (e) { if ($('nur-stats')) $('nur-stats').textContent = 'falta SQL 0040'; } })();
    nurLoad();

    // agregado de envíos por campaña
    const agg = {};
    sends.forEach((s) => { const a = agg[s.newsletter_id] = agg[s.newsletter_id] || { n: 0, open: 0, click: 0, openLeads: [] }; a.n++; if (s.opened_at){ a.open++; if (s.lead_id) a.openLeads.push(s.lead_id); } if (s.clicked_at) a.click++; });

    // KPI mini
    if ($('nw-kmini-subs')) $('nw-kmini-subs').textContent = nwSubsCount();
    const lastSent = nwList.find((n) => n.status === 'sent');
    if ($('nw-kmini-open')){ if (lastSent){ const a = agg[lastSent.id] || { n: 0, open: 0 }; const sn = lastSent.sent_count || a.n; $('nw-kmini-open').textContent = sn ? Math.round(a.open / sn * 100) + '%' : '—'; } else $('nw-kmini-open').textContent = '—'; }
    if ($('nw-kmini-unsub')) $('nw-kmini-unsub').textContent = (allLeads || []).filter((l) => l.unsubscribed).length;

    // lista de campañas con atribución
    $('nw-list').innerHTML = nwList.map((n) => {
      const a = agg[n.id] || { n: 0, open: 0, click: 0, openLeads: [] };
      const sentN = n.sent_count || a.n;
      const date = new Date(n.sent_at || n.created_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short' });
      const seg = n.segment_stage === 'won' ? 'Clientes' : n.segment_stage === 'open' ? 'Prospectos' : 'Todos';
      let right;
      if (n.status === 'sent'){
        const openPct = sentN ? Math.round(a.open / sentN * 100) : 0;
        const clickPct = sentN ? Math.round(a.click / sentN * 100) : 0;
        // atribución directa (utm_campaign del lead) e influida (abrió → ganó en 30d)
        let directWon = 0; (allLeads || []).forEach((l) => { if (l.utm_campaign === 'nl-' + n.id){ const d = nwWonDeal(l.id); if (d) directWon += dealValue(d); } });
        const sentT = n.sent_at ? Date.parse(n.sent_at) : 0; let inflWon = 0; const seen = new Set();
        (a.openLeads || []).forEach((lid) => { if (seen.has(String(lid))) return; seen.add(String(lid)); const d = nwWonDeal(lid); if (!d) return; const wt = Date.parse(d.won_at || d.last_stage_at || ''); if (sentT && wt && wt >= sentT && wt <= sentT + 30 * 864e5) inflWon += dealValue(d); });
        let attr;
        if (directWon > 0) attr = '<b style="color:var(--won)">💰 ' + nwMoneyShort(directWon) + ' ganados</b>';
        else if (inflWon > 0) attr = '<b style="color:var(--won)">💰 ' + nwMoneyShort(inflWon) + ' influido</b>';
        else attr = '<span style="color:var(--muted-2)">sin ventas atribuidas</span>';
        right = '<span class="nw-pill ' + (openPct >= 35 ? 'ok' : 'warn') + '">' + openPct + '% abrió</span> <span class="nw-pill ' + (clickPct >= 5 ? 'ok' : 'warn') + '">' + clickPct + '% click</span><br/>' + attr;
      } else if (n.scheduled_at){
        right = '<span class="nw-pill warn">⏰ ' + new Date(n.scheduled_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) + '</span>';
      } else {
        right = '<span class="of-badge" style="color:#8ab4ff;border-color:currentColor">Borrador</span>';
      }
      return '<div class="nw-sr clickable" data-nw="' + n.id + '"><div style="min-width:0"><div class="tt">' + esc(n.subject) + '</div>' +
        '<div class="sub">' + date + ' · ' + seg + ' · ' + (n.status === 'sent' ? sentN + ' enviados' : 'sin enviar') + '</div></div>' +
        '<div class="st2">' + right + '</div></div>';
    }).join('') || '<p class="muted-note">Sin campañas todavía.</p>';

    $('nw-list').querySelectorAll('[data-nw]').forEach((c) => c.addEventListener('click', () => {
      const n = nwList.find((x) => x.id === c.dataset.nw); if (!n) return;
      nwCur = n.status === 'sent' ? null : n;
      $('nw-subject').value = n.subject; $('nw-stage').value = n.segment_stage; $('nw-lang').value = n.segment_lang;
      nwBlocks = nwBlocksFromRow(n); nwRenderEditor();
      nwExcludeIds = new Set((n.exclude_ids || []).map(String)); nwExtraEmails = (n.extra_emails || []).slice();
      if (n.scheduled_at && n.status !== 'sent'){ $('nw-sched-mode').value = 'at'; $('nw-sched-at').hidden = false; try { $('nw-sched-at').value = new Date(n.scheduled_at).toISOString().slice(0, 16); } catch (e) {} }
      else { $('nw-sched-mode').value = 'now'; $('nw-sched-at').hidden = true; }
      $('nw-note').textContent = n.status === 'sent' ? 'Cargada como COPIA (la original ya se envió) — al enviar se crea una campaña nueva.' : 'Borrador cargado.';
      nwUpdateSendPanel();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }));
  }
  async function nwSave(){
    const cleanBlocks = nwBlocks.map((b) => ({ ...b })).filter((b) => b.type !== 'text' || String(b.text || '').trim());
    const body = nwDerivedBody();
    const hasContent = body.trim() || cleanBlocks.some((b) => b.type !== 'text');
    const subject = $('nw-subject').value.trim();
    if (!subject || !hasContent){ toast('Falta asunto o contenido'); return null; }
    const schedAt = ($('nw-sched-mode') && $('nw-sched-mode').value === 'at' && $('nw-sched-at').value) ? new Date($('nw-sched-at').value).toISOString() : null;
    const row = { subject, body, blocks: cleanBlocks, scheduled_at: schedAt, segment_stage: $('nw-stage').value, segment_lang: $('nw-lang').value, exclude_ids: [...nwExcludeIds].map(Number), extra_emails: nwExtraEmails.slice(), updated_at: new Date().toISOString() };
    const saveRow = async (r) => {
      if (nwCur && nwCur.id){ const { error } = await supabase.from('newsletters').update(r).eq('id', nwCur.id); return { id: nwCur.id, error }; }
      const { data, error } = await supabase.from('newsletters').insert(r).select().single(); if (!error) nwCur = data; return { id: data && data.id, error };
    };
    let { id, error } = await saveRow(row);
    if (error && /blocks|scheduled_at|column/i.test(error.message || '')){
      const legacy = { subject: row.subject, body: row.body, segment_stage: row.segment_stage, segment_lang: row.segment_lang, exclude_ids: row.exclude_ids, extra_emails: row.extra_emails, updated_at: row.updated_at };
      ({ id, error } = await saveRow(legacy));
      if (!error) toast('Guardado sin bloques/programación — corré el SQL 0075');
    }
    if (error){ toast(/does not exist|relation/i.test(error.message) ? 'Falta correr el SQL 0039' : error.message); return null; }
    return id;
  }
  function nwSegFilter(r){
    const TEST = /@viven\.ch$|@entropia|@example\.|test/i;
    if (!r.email || TEST.test(r.email) || r.unsubscribed) return false;
    if (/spam|descartado/i.test(r.status || '')) return false;
    const won = /ganado|won|cerrado/i.test(r.status || '');
    const st = $('nw-stage').value; if (st === 'won' && !won) return false; if (st === 'open' && won) return false;
    const lg = $('nw-lang').value; if (lg !== 'all' && (r.lang || 'en') !== lg) return false;
    return true;
  }
