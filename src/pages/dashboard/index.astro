    const offerOpts = '<option value="">⟵ usar oferta…</option>' + (offersList || []).filter((o) => !o.archived)
      .map((o) => '<option value="' + o.id + '">' + esc((o.title || '(sin título)') + ' · ' + fmtM(offerNet(o))) + '</option>').join('');
