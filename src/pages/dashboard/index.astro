    })();
    // reconciliar: propuesta aceptada pero lead sin ganar (aceptó con el dashboard cerrado) → sync
    if (propsQ && !propsQ.error) (propsQ.data || []).forEach((p) => {
      if (p.status !== 'accepted' || !p.lead_id) return;
      const l = allLeads.find((x) => String(x.id) === String(p.lead_id));
