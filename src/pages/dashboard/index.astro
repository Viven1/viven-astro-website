  async function saveProp(publish){
    collectEditor();
    if (!ppCur.title){ toast('Ponele un título a la propuesta'); return; }
    if (publish && !ppCur.password){ toast('Ponele un password para el cliente antes de publicar'); return; }
    if (!ppCur.slug) ppCur.slug = makeSlug(ppCur.title);
    if (publish) ppCur.status = 'sent';
    const payload = { slug: ppCur.slug, password: ppCur.password || '', title: ppCur.title, client_name: ppCur.client_name, client_email: ppCur.client_email, lead_id: ppCur.lead_id, status: ppCur.status, content: buildContent() };
    const btn = publish ? $('pp-publish') : $('pp-save'), prev = btn.textContent; btn.disabled = true; btn.textContent = '…';
    const res = ppCur.id
      ? await supabase.from('proposals').update(payload).eq('id', ppCur.id).select().single()
      : await supabase.from('proposals').insert(payload).select().single();
    btn.disabled = false; btn.textContent = prev;
    if (res.error){ toast('No se pudo guardar (¿corriste el SQL 0004?): ' + res.error.message); return; }
    ppCur.id = res.data.id; ppCur.status = res.data.status;
    toast(publish ? 'Propuesta publicada ✅' : 'Guardada');
    fillPropEditor(); ppLoad();
