  async function licSave(){
    const title = $('lic-title').value.trim();
    const renewal = $('lic-renewal').value;
    if (!title || !renewal){ toast('Falta título o fecha de renovación'); return; }
    const row = {
      title, lead_id: $('lic-lead').value || null,
      amount: $('lic-amount').value ? +$('lic-amount').value : null,
      start_date: $('lic-start').value || null,
      renewal_date: renewal,
      notes: $('lic-notes').value.trim() || null,
      updated_at: new Date().toISOString(),
    };
    let error;
    if (licEditing){ ({ error } = await supabase.from('licenses').update(row).eq('id', licEditing.id)); }
    else { ({ error } = await supabase.from('licenses').insert(row)); }
    if (error){ toast(/does not exist|relation/i.test(error.message) ? 'Falta correr el SQL 0048' : '⚠️ ' + error.message); return; }
    toast('💾 Guardada'); $('lic-form').hidden = true; licLoad();
  }
  function licDaysBadge(renewalDate){
    const days = Math.round((new Date(renewalDate + 'T00:00:00').getTime() - new Date(new Date().toDateString()).getTime()) / 864e5);
    let cls, txt;
    if (days < 0){ cls = 'past'; txt = 'venció hace ' + Math.abs(days) + 'd'; }
    else if (days === 0){ cls = 'due'; txt = 'HOY'; }
    else if (days <= 30){ cls = 'due'; txt = 'en ' + days + 'd'; }
    else if (days <= 90){ cls = 'soon'; txt = 'en ' + days + 'd'; }
    else { cls = 'ok'; txt = 'en ' + days + 'd'; }
    return '<span class="lic-days ' + cls + '">' + txt + '</span>';
  }
  async function licLoad(){
    const { data, error } = await supabase.from('licenses').select('*').order('renewal_date', { ascending: true });
    if (error){ $('lic-list').innerHTML = '<p class="muted-note">Corré el SQL 0048 para activar Licencias.</p>'; return; }
    licList = data || [];
    licRender();
  }
  function licRender(){
    const box = $('lic-list');
    if (!licList.length){ box.innerHTML = '<p class="muted-note">Sin licencias todavía — agregá la primera con ➕.</p>'; return; }
    box.innerHTML = licList.map((l) => {
      const lead = l.lead_id ? leadById(l.lead_id) : null;
      const statusLbl = { renewed: '✅ Renovada', expired: '⏹ Vencida', cancelled: '🚫 Cancelada' }[l.status] || '';
      return '<div class="of-card" data-lid="' + l.id + '"><div class="of-card-open"><div class="of-card-main">' +
        '<div class="of-card-title">' + esc(l.title) + '</div>' +
        '<div class="of-card-sub">' + esc(lead ? (lead.name || lead.email) : 'Sin cliente') + (l.amount ? ' · CHF ' + Number(l.amount).toLocaleString('de-CH') : '') + ' · renueva ' + esc(l.renewal_date) + '</div></div>' +
        (l.status === 'active' ? licDaysBadge(l.renewal_date) : '<span class="lic-days past">' + statusLbl + '</span>') +
        '</div><div class="of-actions">' +
        (l.status === 'active' ? '<button class="of-act" data-act="renew" type="button">✅ Renovar</button><button class="of-act" data-act="edit" type="button">✏️ Editar</button><button class="of-act danger" data-act="cancel" type="button">🚫 Cancelar</button>' : '') +
        '<button class="of-act danger" data-act="del" type="button">🗑 Borrar</button>' +
        '</div></div>';
    }).join('');
    box.querySelectorAll('[data-act]').forEach((btn) => btn.addEventListener('click', async () => {
      const card = btn.closest('[data-lid]'); const id = card.dataset.lid; const l = licList.find((x) => String(x.id) === id); if (!l) return;
      const act = btn.dataset.act;
      if (act === 'edit'){ licEditing = l; licOpenForm(l); }
      else if (act === 'renew'){
        const next = prompt('Nueva fecha de renovación (YYYY-MM-DD):', l.renewal_date);
        if (!next) return;
        await supabase.from('licenses').update({ renewal_date: next, updated_at: new Date().toISOString() }).eq('id', l.id);
        toast('✅ Renovada — próxima: ' + next); licLoad();
      } else if (act === 'cancel'){
        if (!confirm('¿Marcar como cancelada?')) return;
        await supabase.from('licenses').update({ status: 'cancelled' }).eq('id', l.id);
        licLoad();
      } else if (act === 'del'){
        if (!confirm('¿Borrar esta licencia del todo?')) return;
        await supabase.from('licenses').delete().eq('id', l.id);
        licLoad();
      }
    }));
  }
  function servicesInit(){
    if (!servicesBuilt){
      servicesBuilt = true;
      $('sv-add').addEventListener('click', async () => {
        const { data, error } = await supabase.from('services').insert({ name: 'Nuevo servicio', phase: 'Production', unit: 'Tag', price: 0, cost: 0 }).select().single();
        if (error){ toast('No se pudo agregar (¿corriste el SQL 0025?): ' + error.message); return; }
        servicesList.push(data); renderServices();
        const inp = document.querySelector('.sv-row[data-id="' + data.id + '"] input[data-f="name"]');
        if (inp){ inp.focus(); inp.select(); }
      });
    }
    servicesLoad().then(({ error }) => {
      const note = $('sv-note');
      if (error){ note.hidden = false; note.innerHTML = '⚠️ La tabla <b>services</b> no existe todavía — corré el SQL <b>0025</b> en Supabase. Mientras tanto las ofertas usan el catálogo fijo.'; $('sv-list').innerHTML = ''; return; }
      note.hidden = true; renderServices();
    });
  }
  function renderServices(){
    const box = $('sv-list'); if (!box) return;
    if (!servicesList.length){ box.innerHTML = '<p class="muted-note">Sin servicios. Agregá el primero con ➕ — o corré el SQL 0025 que precarga el catálogo actual.</p>'; return; }
    let html = '';
    PHASES.forEach((ph) => {
      const rows = servicesList.filter((x) => (PHASES.includes(x.phase) ? x.phase : 'Production') === ph);
      if (!rows.length) return;
      html += '<div class="sv-phase">' + esc(ph) + '</div>';
      rows.forEach((x) => {
        html += '<div class="sv-row' + (x.active === false ? ' sv-off' : '') + '" data-id="' + x.id + '">' +
          '<input data-f="name" value="' + esc(x.name || '') + '" placeholder="Nombre del servicio" />' +
          '<select data-f="phase">' + PHASES.map((p) => '<option' + (p === x.phase ? ' selected' : '') + '>' + p + '</option>').join('') + '</select>' +
          '<input data-f="unit" value="' + esc(x.unit || '') + '" placeholder="Tag/Std/Fix" title="Unidad: Tag, Std, Fix, Stk, Person, Sprache…" />' +
          '<label class="sv-num">CHF<input data-f="price" type="number" step="10" value="' + (Number(x.price) || 0) + '" title="Precio al cliente" /></label>' +
          '<label class="sv-num sv-cost">costo<input data-f="cost" type="number" step="10" value="' + (Number(x.cost) || 0) + '" title="Costo interno (freelancer/alquiler) — para calcular tu margen" /></label>' +
          '<button class="sv-tgl" data-act="tgl" type="button" title="' + (x.active === false ? 'Reactivar (hoy no aparece en el catálogo)' : 'Pausar (sale del catálogo sin borrarlo)') + '">' + (x.active === false ? '▶' : '⏸') + '</button>' +
          '<button class="sv-del" data-act="del" type="button" title="Borrar definitivamente">✕</button>' +
        '</div>';
      });
    });
    box.innerHTML = html;
    box.querySelectorAll('.sv-row input,.sv-row select').forEach((inp) => inp.addEventListener('change', async () => {
      const row = inp.closest('.sv-row'), id = row.dataset.id, f = inp.dataset.f;
      let v = inp.value;
      if (f === 'price' || f === 'cost') v = parseFloat(v) || 0;
      const it = servicesList.find((x) => String(x.id) === String(id)); if (it) it[f] = v;
      const { error } = await supabase.from('services').update({ [f]: v, updated_at: new Date().toISOString() }).eq('id', id);
      if (error) toast('No se pudo guardar: ' + error.message); else svTouch();
    }));
    box.querySelectorAll('[data-act="tgl"]').forEach((b) => b.addEventListener('click', async () => {
      const id = b.closest('.sv-row').dataset.id, it = servicesList.find((x) => String(x.id) === String(id));
      const nv = it.active === false;
      const { error } = await supabase.from('services').update({ active: nv }).eq('id', id);
      if (error){ toast(error.message); return; }
      it.active = nv; renderServices(); svTouch();
    }));
    box.querySelectorAll('[data-act="del"]').forEach((b) => b.addEventListener('click', async () => {
      const id = b.closest('.sv-row').dataset.id, it = servicesList.find((x) => String(x.id) === String(id));
      if (!confirm('¿Borrar «' + (it.name || 'servicio') + '» del catálogo?')) return;
      const { error } = await supabase.from('services').delete().eq('id', id);
      if (error){ toast(error.message); return; }
      servicesList = servicesList.filter((x) => String(x.id) !== String(id)); renderServices(); svTouch();
    }));
  }
  // el catálogo de ofertas se rearma la próxima vez que entres a Ofertas
  function svTouch(){ const sel = $('of-preset'); if (sel) delete sel.dataset.built; }

  function buildPresetSelect(){
    const sel = $('of-preset');
    if (sel.dataset.built) return;
    sel.dataset.built = '1';
    const cat = CATALOG();
    sel.innerHTML = Object.keys(cat).map((ph) =>
      '<optgroup label="' + ph + '">' +
      cat[ph].map((it, i) => '<option value="' + ph + '::' + i + '">' + esc(it.name) + ' — ' + fmtM(it.price) + '/' + it.unit + '</option>').join('') +
      '</optgroup>').join('');
  }

  const offerNet = (o) => (o.items || []).reduce((a, it) => a + (Number(it.qty) || 0) * (Number(it.price) || 0), 0) * (1 - (Number(o && o.discount_pct) || 0) / 100);
  const offerCost = (o) => (o.items || []).reduce((a, it) => a + (Number(it.qty) || 0) * (Number(it.cost) || 0), 0);
  const offerMarginPct = (o) => { const n = offerNet(o); return n ? (n - offerCost(o)) / n * 100 : NaN; };

  async function offersLoad(){
    const { data, error } = await supabase.from('offers').select('*').order('updated_at', { ascending: false });
    if (error){ $('of-empty').hidden = false; $('of-empty').textContent = 'No se pudo cargar (¿corriste el SQL 0003_offers?): ' + error.message; return; }
    offersList = data || [];
    renderOffersList();
    // el valor de las ofertas se ve también en Deals (board), Personas y Home → refrescarlos
    try { renderLeads(); renderHome(); } catch (e) {}
  }

  function renderOffersList(){
    const box = $('of-list');
    $('of-empty').hidden = offersList.length > 0;
    const base = offersList.filter((o) => !o.is_template && !o.archived);
    const pool = base.filter((o) => o.status !== 'tier');   // paquetes de propuesta: visibles pero FUERA de los números
    const open = pool.filter((o) => o.status === 'sent');
    const won = pool.filter((o) => o.status === 'won');
    const lost = pool.filter((o) => o.status === 'lost');
    const propExtra = acceptedProps().filter((p) => !propCovered(p));   // propuestas ganadas sin oferta ligada
    const propExtraNet = propExtra.reduce((a, p) => a + propNet(p), 0);
    const decided = won.length + lost.length + propExtra.length;
    const margins = pool.map(offerMarginPct).filter((m) => isFinite(m));
    renderTplStrip('of-tpl-strip', offersList.filter((o) => o.is_template), useOfferTemplate, delOfferTemplate);
    // semanas para cerrar (ganadas): updated_at - created_at, aprox del cierre
    const closeDurs = won.map((o) => (Date.parse(o.updated_at) - Date.parse(o.created_at)) / 6048e5).filter((d) => d >= 0);
    $('of-k-open').textContent = open.length;
    $('of-k-won').textContent = won.length + propExtra.length;
    $('of-k-conv').innerHTML = decided ? Math.round(won.length / decided * 100) + '<small>%</small>' : '–';
    $('of-k-weeks').textContent = closeDurs.length ? (closeDurs.reduce((a, b) => a + b, 0) / closeDurs.length).toFixed(1) : '–';
    $('of-k-count').textContent = pool.length;
    // ganadas: bruto (lo que facturás), neto, costos externos (lo que debés) y ganancia real
    const wonNet = won.reduce((a, o) => a + offerNet(o), 0) + propExtraNet;
    const wonGross = won.reduce((a, o) => a + offerNet(o) * (1 + (o.vat_rate ?? 8.1) / 100), 0) + propExtraNet * 1.081;
    const wonCost = won.reduce((a, o) => a + offerCost(o), 0);
    $('of-k-gross').textContent = fmtM(wonGross);
    $('of-k-value').textContent = fmtM(wonNet);
    $('of-k-cost').textContent = fmtM(wonCost);
    $('of-k-cost').style.color = wonCost ? '#f0c060' : 'var(--text)';
    $('of-k-profit').textContent = fmtM(wonNet - wonCost);
    $('of-k-profit').style.color = (wonNet - wonCost) > 0 ? '#7ed957' : 'var(--text)';
    $('of-k-margin').textContent = margins.length ? Math.round(margins.reduce((a, b) => a + b, 0) / margins.length) + '%' : '–';
    // reconciliación con el pipeline: ofertas sin persona ligada = la diferencia entre ambos números
    const unlinked = pool.filter((o) => !o.lead_id && !o.archived);
    const un = $('of-unlinked-note');
    if (un){
      un.hidden = !unlinked.length;
      if (unlinked.length) un.innerHTML = '⚠️ <b>' + unlinked.length + ' oferta' + (unlinked.length > 1 ? 's' : '') + ' sin persona ligada</b> (' + fmtM(unlinked.reduce((a, o) => a + offerNet(o), 0)) + ') — no aparecen en el pipeline. Abrilas y guardá: te propone crear la persona en un click.';
    }
    const badge = { draft: ['Borrador', '#8ab4ff'], sent: ['Enviada', '#f0c060'], won: ['Ganada', '#7ed957'], lost: ['Perdida', '#ff6b6b'], tier: ['Paquete propuesta', '#c58af9'] };
    const active = base;   // la lista SÍ muestra los paquetes (para editarlos), los KPIs no
    const archived = offersList.filter((o) => o.archived && !o.is_template);
    const cardHtml = (o) => {
      const net = offerNet(o), mp = offerMarginPct(o), b = badge[o.status] || badge.draft;
      const leadName = o.lead_id ? (allLeads.find((l) => String(l.id) === String(o.lead_id)) || {}).name : '';
      const noLead = (!o.lead_id && !o.is_template) ? ' · <span style="color:#f0c060">⚠ sin persona (fuera del pipeline)</span>' : '';
      return '<div class="of-card' + (o.archived ? ' arch' : '') + '" data-id="' + o.id + '">' +
        '<div class="of-card-open" data-id="' + o.id + '">' +
          '<div class="of-card-main"><div class="of-card-title">' + (o.number ? '<span style="color:var(--acid);font-size:12px;margin-right:7px">' + esc(o.number) + '</span>' : '') + esc(o.title || '(sin título)') + '</div>' +
          '<div class="of-card-sub">' + esc(o.client || leadName || '—') + ' · ' + (o.items ? o.items.length : 0) + ' posiciones · ' + new Date(o.updated_at).toLocaleDateString('es-CH', { day: '2-digit', month: 'short' }) +
            (o.status === 'lost' && (o.lost_reason || leadLostReason(o.lead_id)) ? ' · <span style="color:#ff8b8b">✕ ' + esc(o.lost_reason || leadLostReason(o.lead_id)) + '</span>' : '') + noLead + '</div></div>' +
          '<div class="of-card-nums"><div class="of-card-net">' + fmtM(net) + '</div>' +
          '<div class="of-card-margin" style="color:' + (mp >= 50 ? '#7ed957' : mp >= 30 ? '#f0c060' : '#ff8b8b') + '">' + (isFinite(mp) ? Math.round(mp) + '% margen' : '') + '</div></div>' +
          '<span class="of-badge" style="color:' + b[1] + ';border-color:' + b[1] + '">' + b[0] + '</span></div>' +
        '<div class="of-actions">' +
          '<button class="of-act" data-act="dup" data-id="' + o.id + '" type="button">⧉ Duplicar</button>' +
          '<button class="of-act" data-act="arch" data-id="' + o.id + '" type="button">' + (o.archived ? '↩ Desarchivar' : '🗄 Archivar') + '</button>' +
          '<button class="of-act danger" data-act="del" data-id="' + o.id + '" type="button">🗑 Borrar</button>' +
        '</div></div>';
    };
    let html = active.map(cardHtml).join('');
    if (archived.length){
      html += '<button class="of-arch-toggle" id="of-arch-toggle" type="button">' + (showArchived ? '▾ Ocultar' : '▸ Ver') + ' archivadas (' + archived.length + ')</button>';
      if (showArchived) html += '<div class="of-arch-list">' + archived.map(cardHtml).join('') + '</div>';
    }
    box.innerHTML = html;
    box.querySelectorAll('.of-card-open').forEach((c) => c.addEventListener('click', () => openOffer(c.dataset.id)));
    box.querySelectorAll('.of-act').forEach((btn) => btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const id = btn.dataset.id, act = btn.dataset.act;
      if (act === 'dup') duplicateOffer(id);
      else if (act === 'arch') { const o = offersList.find((x) => String(x.id) === String(id)); archiveOffer(id, !(o && o.archived)); }
      else if (act === 'del') deleteOfferById(id);
    }));
    const at = $('of-arch-toggle');
    if (at) at.addEventListener('click', () => { showArchived = !showArchived; renderOffersList(); });
  }

  async function duplicateOffer(id){
    const src = offersList.find((o) => String(o.id) === String(id));
    if (!src) return;
    const copy = { title: (src.title || '(sin título)') + ' (copia)', client: src.client, lead_id: src.lead_id, vat_rate: src.vat_rate ?? 8.1, status: 'draft', items: src.items || [] };
    const { error } = await supabase.from('offers').insert(copy);
    if (error){ toast('No se pudo duplicar: ' + error.message); return; }
    toast('Oferta duplicada'); offersLoad();
  }
  async function archiveOffer(id, val){
    const { error } = await supabase.from('offers').update({ archived: val }).eq('id', id);
    if (error){ toast('No se pudo ' + (val ? 'archivar' : 'desarchivar') + ' (¿corriste el SQL 0006?): ' + error.message); return; }
    const o = offersList.find((x) => String(x.id) === String(id)); if (o) o.archived = val;
    renderOffersList();
  }
  async function deleteOfferById(id){
    const o = offersList.find((x) => String(x.id) === String(id));
    if (!confirm('¿Borrar definitivamente la oferta "' + ((o && o.title) || '') + '"? No se puede deshacer.')) return;
    const { error } = await supabase.from('offers').delete().eq('id', id);
    if (error){ toast('No se pudo borrar: ' + error.message); return; }
    offersList = offersList.filter((x) => String(x.id) !== String(id));
    renderOffersList();
  }

  function showEditor(on){ $('of-editor').hidden = !on; $('of-list-view').hidden = on; }

  // strip de templates: chips con "usar" y borrar
  function renderTplStrip(id, tpls, useFn, delFn){
    const el = $(id); if (!el) return;
    el.hidden = !tpls.length;
    el.innerHTML = tpls.length ? '<span class="tpl-l">📋 Templates:</span>' + tpls.map((t) =>
      '<span class="tpl-chip"><button class="tpl-use" data-id="' + t.id + '" type="button">' + esc((t.title || '(sin título)').replace(/^\[Template\]\s*/i, '')) + '</button><button class="tpl-del" data-id="' + t.id + '" type="button" title="Borrar template">✕</button></span>').join('') : '';
    el.querySelectorAll('.tpl-use').forEach((b) => b.addEventListener('click', () => useFn(b.dataset.id)));
    el.querySelectorAll('.tpl-del').forEach((b) => b.addEventListener('click', () => delFn(b.dataset.id)));
  }
  async function saveOfferAsTemplate(){
    const title = $('of-title').value.trim() || ofCur.title || '(sin título)';
    const row = { title: '[Template] ' + title.replace(/^\[Template\]\s*/i, ''), client: null, lead_id: null, vat_rate: parseFloat($('of-vat').value) || 8.1, status: 'draft', items: ofCur.items || [], terms: $('of-terms').value.trim() || null, is_template: true };
    try { await sbWriteRowsResilient('offers', [row], null); toast('📋 Template guardado — lo tenés arriba de la lista'); offersLoad(); }
    catch (e) { toast('No se pudo (¿SQL 0018?): ' + e.message); }
  }
  function useOfferTemplate(id){
    const t = offersList.find((o) => String(o.id) === String(id)); if (!t) return;
    ofCur = { title: (t.title || '').replace(/^\[Template\]\s*/i, ''), client: '', lead_id: null, vat_rate: t.vat_rate ?? 8.1, status: 'draft', items: JSON.parse(JSON.stringify(t.items || [])), terms: t.terms || DEFAULT_TERMS };
    fillEditor(); showEditor(true); toast('Oferta creada desde el template — guardala cuando esté lista');
  }
  async function delOfferTemplate(id){
    if (!confirm('¿Borrar este template?')) return;
    await supabase.from('offers').delete().eq('id', id); offersLoad();
  }
  function newOffer(){ ofCur = { title: '', client: '', lead_id: null, vat_rate: 8.1, status: 'draft', items: [], terms: DEFAULT_TERMS }; fillEditor(); showEditor(true); }
  function openOffer(id){
    const src = offersList.find((o) => String(o.id) === String(id));
    if (!src) return;
    ofCur = JSON.parse(JSON.stringify(src));
    if (!Array.isArray(ofCur.items)) ofCur.items = [];
    fillEditor(); showEditor(true);
  }

  function leadOptions(sel){
    return ['<option value="">— ninguno —</option>'].concat(
      (allLeads || []).map((l) => '<option value="' + esc(l.id) + '"' + (String(sel) === String(l.id) ? ' selected' : '') + '>' + esc(l.name || l.email || l.id) + '</option>')
    ).join('');
  }
  function fillEditor(){
    $('of-num').textContent = ofCur.number || '';
    $('of-disc').value = ofCur.discount_pct || 0;
    $('of-title').value = ofCur.title || '';
    $('of-client').value = ofCur.client || '';
    $('of-status').value = ofCur.status || 'draft';
    $('of-vat').value = ofCur.vat_rate ?? 8.1;
    $('of-lead').innerHTML = leadOptions(ofCur.lead_id);
    $('of-inquiry').value = ''; $('of-ai-note').textContent = ''; inquiryFromLead = '';
    $('of-terms').value = ofCur.terms || DEFAULT_TERMS;   // base: los terms reales de las ofertas A260xxx
    $('of-ccompany').value = ofCur.client_company || '';
    $('of-cperson').value = ofCur.client_contact || '';
    $('of-caddr').value = ofCur.client_address || '';
    $('of-czip').value = ofCur.client_zip_city || '';
    $('of-cphone').value = ofCur.client_phone || '';
    $('of-cemail').value = ofCur.client_email || '';
    prefillClientBlock();
    showLostNote('of-lostr', ofCur.lost_reason || leadLostReason(ofCur.lead_id), ofCur.status === 'lost');
    prefillInquiry(false);
    renderRows();
    refreshInvoiceBtn();
  }
  // botón de factura: solo tiene sentido con la oferta ganada y ya guardada (con id real).
  // Guard con secuencia: si abrís otra oferta antes de que esta consulta vuelva,
  // el resultado viejo NO debe pisar curInvoice de la oferta que estás mirando ahora
  // (si no, "Marcar pagada" podía terminar marcando la factura de OTRA oferta).
  let invoiceReqSeq = 0;
  async function refreshInvoiceBtn(){
    const btn = $('of-invoice'), paidBtn = $('of-invoice-paid');
    if (!btn) return;
    if (!FEATURE_INVOICING){ btn.hidden = true; paidBtn.hidden = true; return; }
    const show = ofCur.status === 'won' && !!ofCur.id;
    btn.hidden = !show; paidBtn.hidden = true;
    if (!show) return;
    curInvoice = null;
    const seq = ++invoiceReqSeq;
    const forOfferId = ofCur.id;
    const { data } = await supabase.from('invoices').select('*').eq('offer_id', forOfferId).order('created_at', { ascending: false }).limit(1).maybeSingle();
    if (seq !== invoiceReqSeq || ofCur.id !== forOfferId) return;   // se abrió otra oferta mientras esperábamos
    curInvoice = data || null;
    if (curInvoice) {
