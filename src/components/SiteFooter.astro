---
import { T, pick, localePath } from '../i18n.js';
const { lang } = Astro.props;
const p = (s) => localePath(lang, s);
const t = (k) => pick(T[k], lang);
const services = [
  ['brand', 'services/brand-video'],
  ['product', 'services/product-video'],
  ['employer', 'services/employer-branding'],
  ['howto', 'services/how-to-video'],
  ['socialMediaShort', 'services/social-media-video'],
  ['corporate', 'services/corporate-video'],
];
---
<footer>
  <div class="wrap">
    <div class="foot">
      <div class="brand">
        <a href={p('')} class="logo" aria-label="Viven"><svg class="logo-mark"><use href="#viven-logo"/></svg></a>
        <p>{t('footerTag')}</p>
      </div>
      <div class="foot-links">
        <div class="foot-col">
          <h3>{t('services')}</h3>
          {services.map(([k, s]) => (<a href={p(s)}>{t(k)}</a>))}
          <a href={lang === 'de' ? '/de/produktionsservices-schweiz/' : lang === 'es' ? '/es/servicios-de-produccion-audiovisual-suiza/' : '/en/video-production-services-zurich/'}>{lang === 'de' ? 'Produktionsservices Schweiz' : lang === 'es' ? 'Servicios de producción' : 'Production services'}</a>
          <a href={lang === 'de' ? '/de/videoproduktion-genf/' : lang === 'es' ? '/es/produccion-de-video-ginebra/' : '/en/video-production-geneva/'}>{lang === 'de' ? 'Videoproduktion Genf' : lang === 'es' ? 'Video en Ginebra' : 'Video production Geneva'}</a>
        </div>
        <div class="foot-col">
          <h3>{t('company')}</h3>
          <a href={p('why-viven')}>{t('why')}</a>
          <a href={p(lang === 'de' ? 'kunden' : lang === 'es' ? 'clientes' : 'clients')}>{lang === 'de' ? 'Kunden' : lang === 'es' ? 'Clientes' : 'Clients'}</a>
          <a href={p(lang === 'es' ? 'testimonios' : 'testimonials')}>{lang === 'de' ? 'Kundenstimmen' : lang === 'es' ? 'Testimonios' : 'Testimonials'}</a>
          <a href={p(lang === 'de' ? 'fallstudien' : lang === 'es' ? 'casos-de-exito' : 'case-studies')}>{lang === 'de' ? 'Fallstudien' : lang === 'es' ? 'Casos de éxito' : 'Case studies'}</a>
          <a href={p('projects')}>{t('projects')}</a>
          <a href={p("blog")}>{t('blog')}</a>
          <a href={p('faq')}>{t('faq')}</a>
          <a href={p('resources')}>{lang === 'de' ? 'Wissen' : lang === 'es' ? 'Recursos' : 'Resources'}</a>
          <a href={p('tools')}>{lang === 'de' ? 'Kostenlose Tools' : lang === 'es' ? 'Herramientas gratis' : 'Free tools'}</a>
          <a href={lang === 'de' ? '/de/videoproduktion-kosten-rechner/' : lang === 'es' ? '/es/calculadora-costos-video/' : '/en/video-cost-calculator/'}>{lang === 'de' ? 'Kostenrechner' : lang === 'es' ? 'Calculadora de costos' : 'Cost calculator'}</a>
          <a href="/book/">{lang === 'de' ? 'Gratis 15-Min-Call' : lang === 'es' ? 'Llamada gratis de 15 min' : 'Free 15-min call'}</a>
          <a href={p('contact')}>{t('contact')}</a>
        </div>
        <div class="foot-col">
          <h3>{t('contact')}</h3>
          <a href="mailto:info@viven.ch">info@viven.ch</a>
          <a href="tel:+41435083381">+41 43 508 33 81</a>
          <a href="https://maps.google.com/?q=Zeughausstrasse+31,+8004+Z%C3%BCrich" target="_blank" rel="noopener">Zeughausstrasse 31, 8004 Zürich</a>
        </div>
        <div class="foot-col">
          <h3>{t('follow')}</h3>
          <a href="https://www.linkedin.com/company/viven-ag" target="_blank" rel="noopener">LinkedIn</a>
          <a href="https://www.instagram.com/viven.ag" target="_blank" rel="noopener">Instagram</a>
          <a href="https://www.facebook.com/VIVENAG" target="_blank" rel="noopener">Facebook</a>
          <a href="https://x.com/vivenag/" target="_blank" rel="noopener">X</a>
        </div>
      </div>
    </div>
    <div class="nl-signup" data-nl>
      <div class="nl-copy">
        <h3>{lang === 'de' ? 'Video-Marketing-Tipps, monatlich.' : lang === 'es' ? 'Tips de video marketing, mensual.' : 'Video marketing tips, monthly.'}</h3>
        <p>{lang === 'de' ? 'Kein Spam — abmelden jederzeit möglich.' : lang === 'es' ? 'Sin spam — te podés dar de baja cuando quieras.' : "No spam — unsubscribe any time."}</p>
      </div>
      <form class="nl-form" novalidate>
        <input type="email" name="email" required placeholder={lang === 'de' ? 'Ihre Arbeits-E-Mail' : lang === 'es' ? 'Tu email de trabajo' : 'Your work email'} autocomplete="email" />
        <button type="submit" class="btn btn-primary">{lang === 'de' ? 'Abonnieren' : lang === 'es' ? 'Suscribirme' : 'Subscribe'}</button>
      </form>
      <p class="nl-done" hidden>{lang === 'de' ? '✓ Danke — Sie sind auf der Liste.' : lang === 'es' ? '✓ Listo — estás en la lista.' : "✓ Thanks — you're on the list."}</p>
    </div>
    <div class="foot-bottom">
      <span>© <span id="year">2026</span> Viven AG. <span>{t('rights')}</span></span>
      <span>
        <a href={p('impressum')}>Impressum</a> ·
        <a href={p('privacy-policy')}>{t('privacy')}</a> ·
        <a href={p('terms')}>{t('terms')}</a>
      </span>
      <span>{t('madeIn')}</span>
    </div>
  </div>
</footer>
