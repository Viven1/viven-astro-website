---
const { href, icon, title, desc, cta } = Astro.props;
---
<a class="tool-card" href={href}>
  <Fragment set:html={icon} />
  <div>
    <span class="tool-card-title">{title}</span>
    <span class="tool-card-desc">{desc}</span>
  </div>
  <span class="tool-card-cta">{cta} →</span>
</a>
<style is:global>
  .tool-card{display:flex;align-items:center;gap:16px;border:1px solid var(--line);border-radius:14px;background:var(--navy-800);padding:18px 20px;color:var(--text);text-decoration:none;transition:border-color .2s,transform .15s}
  .tool-card:hover{border-color:var(--acid);transform:translateY(-1px)}
  .tool-card svg{flex:none;width:26px;height:26px;color:var(--acid)}
  .tool-card > div{flex:1;min-width:0}
  .tool-card-title{display:block;font-size:16px;font-weight:600;margin-bottom:3px}
  .tool-card-desc{display:block;font-size:13.5px;color:var(--muted-2)}
  .tool-card-cta{flex:none;font-size:14px;font-weight:600;color:var(--acid)}
  @media(max-width:600px){.tool-card{flex-wrap:wrap}.tool-card-cta{margin-left:42px}}
</style>
