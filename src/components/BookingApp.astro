---
// Página pública de booking — reemplaza el meeting link de HubSpot.
// Componente COMPARTIDO por /book/ (preHost=null → selector) y /book/[persona]
// (preHost="sofia"|"sebastian" → salta directo a esa agenda). Grilla completa del
// calendario (booking-slots?all=1): los horarios ocupados se ven EN GRIS, semanas
// navegables ‹ ›. booking-create crea el evento con Meet. Fallback: si la API no
// responde, link de respaldo (HubSpot).
const FN = 'https://lumoevaotokgqnpybkyf.supabase.co/functions/v1';
// fix (pedido explícito 2026-07-14): el respaldo era un solo link fijo al HubSpot de Sofía
// sin importar con quién había fallado la reserva — mismo patrón de bug que ya arreglamos
// (mandar al cliente con la persona equivocada). Ahora cada quien tiene su propio link.
const FALLBACK: Record<string, string> = {
  sofia: 'https://meetings.hubspot.com/sofia-trevino?uuid=76bf013f-3825-4341-8a95-fee769f70c49',
  sebastian: 'https://meetings.hubspot.com/viven/30-mins-meeting?uuid=aaf009a3-8284-4b8e-b64a-68b248d18b55',
};
const FALLBACK_DEFAULT = FALLBACK.sofia;
interface Props { preHost?: string | null }
const { preHost = null } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="robots" content="noindex,nofollow" />
<title>Book a call — Viven Film Production</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="preload" href="/assets/fonts/sg-var.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/assets/fonts/inter-var.woff2" as="font" type="font/woff2" crossorigin />
<link rel="stylesheet" href="/assets/site.css" />
<style is:global>
  body{background:radial-gradient(1200px 700px at 70% -10%, #14233c 0%, #0b1220 55%);min-height:100vh;margin:0}
  .bk-wrap{max-width:1060px;margin:0 auto;padding:clamp(16px,4vw,44px) 18px 70px}
  .bk-card{display:grid;grid-template-columns:320px 1fr;background:rgba(15,24,38,.92);border:1px solid #22304a;border-radius:22px;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,.45)}
  .bk-side{background:linear-gradient(165deg,#111e33,#0c1526);padding:36px 30px;border-right:1px solid #22304a;display:flex;flex-direction:column}
  .bk-logo{font-family:'Space Grotesk';font-weight:800;font-size:25px;letter-spacing:-.02em;color:#ddf98f}
  .bk-fp{font-size:9px;letter-spacing:.16em;text-transform:uppercase;color:#9aa6bd;margin-top:2px}
  .bk-side h1{font-family:'Space Grotesk';font-size:23px;line-height:1.25;letter-spacing:-.01em;color:#fff;margin:28px 0 10px}
  .bk-side p{font-size:13.5px;line-height:1.65;color:#9aa6bd;margin:0}
  .bk-feats{margin:20px 0 0;padding:0;list-style:none;display:grid;gap:9px}
  .bk-feats li{font-size:12.5px;color:#cdd6e6;display:flex;gap:8px;align-items:center}
  .bk-feats li::before{content:'✓';color:#ddf98f;font-weight:700}
  .bk-side .who{display:flex;align-items:center;gap:12px;margin-top:auto;padding-top:26px}
  .bk-side .who .av{width:42px;height:42px;border-radius:50%;background:#ddf98f;color:#1c2508;display:grid;place-items:center;font-weight:800;font-family:'Space Grotesk';font-size:15px;background-size:cover;background-position:center}
  .bk-side .who b{color:#fff;font-size:13.5px;display:block}
  .bk-side .who span{font-size:11.5px;color:#9aa6bd}
  .bk-main{padding:28px 32px 32px;min-height:560px}
  /* ---------- PASO 0 · selector de host (mockup aprobado por Sebastián) ---------- */
  .hs-h{font-family:'Space Grotesk';font-size:17px;color:#fff;margin:2px 0 4px;letter-spacing:-.01em}
  .hs-sub{font-size:13px;color:#9aa6bd;margin-bottom:22px}
  .hs-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
  .hostcard{position:relative;text-align:left;border:1px solid #22304a;background:#0c1526;border-radius:16px;padding:20px 18px 18px;cursor:pointer;color:inherit;font-family:Inter,sans-serif;transition:border-color .15s,transform .15s,background .15s}
  .hostcard:hover{border-color:#ddf98f;transform:translateY(-2px)}
  .hostcard:focus-visible{outline:2px solid #ddf98f;outline-offset:3px}
  .hostcard .av{width:52px;height:52px;border-radius:50%;display:grid;place-items:center;font-weight:800;font-size:18px;color:#fff;margin-bottom:14px;font-family:'Space Grotesk';background-size:cover;background-position:center}
  .hostcard .nm{font-family:'Space Grotesk';font-size:16px;font-weight:700;color:#fff;letter-spacing:-.01em}
  .hostcard .rl{font-size:12px;color:#9aa6bd;margin-top:1px}
  .hostcard .meta{display:flex;flex-wrap:wrap;gap:6px;margin-top:14px}
  .hostcard .chip{font-size:11px;color:#cdd6e6;background:rgba(255,255,255,.05);border:1px solid #22304a;border-radius:100px;padding:3px 9px}
  .hostcard .go{position:absolute;top:20px;right:18px;color:#9aa6bd;font-size:18px;transition:color .15s,transform .15s}
  .hostcard:hover .go{color:#ddf98f;transform:translateX(3px)}
  .hs-note{margin-top:20px;font-size:12px;color:#9aa6bd;display:flex;gap:8px;align-items:flex-start;line-height:1.55}
  .hs-note::before{content:'🔗';flex:none}
  .hs-code{background:#0b1424;border:1px solid #22304a;border-radius:6px;padding:1px 6px;font-size:12px;color:#ddf98f;font-family:ui-monospace,SFMono-Regular,Menlo,monospace}
  .bk-topleft{display:flex;flex-direction:column;gap:6px}
  .bk-back{display:inline-flex;align-items:center;gap:6px;border:0;background:transparent;color:#9aa6bd;font-size:12.5px;font-weight:600;cursor:pointer;font-family:Inter,sans-serif;padding:0;align-self:flex-start}
  .bk-back:hover{color:#ddf98f}
  .bk-hostline{display:flex;align-items:center;gap:9px}
  .bk-hostline .av{width:28px;height:28px;border-radius:50%;display:grid;place-items:center;font-weight:800;font-size:11px;color:#fff;font-family:'Space Grotesk';background-size:cover;background-position:center}
  .bk-hostline b{font-size:13.5px;color:#fff;font-family:'Space Grotesk'}
  .bk-top{display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:18px}
  .bk-h{font-family:'Space Grotesk';font-size:16px;color:#fff;margin:0}
  .bk-durs{display:flex;gap:6px;background:#0b1424;border:1px solid #22304a;border-radius:100px;padding:4px}
  .bk-dur{border:0;background:transparent;color:#9aa6bd;border-radius:100px;padding:7px 16px;font-size:13px;font-weight:600;cursor:pointer;font-family:Inter,sans-serif}
  .bk-dur.on{background:#ddf98f;color:#1c2508}
  .bk-weekbar{display:flex;align-items:center;justify-content:space-between;gap:10px;margin:2px 0 12px}
  .bk-wlabel{font-family:'Space Grotesk';font-weight:600;font-size:14px;color:#dfe6f3}
  .bk-warr{display:flex;gap:6px}
  .bk-arrow{width:34px;height:34px;border-radius:10px;border:1px solid #22304a;background:transparent;color:#dfe6f3;font-size:16px;cursor:pointer;display:grid;place-items:center}
  .bk-arrow:hover:not(:disabled){border-color:#ddf98f;color:#ddf98f}
  .bk-arrow:disabled{opacity:.3;cursor:default}
  .bk-days{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:14px}
  .bk-day{border:1px solid #22304a;background:transparent;border-radius:12px;padding:10px 4px;text-align:center;cursor:pointer;color:#dfe6f3;font-family:Inter,sans-serif}
  .bk-day .dw{font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:#9aa6bd}
  .bk-day .dn{font-family:'Space Grotesk';font-weight:700;font-size:20px;margin:3px 0 1px}
  .bk-day .dfree{font-size:10px;color:#9aa6bd}
  .bk-day.on{border-color:#ddf98f;background:rgba(221,249,143,.08)}
  .bk-day.on .dn{color:#ddf98f}
  .bk-day:disabled{opacity:.32;cursor:default}
  .bk-slots{display:grid;grid-template-columns:repeat(auto-fill,minmax(92px,1fr));gap:8px;max-height:284px;overflow-y:auto;padding-right:4px}
  .bk-slot{border:1px solid #2c3c5c;background:rgba(20,32,51,.6);color:#eef2fa;border-radius:10px;padding:11px 4px;font-size:13.5px;font-weight:600;cursor:pointer;text-align:center;font-family:Inter,sans-serif;font-variant-numeric:tabular-nums}
  .bk-slot:hover:not(:disabled){border-color:#ddf98f;color:#ddf98f}
  .bk-slot:disabled{background:transparent;border-color:#1b2740;color:#4c5a75;cursor:default;text-decoration:line-through;text-decoration-color:#33405c}
  .bk-legend{display:flex;gap:16px;margin-top:12px;font-size:11px;color:#9aa6bd}
  .bk-legend span{display:flex;align-items:center;gap:6px}
  .bk-dot{width:10px;height:10px;border-radius:3px;border:1px solid #2c3c5c;background:rgba(20,32,51,.6);display:inline-block}
  .bk-dot.busy{background:transparent;border-color:#1b2740}
  .bk-tz{font-size:11.5px;color:#9aa6bd;margin:12px 0 0}
  .bk-note{font-size:13px;color:#9aa6bd;line-height:1.6}
  .bk-form label{display:block;font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:#9aa6bd;margin:14px 0 5px}
  .bk-form input,.bk-form textarea{width:100%;box-sizing:border-box;background:#0b1424;border:1px solid #22304a;border-radius:10px;color:#fff;padding:11px 12px;font-size:14px;font-family:Inter,sans-serif}
  .bk-form input:focus,.bk-form textarea:focus{outline:none;border-color:#ddf98f}
  .bk-form textarea{min-height:70px;resize:vertical}
  .bk-actions{display:flex;gap:10px;align-items:center;margin-top:20px;flex-wrap:wrap}
  .bk-btn{border:0;background:#ddf98f;color:#1c2508;font-weight:700;font-size:14.5px;border-radius:100px;padding:13px 26px;cursor:pointer;font-family:Inter,sans-serif}
  .bk-btn[disabled]{opacity:.55;cursor:wait}
  .bk-ghost{background:transparent;border:1px solid #22304a;color:#dfe6f3;border-radius:100px;padding:12px 22px;font-size:13.5px;font-weight:600;cursor:pointer;font-family:Inter,sans-serif}
  .bk-chosen{background:rgba(221,249,143,.08);border:1px solid rgba(221,249,143,.35);border-radius:12px;padding:12px 16px;font-size:14px;color:#fff;margin-bottom:6px}
  .bk-ok{text-align:center;padding:46px 10px}
  .bk-ok .big{font-size:46px}
  .bk-ok h2{font-family:'Space Grotesk';color:#fff;font-size:22px;margin:14px 0 8px}
  .bk-ok p{color:#9aa6bd;font-size:14.5px;line-height:1.7;max-width:430px;margin:0 auto 10px}
  .bk-err{color:#ff8f8f;font-size:13.5px;margin-top:10px}
  .bk-skel{height:284px;display:grid;place-items:center;color:#9aa6bd;font-size:13px}
  @media(max-width:860px){
    .bk-card{grid-template-columns:1fr}
    .bk-side{border-right:0;border-bottom:1px solid #22304a;padding:24px 22px}
    .bk-side h1{margin-top:16px;font-size:20px}
    .bk-side .who{padding-top:18px}
    .bk-main{padding:20px 16px;min-height:0}
    .bk-slots{max-height:260px}
    .hs-grid{grid-template-columns:1fr}
  }
</style>
</head>
<body>
<div class="bk-wrap">
  <div class="bk-card">
    <aside class="bk-side">
      <div><div class="bk-logo">viven</div><div class="bk-fp">Film Production</div></div>
      <h1 data-i="t">Book your free intro call</h1>
      <p data-i="p">Let's talk about your video project — goals, timing and budget.</p>
      <ul class="bk-feats">
        <li data-i="f1">Free &amp; no obligation</li>
        <li data-i="f2">Google Meet link right away</li>
        <li data-i="f3">Concrete next steps in 15 min</li>
      </ul>
      <div class="who" id="bk-who">
        <div class="av">SC</div>
        <div><b>Sebastian Cepeda</b><span data-i="role">Founder — Viven AG, Zürich</span></div>
      </div>
    </aside>
    <main class="bk-main" id="bk-main">
      <section id="screen-pick" hidden>
        <h2 class="hs-h" data-i="pickT">Who would you like to meet?</h2>
        <p class="hs-sub" data-i="pickSub">Pick who you'd like to talk to — each has their own calendar.</p>
        <div class="hs-grid" id="hs-grid"></div>
        <p class="hs-note" id="hs-note"></p>
      </section>
      <div id="bk-step1" hidden>
        <div class="bk-top">
          <div class="bk-topleft">
            <button class="bk-back" id="bk-changehost" type="button" data-i="changePerson" hidden>← Change person</button>
            <div class="bk-hostline" id="bk-hostline" hidden><span class="av"></span><b></b></div>
            <div class="bk-h" data-i="when">Pick a time</div>
          </div>
          <div class="bk-durs">
            <button class="bk-dur on" data-d="15" type="button">15 min</button>
            <button class="bk-dur" data-d="30" type="button">30 min</button>
          </div>
        </div>
        <div class="bk-weekbar">
          <div class="bk-wlabel" id="bk-wlabel">&nbsp;</div>
          <div class="bk-warr">
            <button class="bk-arrow" id="bk-prev" type="button" aria-label="Previous week">‹</button>
            <button class="bk-arrow" id="bk-next" type="button" aria-label="Next week">›</button>
          </div>
        </div>
        <div id="bk-days" class="bk-days"></div>
        <div id="bk-slots" class="bk-slots"><div class="bk-skel" data-i="loading">Loading your calendar…</div></div>
        <div class="bk-legend"><span><span class="bk-dot"></span><span data-i="lgFree">Available</span></span><span><span class="bk-dot busy"></span><span data-i="lgBusy">Booked out</span></span></div>
        <p class="bk-tz" id="bk-tz"></p>
        <p class="bk-err" id="bk-err" hidden></p>
      </div>
      <div id="bk-step2" hidden>
        <div class="bk-chosen" id="bk-chosen"></div>
        <div class="bk-form">
          <label data-i="name">Your name *</label><input id="bk-name" autocomplete="name" />
          <label>Email *</label><input id="bk-email" type="email" autocomplete="email" />
          <label data-i="phone">Phone (optional)</label><input id="bk-phone" type="tel" autocomplete="tel" />
          <label data-i="msg">What's the project about? (optional)</label><textarea id="bk-msg"></textarea>
        </div>
        <div class="bk-actions">
          <button class="bk-ghost" id="bk-back" type="button" data-i="back">← Back</button>
          <button class="bk-btn" id="bk-confirm" type="button" data-i="confirm">Confirm booking</button>
        </div>
        <p class="bk-err" id="bk-err2" hidden></p>
      </div>
      <div id="bk-ok" class="bk-ok" hidden>
        <div class="big">🎉</div>
        <h2 data-i="okt">You're booked!</h2>
        <p id="bk-ok-when"></p>
        <p data-i="okp">The calendar invite with the Google Meet link is on its way to your inbox.</p>
        <p data-i="okb">One more thing: fill in the 2-minute project brief so we can make the most of the call.</p>
        <div class="bk-actions" style="justify-content:center">
          <a class="bk-btn" href="/brief/" data-i="brief">→ Fill in the brief</a>
        </div>
      </div>
    </main>
  </div>
</div>
<script is:inline define:vars={{ FN, FALLBACK, FALLBACK_DEFAULT, preHost }}>
  const qs = new URLSearchParams(location.search);
  const lang = ['en','de','es'].includes(qs.get('lang')) ? qs.get('lang')
    : (navigator.language || 'en').slice(0,2) === 'de' ? 'de'
    : (navigator.language || 'en').slice(0,2) === 'es' ? 'es' : 'en';
  const L = {
    en: {},
    de: { t:'Buchen Sie Ihren kostenlosen Kennenlern-Call', p:'Sprechen wir über Ihr Videoprojekt — Ziele, Timing und Budget.', f1:'Kostenlos & unverbindlich', f2:'Google-Meet-Link sofort', f3:'Konkrete nächste Schritte in 15 Min.', role:'Founder — Viven AG, Zürich', when:'Zeit wählen', loading:'Kalender wird geladen…', lgFree:'Verfügbar', lgBusy:'Ausgebucht', name:'Ihr Name *', phone:'Telefon (optional)', msg:'Worum geht es im Projekt? (optional)', back:'← Zurück', confirm:'Termin bestätigen', okt:'Gebucht!', okp:'Die Kalender-Einladung mit dem Google-Meet-Link ist unterwegs in Ihre Inbox.', okb:'Noch etwas: Füllen Sie das 2-Minuten-Briefing aus, damit wir das Maximum aus dem Call holen.', brief:'→ Briefing ausfüllen', taken:'Dieser Slot wurde gerade gebucht — bitte einen anderen wählen.', err:'Buchung fehlgeschlagen — bitte erneut versuchen.', need:'Bitte Name und gültige E-Mail angeben.', fb:'Der Kalender ist gerade nicht erreichbar. Buchen Sie hier:', fbBtn:'📅 Call buchen (Backup-Link)', week:'Woche', pickT:'Wen möchten Sie treffen?', pickSub:'Wählen Sie, mit wem Sie sprechen möchten — jede Person hat einen eigenen Kalender.', changePerson:'← Person wechseln', withHost:'Call buchen mit', noteLead:'Direktlinks', noteTrail:'überspringen diesen Schritt — für die E-Mail-Signatur jeder Person.' },
    es: { t:'Reservá tu llamada gratis', p:'Hablemos de tu proyecto de video — objetivos, tiempos y presupuesto.', f1:'Gratis y sin compromiso', f2:'Link de Google Meet al instante', f3:'Próximos pasos concretos en 15 min', role:'Founder — Viven AG, Zúrich', when:'Elegí un horario', loading:'Cargando el calendario…', lgFree:'Disponible', lgBusy:'Ocupado', name:'Tu nombre *', phone:'Teléfono (opcional)', msg:'¿De qué va el proyecto? (opcional)', back:'← Volver', confirm:'Confirmar reserva', okt:'¡Reservado!', okp:'La invitación de calendario con el link de Google Meet va en camino a tu inbox.', okb:'Una cosa más: completá el brief de 2 minutos así aprovechamos la llamada al máximo.', brief:'→ Completar el brief', taken:'Ese horario se acaba de ocupar — elegí otro.', err:'No se pudo reservar — probá de nuevo.', need:'Poné tu nombre y un email válido.', fb:'El calendario no responde en este momento. Reservá por acá:', fbBtn:'📅 Agendar (link de respaldo)', week:'Semana', pickT:'¿Con quién querés hablar?', pickSub:'Elegí con quién querés hablar — cada persona tiene su propia agenda.', changePerson:'← Cambiar persona', withHost:'Reservá con', noteLead:'Los links directos', noteTrail:'saltan esta pantalla — para la firma de email de cada persona.' },
  }[lang] || {};
  const EN = { taken:'That slot was just taken — please pick another.', err:'Booking failed — please try again.', need:'Please enter your name and a valid email.', fb:'The calendar is unreachable right now. Book here instead:', fbBtn:'📅 Book a call (backup link)', week:'Week', loading:'Loading your calendar…', withHost:'Book a call with', noteLead:'Direct links', noteTrail:"skip this screen — for each person's email signature." };
  const t = (k) => L[k] || EN[k] || null;
  document.querySelectorAll('[data-i]').forEach((el) => { const v = L[el.dataset.i]; if (v) el.textContent = v; });
  if (lang === 'de') document.title = 'Call buchen — Viven Film Production';
  if (lang === 'es') document.title = 'Reservar una llamada — Viven Film Production';

  const $ = (id) => document.getElementById(id);
  // heading por defecto (ya traducido por el loop data-i) para restaurarlo al volver al selector
  const DEFAULT_H = document.querySelector('.bk-side h1').textContent;

  // ---- host: identidad visual (gradiente por persona; foto si hay avatar_url) ----
  const GRAD = { sofia:'linear-gradient(135deg,#e8a1c0,#9a6df0)', sebastian:'linear-gradient(135deg,#6db3f0,#3a6df0)' };
  function hashGrad(s){ let h=0; for (let i=0;i<s.length;i++) h=(h*31+s.charCodeAt(i))>>>0; const a=h%360, b=(a+40)%360; return 'linear-gradient(135deg,hsl('+a+',60%,62%),hsl('+b+',66%,52%))'; }
  const grad = (slug) => GRAD[slug] || hashGrad(String(slug||'x'));
  const initialsOf = (nm) => String(nm||'').split(/\s+/).map((w)=>w[0]).slice(0,2).join('').toUpperCase();
  const hhmm = (m) => String(Math.floor(m/60)).padStart(2,'0')+':'+String(m%60).padStart(2,'0');
  const DNAMES = { en:['','Mon','Tue','Wed','Thu','Fri','Sat','Sun'], de:['','Mo','Di','Mi','Do','Fr','Sa','So'], es:['','Lun','Mar','Mié','Jue','Vie','Sáb','Dom'] };
  function fmtDays(days){
    if (!Array.isArray(days) || !days.length) return '';
    const nm = DNAMES[lang] || DNAMES.en;
    const s = [...days].sort((a,b)=>a-b);
    let contig = true; for (let i=1;i<s.length;i++) if (s[i] !== s[i-1]+1) contig = false;
    return (contig && s.length>1) ? nm[s[0]]+'–'+nm[s[s.length-1]] : s.map((d)=>nm[d]).join(', ');
  }
  function avHTML(h, cls){
    if (h.avatar_url) return '<span class="'+cls+'" style="background-image:url(\''+h.avatar_url+'\')"></span>';
    return '<span class="'+cls+'" style="background:'+grad(h.slug)+'">'+initialsOf(h.name)+'</span>';
  }
  function hostCard(h){
    const roleShort = (h.role || '').split('—')[0].trim();
    const chips = [];
    if (h.work_start != null && h.work_end != null) chips.push('<span class="chip">🕑 '+hhmm(h.work_start)+'–'+hhmm(h.work_end)+(fmtDays(h.days)?' · '+fmtDays(h.days):'')+'</span>');
    if (Array.isArray(h.durations) && h.durations.length) chips.push('<span class="chip">'+h.durations.join(' / ')+' min</span>');
    return '<button class="hostcard" data-host="'+h.slug+'" type="button">'
      + '<span class="go">→</span>'
      + avHTML(h,'av')
      + '<div class="nm">'+h.name+'</div><div class="rl">'+roleShort+'</div>'
      + '<div class="meta">'+chips.join('')+'</div></button>';
  }

  // meta del servidor: anfitrión + duraciones configuradas en el dashboard
  let metaApplied = false;
  function applyMeta(m){
    if (metaApplied || !m) return; metaApplied = true;
    if (m.host && m.host.name){
      const who = document.querySelector('.who');
      if (who){
        const avEl = who.querySelector('.av');
        avEl.textContent = initialsOf(m.host.name);
        who.querySelector('b').textContent = m.host.name;
        if (m.host.role) who.querySelector('span').textContent = m.host.role;
        if (HOST){
          // modo por-persona: gradiente + heading + hostline con el host real
          avEl.style.background = grad(HOST); avEl.style.color = '#fff';
          const first = m.host.name.split(/\s+/)[0];
          const sideH = document.querySelector('.bk-side h1'); if (sideH) sideH.textContent = (t('withHost') || 'Book a call with') + ' ' + first;
          const hl = $('bk-hostline');
          if (hl){ hl.querySelector('.av').textContent = initialsOf(m.host.name); hl.querySelector('.av').style.background = grad(HOST); hl.querySelector('b').textContent = m.host.name; hl.hidden = false; }
          const bh = document.querySelector('.bk-h'); if (bh) bh.hidden = true;
        }
      }
    }
    if (Array.isArray(m.durations) && m.durations.length){
      const box = document.querySelector('.bk-durs');
      box.innerHTML = m.durations.map(function(x, i){ return '<button class="bk-dur' + (i === 0 ? ' on' : '') + '" data-d="' + x + '" type="button">' + x + ' min</button>'; }).join('');
      dur = m.durations[0];
      box.querySelectorAll('.bk-dur').forEach(function(b){ b.addEventListener('click', function(){ dur = parseInt(b.dataset.d); box.querySelectorAll('.bk-dur').forEach(function(x){ x.classList.toggle('on', x === b); }); load(); }); });
    }
    if (m.msgs) window.__bkMsg = m.msgs;
  }
  const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
  $('bk-tz').textContent = '🌍 ' + tz;
  const LOC = lang === 'en' ? 'en-GB' : lang;
  let dur = 15, grid = [], days = [], weeks = [], wi = 0, day = null, chosen = null;
  let hosts = [], HOST = null;   // HOST = slug enviado a la API (null → default id=1, idéntico a hoy)

  const dayKey = (iso) => new Date(iso).toLocaleDateString('en-CA');
  const fmtTime = (iso) => new Date(iso).toLocaleTimeString(LOC, { hour: '2-digit', minute: '2-digit' });
  const fmtDay = (iso, o) => new Date(iso).toLocaleDateString(LOC, o);

  async function load(){
    $('bk-err').hidden = true;
    $('bk-days').innerHTML = '';
    $('bk-slots').innerHTML = '<div class="bk-skel">' + (t('loading') || 'Loading…') + '</div>';
    try {
      const hostQ = HOST ? '&host=' + encodeURIComponent(HOST) : '';
      const r = await fetch(FN + '/booking-slots?dur=' + dur + '&days=28&all=1' + hostQ);
      const d = await r.json();
      if (d && d.meta) applyMeta(d.meta);
      if (d && d.error === 'booking_off') throw new Error('booking_off');
      if (!d.ok || (!Array.isArray(d.grid) && !Array.isArray(d.slots))) throw new Error(d.error || 'no grid');
      // compat: función sin all=1 deployada todavía → solo libres (sin grises)
      grid = Array.isArray(d.grid) ? d.grid : d.slots.map((t) => ({ t, free: true }));
      const byDay = {};
      grid.forEach((s) => { (byDay[dayKey(s.t)] = byDay[dayKey(s.t)] || []).push(s); });
      days = Object.keys(byDay).sort().map((k) => ({ k, slots: byDay[k], free: byDay[k].filter((x) => x.free).length }));
      // semanas: bloques de lunes a viernes (por semana ISO local)
      const wk = (k) => { const dt = new Date(k + 'T12:00:00'); const day1 = new Date(dt); day1.setDate(dt.getDate() - ((dt.getDay() + 6) % 7)); return day1.toLocaleDateString('en-CA'); };
      const wmap = {};
      days.forEach((x) => { (wmap[wk(x.k)] = wmap[wk(x.k)] || []).push(x); });
      weeks = Object.keys(wmap).sort().map((k) => wmap[k]);
      wi = 0;
      // primera semana con algo libre
      const firstFree = weeks.findIndex((w) => w.some((x) => x.free > 0));
      if (firstFree > -1) wi = firstFree;
      renderWeek();
    } catch (e) {
      $('bk-days').innerHTML = '';
      $('bk-slots').innerHTML = '';
      $('bk-err').hidden = false;
      // respaldo de LA PERSONA que estaba fallando (HOST), no siempre el mismo para todos
      const fb = (HOST && FALLBACK[HOST]) || FALLBACK_DEFAULT;
      $('bk-err').innerHTML = t('fb') + '<br><br><a class="bk-btn" style="text-decoration:none;display:inline-block" href="' + fb + '">' + t('fbBtn') + '</a>';
    }
  }
  function renderWeek(){
    const w = weeks[wi] || [];
    $('bk-prev').disabled = wi <= 0;
    $('bk-next').disabled = wi >= weeks.length - 1;
    if (w.length) {
      const a = fmtDay(w[0].slots[0].t, { day: 'numeric', month: 'short' });
      const b = fmtDay(w[w.length - 1].slots[0].t, { day: 'numeric', month: 'short' });
      $('bk-wlabel').textContent = (t('week') || 'Week') + ' · ' + a + ' – ' + b;
    }
    // día seleccionado: el primero con lugar libre de la semana
    const firstFree = w.find((x) => x.free > 0);
    day = firstFree ? firstFree.k : (w[0] && w[0].k);
    $('bk-days').innerHTML = w.map((x) => {
      const iso = x.slots[0].t;
      return '<button class="bk-day' + (x.k === day ? ' on' : '') + '" data-k="' + x.k + '"' + (x.free ? '' : ' disabled') + ' type="button">' +
        '<div class="dw">' + fmtDay(iso, { weekday: 'short' }) + '</div>' +
        '<div class="dn">' + new Date(iso).getDate() + '</div>' +
        '<div class="dfree">' + (x.free ? x.free + ' ✓' : '—') + '</div></button>';
    }).join('');
    document.querySelectorAll('.bk-day:not(:disabled)').forEach((b) => b.addEventListener('click', () => {
      day = b.dataset.k;
      document.querySelectorAll('.bk-day').forEach((x) => x.classList.toggle('on', x === b));
      renderSlots();
    }));
    renderSlots();
  }
  function renderSlots(){
    const w = weeks[wi] || [];
    const dd = w.find((x) => x.k === day);
    $('bk-slots').innerHTML = (dd ? dd.slots : []).map((s) =>
      '<button class="bk-slot" data-s="' + s.t + '"' + (s.free ? '' : ' disabled') + ' type="button">' + fmtTime(s.t) + '</button>').join('');
    document.querySelectorAll('.bk-slot:not(:disabled)').forEach((b) => b.addEventListener('click', () => {
      chosen = b.dataset.s;
      $('bk-chosen').textContent = '📅 ' + fmtDay(chosen, { weekday: 'long', day: 'numeric', month: 'long' }) + ' · ' + fmtTime(chosen) + ' (' + dur + ' min · ' + tz + ')';
      $('bk-step1').hidden = true; $('bk-step2').hidden = false;
      $('bk-name').focus();
    }));
  }
  $('bk-prev').addEventListener('click', () => { if (wi > 0) { wi--; renderWeek(); } });
  $('bk-next').addEventListener('click', () => { if (wi < weeks.length - 1) { wi++; renderWeek(); } });
  document.querySelectorAll('.bk-dur').forEach((b) => b.addEventListener('click', () => {
    dur = parseInt(b.dataset.d);
    document.querySelectorAll('.bk-dur').forEach((x) => x.classList.toggle('on', x === b));
    load();
  }));
  $('bk-back').addEventListener('click', () => { $('bk-step2').hidden = true; $('bk-step1').hidden = false; });

  // ---- selector de host (paso 0) ----
  function renderPicker(){
    $('hs-grid').innerHTML = hosts.map(hostCard).join('');
    $('hs-grid').querySelectorAll('.hostcard').forEach((b) => b.addEventListener('click', () => startCal(b.dataset.host, true)));
    const codes = hosts.map((h) => '<code class="hs-code">/book/' + h.slug + '</code>').join(' &amp; ');
    $('hs-note').innerHTML = (t('noteLead') || 'Direct links') + ' ' + codes + ' ' + (t('noteTrail') || "skip this screen — for each person's email signature.");
    showPicker();
  }
  function showPicker(){
    HOST = null; metaApplied = false;
    $('screen-pick').hidden = false;
    $('bk-step1').hidden = true; $('bk-step2').hidden = true; $('bk-ok').hidden = true;
    $('bk-who').hidden = true;
    $('bk-changehost').hidden = true; $('bk-hostline').hidden = true;
    const bh = document.querySelector('.bk-h'); if (bh) bh.hidden = false;
    const sideH = document.querySelector('.bk-side h1'); if (sideH) sideH.textContent = DEFAULT_H;
  }
  function startCal(slug, canGoBack){
    HOST = slug || null; metaApplied = false;   // re-aplicar identidad/duraciones del host elegido
    $('screen-pick').hidden = true;
    $('bk-step2').hidden = true; $('bk-ok').hidden = true; $('bk-step1').hidden = false;
    $('bk-who').hidden = false;
    $('bk-changehost').hidden = !canGoBack;
    if (!HOST){ $('bk-hostline').hidden = true; const bh = document.querySelector('.bk-h'); if (bh) bh.hidden = false; }
    load();
  }
  $('bk-changehost').addEventListener('click', () => { if (hosts.length >= 2 && !preHost) showPicker(); });

  async function init(){
    try {
      const r = await fetch(FN + '/booking-slots?hosts=1');
      const d = await r.json();
      if (d && d.ok && Array.isArray(d.hosts)) hosts = d.hosts;
    } catch (e) { hosts = []; }
    if (preHost){ startCal(preHost, false); return; }      // /book/[persona] → agenda directa, sin selector
    if (hosts.length >= 2){ renderPicker(); }               // 2+ visibles → selector primero
    // fix: con 1 solo visible, ANTES caía a HOST=null → fila legacy id=1 (booking_settings sin
    // email), que muestra un host_name viejo pero usa el calendario COMPARTIDO original — con
    // el sistema por-persona ya andando eso es un mismatch real (nombre de una persona, agenda
    // de otra). Ahora, con 1 visible, usa DIRECTAMENTE su calendario propio.
    else if (hosts.length === 1){ startCal(hosts[0].slug, false); }
    else { startCal(null, false); }                         // 0 visibles → default legacy (nadie configurado todavía)
  }

  $('bk-confirm').addEventListener('click', async () => {
    const name = $('bk-name').value.trim(), email = $('bk-email').value.trim();
    const err = $('bk-err2'); err.hidden = true;
    if (!name || !/.+@.+\..+/.test(email)) { err.textContent = t('need'); err.hidden = false; return; }
    const btn = $('bk-confirm'); btn.disabled = true;
    try {
      const r = await fetch(FN + '/booking-create', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, phone: $('bk-phone').value.trim(), message: $('bk-msg').value.trim(), start: chosen, dur, lang, host: HOST || undefined }),
      });
      const d = await r.json();
      if (r.status === 409) { err.hidden = false; err.textContent = t('taken'); $('bk-step2').hidden = true; $('bk-step1').hidden = false; load(); return; }
      if (!d.ok) throw new Error(d.error || 'error');
      $('bk-step2').hidden = true; $('bk-ok').hidden = false;
      $('bk-ok-when').textContent = '📅 ' + fmtDay(d.start, { weekday: 'long', day: 'numeric', month: 'long' }) + ' · ' + fmtTime(d.start) + ' (' + d.duration + ' min)';
      const cm = d.msg || (window.__bkMsg && window.__bkMsg[lang]);
      if (cm) { const p = document.createElement('p'); p.textContent = cm; p.style.cssText = 'color:#dfe6f3;font-size:14px'; $('bk-ok-when').after(p); }
      if (lang !== 'en') { const a = document.querySelector('#bk-ok a.bk-btn'); if (a) a.href = '/brief/?lang=' + lang; }
    } catch (e) {
      err.textContent = t('err') + ' — ' + e.message; err.hidden = false;
    } finally { btn.disabled = false; }
  });
  init();
</script>
</body>
</html>
