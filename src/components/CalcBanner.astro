---
const { lang = 'en' } = Astro.props;
const href = { en: '/en/video-cost-calculator/', de: '/de/videoproduktion-kosten-rechner/', es: '/es/calculadora-costos-video/' }[lang] || '/en/video-cost-calculator/';
const T = {
  text: { en: 'Not sure what your video will cost?', de: 'Nicht sicher, was Ihr Video kostet?', es: '¿No sabés cuánto puede costar tu video?' },
  cta: { en: 'Free cost calculator', de: 'Kostenloser Kostenrechner', es: 'Calculadora gratis de costos' },
};
const t = (o) => o[lang] || o.en;
---
<section class="sec" style="padding-top:0;padding-bottom:0">
  <div class="wrap">
    <a href={href} class="calc-banner reveal">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="4" y="3" width="16" height="18" rx="2"/><path d="M8 8h8M8 12h2m3 0h2m-7 4h2m3 0h2"/></svg>
      <span class="calc-banner-txt">{t(T.text)}</span>
      <span class="calc-banner-cta">{t(T.cta)} →</span>
    </a>
  </div>
</section>
<style>
  .calc-banner{display:flex;align-items:center;gap:12px;flex-wrap:wrap;border:1px solid var(--line);border-radius:14px;background:var(--navy-800);padding:14px 20px;color:var(--text);text-decoration:none;transition:border-color .2s,transform .15s}
  .calc-banner:hover{border-color:var(--acid);transform:translateY(-1px)}
  .calc-banner svg{flex:none;width:22px;height:22px;color:var(--acid)}
  .calc-banner-txt{flex:1;min-width:200px;font-size:14.5px;font-weight:500}
  .calc-banner-cta{flex:none;font-size:14px;font-weight:600;color:var(--acid)}
</style>
