---
import videos from '../data/videos.json';
import projects from '../data/projects.json';
import { pick } from '../i18n.js';
const { cat = '', lang = 'en', limit = 0, feature = false, perClient = 2, seed = '', caseFirst = false } = Astro.props;

// Clientes con case study en este idioma → sus tiles abren la página completa en vez del modal.
// Match por cliente (no por id de video exacto) para que sea consistente en los 3 idiomas.
const caseByClient = new Map();
for (const pr of projects) {
  const key = (pr.client || '').trim().toLowerCase();
  if (pr.lang === lang && key && !caseByClient.has(key)) caseByClient.set(key, pr.slug);
}
const caseFor = (v) => caseByClient.get((v.client || '').trim().toLowerCase());
const CS_LABEL = { en: 'Case study', de: 'Case Study', es: 'Caso de éxito' };
const csLabel = CS_LABEL[lang] || CS_LABEL.en;


// service (idioma de la página) → categoría del filtro
const serviceCat = (s) => {
  const x = (s || '').toLowerCase();
  if (/employer/.test(x)) return 'employer';
  if (/feature film|spielfilm|largometraje/.test(x)) return 'film';
  if (/documentary|dokumentar|documental/.test(x)) return 'doc';
  if (/produkt|product|producto/.test(x)) return 'product';
  if (/social/.test(x)) return 'social';
  if (/explain|explicativo|erklär|how.?to|tutorial/.test(x)) return 'howto';
  if (/marca|brand|marken/.test(x)) return 'brand';
  return 'corporate';
};
// Un tile por proyecto con página propia — TODOS los del idioma (puede haber varios por cliente)
const csProjects = [];
if (caseFirst) {
  for (const pr of projects) {
    if (pr.lang === lang && pr.stills && pr.stills.length) csProjects.push(pr);
  }
}

const CATLABEL = {
  brand:     { en: 'Brand video', de: 'Markenfilm', es: 'Video de marca' },
  product:   { en: 'Product video', de: 'Produktvideo', es: 'Video de producto' },
  employer:  { en: 'Employer branding', de: 'Employer Branding', es: 'Employer branding' },
  howto:     { en: 'How-to video', de: 'How-To-Video', es: 'Video tutorial' },
  social:    { en: 'Social media', de: 'Social Media', es: 'Redes sociales' },
  corporate: { en: 'Corporate', de: 'Corporate', es: 'Corporativo' },
  film:      { en: 'Feature film', de: 'Spielfilm', es: 'Largometraje' },
  doc:       { en: 'Documentary film', de: 'Dokumentarfilm', es: 'Documental' },
};

// clientes más relevantes primero
const IMPORTANT = ['UBS','Siemens','Porsche','ON','FIFA','Netflix','Philips','V-ZUG','Franke','Chanel','Swarovski','IBM','Julius Bär','KPMG','Sennheiser','Sigg','ABB','Sonova','Kanebo','SENSAI','Meteomatics','Capgemini','Büchi','Nile','TomFit','SV Group','PMI Science','Stadtspital','Carvolution','Calda Clinic','LEM'];
const rank = (c) => { const i = IMPORTANT.indexOf(c); return i === -1 ? 999 : i; };
const time = (d) => (d ? Date.parse(d) || 0 : 0);

// título de archivo/interno (sin valor para mostrar)
const junkTitle = (t) => !t || /VIVEN_|showreel|prores|_\d+$|\.mo?v|_16x9|multichannel|clean|nooutro/i.test(t);
// testimonios (reseñas en video) — NO son piezas de portfolio, fuera de la galería
const isTestimonial = (v) => v.category === 'Testimonial' || /testimonial|why work with viven/i.test((v.title || '') + ' ' + (v.name || ''));
// nombre limpio de showreel: "VIVEN_Showreel-EmployerBranding_Full..." → "Showreel — Employer Branding"
const SRMAP = { Prodcuts: 'Product', Products: 'Product', EmployerBranding: 'Employer Branding', SOME: 'Social Media', LandingPage: 'Brand', Image: 'Image', 'Best-Of': 'Best of', Events: 'Events', Testimonial: 'Testimonial', AboutUs: 'About us', People: 'People', Interviews: 'Interviews', Interview: 'Interview', StartUp: 'Start-up' };
const showreelName = (t) => { const m = (t || '').match(/Showreel[-_]([A-Za-z-]+)/i); return m ? ('Showreel — ' + (SRMAP[m[1]] || m[1].replace(/-/g, ' '))) : null; };
const displayTitle = (v) => v.client || showreelName(v.title) || (junkTitle(v.title) ? 'Viven' : v.title);

// --- balanceo: diversidad de marcas, destacados/nuevos/importantes primero ---
// fuera videos sin cliente Y con título de archivo (ruido de showreels internos)
// en la grilla de proyectos, los clientes con case study aparecen SOLO como su tile de case study
// cat puede ser múltiple por video (separado por espacios) → un video puede salir en varias páginas de servicio
const hasCat = (v, c) => (v.cat || '').split(' ').indexOf(c) !== -1;
// Nota: NO ocultamos los videos de clientes con case study — son los mejores (UBS, Siemens…).
// En la grilla de proyectos (caseFirst) aparecen como tiles reproducibles, además del tile de case study.
const pool = videos.filter((v) => v.thumb && (!cat || hasCat(v, cat)) && (v.client || !junkTitle(v.title))
  && !isTestimonial(v));
const groups = new Map();                                  // agrupar por cliente (sin cliente → único)
for (const v of pool) {
  const key = v.client || ('__' + v.id);
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key).push(v);
}
for (const arr of groups.values()) {                       // dentro de cada marca: destacado, luego más nuevo
  arr.sort((a, b) => (b.featured ? 1 : 0) - (a.featured ? 1 : 0) || time(b.date) - time(a.date));
}
// cap por cliente: ON pocos (casi todos iguales); el resto usa el default (en /projects es alto → se muestran ~todos)
const CLIENT_CAP = { ON: 2 };
const capFor = (k) => CLIENT_CAP[k] ?? perClient;
const capped = [...groups.entries()].map(([k, arr]) => [k, arr.slice(0, capFor(k))]);
capped.sort((A, B) => {                                     // ordenar marcas: destacada, importante, más nueva
  const fa = A[1].some((x) => x.featured) ? 0 : 1, fb = B[1].some((x) => x.featured) ? 0 : 1;
  if (fa !== fb) return fa - fb;
  const ra = rank(A[0]), rb = rank(B[0]);
  if (ra !== rb) return ra - rb;
  return time(B[1][0].date) - time(A[1][0].date);
});
let list = [];                                             // round-robin: 1 de cada marca, luego el 2º de cada una
let round = 0, added = true;
while (added) {
  added = false;
  for (const [, arr] of capped) { if (arr[round]) { list.push(arr[round]); added = true; } }
  round++;
}
/* seed opcional (ej. slug del blog): rota la lista para que cada post muestre
   un tramo distinto → diversidad de marcas a lo largo del blog, no siempre las mismas */
if (seed && list.length) {
  let h = 0;
  for (let i = 0; i < seed.length; i++) h = (h * 31 + seed.charCodeAt(i)) >>> 0;
  const off = h % list.length;
  list = list.slice(off).concat(list.slice(0, off));
}
if (limit) list = list.slice(0, limit);

// case studies primero (ordenados por relevancia de marca)
csProjects.sort((a, b) => rank(a.client) - rank(b.client));

const play = '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>';
---
<div class="work-grid" data-shuffle={caseFirst ? '1' : undefined}>
  {csProjects.map((pr, i) => {
    const feat = feature && i === 0 ? ' wt-feature' : '';
    const c = serviceCat(pr.service);
    return (
      <a class={'work-tile reveal wt-case' + feat} href={'/' + pr.slug + '/'} data-cat={c} aria-label={pr.client}>
        <span class="wt-thumb"><img src={pr.stills[0]} width="1280" height="720" loading="lazy" decoding="async" alt={pr.headline} /></span>
        <span class="wt-meta">
          <span class="wt-title">{pr.client}</span>
          <span class="wt-cat">{pick(CATLABEL[c], lang)}</span>
        </span>
      </a>
    );
  })}
  {!caseFirst && list.map((v, i) => {
    const feat = feature && !caseFirst && i === 0 ? ' wt-feature' : '';
    // los videos de un cliente con case study llevan el "double tag" (badge Case study + categoría)
    // y linkean al case study — así los case studies SIEMPRE se muestran como tal
    const csSlug = null;   // tiles de video SIEMPRE reproducen; los case studies tienen sus propios tiles
    const thumb = <span class="wt-thumb"><img src={v.thumb} width={v.tw || 960} height={v.th || 540} loading="lazy" decoding="async" alt={v.title} /></span>;
    const cats = (v.cat || '').split(' ').filter(Boolean);
    // todas las etiquetas de categoría; el JS de filtros muestra la del filtro activo (la primera por defecto)
    const meta = (
      <span class="wt-meta">
        <span class="wt-title">{displayTitle(v)}</span>
        <span class="wt-cat">{cats.map((c, idx) => (
          <span class="cl" data-c={c} hidden={idx !== 0 ? true : undefined}>{pick(CATLABEL[c] || CATLABEL.corporate, lang)}</span>
        ))}</span>
      </span>
    );
    return csSlug ? (
      <a class={'work-tile reveal wt-case' + feat} href={'/' + csSlug + '/'} data-cat={v.cat} aria-label={displayTitle(v) + ' — ' + csLabel}>
        {thumb}
        <span class="wt-badge">{csLabel}</span>
        <span class="wt-play" set:html={play} />
        {meta}
      </a>
    ) : (
      <button class={'work-tile reveal' + feat} type="button"
        data-vimeo={v.id} data-hash={v.hash || ''} data-label={v.title} data-cat={v.cat}>
        {thumb}
        <span class="wt-play" set:html={play} />
        {meta}
      </button>
    );
  })}
</div>
