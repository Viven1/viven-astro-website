---
import { localePath } from '../i18n.js';
import Testimonials from './Testimonials.astro';
const { project, lang = 'en' } = Astro.props;
const p = (s) => localePath(lang, s);
const t = (o) => o[lang] || o.en;

const L = {
  eyebrow: { en: 'Case study', de: 'Case Study', es: 'Caso de éxito' },
  watch: { en: 'Watch the film', de: 'Film ansehen', es: 'Ver el film' },
  back: { en: 'All projects', de: 'Alle Projekte', es: 'Todos los proyectos' },
  gallery: { en: 'From the production', de: 'Aus der Produktion', es: 'De la producción' },
  ctaH: { en: 'Start your success story.', de: 'Starten Sie Ihre Erfolgsgeschichte.', es: 'Empezá tu historia de éxito.' },
  ctaP: { en: 'Tell us what you’re working on — we’ll come back with ideas, timing and a clear quote.', de: 'Erzählen Sie uns von Ihrem Projekt — wir melden uns mit Ideen, Timing und einem klaren Angebot.', es: 'Contá tu proyecto — volvemos con ideas, tiempos y un presupuesto claro.' },
  ctaBtn: { en: 'Start a project', de: 'Projekt starten', es: 'Iniciar proyecto' },
};

const lead = project.body[0] || '';
const rest = project.body.slice(1);
const poster = project.stills[0];
const galleryStills = project.stills.slice(1);
const play = '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>';
---
<article>
  <section class="page-hero cs-hero">
    <div class="wrap">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href={p('')}>Home</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <a href={p('projects')}>{t(L.back)}</a>
      </nav>
      <span class="eyebrow">{t(L.eyebrow)}{project.client ? ' · ' + project.client : ''}</span>
      <h1>{project.headline}</h1>
      {lead && <p class="lead">{lead}</p>}
    </div>
  </section>

  {project.vimeo && (
    <section class="sec" style="padding-top:0">
      <div class="wrap">
        <button class="work-tile cs-player reveal" type="button" data-vimeo={project.vimeo} data-label={project.client + ' — ' + project.headline}>
          <span class="wt-thumb">{poster && <img src={poster} width="1280" height="720" loading="lazy" decoding="async" alt={project.headline} />}</span>
          <span class="wt-play" set:html={play} />
          <span class="wt-meta"><span class="wt-title">{t(L.watch)}</span></span>
        </button>
      </div>
    </section>
  )}

  {rest.length > 0 && (
    <section class="sec" style="padding-top:0">
      <div class="wrap prose cs-body">
        {rest.map((para) => <p>{para}</p>)}
      </div>
    </section>
  )}

  {galleryStills.length > 0 && (
    <section class="sec" style="padding-top:0">
      <div class="wrap">
        <h2 class="cs-gallery-h">{t(L.gallery)}</h2>
        <div class="cs-gallery">
          {galleryStills.map((src) => (
            <div class="cs-still reveal"><img src={src} loading="lazy" decoding="async" width="800" height="450" alt={project.client + ' production still'} /></div>
          ))}
        </div>
      </div>
    </section>
  )}

  <Testimonials lang={lang} client={project.client} />

  <section class="cta" style="padding-top:0">
    <div class="wrap">
      <div class="cta-card reveal" style="grid-template-columns:1fr;text-align:center">
        <div>
          <span class="eyebrow" style="justify-content:center">{t(L.eyebrow)}</span>
          <h2>{t(L.ctaH)}</h2>
          <p class="lead" style="margin-left:auto;margin-right:auto">{t(L.ctaP)}</p>
          <div class="hero-cta" style="justify-content:center;margin-top:28px">
            <a href={p('contact')} class="btn btn-primary">{t(L.ctaBtn)}</a>
            <a href={p('projects')} class="btn btn-ghost">← {t(L.back)}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</article>
